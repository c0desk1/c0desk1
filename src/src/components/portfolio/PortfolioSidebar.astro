---
// src/components/portfolio/PortfolioSidebar.astro

import AboutCard from '@/components/ui/sidebar/AboutCard.astro';
import TechStackCard from '@/components/ui/sidebar/TechStackCard.astro';
import RecentProjectsCard from './RecentProjectsCard.astro';

interface Props {
  popularTech: string[];
  recentProjects: any[];
}

const { popularTech, recentProjects } = Astro.props;
---

<aside class="space-y-8">
  <AboutCard />
  <TechStackCard techs={popularTech} />
  <RecentProjectsCard projects={recentProjects} />
</aside>