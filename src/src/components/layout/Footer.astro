---
// src/components/layout/Footer.astro

import { siteConfig } from "@/config/site";
import Container from "../ui/Container.astro";
---

<footer class="border-t border-zinc-200 dark:border-zinc-900/50 bg-white dark:bg-black">
  <Container size="md" class="mx-auto py-6">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-2 text-sm text-zinc-500 dark:text-zinc-500">
      <div class="flex items-center gap-2">
        <span>© {new Date().getFullYear()} {siteConfig.name}</span>
      </div>
      
      <div class="flex items-center gap-3">
        <span class="text-zinc-500 dark:text-zinc-500 font-bold">▼</span>
      </div>
    </div>
  </Container>
</footer>