---
// src/components/blog/BlogFeaturedImage.astro

interface Props {
  image: string;
  alt?: string;
  caption?: string;
}

const { image, alt, caption } = Astro.props;
const finalCaption = caption || alt;
---

<div class="mx-auto mt-4 md:mt-6 mb-6 md:mb-8 max-w-3xl">
  <figure class="overflow-hidden rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900">
    <div class="relative aspect-16/9 overflow-hidden">
      <div class=" absolute inset-0 animate-pulse bg-zinc-200 dark:bg-zinc-800"aria-hidden="true"></div>
      <img
        src={image}
        alt={alt || ''}
        class="relative z-10 w-full h-full object-cover opacity-0 transition-opacity duration-500"
        loading="eager"
        decoding="async"
        onload="this.style.opacity='1'"
      />
    </div>
    {finalCaption && (
      <figcaption class=" border-t border-zinc-200 dark:border-zinc-800 px-3 py-2 text-xs md:text-sm text-center text-zinc-500 dark:text-zinc-400 leading-snug">
        {finalCaption}
      </figcaption>
    )}
  </figure>
</div>