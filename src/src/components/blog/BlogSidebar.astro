---
// src/components/blog/BlogSidebar.astro
import AboutCard from '../ui/sidebar/AboutCard.astro';
import TagsCard from '../ui/sidebar/TagsCard.astro';
import ArchivesCard from './sidebar/ArchivesCard.astro';

interface Props {
  popularTags: string[];
  archiveCounts: Record<number, number>;
}

const { popularTags, archiveCounts } = Astro.props;
---

<aside class="space-y-8">
  <AboutCard />
  <ArchivesCard counts={archiveCounts} />
  <TagsCard tags={popularTags} />
</aside>