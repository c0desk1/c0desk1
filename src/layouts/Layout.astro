---

import { 
  SITE, 
  buildMeta 
} from "@/consts";

import Head     from "@/components/Head.astro";
import Navbar   from "@/components/Navbar.astro";
import Footer   from "@/components/Footer.astro";
import ThemeScript from "@/components/scripts/ThemeScript.astro";
import Mobile from "@/components/Mobile.astro";
import Search from "@/components/Search.astro";
import ScrollScript from "@/components/scripts/ScrollScript.astro";

interface Props {
  meta?:      Partial<ReturnType<typeof buildMeta>>;
  schema?:    object | object[];
  isHome?:    boolean;
  variant?:   "default" | "full" | "bare";
  bodyClass?: string;
  mainClass?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
  canonical?: string;
}

const {
  meta,
  schema,
  isHome    = false,
  variant   = "default",
  bodyClass = "",
  mainClass = "",
  hideHeader = false,
  hideFooter = false,
  canonical,
} = Astro.props;

const currentPath = new URL(Astro.request.url).pathname;
---

<!DOCTYPE html>
<html lang={SITE.lang} dir={SITE.dir}>
  <Head {meta} {schema} {isHome} {canonical} />
  <body class:list={[bodyClass]}>
    <ThemeScript />
    <a href="#main-content"
      class="
        sr-only focus:not-sr-only
        fixed top-4 left-4 z-9999
        px-4 py-2
        bg-elevated text-strong
        border border-strong
        rounded-(--radius)
        text-heading-24 font-semibold
        focus:outline-none focus:ring-2 focus:ring-(--accent)
        transition-all duration-150
      ">
      Lewati ke konten
    </a>
    {!hideHeader && variant !== "bare" && (<Navbar currentPath={currentPath} />)}
    <main
      id="main-content"
      class:list={[
        "min-h-[calc(100svh-var(--header-height))]",
        variant !== "bare" && "pt-(--header-height)",
        variant === "full"  && "min-h-svh pt-0",
        variant === "bare"  && "min-h-svh pt-0",
        mainClass,
      ]}
    >
      <slot />
    </main>
    {!hideFooter && variant !== "bare" && (<Footer />)}
    <Mobile />
    <ScrollScript />
    <Search />
    
    <script>
      const initShortcuts = () => {
        let lastKey = "";
        const handleKeydown = (e: KeyboardEvent) => {
          const active = document.activeElement;
          const isEditing =
            active instanceof HTMLInputElement  ||
            active instanceof HTMLTextAreaElement ||
            (active as HTMLElement)?.isContentEditable;

          if (isEditing) return;

          if (lastKey === "g" && e.key === "h") {
            window.location.href = "/";
          }

          lastKey = e.key;
          setTimeout(() => { lastKey = ""; }, 800);
        };

        document.removeEventListener("keydown", (window as any).__shortcutKeyHandler);
        (window as any).__shortcutKeyHandler = handleKeydown;
        document.addEventListener("keydown", (window as any).__shortcutKeyHandler);
      };

      initShortcuts();
      document.addEventListener("astro:page-load", initShortcuts);
    </script>
    
    <slot name="body-end" />
  </body>
</html>