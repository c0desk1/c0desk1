---
import BaseHead from "@/components/layout/BaseHead.astro";
import BG from "@/components/ui/BG.astro";
import ThemeScript from "@/components/scripts/ThemeScript.astro";
import Container from "@/components/ui/Container.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { siteConfig } from "@/config/site";

interface Props {
  header?: boolean;
  footer?: boolean;
  withContainer?: boolean;
  size?: "sm" | "md" | "lg" | "xl" | "full";
  title?: string;
  description?: string;
  noIndex?: boolean;
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile";
  image?: { src: string; alt: string };
}

const {
  header = false,
  footer = false,
  withContainer = false,
  size = "full",
  ...seoProps
} = Astro.props;

const Lang = 'id-ID';
const skipLabel = siteConfig.skipToContent;
---

<!DOCTYPE html>

<html lang={Lang} dir="ltr" class="scroll-smooth antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <ThemeScript />
    <BaseHead {...seoProps} />
  </head>
  <body>
    <BG />
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:bg-(--bg) focus:text-(--fg) focus:px-4 focus:py-2 focus:border focus:border-(--border)">
      {skipLabel}
    </a>
    <div class="relative z-10 flex min-h-screen flex-col">
      {header && <Header />}
      <main id="main-content">
        {withContainer ? (
          <Container size={size}>
            <slot />
          </Container>
        ) : (
          <slot />
        )}
      </main>
      {footer && <Footer />}
    </div>
  </body>
</html>