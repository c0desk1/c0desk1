---
// src/layouts/BaseLayout.astro
import "@/styles/global.css";

import { getEntry } from 'astro:content';
import { siteConfig } from "@/config/site";

import BaseHead from "@/components/layout/BaseHead.astro";
import Header from "@/components/layout/Header.astro";
import Cookie from "@/components/ui/Cookie.astro";
import Toast from "@/components/ui/Toast.astro";
import Footer from "@/components/layout/Footer.astro";
import Search from "@/components/layout/Search.astro";
import Container from "@/components/ui/Container.astro";
import BG from "@/components/ui/BG.astro";
import MobileMenu from "@/components/layout/MobileMenu.astro";

import Ads from "@/components/layout/Ads.astro";

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile" | "creativeWork";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  category?: { name: string; description?: string; slug: string };
  author?: { name: string; role: string; avatar: string; bio: string; slug: string };
  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };
  header?: boolean;
  footer?: boolean;
  withContainer?: boolean;
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  client?: string;
  role?: string;
  duration?: string;
  demoUrl?: string;
  repoUrl?: string;
}

const { 
  header = true,
  footer = true,
  withContainer = true,
  size = 'full',
  client,
  role: creativeWorkRole,
  duration,
  demoUrl,
  repoUrl,
  ...seoProps 
} = Astro.props;

let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {
  console.warn('Settings not found, using siteConfig fallback');
}
const siteData = settings?.data || siteConfig;
const analyticsId = siteData.googleAnalyticsId || siteConfig.googleAnalyticsId;
---

<!DOCTYPE html>
<html 
  lang= "id-ID"
  dir="ltr"
  class="scroll-smooth antialiased"
  prefix={seoProps.type === "article" ? "og: https://ogp.me/ns# article: https://ogp.me/ns/article#" : "og: https://ogp.me/ns#"}
>
  <head>
    <script is:inline>
      const theme = (() => {
        const stored = localStorage.getItem('theme');
        if (stored) return stored;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      })();
      document.documentElement.classList[theme === 'dark' ? 'add' : 'remove']('dark');
    </script>
    <BaseHead 
      {...seoProps}
      siteData={siteData}
      client={client} 
      role={creativeWorkRole} 
      duration={duration} 
      demoUrl={demoUrl} 
      repoUrl={repoUrl} 
    />
    {import.meta.env.PROD && (siteData.googleAnalyticsId || siteConfig.googleAnalyticsId) && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${analyticsId}`} />
        <script is:inline define:vars={{ analyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', analyticsId);
        </script>
      </>
    )}
    <Ads />
 <script>window.yaContextCb=window.yaContextCb||[]</script>
  <script src="https://yandex.ru/ads/system/context.js" async></script>
  </head>
  <body>
    <BG />
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:border focus:border-black dark:focus:bg-black dark:focus:text-white">
      loncat ke konten utama
    </a>
    <div class="relative z-10 flex min-h-screen flex-col">
      {header && <Header />}
      <main id="main-content">
        {withContainer ? (
          <Container size={size}>
            <slot />
          </Container>
        ) : (
          <slot />
        )}
        <Search />
      </main>
      {footer && <Footer />}
    </div>
    <div id="modal-root"></div>
    <Toast />
    <Cookie />
    <MobileMenu />
    <script is:inline>
      document.addEventListener('click', (e) => {
        const link = e.target.closest('.anchor-link');
        
        if (!link) return;
        
        const href = link.getAttribute('href');
        
        if (href?.startsWith('#') && href.length > 1) {
          const target = document.querySelector(href);
          
          if (!target) return;
      
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.pushState(null, '', href);
        }
      });
      
      document.addEventListener('click', (e) => {
        if (window.innerWidth >= 768) return;
      
        const heading = e.target.closest('.heading-group.has-anchor');
     
        if (!heading || e.target.closest('.anchor-link')) return;
        
        document.querySelectorAll('.anchor-link-active').forEach(el => {
          el.classList.remove('anchor-link-active');
        });
    
        const link = heading.querySelector('.anchor-link');
      
        if (link) {
          link.classList.add('anchor-link-active');
          setTimeout(() => link.classList.remove('anchor-link-active'), 2000);
        }
      });
      
      if ('serviceWorker' in navigator && location.hostname !== 'localhost') {
        addEventListener('load', () => {
          navigator.serviceWorker.register('/pwa.js').catch(console.error);
        });
      }
    </script>
    <script is:inline>
    window.yaContextCb.push(() => {
        Ya.Context.AdvManager.render({
            "blockId": "R-A-19179231-1",
            "type": "floorAd",
            "platform": "touch"
        })
    })
  </script>
  </body>
</html>