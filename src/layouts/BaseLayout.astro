---
// src/layouts/BaseLayout.astro
import { siteConfig } from "@/config/site";
import BaseHead from "@/components/layout/BaseHead.astro";
import Header from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import Container from "@/components/ui/Container.astro";
import MobileMenu from "@/components/layout/MobileMenu.astro";
import Search from "@/components/layout/Search.astro";
import ScrollScript from "@/components/scripts/ScrollScript.astro";
import YandexAds from "@/components/ads/YandexAds.astro";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  category?: { name: string; description?: string; slug: string };
  author?: { name: string; role: string; avatar: string; bio: string; slug: string; twitter: string };
  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };
  breadcrumbItems?: { name: string; item: string }[];
  header?: boolean;
  footer?: boolean;
  withContainer?: boolean;
  size?: "sm" | "md" | "lg" | "xl" | "full";
}

const {
  lang = "id-ID",
  breadcrumbItems = [],
  header = true,
  footer = true,
  withContainer = false,
  size = "xl",
  ...seoProps
} = Astro.props;
---

<!DOCTYPE html>
<html
  lang={lang}
  dir="ltr"
  class="antialiased"
  prefix={seoProps.type === "article"
    ? "og: https://ogp.me/ns# article: https://ogp.me/ns/article#"
    : "og: https://ogp.me/ns#"}>
  <head>
    <BaseHead {...seoProps} breadcrumbItems={breadcrumbItems} />
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only text-body-16 md:text-body-18 focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:bg-base focus:text-(--fg) focus:px-4 focus:py-2 focus:border focus:border-(--border)"
    >
      {siteConfig.skipToContent}
    </a>
    {header && <Header />}
    <main id="main-content">
      {withContainer ? (
        <Container size={size}>
          <slot />
        </Container>
      ) : (
        <slot />
      )}
    </main>
    <Search />
    {footer && <Footer />}
    <div id="modal-root"></div>
    <MobileMenu />
    <ScrollScript />
  </body>
</html>