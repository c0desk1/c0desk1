---
// src/layouts/BaseLayout.astro
import "@/styles/global.css";

import { siteConfig } from "@/config/site";

import ThemeScript from "@/components/scripts/ThemeScript.astro";

import BaseHead from "@/components/layout/BaseHead.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";

import Container from "@/components/ui/Container.astro";

import MobileMenu from "@/components/layout/MobileMenu.astro";
import Cookie from "@/components/layout/Cookie.astro";
import Search from "@/components/layout/Search.astro";

import Google from "@/components/scripts/Google.astro";
import YandexLoader from "@/components/ads/YandexLoader.astro";
import Yandex from "@/components/ads/YandexAds.astro";

import ScrollScript from "@/components/scripts/ScrollScript.astro";

interface Props {
  title?: string;
  description?: string;
  
  image?: { 
    src: string; 
    alt: string 
  };
  
  canonicalURL?: 
    URL | 
    string;
    
  type?: 
    "website" | 
    "article" | 
    "profile" | 
    "creativeWork";
    
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  
  category?: { 
    name: string;
    description?: string;
    slug: string;
  };
  
  author?: { 
    name: string; 
    role: string; 
    avatar: string; 
    bio: string; 
    slug: string 
  };
  
  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };
  
  header?: boolean;
  footer?: boolean;
  withContainer?: boolean;
  
  size?: 
    "sm" | 
    "md" | 
    "lg" | 
    "xl" | 
    "full";
    
  client?: string;
  role?: string;
  duration?: string;
  demoUrl?: string;
  repoUrl?: string;
}

const {
  header = true,
  footer = true,
  withContainer = false,
  size = "xl",
  client,
  role: creativeWorkRole,
  duration,
  demoUrl,
  repoUrl,
 ...seoProps
} = Astro.props;

const siteData = siteConfig;

const lang = "en-US"
---

<!DOCTYPE html>

<html
  lang={lang}
  dir="ltr"
  class="scroll-smooth antialiased"
  prefix={seoProps.type === "article"? "og: https://ogp.me/ns# article: https://ogp.me/ns/article#" : "og: https://ogp.me/ns#"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    
    <BaseHead
      {...seoProps}
      siteData={siteData}
      client={client}
      role={creativeWorkRole}
      duration={duration}
      demoUrl={demoUrl}
      repoUrl={repoUrl}
    />
    <ThemeScript />
    <Google />
    <YandexLoader />
  </head>
  <body>
    <a href="#main-content" class="sr-only text-copy-16 md:text-copy-18 focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:bg-(--bg) focus:text-(--fg) focus:px-4 focus:py-2 focus:border focus:border-(--border)">
      {siteConfig.skipToContent}
    </a>
    {header && <Header />}
    <main id="main-content">
      {withContainer? (
        <Container size={size}>
          <slot />
        </Container>
        ) : (
          <slot />
        )
      }
    </main>
    <Search />
    <Yandex />
    {footer && <Footer />}
    <div id="modal-root"></div>
    <Cookie />
    <MobileMenu />
    <ScrollScript />
  </body>
</html>