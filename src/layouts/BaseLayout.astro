---
// src/layouts/BaseLayout.astro
import "@/styles/global.css";
import BaseHead from "@/components/layout/BaseHead.astro";

import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/ui/Container.astro";
import HomeCTA from "@/components/home/HomeCTA.astro";
import ReadingProgress from '@/components/ui/ReadingProgress.astro';

interface Props {
  title?: string;
  description?: string;
  image?: any; 
  canonicalURL?: URL | string;
  type?: "website" | "article";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  header?: boolean;
  footer?: boolean;
  container?: boolean;
  containerSize?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
}

const { 
  title, 
  description, 
  image, 
  canonicalURL, 
  type = "website",
  noIndex = false,
  publishedTime,
  modifiedTime,
  tags = [],
  header = true,
  footer = true,
  container = true,
  containerSize = "md"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <script is:inline>
      (function() {
        const theme = (() => {
          const stored = localStorage.getItem('theme');
          if (stored === 'dark') return 'dark';
          if (stored === 'light') return 'light';
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        })();
        
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <BaseHead 
      title={title}
      description={description}
      image={image} 
      canonicalURL={canonicalURL}
      type={type}
      noIndex={noIndex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
    />
  </head>
  <body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-950 dark:text-zinc-50 antialiased font-medium">
    <ReadingProgress />
    {header && <Header />}    
    <main>
      {container ? (
        <Container size={containerSize}>
          <slot />
        </Container>
      ) : (
        <slot />
      )}

      <!-- Yandex Ads  -->
      {import.meta.env.PROD && (
  		<Container size={containerSize}>
			<div class="yandex-ads my-8">
      		<script is:inline>window.yaContextCb = window.yaContextCb || [];</script>
      		<script async src="https://yandex.ru/ads/system/context.js"></script>
      		<script is:inline>
        		window.yaContextCb.push(() => {
          		Ya.Context.AdvManager.render({
            		blockId: "R-A-19135204-1",
            		type: "topAd",
          		});
        		});
      		</script>
      
      		<script is:inline>
        		window.yaContextCb.push(() => {
          		Ya.Context.AdvManager.render({
            		blockId: "R-A-19135204-2",
            		type: "floorAd",
            		platform: "desktop"
          		});
        		});
      		</script>
    		</div>
  		</Container>
		)}
      <HomeCTA />
    </main>    
    {footer && <Footer />}
    <noscript>
		<div><img src="https://mc.yandex.ru/watch/108674014" style="position:absolute; left:-9999px;" alt="" /></div>
	</noscript>
  </body>
</html>