---
import "@/styles/global.css";
import BaseHead from "@/components/layout/BaseHead.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Search from "@/components/layout/Search.astro";

interface Props {
  title?: string;
  description?: string;
  image?: any; 
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  category?: string;
  header?: boolean;
  footer?: boolean;
  container?: boolean;
  containerSize?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
}

const { 
  header = true,
  footer = true,
  container = true,
  containerSize = 'lg',
  ...seoProps 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <script is:inline>
      (function() {
        const theme = (() => {
          const stored = localStorage.getItem('theme');
          if (stored === 'dark') return 'dark';
          if (stored === 'light') return 'light';
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        })();
        
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <BaseHead {...seoProps} />
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2TKFP229HJ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2TKFP229HJ', {
        anonymize_ip: true,
        send_page_view: true
      });
    </script>
  </head>
  <body class="bg-white dark:bg-black text-zinc-950 dark:text-zinc-50 font-medium">
    <div aria-hidden="true" class="pointer-events-none fixed inset-0 z-0">
      <div class="absolute inset-y-0 left-1/2 w-px bg-black/5 dark:bg-white/5"></div>
    </div>
    
    {header && <Header />}
    
    <main class={container ? `container-${containerSize} mx-auto` : ''}>
      <slot />
      <Search />
    </main>
    
    {footer && <Footer />}
    
    <script is:inline>
      (function(m,e,t,r,i,k,a){
        m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
        m[i].l=1*new Date();
        for (var j = 0; j < document.scripts.length; j++) {
          if (document.scripts[j].src === r) { return; }
        }
        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
      })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=108731154', 'ym');

      ym(108731154, 'init', {
        ssr: true, 
        clickmap: true, 
        referrer: document.referrer, 
        url: location.href, 
        accurateTrackBounce: true, 
        trackLinks: true
      });
    </script>
    <noscript>
      <div>
        <img src="https://mc.yandex.ru/watch/108731154" style="position:absolute; left:-9999px;" alt="" />
      </div>
    </noscript>
  </body>
</html>