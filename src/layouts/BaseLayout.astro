---
// src/layouts/BaseLayout.astro
import "@/styles/global.css";

import { siteConfig } from "@/config/site";
import ThemeScript from "@/components/scripts/ThemeScript.astro";
import BaseHead from "@/components/layout/BaseHead.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Container from "@/components/ui/Container.astro";
import MobileMenu from "@/components/layout/MobileMenu.astro";
import Search from "@/components/layout/Search.astro";
import ScrollScript from "@/components/scripts/ScrollScript.astro";
import YandexLoader from "@/components/ads/YandexLoader.astro";
import YandexAds from "@/components/ads/YandexAds.astro";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile" | "creativeWork";
  basePath: 'blog' | 'portfolio' | 'legal' | 'blog/category' | 'author' | '';
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  category?: { name: string; description?: string; slug: string };
  author?: { name: string; role: string; avatar: string; bio: string; slug: string };
  client?: string;
  role?: string;
  duration?: string;
  demoUrl?: string;
  repoUrl?: string;
  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };
  header?: boolean;
  footer?: boolean;
  withContainer?: boolean;
  size?: "sm" | "md" | "lg" | "xl" | "full";
}

const {
  lang = "en-US",
  header = true,
  footer = true,
  withContainer = false,
  size = "xl",
  client,
  role: creativeWorkRole,
  duration,
  demoUrl,
  repoUrl,
  ...seoProps
} = Astro.props;

const siteData = siteConfig;
---

<!DOCTYPE html>
<html
  lang={lang}
  dir="ltr"
  class="antialiased"
  prefix={seoProps.type === "article"
    ? "og: https://ogp.me/ns# article: https://ogp.me/ns/article#"
    : "og: https://ogp.me/ns#"}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <BaseHead
      {...seoProps}
      siteData={siteData}
      client={client}
      role={creativeWorkRole}
      duration={duration}
      demoUrl={demoUrl}
      repoUrl={repoUrl}
    />
    <ThemeScript />
    <script src="https://cdn.cookiehub.eu/c2/561fe9ba.js"></script>
    <script type="text/javascript">
      document.addEventListener("DOMContentLoaded", function (event) {
        var cpm = {};
        window.cookiehub.load(cpm);
      });
    </script>
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-NJJPZV2M");
    </script>   
    <script async type="application/javascript" src="https://news.google.com/swg/js/v1/swg-basic.js"></script>
    <script is:inline>
      (self.SWG_BASIC = self.SWG_BASIC || []).push((basicSubscriptions) => {
        basicSubscriptions.init({
          type: "NewsArticle",
          isPartOfType: ["Product"],
          isPartOfProductId: "CAow3NjGDA:openaccess",
          clientOptions: { theme: "dark", lang: "id" },
          autoPromptType: "none"
        });
      });
    </script>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4943136052113535" crossorigin="anonymous"></script>
    <YandexLoader />
  </head>
  <body>
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NJJPZV2M"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <a
      href="#main-content"
      class="sr-only text-copy-16 md:text-copy-18 focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:bg-(--bg) focus:text-(--fg) focus:px-4 focus:py-2 focus:border focus:border-(--border)"
    >
      {siteConfig.skipToContent}
    </a>
    {header && <Header />}
    <main id="main-content">
      {withContainer ? (
        <Container size={size}>
          <slot />
        </Container>
      ) : (
        <slot />
      )}
    </main>
    <Search />
    {footer && <Footer />}
    <div id="modal-root"></div>
    <MobileMenu />
    <ScrollScript />
    <YandexAds />
  </body>
</html>
