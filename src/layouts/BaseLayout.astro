---
// src/layouts/BaseLayout.astro
import "@/styles/global.css";
import { getEntry } from 'astro:content';
import { siteConfig } from "@/config/site";

import BaseHead from "@/components/layout/BaseHead.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Search from "@/components/layout/Search.astro";
import Container from "@/components/ui/Container.astro";


interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile" | "creativeWork";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  category?: { name: string; description?: string; slug: string };
  author?: { name: string; role: string; avatar: string; bio: string; slug: string };
  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };
  header?: boolean;
  footer?: boolean;
  withContainer?: boolean;
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  client?: string;
  role?: string;
  duration?: string;
  demoUrl?: string;
  repoUrl?: string;
}

const { 
  header = true,
  footer = true,
  withContainer = true,
  size = 'lg',
  client,
  role: creativeWorkRole,
  duration,
  demoUrl,
  repoUrl,
  ...seoProps 
} = Astro.props;

let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {
  console.warn('Settings not found, using siteConfig fallback');
}
const siteData = settings?.data || siteConfig;
---

<!DOCTYPE html>
<html 
  lang="id" 
  dir="ltr"
  class="scroll-smooth antialiased"
  prefix={seoProps.type === "article" ? "og: https://ogp.me/ns# article: https://ogp.me/ns/article#" : "og: https://ogp.me/ns#"}
>
  <head>
    <script is:inline>
      const theme = (() => {
        const stored = localStorage.getItem('theme');
        if (stored) return stored;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      })();
      document.documentElement.classList[theme === 'dark' ? 'add' : 'remove']('dark');
    </script>
    <BaseHead 
      {...seoProps} 
      client={client} 
      role={creativeWorkRole} 
      duration={duration} 
      demoUrl={demoUrl} 
      repoUrl={repoUrl} 
    />
  </head>

  <body class="bg-white dark:bg-black text-zinc-950 dark:text-zinc-50 font-medium selection:bg-zinc-900 selection:text-white dark:selection:bg-white dark:selection:text-black">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:border focus:border-black dark:focus:bg-black dark:focus:text-white">
      Loncat ke konten utama
    </a>

    <div aria-hidden="true" class="pointer-events-none fixed inset-0 z-0 flex justify-center">
      <div class="absolute inset-y-0 left-1/2 w-px bg-black/5 dark:bg-white/5 -translate-x-1/2"></div>
      <div class="hidden h-full w-[1024px] border-x border-black/5 dark:border-white/5 lg:block"></div>
    </div>
    
    <div class="relative z-10 flex min-h-screen flex-col">
      {header && <Header />}
      
      <main id="main-content" class="flex-1 outline-none">
        {withContainer ? (
          <Container size={size}>
            <slot />
          </Container>
        ) : (
          <slot />
        )}
        <Search />
      </main>
      
      {footer && <Footer />}
    </div>

    <div id="modal-root"></div>
    <div id="toast-root" class="fixed bottom-4 right-4 z-100"></div>

    {import.meta.env.PROD && siteData.yandexMetrikaId && (
      <>
        <script is:inline type="text/javascript">
          (function(m,e,t,r,i,k,a){
              m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
              m[i].l=1*new Date();
              for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
              k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
          })(window, document,'script',`https://mc.yandex.ru/metrika/tag.js?id=${siteData.yandexMetrikaId}`, 'ym');
          ym(`${siteData.yandexMetrikaId}`, 'init', {ssr:true, clickmap:true, trackLinks:true, accurateTrackBounce:true});
        </script>
        <noscript><div><img src={`https://mc.yandex.ru/watch/${siteData.yandexMetrikaId}`} style="position:absolute; left:-9999px;" alt="" /></div></noscript>
      </>
    )}
  </body>
</html>