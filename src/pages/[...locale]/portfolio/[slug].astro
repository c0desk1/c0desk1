---
// src/pages/[...locale]/portfolio/[...slug].astro
export const prerender = true;

import "@/styles/prose/index.css";

import { getCollection, render } from "astro:content";
import { siteConfig } from "@/config/site";
import { getSmartRelatedProjects } from "@/lib/botEngine";
import { getCurrentLocale, localizePath, getLabel } from "@/utils/i18n";
import { slugify } from "@/lib/utils";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import BackToTop from "@/components/ui/BackToTop.astro";
import ReadingProgress from "@/components/ui/ReadingProgress.astro";

import PortfolioHeader from "@/components/portfolio/PortfolioHeader.astro";
import PortfolioMetrics from "@/components/portfolio/PortfolioMetrics.astro";
import PortfolioGallery from "@/components/portfolio/PortfolioGallery.astro";
import PortfolioRelated from "@/components/portfolio/PortfolioRelated.astro";
import PortfolioFeaturedImage from "@/components/portfolio/PortfolioFeaturedImage.astro";
import PortfolioCaseStudy from "@/components/portfolio/PortfolioCaseStudy.astro";

import { components } from '@/components/layout/MDXComponents';

export async function getStaticPaths() {
  const projects = await getCollection("portfolio", ({ data }) =>!data.draft);

  return projects.map((project) => {
    const lang = project.data.lang || 'id';
    const urlSlug = slugify(project.data.title);
    const baseId = project.id.split('/')[0];
    const alternates = projects.filter(p => p.id.startsWith(baseId + '/'));

    const alternateSlugs = Object.fromEntries(
      alternates.map(p => [
        p.data.lang || 'id',
        slugify(p.data.title)
      ])
    );

    return {
      params: {
        locale: lang === 'id'? undefined : lang,
        slug: urlSlug
      },
      props: { project, alternateSlugs }
    };
  });
}

const { project, alternateSlugs } = Astro.props;

const locale = getCurrentLocale(Astro);

const data = project.data;

const {
  title,
  description,
  pubDate,
  updatedDate,
  techStack,
  demoUrl,
  repoUrl,
  image,
  gallery,
  featured,
  client,
  role,
  duration,
  challenge,
  solution,
  result,
  metrics,
  seo
} = data;

const { Content } = await render(project);

const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = {
  src: seo?.ogImage || image?.src || siteConfig.ogImage,
  alt: image?.alt || title
};

const allProjects = await getCollection("portfolio", ({ data }) =>
!data.draft && (data.lang || 'id') === locale
);
const relatedProjects = getSmartRelatedProjects(project, allProjects, 2);
const displayGallery = Array.isArray(gallery)? gallery : [];

const siteURL = Astro.site?.toString()?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

// i18n labels
const homeLabel = getLabel(locale, 'home');
const portfolioLabel = getLabel(locale, 'p_PageTitle');
const portfolioDesc = getLabel(locale, 'p_PageDesc');
const galleryLabel = getLabel(locale, 'p_Gallery');

// sr-only labels
const srPortfolioHeader = getLabel(locale, 'p_Header');
const srPortfolioImage = getLabel(locale, 'p_ImageContent');
const srPortfolioMetrics = getLabel(locale, 'p_MetricsCase');
const srPortfolioContent = getLabel(locale, 'p_Content');
const srPortfolioRelated = getLabel(locale, 'p_RelatedContent');

const portfolioCategory = {
  name: portfolioLabel,
  slug: "portfolio",
  description: portfolioDesc
};

const seoBreadcrumbItems = [
  { name: homeLabel, href: localizePath('/', locale) },
  { name: portfolioLabel, href: localizePath('/portfolio', locale) },
  { name: title, href: canonicalURL }
];

const Breadcrumbs = seoBreadcrumbItems.filter(item =>
  item.name === homeLabel || item.name === portfolioLabel
);
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="creativeWork"
  publishedTime={pubDate}
  modifiedTime={updatedDate || pubDate}
  tags={techStack}
  category={portfolioCategory}
  client={client}
  role={role}
  duration={duration}
  demoUrl={demoUrl}
  repoUrl={repoUrl}
  canonicalURL={canonicalURL}
  alternateSlugs={alternateSlugs}
  basePath="portfolio"
>
  <article>
    <h1 class="sr-only">{title}</h1>
    <Section size="md">
      <Container size="md">
        <h2 class="sr-only">{srPortfolioHeader}</h2>
        <div class="flex flex-col justify-center items-center">
          <Breadcrumb items={Breadcrumbs} />
          <PortfolioHeader
            title={title}
            date={pubDate}
            updatedDate={updatedDate}
            featured={featured}
            client={client}
            role={role}
            duration={duration}
            techStack={techStack}
            demoUrl={demoUrl}
            repoUrl={repoUrl}
          />
        </div>
      </Container>
    </Section>
    {image && (
      <Section size="none">
        <Container size="md">
          <h2 class="sr-only">{srPortfolioImage}</h2>
          <PortfolioFeaturedImage
            src={image.src}
            alt={image.alt || title}
            caption={(image as any).caption || title}
          />
        </Container>
      </Section>
    )}
    <Section size="sm">
      <Container size="md">
        <h2 class="sr-only">{srPortfolioMetrics}</h2>
        <PortfolioMetrics metrics={metrics} />
        <PortfolioCaseStudy
          challenge={challenge}
          solution={solution}
          result={result}
          allowMultiple={true}
        />
      </Container>
    </Section>
    <Section size="sm">
      <Container size="md">
        <h2 class="sr-only">{srPortfolioContent}</h2>
        {displayGallery.length > 0 && (
          <div class="prose-custom mb-6">
            <h2 class="mb-4">{galleryLabel}</h2>
            <PortfolioGallery
              images={displayGallery}
              title={title}
            />
          </div>
        )}
        <div id="article-content" class="prose-custom w-full">
          <Content components={components} />
        </div>
      </Container>
    </Section>
    <Section size="sm">
      <Container size="lg">
        <h2 class="sr-only">{srPortfolioRelated}</h2>
        <PortfolioRelated projects={relatedProjects} />
        <BackToTop showBorder align="center" />
      </Container>
    </Section>
  </article>
  <ReadingProgress />
</BaseLayout>
