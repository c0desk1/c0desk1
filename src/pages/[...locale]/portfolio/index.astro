---
// src/pages/portfolio/index.astro
export const prerender = true;

import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Grid from "@/components/ui/Grid.astro";
import Hero from "@/components/ui/Hero.astro";
import PortfolioCard from "@/components/portfolio/PortfolioCard.astro";

import { sortByDate, filterByFeatured, filterByDraft, cn } from "@/lib/utils";
import { getCurrentLocale, getLabel } from "@/utils/i18n";

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    { params: { locale: 'en' } },
    { params: { locale: 'ru' } },
  ];
}

const locale = getCurrentLocale(Astro);

const allProjects = await getCollection("portfolio", ({ data }) =>
 !data.draft && data.lang === locale
);
const projects = sortByDate(filterByDraft(allProjects));

const featuredProjects = filterByFeatured(projects);
const featuredProject = featuredProjects?.[0];
const regularProjects = projects.filter((p) => p.id!== featuredProject?.id);

const siteURL = Astro.site?.toString()?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const seoData = {
  title: getLabel(locale, 'p_PageTitle'),
  description: getLabel(locale, 'p_PageDesc'),
  type: "website" as const,
  canonicalURL,
};

const HeroAria = getLabel(locale, "p_HeroAria");
const Herotitle = getLabel(locale, 'p_HeroTitle');
const HeroHighlight = getLabel(locale, 'p_HeroHighlight');
const HeroDescription = getLabel(locale, 'p_HeroDesc');

const p_f = getLabel(locale, "p_FeaturedPosts");
const p_a = getLabel(locale, "p_AllProjects");

---

<BaseLayout {...seoData}>
  <Section id="portfolio-hero" size="none" aria-label={HeroAria}>
    <div class="relative items-center">
      <div
        class={cn(
          "absolute inset-0",
          "bg-size-[20px_20px]",
          "bg-[radial-gradient(#d4d4d4_1px,transparent_1px)]",
          "dark:bg-[radial-gradient(#404040_1px,transparent_1px)]",
        )}
      />
      <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-(--bg) mask-[radial-gradient(ellipse_at_center,transparent_20%,black)]"></div>
      <Container size="full" class="relative items-center z-20">
        <Hero
          title={Herotitle}
          highlight={HeroHighlight}
          description={HeroDescription}
        />
      </Container>
    </div>
  </Section>

  <Section size="lg" class="section-divider">
    <Container size="xl">
      <h2 class="sr-only">{p_f}</h2>
      {featuredProject && (
        <div class="mb-10">
          <PortfolioCard project={featuredProject} />
        </div>
      )}

      <h2 class="sr-only">{p_a}</h2>
      <Grid cols="cards" gap="md">
        {regularProjects.map((project) => (
          <PortfolioCard project={project} />
        ))}
      </Grid>
    </Container>
  </Section>
</BaseLayout>
