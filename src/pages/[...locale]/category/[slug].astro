---
// src/pages/[...locale]/category/[slug].astro
export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";

import { getCollection, getEntry } from "astro:content";
import { siteConfig } from "@/config/site";
import { formatDateCompact } from "@/lib/utils";
import { getCurrentLocale, localizePath, getLabel } from "@/utils/i18n";

export async function getStaticPaths() {
  const categories = await getCollection("categories");
  const locales = siteConfig.locales;

  return locales.flatMap((locale) => {
    // Filter kategori berdasarkan bahasa saat ini (jika kategori kamu memiliki field lang)
    const localeCategories = categories.filter(c => (c.data.lang || siteConfig.defaultLocale) === locale);
    
    // Jika tidak punya field lang dan slugnya universal, gunakan semua 'categories' 
    const targetCategories = localeCategories.length > 0 ? localeCategories : categories;

    return targetCategories.map((category) => {
      // Mendapatkan base ID untuk mencari alternateSlugs antar bahasa
      const baseId = category.id.split('/')[0];
      const alternates = categories.filter(c => c.id.startsWith(baseId + '/'));
      
      const alternateSlugs = Object.fromEntries(
        alternates.map(c => [
          c.data.lang || siteConfig.defaultLocale,
          c.data.slug || baseId
        ])
      );

      return {
        params: { 
          locale: locale === siteConfig.defaultLocale ? undefined : locale,
          slug: category.data.slug || baseId
        },
        props: { category, alternateSlugs },
      };
    });
  });
}

const { category, alternateSlugs } = Astro.props;
const locale = getCurrentLocale(Astro);

// Hanya ambil artikel sesuai locale aktif
const allPosts = await getCollection("blog", ({ data }) => {
  const postLang = data.lang || siteConfig.defaultLocale;
  return !data.draft && postLang === locale;
});

const categoryPosts = allPosts
  .filter((post) => post.data.category?.id === category.id || post.data.category?.slug === category.data.slug)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const postsWithAuthor = await Promise.all(
  categoryPosts.map(async (post) => {
    const author = post.data.author ? await getEntry(post.data.author) : null;
    return { ...post, authorData: author?.data };
  })
);

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const t_home = getLabel(locale, 'home');
const t_blog = getLabel(locale, 'blog');
const t_empty = getLabel(locale, 'noPostsInCategory');

const seoData = {
  title: category.data.name,
  description: category.data.description || `${t_blog} - ${category.data.name}`,
  type: "website" as const,
  canonicalURL,
  alternateSlugs,
};

const blogCategory = {
  name: t_blog,
  slug: "blog",
  description: getLabel(locale, 'blog_PageDescription')
};

const breadcrumbItems = [
  { name: t_home, href: localizePath('/', locale) },
  { name: t_blog, href: localizePath('/blog', locale) },
  { name: category.data.name, href: canonicalURL }
];
---

<BaseLayout {...seoData} category={blogCategory}>
    <Container size="lg" class="pt-8">
      <Breadcrumb items={breadcrumbItems} />
    </Container>
    <div class="border-b border-zinc-100 dark:border-zinc-800">
      <Container size="lg" class="py-16 md:py-24">
        <div class="max-w-2xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 mb-6">
            <span class="text-[11px] font-mono uppercase tracking-wider text-zinc-500">
              {getLabel(locale, 'filterCategory').split(' ')[1] || 'Category'}
            </span>
          </div>
          <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-white mb-4">
            {category.data.name}
          </h1>
        
          {category.data.description && (
            <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-md mx-auto">
              {category.data.description}
            </p>
          )}
          
          <div class="mt-6 inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
            <span class="text-[11px] font-mono text-zinc-500">
              {categoryPosts.length} {locale === 'id' ? 'artikel' : locale === 'ru' ? 'статей' : 'articles'}
            </span>
          </div>
        </div>
      </Container>
    </div>

    <Container size="lg" class="py-16 md:py-24">
      <div class="max-w-3xl mx-auto">
        {categoryPosts.length > 0 ? (
          <div class="space-y-px">
            {postsWithAuthor.map((post) => (
              <article class="group py-8 border-b border-zinc-100 dark:border-zinc-800 last:border-0">
                <a href={localizePath(`/blog/${post.id.split('/').pop() || post.data.slug}/`, locale)} class="block">
                  <div class="flex flex-col md:flex-row md:items-center gap-3 md:gap-6 mb-2">
                    <time class="text-[13px] text-zinc-500 font-mono tabular-nums">
                      {formatDateCompact(post.data.pubDate, locale === 'id' ? 'id-ID' : locale === 'ru' ? 'ru-RU' : 'en-US')}
                    </time>
                    {post.authorData && (
                      <>
                        <span class="hidden md:inline text-zinc-300 dark:text-zinc-700">•</span>
                        <span class="text-[13px] text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">
                          {post.authorData.name}
                        </span>
                      </>
                    )}
                  </div>
                  
                  <h2 class="text-xl md:text-2xl font-medium tracking-tight text-zinc-900 dark:text-white mb-2 group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-colors">
                    {post.data.title}
                  </h2>
                  
                  <p class="text-sm text-zinc-500 dark:text-zinc-400 line-clamp-2 leading-relaxed">
                    {post.data.description}
                  </p>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <div class="text-center py-12">
            <p class="text-zinc-400 dark:text-zinc-600">{t_empty}</p>
          </div>
        )}
      </div>
    </Container>
</BaseLayout>
