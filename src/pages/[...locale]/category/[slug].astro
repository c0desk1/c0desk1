---
// src/pages/[...locale]/category/[slug].astro
export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";

import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";
import { localizePath, getLabel } from "@/utils/i18n";
import { slugify } from "@/lib/utils";

import PostCard from "@/components/blog/PostCard.astro";
import Icon from "@/components/ui/Icon";

type Locale = 'id' | 'en' | 'ru' | 'jp';

export async function getStaticPaths() {
  const categories = await getCollection("categories");
  const locales = siteConfig.locales;

  return locales.flatMap((locale) =>
    categories.map((category) => {
      const loc = locale as Locale;
      const categoryName = category.data.name[loc] || category.data.name.id;
      const slug = slugify(categoryName) || category.id;

      return {
        params: {
          locale: locale === siteConfig.defaultLocale ? undefined : locale,
          slug,
        },
        props: { category, locale },
      };
    })
  );
}

const { category, locale } = Astro.props;

const loc = locale as Locale;

const allPosts = await getCollection("blog", ({ data }) => {
  const postLang = data.lang || siteConfig.defaultLocale;
  return !data.draft && postLang === locale;
});

const categoryPosts = allPosts
  .filter((post) => post.data.category?.id === category.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;

const categoryName = category.data.name[loc] || category.data.name.id;
const categoryDesc = category.data.description?.[loc] || category.data.description?.id || '';
const categorySlug = slugify(categoryName) || category.id;

const canonicalURL = new URL(
  localizePath(`/category/${categorySlug}`, locale),
  siteURL
).toString();

const t_home = getLabel(locale, 'home');
const t_blog = getLabel(locale, 'blog');
const t_empty = getLabel(locale, 'noPostsInCategory');
const t_articles = getLabel(locale, 'articles');

const seoData = {
  title: categoryName,
  description: categoryDesc || `${t_blog} - ${categoryName}`,
  type: "website" as const,
  canonicalURL,
};

const blogCategory = {
  name: t_blog,
  slug: "blog",
  description: getLabel(locale, 'blog_PageDescription')
};

const breadcrumbItems = [
  { name: t_home, href: localizePath('/', locale) },
  { name: t_blog, href: localizePath('/blog', locale) },
  { name: categoryName, href: localizePath(`/category/${categorySlug}`, locale) }
];
---

<BaseLayout 
  {...seoData} 
  category={blogCategory}
  basePath="blog"
  >
  <!-- Breadcrumb -->
  <Container size="lg" class="pt-6">
    <Breadcrumb items={breadcrumbItems} />
  </Container>

  <!-- Category header – Vercel‑style -->
  <section class="pb-16 pt-12 md:pb-24 md:pt-20">
    <Container size="lg" class="text-center">
      <div class="inline-flex items-center gap-1.5 rounded-full bg-(--bg-muted) px-3 py-1 text-xs font-medium text-(--fg-muted) ring-1 ring-(--border) mb-8">
        <svg class="h-3.5 w-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        {getLabel(locale, 'filterCategory')}
      </div>

      <h1 class="text-4xl font-bold tracking-tight text-(--fg) sm:text-5xl md:text-6xl">
        {categoryName}
      </h1>

      {categoryDesc && (
        <p class="mx-auto mt-6 max-w-xl text-lg text-(--fg-subtle) leading-relaxed">
          {categoryDesc}
        </p>
      )}

      <p class="mt-8 text-sm font-mono text-(--fg-dim)">
        {categoryPosts.length} {t_articles}
      </p>
    </Container>
  </section>

  <!-- Posts list -->
  <section class="pb-24 pt-8 md:pb-32">
    <Container size="lg">
      {categoryPosts.length > 0 ? (
        <div class="space-y-10">
          {categoryPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div class="rounded-full bg-(--bg-muted) p-4 text-(--fg-dim) mb-4">
            <Icon name="logo" />
          </div>
          <p class="text-(--fg-muted)">{t_empty}</p>
        </div>
      )}
    </Container>
  </section>
</BaseLayout>
