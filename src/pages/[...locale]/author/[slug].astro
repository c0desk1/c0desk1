---
// src/pages/[...locale]/author/[slug].astro
export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Icon from "@/components/ui/Icon";
import PostCard from "@/components/blog/PostCard.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import BackToTop from "@/components/ui/BackToTop.astro";

import { getCollection } from "astro:content";
import { Image } from 'astro:assets';
import { siteConfig } from "@/config/site";
import { cdnImage, cn, isCdnUrl } from "@/lib/utils";
import { localizePath } from "@/utils/i18n";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  const locales = siteConfig.locales;

  return locales.flatMap((locale) =>
    authors.map((author) => ({
      params: {
        locale: locale === siteConfig.defaultLocale? undefined : locale,
        slug: author.id
      },
      props: { author, locale },
    }))
  );
}

const { author, locale } = Astro.props;
const allPosts = await getCollection("blog", ({ data }) => {
  const postLang = data.lang || 'id';
  return!data.draft && postLang === locale;
});

const authorPosts = allPosts
 .filter((post) => post.data.author?.id === author.id)
 .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const siteURL = Astro.site?.toString()?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const social = author.data.social || siteConfig.author.social;

const labels = {
  id: {
    author: "Penulis",
    authorDesc: "Daftar artikel dari penulis.",
    home: "Beranda",
    latestArticles: "Artikel Terbaru",
    articleCount: "artikel",
    noArticles: "Belum ada artikel yang diterbitkan."
  },
  en: {
    author: "Author",
    authorDesc: "List of articles from the author.",
    home: "Home",
    latestArticles: "Latest Articles",
    articleCount: "articles",
    noArticles: "No articles have been published yet."
  },
  ru: {
    author: "Автор",
    authorDesc: "Список статей автора.",
    home: "Главная",
    latestArticles: "Последние статьи",
    articleCount: "статей",
    noArticles: "Статьи еще не опубликованы."
  }
}

const t = labels[locale] || labels.id;

const seoData = {
  title: author.data.name,
  description: author.data.bio,
  type: "profile" as const,
  canonicalURL,
  author: {
    name: author.data.name,
    role: author.data.role,
    avatar: author.data.avatar,
    bio: author.data.bio,
    slug: author.id,
  },
};

const authorCategory = {
  name: t.author,
  slug: "author",
  description: t.authorDesc
};

const optimizedAvatar = isCdnUrl(author.data.avatar)? cdnImage(author.data.avatar, { w: 112, h: 112, q: 85 }) : author.data.avatar;

const seoBreadcrumbItems = [
  { name: t.home, href: localizePath('/', locale) },
  { name: t.author, href: localizePath('/authors/', locale) },
  { name: author.data.name, href: canonicalURL }
];

const Breadcrumbs = seoBreadcrumbItems.filter(item =>
  item.name === t.home || item.name === t.author
);
---

<BaseLayout {...seoData} category={authorCategory}>
  <Section size="none" class="border-b border-dashed border-(--border)">
    <div class="relative items-center">
      <div
        class={cn(
          "absolute inset-0 z-1",
          "bg-size-[20px_20px]",
          "bg-[radial-gradient(#d4d4d4_1px,transparent_1px)]",
          "dark:bg-[radial-gradient(#404040_1px,transparent_1px)]",
        )}
      />
      <div class="pointer-events-none absolute inset-0 z-1 flex items-center justify-center bg-(--bg) mask-[radial-gradient(ellipse_at_center,transparent_20%,black)]" />
      <Container size="lg" class="py-16">
        <section class="flex flex-col-reverse md:flex-row items-center justify-center md:justify-between gap-4" aria-labelledby="author-heading">
          <div class="flex flex-col justify-center md:justify-start items-center md:items-start z-3">
            <Breadcrumb items={Breadcrumbs} />
            <div class="mt-5 space-y-5">
              <div class="space-y-3">
                <h1 id="author-heading" class="text-4xl md:text-5xl font-semibold tracking- text-(--fg) text-center md:text-start">
                  {author.data.name}
                </h1>
                <p class="text- md:text-sm text-(--fg-subtle) tracking-tight text-center md:text-start">
                  {author.data.role}
                </p>
              </div>
              <p class="max-w-2xl text- md:text-sm leading-7 text-(--fg-muted) text-center md:text-start">
                {author.data.bio}
              </p>
              <div class="flex items-center text-center md:text-start gap-2 pt-2 flex-wrap">
                {social.map((item: { href: string; label: string }) => (
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={item.label}
                    class="group flex items-center justify-center rounded-full border border-transparent text-(--fg-muted) transition-all duration-200 hover:border-(--border) hover:bg-(--bg-muted) hover:text-(--fg) p-0.5 gap-2"
                  >
                    <Icon
                      name={item.label as any}
                      className="w-4 h-4 transition-transform duration-200 group-hover:scale-110"
                    />
                    <span class="text- capitalize">
                      {item.label}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
          <div class="flex items-center z-3">
            <div
              class="relative overflow-hidden rounded-[28px] border border-(--border) bg-(--bg-subtle) p-2 shadow-sm">
              <Image
                src={optimizedAvatar}
                alt={author.data.name}
                width={224}
                height={224}
                loading="eager"
                decoding="async"
                class="h-auto w-full md:h-full md:w-56 rounded-[22px] object-cover"
              />
            </div>
          </div>
        </section>
      </Container>
    </div>
  </Section>
  <Section size="lg">
    <Container size="xl">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-(--fg) text-2xl md:text-3xl font-semibold tracking-tighter">
          {t.latestArticles}
        </h2>
        <span class="text- md:text-sm text-(--fg-muted)">{authorPosts.length} {t.articleCount}</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8">
        {authorPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
      {authorPosts.length === 0 && (
        <div class="py-20 text-center rounded-2xl border border-dashed border-(--border)">
          <p class="text-sm md:text-base text-(--fg-muted)">{t.noArticles}</p>
        </div>
      )}
    </Container>
    <BackToTop align="center" />
  </Section>
</BaseLayout>
