---
// src/pages/[...locale]/[...slug].astro
export const prerender = true;

import '@/styles/prose/index.css';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '@/config/site';
import { formatDate } from "@/lib/utils";
import { components } from '@/components/layout/MDXComponents';
import { getCurrentLocale, localizePath, getLabel } from "@/utils/i18n";

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Section from '@/components/ui/Section.astro';

export async function getStaticPaths() {
  const legalPages = await getCollection('legal');

  return legalPages.map((page) => {
    const pathParts = page.id.split('/');
    const baseId = pathParts[0];
    const lang = page.data.lang || 'id';
    const alternates = legalPages.filter(p => p.id.startsWith(baseId + '/'));
    const alternateSlugs = Object.fromEntries(
      alternates.map(p => [
        p.data.lang || 'id',
        p.id.split('/')[0]
      ])
    );

    return {
      params: {
        locale: lang === 'id' ? undefined : lang,
        slug: baseId
      },
      props: { page, alternateSlugs },
    };
  });
}

const { page, alternateSlugs } = Astro.props;
if (!page) return Astro.redirect('/404');

const { Content } = await render(page);
const locale = getCurrentLocale(Astro);

const siteData = siteConfig;

const siteURL = Astro.site?.toString() ?? siteData.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const seoTitle = page.data.seo?.title || page.data.title;
const seoDescription = page.data.seo?.description
  || page.data.description
  || siteData.defaultSeo[locale]?.description
  || siteData.defaultSeo.id.description;

const homeLabel = getLabel(locale, 'home') || 'Home';

const Breadcrumbs = [
  { name: homeLabel, href: localizePath('/', locale) },
  { name: page.data.title, href: canonicalURL }
];

const dateLocale = 
  locale === 'en' ? 'en-US' : 
  locale === 'ru' ? 'ru-RU' :
  locale === 'jp' ? 'ja-JP' : 
  'id-ID';

const formattedLastUpdated = page.data.lastUpdated
  ? formatDate(page.data.lastUpdated, dateLocale)
  : null;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  type="website"
  canonicalURL={canonicalURL}
  alternateSlugs={alternateSlugs}
  basePath="">
  
  <div class="relative w-full max-w-[1040px] mx-auto min-h-screen border-x border-[var(--border)] overflow-hidden">
    
    <div 
      class="pointer-events-none absolute inset-0 z-0
             bg-[linear-gradient(to_right,var(--border)_1px,transparent_1px),linear-gradient(to_bottom,var(--border)_1px,transparent_1px)] 
             bg-[size:100%_120px] md:bg-[size:50%_160px] lg:bg-[size:33.333%_160px] 
             [mask-image:linear-gradient(to_bottom,transparent_0%,black_10%,black_90%,transparent_100%)] 
             opacity-50 dark:opacity-100"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 flex flex-col">
      
      <Section size="md">
        <Container size="md" class="flex flex-col items-center justify-center text-center bg-[var(--bg)] py-20 px-6 my-16 md:my-24 border border-[var(--border)] shadow-sm">
          <Breadcrumb items={Breadcrumbs} />
          
          <h1 class="text-heading-32 md:text-heading-48 lg:text-heading-56 mt-8 max-w-[800px] text-balance tracking-tight">
            {page.data.title}
          </h1>
          
          {formattedLastUpdated && (
            <p class="text-copy-14 lg:text-copy-16 mt-6 text-[var(--fg-muted)]">
              {getLabel(locale, 'lastUpdated') || 'Terakhir diperbarui'}: 
              <time datetime={page.data.lastUpdated?.toISOString()}>{formattedLastUpdated}</time>
            </p>
          )}
        </Container>
      </Section>

      <Section size="lg" class="pt-0">
        <Container size="md" class="bg-[var(--bg)] px-6 py-12 md:px-12 md:py-16 border border-[var(--border)] shadow-sm">
          <div id="article-content" class="prose-custom max-w-none">
            <Content components={components} />
          </div>
        </Container>
      </Section>

    </div>
  </div>
</BaseLayout>