---
// src/pages/[...locale]/blog/[...slug].astro
export const prerender = true;

import '@/styles/prose/index.css';

import { getCollection, render, getEntry } from "astro:content";
import { siteConfig } from "@/config/site";
import { getCurrentLocale, localizePath, getLabel } from "@/utils/i18n";
import { components } from '@/components/layout/MDXComponents';
import { filterHeadingsForTOC, slugify } from "@/lib/utils";
import { getSmartRelatedPosts } from "@/lib/botEngine";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import PostHeader from "@/components/layout/PostHeader.astro";
import TOC from "@/components/ui/TOC.astro";
import PostNavigation from '@/components/blog/PostNavigation.astro';
import BlogRelatedPosts from "@/components/blog/BlogRelatedPosts.astro";
import BackToTop from "@/components/ui/BackToTop.astro";
import SharePost from '@/components/blog/SharePost.astro';
import CopyButton from '@/components/ui/CopyButton.astro';

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) =>!data.draft);

  return posts.map((post) => {
    const lang = post.data.lang || 'id';
    const urlSlug = slugify(post.data.title);
    const baseId = post.id.split('/')[0];
    const alternates = posts.filter(p => p.id.startsWith(baseId + '/'));

    const alternateSlugs = Object.fromEntries(
      alternates.map(p => [
        p.data.lang || 'id',
        slugify(p.data.title)
      ])
    );

    return {
      params: {
        locale: lang === 'id'? undefined : lang,
        slug: urlSlug
      },
      props: { post, alternateSlugs }
    };
  });
}

const { post, alternateSlugs} = Astro.props;
const locale = getCurrentLocale(Astro);

const allPosts = await getCollection("blog", ({ data }) => 
  !data.draft && (data.lang || 'id') === locale
);

const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const siteData = siteConfig;

const authorEntry = await getEntry(post.data.author);
const categoryEntry = await getEntry(post.data.category);

const { Content, headings } = await render(post);

const relatedPosts = getSmartRelatedPosts(post, allPosts, 3);

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  image,
  seo
} = post.data;

const seoImage = {
  src: seo?.ogImage || image?.src || siteConfig.ogImage,
  alt: image?.alt || title
};

const categorySlug = categoryEntry?.id || slugify(
  categoryEntry?.data?.name?.[locale] || categoryEntry?.data?.name?.id || getLabel(locale, "general")
);

const seoCategory = {
  name: categoryEntry?.data?.name || { id: getLabel(locale, "general"), en: getLabel(locale, "general"), ru: getLabel(locale, "general"), jp: getLabel(locale, "general") },
  description: categoryEntry?.data?.description?.[locale] || categoryEntry?.data?.description?.id || "",
  slug: categorySlug,
};

const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const tocHeadings = filterHeadingsForTOC(headings);

const siteURL = Astro.site?.toString() ?? siteData.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const homeLabel = getLabel(locale, 'home') || 'Home';
const blogLabel = getLabel(locale, 'blog') || 'Blog';

const categoryLabel =
  (typeof seoCategory.name === 'object' ? (seoCategory.name as Record<string, string>)[locale] : seoCategory.name)
  || getLabel(locale, "general")
  || "Umum";

const SeoBreadcrumbItems = [
  { name: homeLabel, href: localizePath('/', locale) },
  { name: blogLabel, href: localizePath('/blog', locale) },
  { name: categoryLabel, href: localizePath(`/blog/category/${seoCategory.slug}`, locale) },
  { name: title, href: canonicalURL }
];

const Breadcrumbs = SeoBreadcrumbItems.filter(
  (item) =>
    item.name === blogLabel ||
    item.name === categoryLabel
);
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  tags={tags}
  category={seoCategory}
  author={{
    name: authorEntry?.data.name,
    role: authorEntry?.data.role,
    avatar: authorEntry?.data.avatar,
    bio: authorEntry?.data.bio,
    slug: authorEntry?.id
  }}
  canonicalURL={canonicalURL}
  alternateSlugs={alternateSlugs}
  basePath="blog">
  <Section size="lg">
    <Section size="sm">
      <Container size="md">
        <h2 class="sr-only">{title}</h2>
        <Section size="none">
          <h2 class="sr-only">{getLabel(locale, 'b_breadcrumb')}</h2>
          <Breadcrumb items={Breadcrumbs} />
        </Section>
        <article id="post-article">
          <Section size="sm">
            <h2 class="sr-only">{getLabel(locale, 'b_articleHeader')}</h2>
            <PostHeader
              title={title}
              pubDate={pubDate}
              content={post.body}
              authorName={authorEntry?.data.name}
              authorAvatar={authorEntry?.data.avatar}
              authorTitle={authorEntry?.data.role}
              authorSlug={authorEntry?.id}
              image={image}
            />
          </Section>
          <Section size="sm" class="section-divider">
            <div class="flex justify-between items-center">
        		<SharePost url={canonicalURL} title={title} description={description} />
                <CopyButton />
        	</div>
          </Section>
          <Section size="sm">
            <div id="article">
              <div id="article-toc" class="hidden sticky top-15 z-50 my-6">
                {tocHeadings.length > 0 && (
                  <TOC headings={tocHeadings} />
                )}
              </div>
              <div id="article-content" class="prose-custom min-w-0 max-w-3xl mx-auto">
                <Content components={components} />
              </div>
            </div>
	        </Section>
	      </article>
	    </Container>
	  </Section>
    <Section size="sm">
      <h2 class="sr-only">{getLabel(locale, 'backToTop')}</h2>
      <Container size="lg">
        <BackToTop align="center" />
      </Container>
    </Section>
      <Section size="md" class="section-divider">
        <h2 class="sr-only">{getLabel(locale, 'b_relatedPosts')}</h2>
        <Container size="xl">
          <BlogRelatedPosts posts={relatedPosts} />
        </Container>
      </Section>
      <Section size="sm" class="section-divider">
      <h2 class="sr-only">{getLabel(locale, 'b_articleNavigation')}</h2>
      <Container size="xl">
          <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </Container>
      </Section>
    </Section>
  </Section>
</BaseLayout>
