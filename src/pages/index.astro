---
// src/pages/index.astro
import { getCollection } from "astro:content";
import { sortByDate } from "@/lib/utils";
import { siteConfig } from "@/config/site";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";

import Hero from "@/components/ui/Hero.astro";
import BlogSection from "@/components/section/BlogSection.astro";
import PortfolioSection from "@/components/section/PortfolioSection.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const blogPosts = sortByDate(allPosts).slice(0, 6);

const allProjects = await getCollection("portfolio", ({ data }) => !data.draft);
const portfolioProjects = sortByDate(allProjects, "date").slice(0, 2);

// FIX 1: Pastiin siteURL ada trailing slash
const siteURL = Astro.site?.toString() ?? siteConfig.url;

const seoData = {
  title: siteConfig.name,
  description: siteConfig.description,
  type: "website" as const,
};

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `${siteURL}#homepage-list`,
  "name": "Latest Content",
  "numberOfItems": blogPosts.length + portfolioProjects.length,
  "itemListElement": [
    ...blogPosts.map((post, i) => {
      const url = new URL(`blog/${post.id}/`, siteURL).toString();
      return {
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "BlogPosting",
          "@id": url,
          "url": url,
          "name": post.data.title,
          "headline": post.data.title
        }
      };
    }),
    ...portfolioProjects.map((project, i) => {
      const url = new URL(`portfolio/${project.id}/`, siteURL).toString();
      return {
        "@type": "ListItem",
        "position": blogPosts.length + i + 1,
        "item": {
          "@type": "CreativeWork",
          "@id": url,
          "url": url,
          "name": project.data.title
        }
      };
    })
  ]
};
---

<BaseLayout {...seoData}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <Section id="hero" size="xl" aria-label="Hero section">
    <Container size="md"> 
      <Hero />
    </Container>
  </Section>
  <Section id="blog" size="md" aria-label="Latest articles">
    <Container size="md">
      <BlogSection posts={blogPosts} />
    </Container>
  </Section>
  <Section id="portfolio" size="md" aria-label="Featured projects">
    <Container size="md">
      <PortfolioSection projects={portfolioProjects} />
    </Container>
  </Section>
</BaseLayout>