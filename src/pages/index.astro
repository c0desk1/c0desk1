---
// src/pages/[...locale]/index.astro
export const prerender = true;

import { getCollection } from "astro:content";
import { sortByDate } from "@/lib/utils";
import { siteConfig } from "@/config/site";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PostCard from "@/components/blog/PostCard.astro";
import PortfolioCard from '@/components/portfolio/PortfolioCard.astro';
import Button from "@/components/ui/Button.astro";

const allPosts = await getCollection("blog", ({ data }) =>
 !data.draft
);

const blogPosts = sortByDate(allPosts).slice(0, 6);

const allProjects = await getCollection("portfolio", ({ data }) =>
 !data.draft
);
const portfolioProjects = sortByDate(allProjects).slice(0, 3);

const seo = siteConfig.defaultSeo

const seoData = {
  title: seo.title,
  description: seo.description,
  type: "website" as "website",
  image: {
    src: siteConfig.ogImage,
    alt: seo.title,
  },
  canonicalURL: new URL(Astro.url.pathname, siteConfig.siteUrl).href,
};

const siteData = siteConfig

const h_c   = seo.title;
const title = siteData.HeroTitle;
const blog_s = siteData.home_BlogSection;
const portfolio_s = siteData.home_PortfolioSection;

const latestTitle = siteData.home_BlogSection;
const noPostsText = siteData.blog_noBlogPosts;
const viewAllText = siteData.blog_viewAll;
const blogPath = '/blog/';

const p_l = siteData.p_latestPost;
const p_e = siteData.p_Empty;
const p_a =siteData.p_AllProjects;
const portfolioPath = '/portfolio/';
---

<BaseLayout {...seoData}>
  <Section id="browse-portfolio" size="lg" aria-label={h_c}>
    <Container size="xl">
      <div class="relative grid grid-cols-1 lg:grid-cols-[300px_1fr] border border-(--border)">
        <aside class="border-b lg:border-b-0 border-(--border) lg:sticky lg:top-16 self-start">
          <h1 class="text-heading-24 md:text-heading-32 lg:text-heading-40 font-semibold text-(--fg) text-center md:text-start wrap-break-word">
            {title}
          </h1>
        </aside>
        <div class="flex flex-col min-w-0 border-0 lg:border-l border-(--border)">
          <div class="flex flex-col divide-y divide-(--border)">
            <Section id="blog" size="none" aria-label={blog_s}>
              <div class="flex items-center border-b border-(--border)">
                <h2 class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold p-4 lg:p-6">
                  {latestTitle}
                </h2>
              </div>
              {blogPosts.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-b border-(--border)">
                  {blogPosts.map((post) => (
                    <div class="transition-colors hover:bg-(--bg-muted) 
                      border-t border-(--border) first:border-t-0
                      md:nth-2:border-t-0
                      md:even:border-l md:border-(--border)
                      lg:nth-2:border-t-0 lg:nth-3:border-t-0
                      lg:nth-[3n+1]:border-l-0
                      lg:border-l lg:border-(--border)
                    ">
                      <PostCard post={post} />
                    </div>
                  ))}
                </div>
                ) : (
                <div class="py-12 text-center">
                  <p class="text-copy-16 md:text-copy-18 text-(--fg-subtle)">
                    {noPostsText}
                  </p>
                </div>
              )}
              <div class="flex justify-center py-8">
                <Button href={blogPath} variant="secondary" size="md">
                  {viewAllText}
                </Button>
              </div>
            </Section>
            <Section id="portfolio" size="none" aria-label={portfolio_s}>
              <div class="flex items-center border-b border-(--border) p-4 lg:p-6">
                <h2 class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold">
                  {p_l}
                </h2>
              </div>
              {portfolioProjects.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-b border-(--border)">
                  {portfolioProjects.map((project) => (
                    <div class="transition-colors hover:bg-(--bg-muted) 
                      border-t border-(--border) first:border-t-0
                      md:nth-2:border-t-0
                      md:even:border-l md:border-(--border)
                      lg:nth-2:border-t-0 lg:nth-3:border-t-0
                      lg:nth-[3n+1]:border-l-0
                      lg:border-l lg:border-(--border)
                    ">
                      <PortfolioCard project={project} />
                    </div>
                  ))}
                </div>
              ) : (
                <div class="py-12 text-center">
                  <p class="text-copy-16 md:text-copy-18 text-(--fg-subtle)">
                    {p_e}
                  </p>
                </div>
              )}
              <div class="flex justify-center py-8">
                <Button href={portfolioPath} variant="secondary" size="md">
                  {p_a}
                </Button>
              </div>
            </Section>
          </div>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
