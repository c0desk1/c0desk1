// src/pages/index.astro

import { getCollection } from "astro:content";
import { sortByDate } from "@/lib/utils";
import { siteConfig } from "@/config/site";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/ui/Hero.astro";
import HomeBlogSection from "@/components/home/HomeBlogSection.astro";
import HomePortfolioSection from "@/components/home/HomePortfolioSection.astro";

// ================= DATA LAYER =================
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const blogPosts = sortByDate(allPosts).slice(0, 6);

const allProjects = await getCollection("portfolio", ({ data }) => !data.draft);
const portfolioProjects = sortByDate(allProjects, "date").slice(0, 2);

// ================= SEO =================
const seoData = {
  title: siteConfig.name,
  description: siteConfig.description,
  type: "website" as const,
  canonicalURL: siteConfig.url,
};
---

<BaseLayout {...seoData}>
  <Hero />
  <section aria-label="Latest articles">
    <HomeBlogSection posts={blogPosts} />
  </section>
  <section aria-label="Featured projects">
    <HomePortfolioSection projects={portfolioProjects} />
  </section>
</BaseLayout>