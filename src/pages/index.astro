---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/ui/Hero.astro';
import HomeBlogSection from '@/components/home/HomeBlogSection.astro';
import HomePortfolioSection from '@/components/home/HomePortfolioSection.astro';
import HomeCTA from '@/components/home/HomeCTA.astro';
import { sortByDate } from '@/lib/utils';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const blogPosts = sortByDate(allPosts).slice(0, 4);

const allProjects = await getCollection('portfolio', ({ data }) => !data.draft);
const portfolioProjects = sortByDate(allProjects, 'date').slice(0, 2);
---

<BaseLayout>
  <Hero />
  <HomeBlogSection posts={blogPosts} />
  <HomePortfolioSection projects={portfolioProjects} />
  <HomeCTA />
</BaseLayout>