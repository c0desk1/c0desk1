---
// src/pages/index.astro
import { getCollection } from "astro:content";

import {
  SITE, 
  CATEGORIES,
  SERIES,
  ROUTES, 
  buildMeta, 
  schemaWebPage,
} from "@/consts";

import { sortByDate } from "@/lib/utils";

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Link from "@/components/ui/Link.astro";
import Hero from "@/components/ui/Hero.astro";
import PostCard from "@/components/blog/PostCard.astro";
import PostCardFeatured from "@/components/blog/PostCardFeatured.astro";
import GuideCard from "@/components/guide/GuideCard.astro";
import GuideCardFeatured from "@/components/guide/GuideCardFeatured.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const allGuides = await getCollection("guide", ({ data }) => !data.draft);

const sortedPosts = sortByDate(allPosts).slice(0, 6);
const featuredPosts = sortedPosts.slice(0, 3);
const regularPosts = sortedPosts.slice(3, 6);

const sortedGuides = allGuides
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
const featuredGuides = sortedGuides.slice(0, 3);
const regularGuides = sortedGuides.slice(3, 6);

const meta = buildMeta({ description: SITE.description, canonical: SITE.url });
const homepageSchema = schemaWebPage({ title: SITE.name, description: SITE.description, url: SITE.url, type: "WebPage" });

const heroCTA = { label: "Jelajahi Guide", href: "#guide" };
const heroCTA2 = { label: "Blog Terbaru", href: "#blog" };
---

<Layout {meta} isHome={true} schema={homepageSchema}>
  <Hero title="UN" subTitle="LOYD" description={SITE.description} cta={heroCTA} cta2={heroCTA2} />
  <Section size="none">
    <div class="marquee-wrap">
      <div class="marquee-track">
        {[...CATEGORIES, ...CATEGORIES].map((cat) => <span class="marquee-item">{cat.label}</span>)}
      </div>
    </div>
  </Section>
  {sortedGuides.length > 0 && (
    <Section size="lg">
      <Container size="xl">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 id="guide" class="text-heading-24 lg:text-heading-32 text-strong font-semibold">Guide</h2>
            <p class="text-body-14 text-muted mt-2 max-w-xl">Tutorial langkah-demi-langkah, teknik kustomisasi, dan panduan praktis.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-8">
          {featuredGuides.map((guide) => <GuideCardFeatured entry={guide} />)}
        </div>
        {regularGuides.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {regularGuides.map((guide) => <GuideCard entry={guide} />)}
          </div>
        )}
        <div class="flex justify-center mt-8 sm:hidden">
          <Link href={ROUTES.guide} variant="noir" size="sm">Lihat semua</Link>
        </div>
      </Container>
    </Section>
  )}
  {sortedPosts.length > 0 && (
    <Section size="lg" id="blog">
      <Container size="xl">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 id="blog" class="text-heading-24 lg:text-heading-32 text-strong font-semibold">Blog</h2>
            <p class="text-body-14 text-muted mt-2 max-w-xl">Berita, opini, dan update seputar pop culture, game, anime, dan teknologi.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-8">
          {featuredPosts.map((post) => <PostCardFeatured post={post} />)}
        </div>
        {regularPosts.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {regularPosts.map((post) => <PostCard post={post} />)}
          </div>
        )}
        <div class="flex justify-center mt-8 sm:hidden">
          <Link href={ROUTES.blog} variant="noir" size="sm">Lihat semua</Link>
        </div>
      </Container>
    </Section>
  )}
</Layout>

<style is:global>
  .marquee-wrap {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    padding: 16px 0;
    background: var(--bg-subtle);
  }
  .marquee-track {
    display: flex;
    align-items: center;
    gap: 48px;
    animation: marquee 20s linear infinite;
    white-space: nowrap;
  }
  .marquee-item {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--fg);
    text-transform: uppercase;
    flex-shrink: 0;
  }
</style>