---
// src/pages/index.astro
import { 
  SITE, 
  CATEGORIES, 
  ROUTES, 
  buildMeta, 
  schemaWebPage 
} from "@/consts";

import { sortByDate } from "@/lib/utils";
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Hero from "@/components/ui/Hero.astro";
import PostCard from "@/components/blog/PostCard.astro";
import Link from "@/components/ui/Link.astro";

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = sortByDate(posts).slice(0, 10);

const [latestPost, ...restPosts] = sortedPosts;

const meta = buildMeta({
  description: SITE.description,
  canonical: SITE.url,
});

const homepageSchema = schemaWebPage({
  title: SITE.name,
  description: SITE.description,
  url: SITE.url,
  type: "WebPage",
});

const heroCTA = { 
  label: "Blog", 
  href: ROUTES.blog 
};
const heroCTA2 = { 
  label: "Konten Terbaru", 
  href: "#article" 
};
---

<Layout
  {meta}
  isHome={true} 
  schema={homepageSchema}
  >
  <Hero
    title="UN"
    subTitle="LOYD"
    description={SITE.description}
    cta={heroCTA}
    cta2={heroCTA2}
  />
  <Section size="sm">
    <div class="marquee-wrap">
      <div class="marquee-track">
        {[...CATEGORIES, ...CATEGORIES].map((cat, i) => (
          <>
            <span class="marquee-item">{cat.label}</span>
            <span class="marquee-dot" />
          </>
        ))}
      </div>
    </div>
  </Section>
  <Section size="sm">
    <Container size="xl">
      <h2 id="article" class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold py-4 lg:py-6">
        {"Terbaru."}
      </h2>
      {latestPost ? (
        <div class="pb-8">
          <PostCard post={latestPost} />
        </div>
      ) : (
        <div class="py-12 text-center">
          <p class="text-body-16 md:text-body-18 text-muted">
            {"Tidak ada postingan"}
          </p>
        </div>
      )}
      <div class="flex justify-center py-8">
        <Link href={ROUTES.blog} variant="secondary" size="sm">
          {"Lihat semua"}
        </Link>
      </div>
    </Container>
  </Section>
  {restPosts.length > 0 && (
    <Section size="sm">
      <Container size="xl">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {restPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </Container>
    </Section>
  )}
</Layout>

<style is:global>
  .marquee-wrap {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    padding: 16px 0;
    background: var(--bg-subtle);
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 48px;
    animation: marquee 20s linear infinite;
    white-space: nowrap;
  }

  .marquee-item {
    font-family: var(--font-mono), 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--fg);
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .marquee-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    background: var(--accent);
    border-radius: 50%;
    margin: 0 24px;
    vertical-align: middle;
    flex-shrink: 0;
  }
</style>