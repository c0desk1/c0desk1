---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404: Not Found">
  <div class="flex flex-col items-center justify-center py-20 md:py-32 text-center">
    <span class="text-sm font-mono font-medium text-zinc-400 dark:text-zinc-600 uppercase tracking-widest mb-4">
      Error 404
    </span>
    
    <h1 class="text-4xl md:text-5xl font-bold tracking-tighter mb-6">
      Page not found.
    </h1>
    
    <p class="text-zinc-500 dark:text-zinc-400 max-w-md leading-relaxed mb-10">
      Halaman yang Anda cari tidak ada atau telah dipindahkan ke alamat lain.
    </p>

    <div class="flex flex-col sm:flex-row items-center gap-4">
      <a 
        href="/" 
        class="w-full sm:w-auto px-6 py-2.5 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 rounded-md text-sm font-medium hover:opacity-90 transition-opacity"
      >
        Back to Home
      </a>
      <a 
        href="/blog" 
        class="w-full sm:w-auto px-6 py-2.5 border border-zinc-200 dark:border-zinc-800 rounded-md text-sm font-medium hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors"
      >
        Read Blog
      </a>
    </div>

    <div class="mt-20 opacity-10 dark:opacity-5">
      <svg class="w-12 h-12" viewBox="0 0 24 24" fill="currentColor">
        <path d="M2 4h20L12 21Z" />
      </svg>
    </div>
  </div>
</BaseLayout>