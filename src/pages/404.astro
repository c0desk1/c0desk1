---
// src/pages/404.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import { siteConfig } from '@/config/site';

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;

const seoData = {
  title: "404: Page Not Found",
  description: "Maaf, halaman yang Anda cari tidak dapat ditemukan.",
  noIndex: true,
  type: "website" as const,
  canonicalURL: new URL('404', siteURL).toString(),
};

---

<BaseLayout {...seoData}>
  <Container size="md">
    <div class="flex flex-col items-center justify-center min-h-[70vh] py-20 text-center">
      
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 mb-8 font-mono text-[10px] uppercase tracking-[0.3em] text-zinc-500">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
        Status: 404
      </div>

      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-zinc-900 dark:text-white mb-6">
        Lost in space<span class="text-zinc-300 dark:text-zinc-700">.</span>
      </h1>
      
      <p class="text-base md:text-lg text-zinc-500 dark:text-zinc-400 max-w-md leading-relaxed mb-12 tracking-tight">
        Halaman yang Anda cari tidak ada atau telah dipindahkan. Mungkin ada kesalahan pada URL atau link yang sudah kadaluarsa.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a 
          href={siteURL} 
          class="px-8 py-2.5 rounded-full bg-zinc-900 dark:bg-white text-white dark:text-black text-sm font-medium hover:bg-zinc-800 dark:hover:bg-zinc-200 transition-all duration-300 shadow-lg shadow-zinc-200 dark:shadow-none"
        >
          Kembali ke Beranda
        </a>
        <a 
          href={new URL('blog/', siteURL).toString()} 
          class="px-8 py-2.5 rounded-full bg-transparent text-zinc-600 dark:text-zinc-400 text-sm font-medium border border-zinc-200 dark:border-zinc-800 hover:border-zinc-900 dark:hover:border-white hover:text-zinc-900 dark:hover:text-white transition-all duration-300"
        >
          Cari Artikel
        </a>
      </div>

      <div class="mt-24 opacity-20 dark:opacity-10 group cursor-default">
        <svg 
          class="w-10 h-10 transition-transform duration-700 group-hover:rotate-180" 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="1.5"
        >
          <path d="M12 2L2 22h20L12 2z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

    </div>
  </Container>
</BaseLayout>

<style>
  :global(body) {
    background-image: radial-gradient(circle at 50% 50%, rgba(24, 24, 27, 0.02) 0%, transparent 100%);
  }
  :global(.dark body) {
    background-image: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.02) 0%, transparent 100%);
  }
</style>