---
// src/pages/[id].astro

import '@/styles/prose/index.css';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Section from '@/components/ui/Section.astro';
import { siteConfig } from '@/config/site';
import { getEntry, getCollection, render } from 'astro:content';
import { formatDate } from "@/lib/utils";
import { components } from '@/components/layout/MDXComponents';

export async function getStaticPaths() {
  const legalPages = await getCollection('legal');
  
  return [
    ...legalPages.map(page => ({
      params: { id: page.id },
      props: { page },
    })),
  ];
}

const { page } = Astro.props;
if (!page) return Astro.redirect('/404');

const { Content } = await render(page);

let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {
  console.warn('Settings not found, using siteConfig fallback');
}
const siteData = settings?.data || siteConfig;

const siteURL = Astro.site?.toString() ?? siteData.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const seoData = {
  title: page.data.title,
  description: page.data.description || siteData.siteDescription,
  type: "website" as const,
  canonicalURL,
};

const breadcrumbItems = [
  { name: 'Home', href: siteURL },
  { name: page.data.title, href: canonicalURL },
];

const formattedLastUpdated = page.data.lastUpdated 
  ? formatDate(page.data.lastUpdated, 'id-ID')
  : null;
---

<BaseLayout {...seoData}>
  <Section size="md" class="border-b border-zinc-100 dark:border-zinc-800/50">
    <Container size="md">
      <Breadcrumb items={breadcrumbItems} />
      
      <div class="mt-8 text-center">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-zinc-900 dark:text-white">
          {page.data.title}
        </h1>
        {formattedLastUpdated && (
          <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-400">
            Terakhir diperbarui: {formattedLastUpdated}
          </p>
        )}
      </div>
    </Container>
  </Section>

  <Section size="lg">
    <Container size="md">
      <div class="mx-auto max-w-3xl">
        <div id="article-content" class="prose-custom w-full">
          <Content components={components} />
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
