---
import "@/styles/prose.css";

import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

import { siteConfig } from "@/config/site";
import { getSmartRelatedProjects } from "@/lib/botEngine";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";

import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import BackToTop from "@/components/ui/BackToTop.astro";

import PortfolioHeader from "@/components/portfolio/PortfolioHeader.astro";
import PortfolioMetrics from "@/components/portfolio/PortfolioMetrics.astro";
import PortfolioGallery from "@/components/portfolio/PortfolioGallery.astro";
import PortfolioRelated from "@/components/portfolio/PortfolioRelated.astro";
import PortfolioFeaturedImage from "@/components/portfolio/PortfolioFeaturedImage.astro";

export async function getStaticPaths() {
  const projects = await getCollection("portfolio", ({ data }) =>!data.draft);
  return projects.map((project: CollectionEntry<"portfolio">) => ({
    params: { slug: project.id },
    props: { project }
  }));
}

interface Props {
  project: CollectionEntry<"portfolio">;
}

const { project } = Astro.props;

const {
  title,
  description,
  date,
  updatedDate,
  techStack,
  demoUrl,
  repoUrl,
  image,
  imageAlt,
  imageCaption,
  gallery,
  featured,
  client,
  role,
  duration,
  challenge,
  solution,
  result,
  metrics,
  seo
} = project.data;

const { Content } = await render(project);

const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = seo?.ogImage || image || siteConfig.ogImage;

const allProjects = await getCollection("portfolio", ({ data }) =>!data.draft);
const relatedProjects = getSmartRelatedProjects(project, allProjects, 2);

const displayGallery = Array.isArray(gallery)? gallery : [];

const siteURL = Astro.site?.toString()?? siteConfig.url;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const seoData = {
  title: seoTitle,
  description: seoDescription,
  image: seoImage,
  type: "website" as const,
  publishedTime: date,
  modifiedTime: updatedDate,
  tags: techStack
};

const breadcrumbItems = [
  { name: "Home", href: siteURL },
  { name: "Portfolio", href: new URL("portfolio/", siteURL).toString() },
  { name: title, href: canonicalURL }
];

const imageURL = image ? new URL(image, siteURL).toString() : undefined;

const creativeWorkSchema = {
  "@type": "CreativeWork",
  "@id": `${canonicalURL}#creativework`,
  "url": canonicalURL,
  "name": title,
  "headline": title,
  "description": description,
  "image": image ? {
    "@type": "ImageObject",
    "url": imageURL,
    "caption": imageCaption || imageAlt || title
  } : undefined,
  "dateCreated": date?.toISOString(),
  "dateModified": updatedDate?.toISOString() || date?.toISOString(),
  "creator": { "@id": `${siteURL}#person` },
  "publisher": { "@id": `${siteURL}#organization` },
  "keywords": techStack?.join(", "),
  "isPartOf": { "@id": new URL("portfolio/", siteURL).toString() + "#collectionpage" },
  ...(client && { "client": { "@type": "Organization", "name": client } }),
  ...(role && { "contributor": { "@id": `${siteURL}#person`, "roleName": role } }),
  ...(duration && { "timeRequired": duration }),
  ...(demoUrl && { "workExample": { "@type": "WebSite", "url": demoUrl } }),
  ...(repoUrl && { "codeRepository": repoUrl })
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    creativeWorkSchema,
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalURL}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteURL },
        { "@type": "ListItem", "position": 2, "name": "Portfolio", "item": new URL("portfolio/", siteURL).toString() },
        { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
      ]
    }
  ]
};
---

<BaseLayout {...seoData} container={false}>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<article>
  <h1 class="sr-only">{title}</h1>
  <Section size="lg">
    <Container size="sm">
      <h2 class="sr-only">Portfolio Header</h2>
      <Breadcrumb items={breadcrumbItems} />
      <PortfolioHeader
        title={title}
        date={date}
        updatedDate={updatedDate}
        featured={featured}
        client={client}
        role={role}
        duration={duration}
        techStack={techStack}
        demoUrl={demoUrl}
        repoUrl={repoUrl}
      />
    </Container>
  </Section>
  {image && (
    <Section size="none">
      <Container size="sm" id={creativeWorkSchema.image? "primaryimage" : undefined}>
        <h2 class="sr-only">Portfolio Image Content</h2>
        <PortfolioFeaturedImage
          src={image}
          alt={imageAlt || title}
          caption={imageCaption || title}
        />
      </Container>
    </Section>
  )}
  <Section size="md">
    <Container size="sm">
      <h2 class="sr-only">Portfolio Metrics</h2>
      <PortfolioMetrics metrics={metrics} />
    </Container>
  </Section>
  <Section size="lg">
    <Container size="sm">
      <h2 class="sr-only">Portfolio Content</h2>
      {(challenge || solution || result) && (
        <div class="space-y-6 mb-10 border-b border-zinc-100 dark:border-zinc-800 pb-8">
          {challenge && (
            <div>
              <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">
                Tantangan
              </h2>
              <p class="text-zinc-600 dark:text-zinc-400">
                {challenge}
              </p>
            </div>
          )}
          {solution && (
            <div>
              <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">
                Solusi
              </h2>
              <p class="text-zinc-600 dark:text-zinc-400">
                {solution}
              </p>
            </div>
          )}
          {result && (
            <div>
              <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">
                Hasil
              </h2>
              <p class="text-zinc-600 dark:text-zinc-400">
                {result}
              </p>
            </div>
          )}
        </div>
      )}
      {displayGallery.length > 0 && (
        <div class="mb-10">
          <h2 class="sr-only">Portfolio Image Gallery</h2>
          <PortfolioGallery
            images={displayGallery}
            title={title}
          />
        </div>
      )}
      <div class="prose-custom">
        <Content />
      </div>
    </Container>
  </Section>
  <Section size="lg">
    <Container size="sm">
      <h2 class="sr-only">Portfolio related Content</h2>
      <PortfolioRelated projects={relatedProjects} />
      <BackToTop showBorder align="center" />
    </Container>
  </Section>
</article>
</BaseLayout>