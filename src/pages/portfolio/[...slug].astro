---
// src/pages/portfolio/[...slug].astro
// @ts-nocheck
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site';
import Container from '@/components/ui/Container.astro';
import PortfolioBreadcrumb from '@/components/portfolio/PortfolioBreadcrumb.astro';
import PortfolioHeader from '@/components/portfolio/PortfolioHeader.astro';
import PortfolioMetrics from '@/components/portfolio/PortfolioMetrics.astro';
import PortfolioSidebar from '@/components/portfolio/PortfolioSidebar.astro';
import ProjectCard from '@/components/portfolio/ProjectCard.astro';
import { formatDate, getRelatedProjects } from '@/lib/utils';

// Generate static paths
export async function getStaticPaths() {
  const projects = await getCollection('portfolio', ({ data }) => !data.draft);
  return projects.map((project: CollectionEntry<'portfolio'>) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'portfolio'>;
}

const { project } = Astro.props;
const { 
  title, 
  description, 
  date,
  updatedDate,
  techStack,
  demoUrl,
  repoUrl,
  image,
  imageAlt,
  gallery,
  featured,
  client,
  role,
  duration,
  challenge,
  solution,
  result,
  metrics,
  seo
} = project.data;

// Render konten
const { Content } = await render(project);

// Format dates
const formattedDate = formatDate(date);
const formattedUpdateDate = updatedDate ? formatDate(updatedDate) : undefined;

// SEO
const seoTitle = seo?.title || `${title} | ${siteConfig.name}`;
const seoDescription = seo?.description || description;
const seoImage = (() => {
  if (seo?.ogImage && typeof seo.ogImage === 'string') return seo.ogImage;
  if (image && typeof image === 'string') return image;
  return siteConfig.ogImage;
})();

// Handle image
const displayImage = typeof image === 'string' ? image : image?.src;

// Get related projects
const allProjects = await getCollection('portfolio', ({ data }) => !data.draft);
const relatedProjects = getRelatedProjects(project, allProjects, 2);
---

<BaseLayout 
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={date}
  modifiedTime={updatedDate}
  tags={techStack}
  container={false}
>
  <article>
    
    {/* Hero Section */}
    <div class="border-b border-zinc-100 dark:border-zinc-900 bg-white dark:bg-zinc-950">
      <Container size="md" class="py-8 md:py-12 lg:py-16">
        <PortfolioBreadcrumb slug={project.id} />
        <PortfolioHeader 
          title={title}
          date={date}
          updatedDate={updatedDate}
          featured={featured}
          client={client}
          role={role}
          duration={duration}
          techStack={techStack}
          demoUrl={demoUrl}
          repoUrl={repoUrl}
        />
      </Container>
    </div>

    {/* Featured Image */}
    {displayImage && (
      <div class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-900/30">
        <Container size="md" class="py-8 md:py-10">
          <div class="relative rounded-xl overflow-hidden bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
            <img 
              src={displayImage} 
              alt={imageAlt || title}
              class="w-full h-auto object-cover"
              loading="eager"
            />
            <div class="absolute top-3 left-3 w-4 h-4 border-l border-t border-white/30 rounded-tl"></div>
            <div class="absolute bottom-3 right-3 w-4 h-4 border-r border-b border-white/30 rounded-br"></div>
          </div>
          {imageAlt && (
            <p class="text-xs text-center text-zinc-500 dark:text-zinc-400 mt-3 font-mono">
              {imageAlt}
            </p>
          )}
        </Container>
      </div>
    )}

    {/* Metrics Section */}
    <PortfolioMetrics metrics={metrics} />

    {/* Main Content */}
    <Container size="md" class="py-12 md:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8 md:gap-12 items-start">
        
        {/* Content Column */}
        <div class="min-w-0">
          
          {/* Challenge, Solution, Result sections */}
          {(challenge || solution || result) && (
            <div class="space-y-8 mb-12 pb-8 border-b border-zinc-100 dark:border-zinc-900">
              {challenge && (
                <section>
                  <h2 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900 dark:text-white mb-3">
                    The Challenge
                  </h2>
                  <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed">
                    {challenge}
                  </p>
                </section>
              )}
              {solution && (
                <section>
                  <h2 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900 dark:text-white mb-3">
                    The Solution
                  </h2>
                  <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed">
                    {solution}
                  </p>
                </section>
              )}
              {result && (
                <section>
                  <h2 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900 dark:text-white mb-3">
                    The Result
                  </h2>
                  <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed">
                    {result}
                  </p>
                </section>
              )}
            </div>
          )}
          
          {/* Full Content */}
          <div class="prose prose-zinc dark:prose-invert max-w-none
            prose-headings:font-bold prose-headings:tracking-tight
            prose-h2:text-2xl md:prose-h2:text-3xl prose-h2:mt-8 prose-h2:mb-4
            prose-h3:text-xl md:prose-h3:text-2xl prose-h3:mt-6 prose-h3:mb-3
            prose-p:text-zinc-700 dark:prose-p:text-zinc-300 prose-p:leading-relaxed
            prose-a:text-zinc-900 dark:prose-a:text-white prose-a:no-underline prose-a:border-b prose-a:border-zinc-400 dark:prose-a:border-zinc-600
            prose-code:text-sm prose-code:bg-zinc-100 dark:prose-code:bg-zinc-900 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
            prose-pre:bg-zinc-950 dark:prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-800
            prose-img:rounded-lg prose-img:border prose-img:border-zinc-200 dark:prose-img:border-zinc-800
            prose-ul:list-disc prose-ol:list-decimal
          ">
            <Content />
          </div>
          
          {/* Gallery */}
          {gallery && gallery.length > 0 && (
            <section class="mt-12 pt-8 border-t border-zinc-100 dark:border-zinc-900">
              <div class="flex items-center gap-3 mb-6">
                <div class="h-px w-8 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
                <h3 class="text-xs md:text-sm font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
                  Gallery
                </h3>
                <div class="h-px flex-1 bg-linear-to-l from-zinc-100 to-transparent dark:from-zinc-900"></div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {gallery.map((img, idx) => {
                  const imgSrc = typeof img === 'string' ? img : img?.src;
                  return imgSrc ? (
                    <img 
                      key={idx}
                      src={imgSrc}
                      alt={`${title} screenshot ${idx + 1}`}
                      class="rounded-lg border border-zinc-200 dark:border-zinc-800 w-full h-auto"
                      loading="lazy"
                    />
                  ) : null;
                })}
              </div>
            </section>
          )}
          
          {/* Related Projects */}
          {relatedProjects.length > 0 && (
            <section class="mt-12 pt-8 border-t border-zinc-100 dark:border-zinc-900">
              <div class="flex items-center gap-3 mb-6">
                <div class="h-px w-8 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
                <h3 class="text-xs md:text-sm font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
                  Related projects
                </h3>
                <div class="h-px flex-1 bg-linear-to-l from-zinc-100 to-transparent dark:from-zinc-900"></div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {relatedProjects.map(relatedProject => (
                  <ProjectCard 
                    project={relatedProject}
                    variant="compact"
                    showTechStack={false}
                  />
                ))}
              </div>
            </section>
          )}
          
          {/* Feedback Section */}
          <section class="mt-12 pt-6">
            <div class="flex flex-wrap items-center justify-between gap-4 p-4 md:p-5 bg-zinc-50 dark:bg-zinc-900/50 rounded-lg border border-zinc-100 dark:border-zinc-800">
              <div class="flex items-center gap-3 font-mono text-xs md:text-sm text-zinc-500 dark:text-zinc-400">
                <span class="text-emerald-600 dark:text-emerald-500 font-bold">$</span>
                <span>found an issue?</span>
                <span class="text-zinc-300 dark:text-zinc-700">/</span>
                <a 
                  href={`${siteConfig.links.github}/issues/new`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-zinc-900 dark:hover:text-white transition-colors underline-offset-4 hover:underline"
                >
                  report on github
                </a>
              </div>
              <div class="flex items-center gap-2 font-mono text-xs md:text-sm text-zinc-400 dark:text-zinc-500">
                <span>[</span>
                <span>last updated: {formattedUpdateDate || formattedDate}</span>
                <span>]</span>
              </div>
            </div>
          </section>
          
        </div>
        
        {/* Sidebar */}
        <PortfolioSidebar 
          techStack={techStack}
          demoUrl={demoUrl}
          repoUrl={repoUrl}
        />
        
      </div>
    </Container>
    
  </article>
</BaseLayout>