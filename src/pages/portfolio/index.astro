---
// src/pages/portfolio/index.astro

import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Grid from "@/components/ui/Grid.astro";

import PortfolioHero from "@/components/portfolio/PortfolioHero.astro";
import PortfolioCard from "@/components/portfolio/PortfolioCard.astro";

import {
  sortByDate,
  filterByFeatured,
  filterByDraft
} from "@/lib/utils";

const allProjects = await getCollection("portfolio");
const projects = sortByDate(filterByDraft(allProjects), "date");

const featuredProjects = filterByFeatured(projects);
const featuredProject = featuredProjects?.[0];
const regularProjects = projects.filter((p) =>!p.data.featured);

const seoData = {
  title: "Portfolio & Projects",
  description: "Koleksi karya digital, mulai dari web application, sistem desain, hingga eksperimen teknologi dan UI/UX modern.",
  type: "website" as const,
  canonicalURL: `${siteConfig.url}portfolio/`
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${seoData.canonicalURL}#collectionpage`,
      "url": seoData.canonicalURL,
      "name": seoData.title,
      "description": seoData.description,
      "isPartOf": {
        "@id": `${siteConfig.url}#website`
      },
      "breadcrumb": {
        "@id": `${seoData.canonicalURL}#breadcrumb`
      },
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": projects.length,
        "itemListElement": projects.slice(0, 10).map((project, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "item": {
            "@type": "CreativeWork",
            "@id": `${siteConfig.url}portfolio/${project.id}/`,
            "url": `${siteConfig.url}portfolio/${project.id}/`,
            "name": project.data.title,
            "description": project.data.description,
            "image": project.data.image? `${siteConfig.url}${project.data.image}` : undefined,
            "dateCreated": project.data.date?.toISOString(),
            "creator": {
              "@type": "Person",
              "name": siteConfig.author.name
            }
          }
        }))
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${seoData.canonicalURL}#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteConfig.url
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Portfolio"
        }
      ]
    }
  ]
};
---

<BaseLayout {...seoData}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <Section size="xl">
    <Container size="md">
      <PortfolioHero />
    </Container>
  </Section>

  <Section size="lg">
    <Container size="md">
      <h2 class="sr-only">Featured Project</h2>
      {featuredProject && (
        <div class="mb-10">
          <PortfolioCard project={featuredProject} />
        </div>
      )}

      <h2 class="sr-only">All Projects</h2>
      <Grid cols="cards" gap="md">
        {regularProjects.map((project) => (
          <PortfolioCard project={project} />
        ))}
      </Grid>
    </Container>
  </Section>
</BaseLayout>