---
// src/pages/portfolio/index.astro
import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Grid from "@/components/ui/Grid.astro";

import PortfolioHero from "@/components/portfolio/PortfolioHero.astro";
import PortfolioCard from "@/components/portfolio/PortfolioCard.astro";

import {
  sortByDate,
  filterByFeatured,
  filterByDraft
} from "@/lib/utils";

const allProjects = await getCollection("portfolio");

const projects = sortByDate(filterByDraft(allProjects), "pubDate");

const featuredProjects = filterByFeatured(projects);
const featuredProject = featuredProjects?.[0];

const regularProjects = projects.filter((p) => p.id !== featuredProject?.id);

const siteURL = Astro.site?.toString() ?? siteConfig.url;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const seoData = {
  title: "Portfolio & Projects",
  description: "Koleksi karya digital, mulai dari web application, sistem desain, hingga eksperimen teknologi dan UI/UX modern.",
  type: "website" as const,
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${canonicalURL}#collectionpage`,
      "url": canonicalURL,
      "name": seoData.title,
      "description": seoData.description,
      "isPartOf": {
        "@id": `${siteURL}#website`
      },
      "breadcrumb": {
        "@id": `${canonicalURL}#breadcrumb`
      },
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": projects.length,
        "itemListElement": projects.slice(0, 12).map((project, i) => {
          const projectURL = new URL(`portfolio/${project.id}/`, siteURL).toString();
          const imageURL = project.data.image?.src
            ? new URL(project.data.image.src, siteURL).toString()
            : undefined;

          return {
            "@type": "ListItem",
            "position": i + 1,
            "item": {
              "@type": "CreativeWork",
              "@id": projectURL,
              "url": projectURL,
              "name": project.data.title,
              "description": project.data.description,
              "image": imageURL,
              "dateCreated": project.data.pubDate?.toISOString(),
              "creator": { "@id": `${siteURL}#person` }
            }
          };
        })
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalURL}#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteURL
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Portfolio",
          "item": canonicalURL
        }
      ]
    }
  ]
};
---

<BaseLayout {...seoData}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  
  <Section size="xl">
    <Container size="md">
      <PortfolioHero />
    </Container>
  </Section>

  <Section size="lg">
    <Container size="md">
      <h2 class="sr-only">Featured Project</h2>
      {featuredProject && (
        <div class="mb-10">
          <PortfolioCard project={featuredProject} />
        </div>
      )}

      <h2 class="sr-only">All Projects</h2>
      <Grid cols="cards" gap="md">
        {regularProjects.map((project) => (
          <PortfolioCard project={project} />
        ))}
      </Grid>
    </Container>
  </Section>
</BaseLayout>