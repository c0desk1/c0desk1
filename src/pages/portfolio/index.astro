---
// src/pages/portfolio/index.astro

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import ProjectCard from '@/components/portfolio/ProjectCard.astro';
import { sortByDate, getAllTechStacks, filterByFeatured, filterByDraft } from '@/lib/utils';

const allProjects = await getCollection('portfolio');
const projects = sortByDate(filterByDraft(allProjects), 'date');

const featuredProjects = filterByFeatured(projects);
const featuredProject = featuredProjects[0];
const regularProjects = projects.filter(p => !p.data.featured);

const recentProjects = regularProjects.slice(0, 3);

const allTechStacks = getAllTechStacks(projects);
const popularTech = allTechStacks.slice(0, 8);
---

<BaseLayout 
  title="Portfolio"
  description="A collection of my work including web applications, design systems, and digital experiences."
  type="website"
>
  
  {/* Hero Section */}
  <div class="border-b border-zinc-100 dark:border-zinc-900 bg-white dark:bg-zinc-950">
    <Container size="md" class="py-12 md:py-16 lg:py-20">
      
      {/* Breadcrumb */}
      <nav class="flex items-center gap-2 font-mono text-[11px] md:text-xs tracking-wide text-zinc-400 dark:text-zinc-500 mb-6">
        <span class="text-emerald-600 dark:text-emerald-500 font-bold">$</span>
        <a href="/" class="hover:text-zinc-900 dark:hover:text-white transition-colors">home</a>
        <span class="text-zinc-300 dark:text-zinc-700">/</span>
        <span class="text-zinc-600 dark:text-zinc-400">portfolio</span>
      </nav>
      
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <div class="h-1.5 w-1.5 rounded-full bg-emerald-500"></div>
          <span class="text-xs font-mono text-zinc-500 dark:text-zinc-400">SELECTED WORK / CASE STUDIES</span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-zinc-900 dark:text-white leading-[1.1]">
          Crafting digital<br />
          <span class="text-zinc-400 dark:text-zinc-600">experiences.</span>
        </h1>
        
        <p class="text-base md:text-lg text-zinc-600 dark:text-zinc-400 max-w-2xl leading-relaxed">
          A showcase of my work including web applications, design systems, and industrial tactical interfaces.
        </p>
        
        <div class="pt-4">
          <div class="h-px w-12 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
        </div>
      </div>
      
    </Container>
  </div>
  
  {/* Main Content */}
  <Container size="md" class="py-12 md:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12 md:gap-16">
      
      {/* Left Column - Projects */}
      <div class="min-w-0">
        
        {/* Featured Project */}
        {featuredProject && (
          <div class="mb-10 pb-8 border-b border-zinc-100 dark:border-zinc-900">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-[10px] font-mono text-amber-600 dark:text-amber-500">[featured]</span>
              <div class="h-px w-8 bg-zinc-200 dark:bg-zinc-800"></div>
            </div>
            <ProjectCard 
              project={featuredProject}
              variant="featured"
              showTechStack={true}
            />
          </div>
        )}
        
        {/* Projects List Header */}
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-2">
            <span class="text-[10px] font-mono text-zinc-400 dark:text-zinc-500">$</span>
            <span class="text-xs font-mono text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">
              All projects ({projects.length})
            </span>
          </div>
          
          <div class="flex items-center gap-1 text-[10px] font-mono text-zinc-400 dark:text-zinc-500">
            <span>[</span>
            <span>grid view</span>
            <span>]</span>
          </div>
        </div>
        
        {/* Regular Projects Grid */}
        {regularProjects.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {regularProjects.map(project => (
              <ProjectCard 
                project={project}
                variant="default"
                showTechStack={true}
              />
            ))}
          </div>
        ) : (
          <div class="py-12 text-center">
            <p class="text-zinc-500 dark:text-zinc-400 font-mono">No projects found.</p>
          </div>
        )}
        
      </div>
      
      {/* Right Column - Sidebar */}
      <aside class="space-y-8">
        
        {/* About Card */}
        <div class="p-5 border border-zinc-200 dark:border-zinc-800 rounded-lg bg-white dark:bg-zinc-950">
          <div class="flex items-center gap-2 mb-3">
            <div class="h-1.5 w-1.5 rounded-full bg-emerald-500"></div>
            <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
              About
            </h3>
          </div>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed mb-3">
            Building industrial tactical interfaces with a focus on performance, accessibility, and clean architecture.
          </p>
          <div class="flex items-center gap-2 text-[10px] font-mono text-zinc-400">
            <span>$</span>
            <span>available for work</span>
          </div>
        </div>
        
        {/* Popular Tech Stack */}
        {popularTech.length > 0 && (
          <div>
            <div class="flex items-center gap-2 mb-4">
              <div class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-500"></div>
              <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
                Tech stack
              </h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {popularTech.map(tech => (
                <span class="px-2 py-1 text-[11px] font-mono border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400 rounded hover:border-zinc-400 dark:hover:border-zinc-600 transition-all">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        )}
        
        {/* Recent Projects */}
        {recentProjects.length > 0 && (
          <div>
            <div class="flex items-center gap-2 mb-4">
              <div class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-500"></div>
              <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
                Recent
              </h3>
            </div>
            <div class="space-y-3">
              {recentProjects.map(project => (
                <a 
                  href={`/portfolio/${project.id}`}
                  class="group block py-2 border-b border-zinc-100 dark:border-zinc-900 hover:pl-2 transition-all duration-200"
                >
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2 flex-1 min-w-0">
                      <div class="w-1 h-1 rounded-full bg-zinc-300 dark:bg-zinc-700 group-hover:bg-emerald-500 transition-colors"></div>
                      <h4 class="font-mono text-sm text-zinc-700 dark:text-zinc-300 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors truncate">
                        {project.data.title}
                      </h4>
                    </div>
                    <span class="text-[9px] font-mono text-zinc-400 dark:text-zinc-600 group-hover:translate-x-0.5 transition-transform">
                      →
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
        
        {/* Newsletter */}
        <div class="pt-4">
          <div class="p-5 border border-zinc-200 dark:border-zinc-800 rounded-lg bg-linear-to-br from-white to-zinc-50 dark:from-zinc-950 dark:to-zinc-900">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-emerald-600 dark:text-emerald-500 font-mono font-bold">$</span>
              <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
                Newsletter
              </h3>
            </div>
            <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4">
              Get notified when I publish new projects.
            </p>
            <form class="space-y-3">
              <input 
                type="email" 
                placeholder="your@email.com"
                class="w-full px-3 py-2 text-sm font-mono border border-zinc-200 dark:border-zinc-800 rounded bg-white dark:bg-zinc-950 text-zinc-900 dark:text-white placeholder:text-zinc-400 focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-600 transition-colors"
              />
              <button 
                type="submit"
                class="w-full px-3 py-2 text-xs font-mono font-medium border border-zinc-200 dark:border-zinc-800 rounded hover:border-zinc-400 dark:hover:border-zinc-600 hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-all"
              >
                [subscribe]
              </button>
            </form>
            <p class="text-[9px] font-mono text-zinc-400 dark:text-zinc-500 mt-3">
              No spam. Unsubscribe anytime.
            </p>
          </div>
        </div>
        
      </aside>
      
    </div>
  </Container>
  
</BaseLayout>