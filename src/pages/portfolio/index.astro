---
// src/pages/portfolio/index.astro

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import PortfolioHero from '@/components/portfolio/PortfolioHero.astro';
import PortfolioFeatured from '@/components/portfolio/PortfolioFeatured.astro';
import PortfolioList from '@/components/portfolio/PortfolioList.astro';
import PortfolioSidebar from '@/components/portfolio/PortfolioSidebar.astro';

import {
  sortByDate,
  getAllTechStacks,
  filterByFeatured,
  filterByDraft
} from '@/lib/utils';

const allProjects = await getCollection('portfolio');

const projects = sortByDate(filterByDraft(allProjects), 'date');

const featuredProjects = filterByFeatured(projects);
const featuredProject = featuredProjects?.[0];

const regularProjects = projects.filter(p => !p.data.featured);

const recentProjects = regularProjects.slice(0, 3);
const allTechStacks = getAllTechStacks(projects);
const popularTech = allTechStacks.slice(0, 8);

const seoData = {
  title: "Portfolio & Projects",
  description: "A collection of my work including web applications, design systems, and digital experiences.",
};
---

<BaseLayout {...seoData} type="website">
  <PortfolioHero />
  <Container size="md" class="py-10 md:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12">
      <div class="min-w-0">
        {featuredProject && (
          <PortfolioFeatured project={featuredProject} />
        )}
        <div class="mt-12">
           <PortfolioList
            projects={regularProjects}
            totalCount={projects.length}
          />
        </div>
      </div>
      <aside>
        <div class="lg:sticky lg:top-24 h-fit">
          <PortfolioSidebar
            popularTech={popularTech}
            recentProjects={recentProjects}
          />
        </div>
      </aside>
    </div>
  </Container>
</BaseLayout>
