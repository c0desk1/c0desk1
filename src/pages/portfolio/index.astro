---
// src/pages/portfolio/index.astro
export const prerender = true;

import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";
import { sortByDate, filterByFeatured, filterByDraft } from "@/lib/utils";
import HERO from '@/assets/images/c0desk1-portfolio-hero.jpeg';

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PortfolioCard from "@/components/portfolio/PortfolioCard.astro";
import Hero from "@/components/ui/Hero.astro";


const allProjects = await getCollection("portfolio", ({ data }) => !data.draft);

const projects = sortByDate(filterByDraft(allProjects));

const featuredProjects = filterByFeatured(projects);
const featuredProject = featuredProjects?.[0];
const regularProjects = projects.filter((p) => p.id !== featuredProject?.id);

const siteData = siteConfig

const siteURL = Astro.site?.toString() ?? siteData.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const seoData = {
  title: siteData.p_PageTitle,
  description: siteData.p_PageDesc,
  type: "website" as const,
  canonicalURL,
};

const hasProjects = projects.length > 0;

const title = siteData.p_HeroTitle;
const p_c   = siteData.p_AllProjects;
---

<BaseLayout {...seoData}>
  <Section size="none">
    <Hero
      title={siteData.p_PageTitle}
      subTitle={title}
      description={siteData.p_PageDesc}
      bgImage={HERO}
      overlayOpacity={0.4}
    />
  </Section>
  <Section id="browse-portfolio" size="lg" aria-label={p_c}>
    <Container size="xl">
      {hasProjects ? (
        <>
          {featuredProject && (
            <Section size="sm" aria-label={siteConfig.p_FeaturedPosts}>
              <h2 class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold">
                {siteConfig.p_FeaturedPosts}
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 mt-4">
                <PortfolioCard project={featuredProject} />
              </div>
            </Section>
          )}
          {regularProjects.length > 0 && (
            <Section size="sm" aria-label={siteConfig.p_latestPost}>
              <h2 class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold">
                {siteConfig.p_latestPost}
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 mt-4">
                {regularProjects.map((project) => (
                  <PortfolioCard project={project} />
                ))}
              </div>
            </Section>
          )}
        </>
      ) : (
        <div class="py-16 text-center">
          <h2 class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold mb-4">
            No projects yet
          </h2>
          <p class="text-muted text-copy-16">
            {siteData.p_Empty}
          </p>
        </div>
      )}
    </Container>
  </Section>
</BaseLayout>