---
// src/pages/[...locale]/portfolio/[...slug].astro
export const prerender = true;

import "@/styles/prose/index.css";

import { getCollection, render } from "astro:content";
import { siteConfig } from "@/config/site";
import { getSmartRelatedProjects } from "@/lib/botEngine";
import { slugify } from "@/lib/utils";

import { components } from '@/components/layout/MDXComponents';

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import BackToTop from "@/components/ui/BackToTop.astro";

import PortfolioHeader from "@/components/portfolio/PortfolioHeader.astro";
import PortfolioMetrics from "@/components/portfolio/PortfolioMetrics.astro";
import PortfolioGallery from "@/components/portfolio/PortfolioGallery.astro";
import PortfolioRelated from "@/components/portfolio/PortfolioRelated.astro";
import PortfolioCaseStudy from "@/components/portfolio/PortfolioCaseStudy.astro";

export async function getStaticPaths() {
  const projects = await getCollection("portfolio", ({ data }) => !data.draft);
  return projects.map((project) => {
    const urlSlug = slugify(project.data.title);
    return {
      params: { slug: urlSlug },
      props: { project }
    };
  });
}

const { project } = Astro.props;
const data = project.data;

const {
  title,
  description,
  pubDate,
  updatedDate,
  techStack,
  demoUrl,
  repoUrl,
  image,
  gallery,
  featured,
  client,
  role,
  duration,
  challenge,
  solution,
  result,
  metrics,
  seo
} = data;

const { Content } = await render(project);
const siteData = siteConfig;

const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = {
  src: seo?.ogImage || image?.src || siteData.ogImage,
  alt: image?.alt || title
};

const allProjects = await getCollection("portfolio", ({ data }) => !data.draft);
const relatedProjects = getSmartRelatedProjects(project, allProjects, 2);
const displayGallery = Array.isArray(gallery) ? gallery : [];

const siteURL = Astro.site?.toString() ?? siteData.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const homeLabel      = siteData.home;
const portfolioLabel = siteData.p_PageTitle;
const galleryLabel   = siteData.p_Gallery;
const srPortfolioMetrics = siteData.p_MetricsCase;
const srPortfolioRelated = siteData.p_RelatedContent;

const Breadcrumbs = [
  { name: homeLabel,      href: '/' },
  { name: portfolioLabel, href: '/portfolio/' },
];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="creativeWork"
  publishedTime={pubDate}
  modifiedTime={updatedDate || pubDate}
  tags={techStack}
  client={client}
  role={role}
  duration={duration}
  demoUrl={demoUrl}
  repoUrl={repoUrl}
  canonicalURL={canonicalURL}>
  <Section size="lg">
    <Section size="sm">
      <Container size="lg">
        <div class="flex flex-col justify-center items-center">
          <Breadcrumb items={Breadcrumbs} />
        </div>    
        <article class="pt-4 px-4 lg:px-6">
          <Section size="sm">
            <PortfolioHeader
              title={title}
              date={pubDate}
              updatedDate={updatedDate}
              image={image}
              featured={featured}
              client={client}
              role={role}
              duration={duration}
              techStack={techStack}
              demoUrl={demoUrl}
              repoUrl={repoUrl}
            />
          </Section>
          <Section size="sm">
            <h2 class="sr-only">{srPortfolioMetrics}</h2>
            <PortfolioCaseStudy
              challenge={challenge}
              solution={solution}
              result={result}
              allowMultiple={true}
            />
          </Section>
          <Section size="sm">
            <PortfolioMetrics metrics={metrics} />
          </Section>
          <Section size="sm">
            <div id="article-content" class="prose-custom max-w-3xl">
              <Content components={components} />
            </div>
            {displayGallery.length > 0 && (
              <div class="prose-custom">
                <h2 class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold">{galleryLabel}</h2>
                <PortfolioGallery title={title} images={displayGallery} />
              </div>
            )}
          </Section>
        </article>
      </Container>
    </Section>
    </article>
    <Section size="sm">
      <Container size="lg" class="pt-8">
        <h2 class="sr-only">{srPortfolioRelated}</h2>
        <PortfolioRelated projects={relatedProjects} />
      </Container>
    </Section>
  </Section>
  <BackToTop />
</BaseLayout>
