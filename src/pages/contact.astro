---
// src/pages/contact/index.astro
import { 
  SITE, 
  ROUTES, 
  SOCIAL, 
  buildMeta, 
  schemaWebPage, 
  schemaOrganization, 
  schemaBreadcrumb 
} from "@/consts";

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import ContactForm from "@/components/ContactForm.tsx";
import Icon from '@/components/ui/icons/Icon.astro';

const pageTitle = "Kontak";
const pageDesc = "Punya proyek atau sekadar ingin menyapa? Isi formulir di bawah dan kami akan merespons dalam 1×24 jam.";

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, SITE.url).href;

const meta = buildMeta({
  title: pageTitle,
  description: pageDesc,
  canonical: canonicalURL,
  ogType: "website", 
});

const schemas = [
  schemaWebPage({ title: pageTitle, description: pageDesc, url: canonicalURL, type: "ContactPage" }),
  schemaOrganization,
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: pageTitle, url: canonicalURL },
  ]),
];

const email = SITE.email;
---

<Layout {meta} schema={schemas}>
  <Section size="lg">
    <Section size="sm">
      <Container size="lg">
        <div class="flex items-center self-start">
          <Breadcrumb
            items={[
              { name: "Beranda", url: ROUTES.home || "/" },
              { name: pageTitle, url: currentPath },
            ]}
          />
        </div>
      </Container>
    </Section>
    <Section size="sm">
      <Container size="lg">
        <div class="max-w-2xl mb-12">
          <h1 class="text-heading-32 md:text-heading-40 lg:text-heading-56 font-bold text-balance mb-4">
            Mari bekerja sama.
          </h1>
          <p class="text-body-16 md:text-body-18 text-muted max-w-xl text-pretty">
            {pageDesc}
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[1fr_260px] lg:grid-cols-[1fr_300px] gap-8 items-start">
          <ContactForm client:visible />

          <aside class="flex flex-col gap-8 p-6 sm:p-8 rounded-xl border border-(--border) bg-elevated shadow-sm">
            
            <div>
              <p class="text-[11px] font-semibold text-subtle uppercase tracking-wider mb-3">
                Status
              </p>
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-500 shrink-0" />
                <span class="text-body-14 font-medium text-strong">Sibuk</span>
              </div>
            </div>

            <div class="w-full h-px bg-(--border)/50" />

            <div>
              <p class="text-[11px] font-semibold text-subtle uppercase tracking-wider mb-3">
                Email
              </p>
              <a
                href={`mailto:${email}`}
                class="text-body-14 font-medium text-muted flex items-center gap-2 hover:text-strong transition-colors"
              >
                <Icon name="email" className="w-4.5 h-4.5 shrink-0" />
                <span class="truncate">{email}</span>
              </a>
            </div>
            <div class="w-full h-px bg-(--border)/50" />
            <div>
              <p class="text-[11px] font-semibold text-subtle uppercase tracking-wider mb-3">
                Sosial
              </p>
              <div class="flex flex-col gap-3">
                {SOCIAL.map((s) => (
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2.5 text-body-14 font-medium text-muted hover:text-strong transition-colors"
                    aria-label={s.name}
                  >
                    <Icon name={s.name.toLocaleLowerCase() as any} className="w-4.5 h-4.5 shrink-0" />
                    {s.name}
                  </a>
                ))}
              </div>
            </div>

          </aside>
        </div>
      </Container>
    </Section>
  </Section>
</Layout>
