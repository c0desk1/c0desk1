---
// src/pages/guide/index.astro
import { getCollection } from "astro:content";
import GuideLayout from "@/layouts/GuideLayout.astro";
import Container from "@/components/ui/Container.astro";
import GuideCard from "@/components/guide/GuideCard.astro"; // Import komponen Anda
import { buildMeta } from "@/consts";

// 1. Ambil semua entri panduan dari koleksi
const allEntries = await getCollection("guide");

// 2. Kelompokkan dokumen secara otomatis berdasarkan properti 'section' (Kategori)
const categoriesMap = new Map<string, typeof allEntries>();

allEntries.forEach((entry) => {
  if (entry.data.draft) return; // Lewati draf dokumen
  const sectionName = entry.data.section || "General";
  
  if (!categoriesMap.has(sectionName)) {
    categoriesMap.set(sectionName, []);
  }
  categoriesMap.get(sectionName)?.push(entry);
});

// Urutkan artikel di dalam kategori berdasarkan properti 'order'
const categories = Array.from(categoriesMap.entries()).map(([name, docs]) => ({
  name,
  docs: docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0)),
}));

const meta = buildMeta({
  title: "Pusat Panduan & Dokumentasi",
  description: "Temukan seluruh referensi komponen, tutorial integrasi, dan dokumentasi proyek.",
});
---

<GuideLayout {meta} isHome={true}>
  <Container size="xl" class="py-12 lg:py-20">
    <header class="mb-16 pb-10 max-w-3xl">
      <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-full bg-muted/60 border border-(--border) text-[11px] font-semibold text-accent tracking-wide uppercase mb-4 select-none">
        Dokumentasi Resmi
      </div>
      <h1 class="text-heading-32 md:text-heading-40 lg:text-heading-56 font-bold text-strong tracking-tight mb-4">
        Pusat Panduan & Referensi
      </h1>
      <p class="text-body-16 md:text-body-18 text-muted leading-relaxed m-0">
        Pelajari cara mengonfigurasi proyek, menggunakan komponen MDX kustom siap pakai, serta menerapkan praktik terbaik pengoptimalan situs Anda.
      </p>
    </header>
    <div class="flex flex-col gap-16 w-full">
      {categories.map((category) => (
        <section class="flex flex-col gap-6 w-full">
          <div class="flex items-center gap-2.5 pb-2 border-b border-(--border)/60 w-full">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-accent">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
            </svg>
            <h2 class="text-[12px] font-bold text-strong tracking-wider uppercase m-0">
              {category.name}
            </h2>
            <span class="text-[11px] text-muted font-medium ml-1">
              ({category.docs.length})
            </span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
            {category.docs.map((doc) => (
              <GuideCard entry={doc} />
            ))}
          </div>
        </section>
      ))}
    </div>
  </Container>
</GuideLayout>
