---
// src/pages/guide/index.astro
import { getCollection } from "astro:content";
import GuideLayout from "@/layouts/GuideLayout.astro";
import Container from "@/components/ui/Container.astro";
import GuideCard from "@/components/guide/GuideCard.astro";
import { buildMeta } from "@/consts";

const allTutorials = await getCollection("guide");

const activeTutorials = allTutorials
  .filter((e) => !e.data.draft)
  .sort(
    (a, b) =>
      b.data.pubDate.valueOf() -
      a.data.pubDate.valueOf()
  );

const featuredTutorial =
  activeTutorials[0];

const remainingTutorials =
  activeTutorials.slice(1);

const categories = Array.from(
  new Set(
    activeTutorials
      .map((t) => t.data.category)
      .filter(Boolean)
  )
);

const meta = buildMeta({
  title: "Tutorial & Panduan Praktis",
  description:
    "Kumpulan artikel tutorial mendalam, tips optimasi, dan panduan langkah-demi-langkah.",
});
---

<GuideLayout {meta} isHome={true}>
  <Container
    size="xl"
    class="py-12 lg:py-20"
  >
    <header class="max-w-3xl mb-12">
      <p class="m-0 mb-3 text-[11px] font-semibold tracking-[0.16em] uppercase text-subtle">
        Guide
      </p>

      <h1 class="m-0 text-heading-32 md:text-heading-40 lg:text-heading-56 font-semibold tracking-tight text-strong">
        Tutorial & Hub Kreatif
      </h1>

      <p class="mt-4 mb-0 text-body-16 md:text-body-18 text-muted leading-relaxed">
        Jelajahi panduan langkah-demi-langkah,
        teknik kustomisasi mendalam,
        dan artikel praktis untuk
        membangun proyek lebih cepat
        dan lebih rapi.
      </p>
    </header>

    {activeTutorials.length > 0 ? (
      <>
        <nav
          class="flex items-center gap-2 overflow-x-auto pb-5 mb-12 border-b border-(--border)/60"
          style="scrollbar-width:none;"
        >
          <a
            href="/guide"
            class="shrink-0 rounded-full border border-(--border) bg-base px-3 py-1.5 text-[13px] font-medium text-strong no-underline transition-colors hover:bg-elevated/40"
          >
            Semua
          </a>

          {categories.map((cat) => (
            <button
              type="button"
              class="shrink-0 rounded-full border border-(--border) bg-base px-3 py-1.5 text-[13px] font-medium text-muted transition-colors hover:text-strong hover:bg-elevated/40"
            >
              {cat}
            </button>
          ))}
        </nav>

        {featuredTutorial && (
          <section class="mb-16">
            <div class="mb-4 flex items-center gap-2">
              <span class="h-1 w-1 rounded-full bg-accent" />

              <span class="text-[11px] font-semibold tracking-[0.14em] uppercase text-subtle">
                Terbaru
              </span>
            </div>

            <div class="rounded-2xl border border-(--border)/70 bg-base p-1">
              <GuideCard
                entry={featuredTutorial}
              />
            </div>
          </section>
        )}

        {remainingTutorials.length > 0 && (
          <section>
            <div class="mb-6 flex items-center justify-between gap-4 border-b border-(--border)/60 pb-3">
              <h2 class="m-0 text-[12px] font-semibold tracking-[0.14em] uppercase text-subtle">
                Semua Tutorial
              </h2>

              <span class="text-[12px] text-muted">
                {remainingTutorials.length}
              </span>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
              {remainingTutorials.map(
                (tutorial) => (
                  <GuideCard
                    entry={tutorial}
                  />
                )
              )}
            </div>
          </section>
        )}
      </>
    ) : (
      <div class="rounded-2xl border border-dashed border-(--border) py-20 text-center">
        <p class="m-0 text-body-15 text-muted">
          Belum ada artikel tutorial
          yang diterbitkan.
        </p>
      </div>
    )}
  </Container>
</GuideLayout>
