---
// src/pages/guide/index.astro
import { 
  buildMeta, 
  CATEGORIES 
} from "@/consts";

import { getCollection } from "astro:content";

import GuideLayout from "@/layouts/GuideLayout.astro";
import Container from "@/components/ui/Container.astro";
import GuideCard from "@/components/guide/GuideCard.astro";

const allGuides = await getCollection("guide", ({ data }) => !data.draft);
const grouped = allGuides.reduce((acc, entry) => {
  const section = entry.data.section || "general";
  if (!acc[section]) acc[section] = [];
  acc[section].push(entry);
  return acc;
}, {} as Record<string, typeof allGuides>);

for (const sec in grouped) {
  grouped[sec].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
}

const orderedSections = CATEGORIES
  .filter(cat => grouped[cat.slug]?.length)
  .map(cat => ({
    slug: cat.slug,
    label: cat.label,
    articles: grouped[cat.slug],
  }));

const meta = buildMeta({
  title: "Tutorial & Panduan Praktis",
  description: "Kumpulan artikel tutorial mendalam, tips optimasi, dan panduan langkah-demi-langkah.",
});
---

<GuideLayout {meta} isHome={true}>
  <Container size="xl" class="py-12 lg:py-20">
    <header class="max-w-3xl mb-16">
      <p class="m-0 mb-3 text-[11px] font-semibold tracking-[0.16em] uppercase text-subtle">
        Guide
      </p>
      <h1 class="m-0 text-heading-32 md:text-heading-40 lg:text-heading-56 font-semibold tracking-tight text-strong">
        Tutorial & Hub Kreatif
      </h1>
      <p class="mt-4 mb-0 text-body-16 md:text-body-18 text-muted leading-relaxed">
        Jelajahi panduan langkah-demi-langkah, teknik kustomisasi mendalam,
        dan artikel praktis untuk membangun proyek lebih cepat dan lebih rapi.
      </p>
    </header>
    {orderedSections.length > 0 ? (
      <div class="space-y-20">
        {orderedSections.map(section => (
          <section>
            <div class="mb-6 flex items-center justify-between border-b border-(--border)/60 pb-3">
              <h2 class="m-0 text-[12px] font-semibold tracking-[0.14em] uppercase text-subtle">
                {section.label}
              </h2>
              <span class="text-[12px] text-muted">
                {section.articles.length} artikel
              </span>
            </div>
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
              {section.articles.map(entry => (
                <GuideCard entry={entry} />
              ))}
            </div>
          </section>
        ))}
      </div>
    ) : (
      <div class="rounded-2xl border border-dashed border-(--border) py-20 text-center">
        <p class="m-0 text-body-15 text-muted">
          Belum ada artikel panduan yang diterbitkan.
        </p>
      </div>
    )}
  </Container>
</GuideLayout>