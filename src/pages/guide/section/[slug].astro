---
// src/pages/guide/section/[slug].astro
import { getCollection } from "astro:content";
import { 
  SITE, 
  ROUTES, 
  CATEGORIES, 
  buildMeta, 
  schemaCollectionPage, 
  schemaBreadcrumb 
} from "@/consts";

import GuideLayout from "@/layouts/GuideLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import GuideCard from "@/components/guide/GuideCard.astro";
import GuideCardFeatured from "@/components/guide/GuideCardFeatured.astro";
import Icon from "@/components/ui/icons/Icon.astro";
import Link from "@/components/ui/Link.astro";

export async function getStaticPaths() {
  const allGuides = await getCollection("guide", ({ data }) => !data.draft);
  const sections = [...new Set(allGuides.map(g => g.data.section))];

  return sections.map(section => ({
    params: { slug: section },
  }));
}

const { slug } = Astro.params;
const allGuides = await getCollection("guide", ({ data }) => !data.draft && data.section === slug);

const sortedGuides = allGuides.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const sectionInfo = CATEGORIES.find(c => c.slug === slug);
const sectionName = sectionInfo?.label || slug;
const sectionDesc = sectionInfo?.description || "";

const featuredGuides = sortedGuides.slice(0, 3);
const regularGuides = sortedGuides.slice(3);

const currentPath = `${ROUTES.guide}/section/${slug}`;
const canonicalURL = new URL(currentPath, SITE.url).href;

const meta = buildMeta({
  title: `${sectionName} - Panduan`,
  description: sectionDesc || `Kumpulan panduan ${sectionName} di ${SITE.name}.`,
  canonical: canonicalURL,
});

const schemas = [
  schemaCollectionPage({
    title: `Section: ${sectionName}`,
    description: sectionDesc || `Kumpulan panduan ${sectionName} di ${SITE.name}.`,
    url: canonicalURL,
  }),
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: "Guide", url: new URL(ROUTES.guide, SITE.url).href },
    { name: "Series", url: new URL(`${ROUTES.guide}/section`, SITE.url).href },
    { name: sectionName, url: canonicalURL },
  ]),
];

const headerClass = "mb-16";
const titleClass = "text-heading-40 md:text-heading-56 font-extrabold tracking-tighter text-strong mb-4 text-balance";
const descClass = "text-body-18 text-muted max-w-xl text-pretty";
const gridClass = "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8";

const emptyWrapper = "flex flex-col items-center justify-center py-32 px-4 text-center border border-dashed border-strong rounded-xl bg-subtle";
const emptyIconClass = "w-12 h-12 text-muted opacity-30 mb-4";
const emptyText = "text-body-16 text-muted font-medium mb-6";
const emptyLink = "inline-flex items-center gap-2 text-label-14 font-semibold text-strong hover:text-muted transition-colors group";
---

<GuideLayout {meta} schema={schemas}>
  <Section size="lg">
    <Container size="xl">
      <Section size="sm">
        <div class="flex items-center self-start mb-8">
          <Breadcrumb
            items={[
              { name: "Series", url: `${ROUTES.guide}/section` },
              { name: sectionName, url: currentPath },
            ]}
          />
        </div>
      </Section>
      <header class={headerClass}>
        <h1 class={titleClass}>
          {sectionName}
        </h1>
        <p class={descClass}>
          {sectionDesc}
        </p>
      </header>
      {sortedGuides.length > 0 ? (
        <div class="space-y-8">
          {featuredGuides.length > 0 && (
            <div class={gridClass}>
              {featuredGuides.map(entry => (
                <GuideCardFeatured entry={entry} />
              ))}
            </div>
          )}
          {regularGuides.length > 0 && (
            <div>
              {featuredGuides.length > 0 && (
                <h2 class="text-heading-20 font-semibold text-strong mb-6 mt-8">
                  Artikel Lainnya
                </h2>
              )}
              <div class={gridClass}>
                {regularGuides.map(entry => (
                  <GuideCard entry={entry} />
                ))}
              </div>
            </div>
          )}
        </div>
      ) : (
        <div class={emptyWrapper}>
          <Icon name="note" className={emptyIconClass} />
          <p class={emptyText}>
            Belum ada artikel di section ini.
          </p>
          <a href={ROUTES.guide} class={emptyLink}>
            <Icon name="arrow-left" className="w-4 h-4 transition-transform group-hover:-translate-x-1" />
            Kembali ke guide
          </a>
        </div>
      )}
    </Container>
  </Section>
</GuideLayout>