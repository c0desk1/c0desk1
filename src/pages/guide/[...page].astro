---
// src/pages/guide/[...page].astro
import type { Page } from "astro";
import { 
  getCollection, 
  type CollectionEntry 
} from "astro:content";

import { 
  SITE, 
  ROUTES, 
  PAGINATION, 
  buildMeta, 
  schemaCollectionPage, 
  schemaBreadcrumb,
  SERIES
} from "@/consts";

import { 
  getPageNums, 
  getPageUrl, 
  sortByDate 
} from "@/lib/utils";

import GuideLayout from "@/layouts/GuideLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import GuideCard from "@/components/guide/GuideCard.astro";
import GuideCardFeatured from "@/components/guide/GuideCardFeatured.astro";
import Button from "@/components/ui/Button.astro";
import Icon from '@/components/ui/icons/Icon.astro';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allGuides = await getCollection("guide", ({ data }) => !data.draft);
  const sortedGuides = sortByDate(allGuides);
  return paginate(sortedGuides, { pageSize: PAGINATION.postsPerPage });
}

interface Props {
  page: Page<CollectionEntry<"guide">>;
}

const { page } = Astro.props;

const pageTitle = page.currentPage > 1 ? `Guide - Halaman ${page.currentPage}` : "Guide";
const pageDesc = `Kumpulan guide berbagai topik di ${SITE.name}.`;
const canonicalURL = new URL(page.url.current, SITE.url).href;

const meta = buildMeta({
  title: pageTitle,
  description: pageDesc,
  canonical: canonicalURL,
  ...(page.url.prev && { canonical: new URL(page.url.prev, SITE.url).href }),
});

const schemas = [
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: "Guide", url: new URL(ROUTES.guide, SITE.url).href },
  ]),
  schemaCollectionPage({
    title: pageTitle,
    description: pageDesc,
    url: canonicalURL,
  }),
];

let featuredGuides: CollectionEntry<"guide">[] = [];

if (page.currentPage === 1) {
  const allGuides = await getCollection("guide", ({ data }) => !data.draft);
  featuredGuides = allGuides
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);
}

const pageNums = getPageNums(page.currentPage, page.lastPage);
---

<GuideLayout {meta} schema={schemas}>
  {page.currentPage === 1 && featuredGuides.length > 0 && (
    <Section size="md" aria-label="Guide unggulan">
      <Container size="xl">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {featuredGuides.map((guide) => <GuideCardFeatured entry={guide} />)}
        </div>
      </Container>
    </Section>
  )}
  <Section size="md" aria-label="Panduan terbaru">
    <Container size="xl">
      <h2 id="latest" class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold py-4 lg:py-6">
        Terbaru
      </h2>
      {page.data.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {page.data.map((guide) => <GuideCard entry={guide} />)}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-muted text-body-16">Belum ada panduan.</p>
        </div>
      )}
      {page.lastPage > 1 && (
        <div class="flex items-center justify-between gap-2 py-8 mt-4">
          <Button href={page.url.prev} disabled={!page.url.prev} variant="secondary" size="sm" class="gap-1.5" aria-label="Sebelumnya">
            <Icon name="arrow-left" className="w-4 h-4" />
            <span class="hidden sm:inline text-button-14">Sebelumnya</span>
          </Button>
          <ol class="hidden sm:flex items-center gap-0.5">
            {pageNums.map((n) => (
              <li>
                <a
                  href={n === 1 ? ROUTES.guide : getPageUrl(n as number)}
                  aria-current={n === page.currentPage ? "page" : undefined}
                  class:list={[
                    "flex items-center justify-center w-6 h-6 rounded-md text-label-14 transition-colors",
                    n === page.currentPage
                      ? "bg-(--fg) text-(--bg) pointer-events-none font-medium"
                      : "text-subtle hover:bg-muted hover:text-(--fg)",
                  ]}
                >
                  {n}
                </a>
              </li>
            ))}
          </ol>
          <Button href={page.url.next} disabled={!page.url.next} variant="secondary" size="sm" class="gap-1.5" aria-label="Berikutnya">
            <span class="hidden sm:inline text-button-14">Berikutnya</span>
            <Icon name="arrow-right" className="w-4 h-4" />
          </Button>
        </div>
      )}
    </Container>
  </Section>
</GuideLayout>