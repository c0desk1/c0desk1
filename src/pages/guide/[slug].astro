---
// src/pages/guide/[slug].astro
import { 
  getCollection, 
  render 
} from "astro:content";
import { 
  buildMeta, 
  ROUTES 
} from "@/consts";

import GuideLayout from "@/layouts/GuideLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { components } from '@/components/layout/MDXComponents';
import Breadcrumb from "@/components/Breadcrumb.astro";
import GuideSidebarDesktop from "@/components/guide/GuideSidebarDesktop.astro";
import GuideTocDesktop from "@/components/guide/GuideTocDesktop.astro";
import GuideSidebarMobile from "@/components/guide/GuideSidebarMobile.astro";
import GuidePager from "@/components/guide/GuidePager.astro";

export async function getStaticPaths() {
  const entries = await getCollection("guide");
  const activeEntries = entries
    .filter((e) => !e.data.draft)
    .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

  return activeEntries.map((entry, index) => {
    const prevEntry = index > 0 ? activeEntries[index - 1] : null;
    const nextEntry = index < activeEntries.length - 1 ? activeEntries[index + 1] : null;
    return {
      params: { slug: entry.id },
      props: { entry, entries: activeEntries, prevEntry, nextEntry },
    };
  });
}

const { entry, entries, prevEntry, nextEntry } = Astro.props;
const { Content, headings } = await render(entry);

const meta = buildMeta({
  title: entry.data.title,
  description: entry.data.description,
});
---

<GuideLayout {meta}>
  <GuideSidebarMobile {entries} currentId={entry.id} {headings} />
  <Container size="full">
    <div class="grid grid-cols-1 lg:grid-cols-[16rem_minmax(0,1fr)_14rem] gap-0 lg:gap-x-8 w-full max-w-full px-4">
      <GuideSidebarDesktop {entries} currentId={entry.id} />
      <Section size="sm">
        <div class="flex-1 min-w-0">
          <Section size="sm">
            <div class="flex justify-start items-start">
              <Breadcrumb
                items={[
                  { name: "Guide", url: ROUTES.guide },
                  { name: entry.data.section },
                ]}
              />
            </div>
          </Section>
          <article class="prose max-w-full w-full">
            <header class="mb-8">
              <h1 class="text-heading-24 md:text-heading-32 lg:text-heading-48 font-semibold">
                {entry.data.title}
              </h1>
            </header>
            <Section size="sm">
              <Content components={components} />
            </Section>
          </article>
          <GuidePager prev={prevEntry} next={nextEntry} />
        </div>
      </Section>
      <GuideTocDesktop {headings} />
    </div>
  </Container>
</GuideLayout>
