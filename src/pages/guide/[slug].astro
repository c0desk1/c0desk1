---
// src/pages/guide/[slug].astro
import { 
  getCollection, 
  getEntry, 
  render 
} from "astro:content";

import { 
  SITE, 
  ROUTES, 
  AUTHOR, 
  SERIES,
  IMAGE,
  buildMeta, 
  schemaArticle, 
  schemaBreadcrumb, 
  schemaSoftwareApplication, 
  schemaPerson 
} from "@/consts";

import { slugify, isCdnUrl, cdnImage } from "@/lib/utils";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import { components } from '@/components/layout/MDXComponents.astro';
import GuideSidebarDesktop from "@/components/guide/GuideSidebarDesktop.astro";
import GuideTocDesktop from "@/components/guide/GuideTocDesktop.astro";
import GuideSidebarMobile from "@/components/guide/GuideSidebarMobile.astro";
import GuidePager from "@/components/guide/GuidePager.astro";
import GuideHeader from "@/components/guide/GuideHeader.astro";
import BackToTop from "@/components/ui/BackToTop.astro";

export async function getStaticPaths() {
  const entries = await getCollection("guide", ({ data }) => !data.draft);
  const sorted = entries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return sorted.map((entry, index) => {
    const prevEntry = index > 0 ? sorted[index - 1] : null;
    const nextEntry = index < sorted.length - 1 ? sorted[index + 1] : null;
    return {
      params: { slug: entry.id },
      props: { entry, entries: sorted, prevEntry, nextEntry },
    };
  });
}

const { entry, entries } = Astro.props;
const { Content, headings } = await render(entry);

const authorEntry = await getEntry(entry.data.author);
const authorName = authorEntry?.data?.name ?? AUTHOR.name;
const authorRole = authorEntry?.data?.role ?? AUTHOR.role;
const authorSlug = authorEntry?.data?.slug ?? slugify(authorName);
const authorHandle = authorEntry?.data?.twitter ?? '';

const rawAvatar = authorEntry?.data?.avatar;
const authorAvatar = rawAvatar 
  ? (isCdnUrl(rawAvatar) ? cdnImage(rawAvatar, { w: IMAGE.avatar.width, h: IMAGE.avatar.height }) : rawAvatar)
  : IMAGE.avatar.placeholder;

const seriesSlug = entry.data.series || 'general';
const seriesArticles = entries
  .filter(e => (e.data.series || 'general') === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentIndex = seriesArticles.findIndex(e => e.id === entry.id);
const prevInSection = currentIndex > 0 ? seriesArticles[currentIndex - 1] : null;
const nextInSection = currentIndex < seriesArticles.length - 1 ? seriesArticles[currentIndex + 1] : null;

const seriesLabel = SERIES.find(c => c.slug === seriesSlug)?.label || seriesSlug;

const rawMainImage = entry.data.heroImage?.src || entry.data.seo?.ogImage;
const mainImage = rawMainImage 
  ? (isCdnUrl(rawMainImage) ? cdnImage(rawMainImage, { w: IMAGE.og.width, h: IMAGE.og.height }) : rawMainImage)
  : IMAGE.thumbnail.placeholder;

const canonicalURL = new URL(Astro.url.href).href;
const datePub = entry.data.pubDate.toISOString();
const dateMod = (entry.data.updatedDate ?? entry.data.pubDate).toISOString();
const hasAppDetails = entry.data.appDetails !== undefined;

const meta = buildMeta({
  title: entry.data.seo?.title || entry.data.title,
  description: entry.data.seo?.description || entry.data.description,
  canonical: canonicalURL,
  ogImage: mainImage,
  ogType: 'article',
  datePublished: datePub,
  dateModified: dateMod,
  authorName: authorName,
  keywords: entry.data.tags,
});

const schemaData = {
  title: entry.data.title,
  description: entry.data.description,
  url: canonicalURL,
  image: mainImage,
  datePublished: datePub,
  dateModified: dateMod,
  authorName: authorName,
  authorUrl: new URL(`/author/${authorSlug}`, SITE.url).href,
  category: seriesLabel,
  tags: entry.data.tags,
};

const activeArticleSchema = hasAppDetails
  ? schemaSoftwareApplication({
      name: schemaData.title,
      description: schemaData.description,
      url: schemaData.url,
      image: schemaData.image,
      operatingSystem: entry.data.appDetails?.operatingSystem,
      applicationCategory: entry.data.appDetails?.applicationCategory,
      price: entry.data.appDetails?.price,
      priceCurrency: entry.data.appDetails?.priceCurrency,
    })
  : schemaArticle(schemaData);

const schemas = [
  activeArticleSchema,
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: "Guide", url: new URL(ROUTES.guide, SITE.url).href },
    { name: seriesLabel, url: new URL(`${ROUTES.guide}/series/${seriesSlug}`, SITE.url).href },
    { name: entry.data.title, url: canonicalURL },
  ]),
  schemaPerson({
    name: authorName,
    url: new URL(`/author/${authorSlug}`, SITE.url).href,
    jobTitle: authorRole,
    image: authorAvatar,
    description: authorEntry?.data?.bio,
    sameAs: authorHandle ? [`https://twitter.com/${authorHandle.replace('@', '')}`] : undefined,
  }),
];
---

<Layout {meta} schema={schemas}>
  <GuideSidebarMobile
    entries={seriesArticles}
    currentId={entry.id}
    headings={headings}
    series={seriesLabel} 
  />
  <Container size="full">
    <div class="grid grid-cols-1 lg:grid-cols-[16rem_1fr_14rem] gap-0 px-0 lg:px-4">
      <div class="hidden lg:block lg:gap-x-8">
        <GuideSidebarDesktop
          entries={seriesArticles}
          currentId={entry.id}
          series={seriesLabel}
        />
      </div>
      <Section size="md" class="w-full max-w-3xl mx-auto">
        <Section size="sm" class="px-0 sm:px-4">
          <GuideHeader
            title={entry.data.title}
            pubDate={entry.data.pubDate}
            authorName={authorName}
            authorAvatar={authorAvatar}
            authorRole={authorRole}
            authorSlug={authorSlug}
            heroImage={entry.data.heroImage}
            content={entry.body}
          />
        </Section>
        <Section size="md">
          <article class="prose max-w-none min-w-0">
            <Content components={components} />
          </article>
          <Section size="sm">
            <div rrm-inline-cta="1b7a649f-eb54-48c5-8106-f2ac499dfc5f"></div>
          </Section>
        </Section>
        <GuidePager prev={prevInSection} next={nextInSection} />
      </Section>
      <div class="hidden lg:block lg:gap-x-8">
        <GuideTocDesktop {headings} />
      </div>
    </div>
  </Container>
  <div class="sm:hidden">
    <BackToTop />
  </div>
</Layout>