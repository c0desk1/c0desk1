---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";
import { categoryLabels } from "@/config/blog";
import { formatDateCompact } from "@/lib/utils";

export async function getStaticPaths() {
  return [
    {
      params: { slug: siteConfig.author.slug }
    }
  ];
}

const { slug } = Astro.params;

const posts = await getCollection("blog", ({ data }) => !data.draft);

const authorPosts = posts.filter((post) => {
  const authorSlug =
    post.data.author?.slug ||
    siteConfig.author.slug;

  return authorSlug === slug;
});

const author = siteConfig.author;

const seo = {
  title: `Artikel oleh ${author.name}`,
  description: author.bio,
  url: `${siteConfig.url}/author/${author.slug}`
};
---

<!-- AUTHOR SCHEMA -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${seo.url}#person`,
  "name": author.name,
  "url": seo.url,
  "image": `${siteConfig.url}${author.avatar}`,
  "jobTitle": author.title,
  "description": author.bio,
  "sameAs": [
    siteConfig.social.github,
    siteConfig.social.twitter,
    siteConfig.social.linkedin
  ],
  "worksFor": {
    "@type": "Organization",
    "name": siteConfig.name
  }
})} />

<BaseLayout title={seo.title} description={seo.description}>
  <Container size="md" class="px-4 md:px-8 py-16">

    <!-- HEADER -->
    <div class="flex items-center gap-4">
      <img
        src={author.avatar}
        alt={author.name}
        class="w-14 h-14 rounded-full object-cover"
      />

      <div>
        <h1 class="text-2xl font-semibold">
          {author.name}
        </h1>

        <p class="text-sm text-zinc-500">
          {author.title}
        </p>

        <p class="mt-2 text-sm text-zinc-500 max-w-xl">
          {author.bio}
        </p>
      </div>
    </div>

    <!-- STATS -->
    <div class="mt-8 text-sm text-zinc-500">
      {authorPosts.length} Artikel
    </div>

    <!-- POSTS -->
    <div class="mt-10 grid gap-6">
      {authorPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="block">
          <div class="text-xs md:text-sm text-zinc-500 items-center justify-between">
            {formatDateCompact(post.data.pubDate)}
			{categoryLabels[post.data.category]}
          </div>

          <div class="text-lg md:text-xl font-semibold line-clamp-3">
            {post.data.title}
          </div>

          <p class="text-sm text-zinc-500 line-clamp-3">
            {post.data.description}
          </p>
        </a>
      ))}
    </div>

  </Container>
</BaseLayout>