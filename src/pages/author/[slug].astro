---
// src/pages/author/[slug].astro
import { getCollection } from "astro:content";
import { Image } from 'astro:assets';
import {
  SITE, 
  ROUTES, 
  AUTHOR, 
  IMAGE, 
  buildMeta, 
  schemaWebPage, 
  schemaBreadcrumb,
  schemaPerson
} from "@/consts";

import { 
  cdnImage, 
  isCdnUrl 
} from "@/lib/utils";

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PostCard from "@/components/blog/PostCard.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.data.slug || author.id },
    props: { author },
  }));
}

const { author } = Astro.props;

const Author = {
  name: author.data.name || AUTHOR.name,
  role: author.data.role || AUTHOR.role,
  avatar: author.data.avatar || AUTHOR.avatar,
  bio: author.data.bio || AUTHOR.bio,
  handle: author.data.twitter || ''
}

const sameAs: string[] = [];
if (Author.handle) {
  sameAs.push(`https://twitter.com/${Author.handle.replace('@', '')}`);
}

const optimizedAvatar = isCdnUrl(Author.avatar)
  ? cdnImage(Author.avatar, { w: IMAGE.avatar.width, h: IMAGE.avatar.height, q: IMAGE.avatar.quality })
  : Author.avatar;

const canonicalURL = new URL(Astro.url.pathname, SITE.url).href;

const meta = buildMeta({
  title: Author.name,
  description: Author.bio || `Artikel oleh ${Author.name}`,
  canonical: canonicalURL,
});

const schemas = [
  schemaWebPage({
    title: Author.name,
    description: Author.bio || `Artikel oleh ${Author.name}`,
    url: canonicalURL,
  }),
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: Author.name, url: canonicalURL },
  ]),
  schemaPerson({
    name: Author.name,
    url: canonicalURL,
    jobTitle: Author.role || undefined,
    image: Author.avatar || undefined,
    description: Author.bio || undefined,
    sameAs: sameAs.length > 0 ? sameAs : undefined,
  }),
];

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const authorPosts = allPosts
  .filter((post) => {
    const postAuthor = post.data.author;
    if (!postAuthor) return false;

    if (typeof postAuthor === "string") {
      return postAuthor === author.id || postAuthor === author.data.slug;
    }
    return postAuthor.id === author.id || postAuthor.id === author.data.slug;
  })
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout {meta} schema={schemas}>
  <Section size="none">
    <Container size="xl">
      <div class="flex items-center self-start">
        <Breadcrumb
          items={[
            { name: "Beranda", url: ROUTES.home },
            { name: Author.name, url: canonicalURL },
          ]}
        />
      </div>
    </Container>
  </Section>
  <Section size="none">
    <Container size="xl">
      <Section size="sm">
        <div class="flex flex-col sm:flex-row items-center p-6 lg:p-8 gap-6 border border-(--border) rounded-lg bg-muted shadow-sm">
          <div class="relative overflow-hidden rounded-2xl border border-(--border) bg-subtle p-1.5 size-36 md:size-48 shrink-0">
            {Author.avatar && (
              <Image
                src={optimizedAvatar}
                alt={Author.name}
                width={IMAGE.avatar.width}
                height={IMAGE.avatar.height}
                loading="eager"
                decoding="async"
                fetchpriority="low"
                class="h-full w-full rounded-xl object-cover"
              />
            )}
          </div>
          <div class="flex flex-col text-center sm:text-left">
            <div class="flex flex-col sm:flex-row items-center sm:items-baseline gap-2 mb-3">
              <h1 class="text-heading-32 lg:text-heading-48 font-semibold text-strong">
                {Author.name}
              </h1>
              {Author.role && (
                <span class="text-label-14 text-muted uppercase">{Author.role}</span>
              )}
            </div>
            {Author.bio && (
              <p class="text-body-16 text-muted max-w-xl">{Author.bio}</p>
            )}
            {Author.handle && (
              <a
                href={`https://twitter.com/${Author.handle.replace('@', '')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-label-14 text-(--fg) hover:underline mt-3 inline-flex items-center gap-1 self-center sm:self-start"
              >
                @{Author.handle.replace('@', '')}
              </a>
            )}
          </div>
        </div>
      </Section>
      <Section size="sm">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-heading-24 lg:text-heading-32 font-semibold text-(--fg)">
            Artikel
          </h2>
          <span class="text-label-14 text-muted bg-muted px-3 py-1 border border-(--border) rounded-full">
            {authorPosts.length} artikel
          </span>
        </div>
        {authorPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {authorPosts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : (
          <div class="py-24 text-center">
            <p class="text-body-16 text-muted">Belum ada artikel.</p>
          </div>
        )}
      </Section>
    </Container>
  </Section>
</Layout>