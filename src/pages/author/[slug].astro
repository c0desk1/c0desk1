---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";
import { categoryLabels } from "@/config/blog";
import { formatDateCompact } from "@/lib/utils";

export async function getStaticPaths() {
  return [{ params: { slug: siteConfig.author.slug } }];
}

const { slug } = Astro.params;

const posts = await getCollection("blog", ({ data }) => !data.draft);

const authorPosts = posts
  .filter((post) => (post.data.author?.slug || siteConfig.author.slug) === slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const author = siteConfig.author;

const seo = {
  title: `${author.name} — Writing`,
  description: author.bio,
  url: `${siteConfig.url}/author/${author.slug}`
};
---

<!-- PERSON ENTITY SEO -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${seo.url}#person`,
  "name": author.name,
  "url": seo.url,
  "image": `${siteConfig.url}${author.avatar}`,
  "jobTitle": author.title,
  "description": author.bio,
  "sameAs": [
    siteConfig.social.github,
    siteConfig.social.twitter,
    siteConfig.social.linkedin
  ],
  "worksFor": {
    "@type": "Organization",
    "name": siteConfig.name
  }
})} />

<BaseLayout title={seo.title} description={seo.description}>
  <Container size="md" class="py-20 md:py-28">

    <!-- AUTHOR HEADER (VERCEL STYLE) -->
    <header class="flex flex-col md:flex-row items-start md:items-center gap-6 pb-12 border-b border-zinc-100 dark:border-zinc-800">

      <img
        src={author.avatar}
        alt={author.name}
        class="w-16 h-16 md:w-20 md:h-20 rounded-full object-cover ring-1 ring-zinc-200 dark:ring-zinc-800"
      />

      <div class="space-y-2">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
          {author.name}
        </h1>

        <p class="text-sm text-zinc-500 dark:text-zinc-400">
          {author.title}
        </p>

        <p class="text-sm leading-relaxed text-zinc-500 dark:text-zinc-400 max-w-2xl">
          {author.bio}
        </p>
      </div>
    </header>

    <!-- SECTION HEADER -->
    <div class="mt-14 mb-6 flex items-center justify-between">
      <h2 class="text-xs font-semibold uppercase tracking-[0.25em] text-zinc-400">
        Writing
      </h2>

      <span class="text-xs text-zinc-500">
        {authorPosts.length} posts
      </span>
    </div>

    <!-- POSTS LIST -->
    <div class="divide-y divide-zinc-100 dark:divide-zinc-800">

      {authorPosts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group block py-6 transition-colors hover:bg-zinc-50/50 dark:hover:bg-zinc-900/30 px-3 -mx-3 rounded-lg"
        >

          <!-- META -->
          <div class="flex items-center justify-between text-xs text-zinc-400 mb-2">

            <span class="px-2 py-0.5 rounded-full border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900">
              {categoryLabels[post.data.category] ?? post.data.category}
            </span>

            <time datetime={post.data.pubDate.toISOString()}>
  {formatDateCompact(post.data.pubDate)}
            </time>
          </div>
          <h3 class="text-base md:text-lg font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-black dark:group-hover:text-white transition-colors leading-snug">
            {post.data.title}
          </h3>
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400 line-clamp-2 max-w-3xl">
            {post.data.description}
          </p>
        </a>
      ))}
    </div>
  </Container>
</BaseLayout>