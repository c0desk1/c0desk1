---

export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon";
import PostCard from "@/components/blog/PostCard.astro";

import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import BackToTop from "@/components/ui/BackToTop.astro";

import { getCollection } from "astro:content";
import { Image } from 'astro:assets';
import { siteConfig } from "@/config/site";
import { cdnImage, isCdnUrl } from "@/lib/utils";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.id },
    props: { author },
  }));
}

const { author } = Astro.props;
const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const authorPosts = allPosts
  .filter((post) => post.data.author?.id === author.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const social = author.data.social || siteConfig.author.social;

const seoData = {
  title: author.data.name,
  description: author.data.bio,
  type: "profile" as const,
  canonicalURL,
  author: {
    name: author.data.name,
    role: author.data.role,
    avatar: author.data.avatar,
    bio: author.data.bio,
    slug: author.id,
  },
};

const authorCategory = {
  name: "Author",
  slug: "author",
  description: "Daftar penulis"
};

const optimizedAvatar = isCdnUrl(author.data.avatar) ? cdnImage(author.data.avatar, { w: 112, h: 112, q: 85 }) : author.data.avatar;

const seoBreadcrumbItems = [
  { name: "Home", href: siteURL },
  { name: "Author", href: new URL("authors/", siteURL).toString() },
  { name: author.data.name, href: canonicalURL }
];

const Breadcrumbs = seoBreadcrumbItems.filter(item => 
  item.name === "Home" || item.name === "Author"
);
---

<BaseLayout {...seoData} category={authorCategory}>
  <Section size="lg">
    <Container size="lg">
      <div class="max-w-2xl mx-auto flex flex-col items-center text-center">
        <h2 class="sr-only">Author Information</h2>
        <Breadcrumb items={Breadcrumbs} />
        <div class="my-8">
          <Image 
            src={optimizedAvatar} 
            alt={author.data.name}
            width={112}
            height={112}
            loading={"eager"}
            decoding= async
            class="w-28 h-28 rounded-full object-cover border border-(--border) p-1"
          />
        </div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tighter text-(--fg) mb-2">
          {author.data.name}
        </h1>
        <p class="text-lg text-(--fg-subtle) tracking-tight mb-6">
          {author.data.role}
        </p>

        <p class="text-(--fg-muted) max-w-md mx-auto leading-relaxed text-base mb-8">
          {author.data.bio}
        </p>

        <div class="flex flex-wrap justify-center gap-3">
          {social.map((item: { href: string; label: string }) => {
            return (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={item.label}
                class="flex size-6 items-center justify-center rounded-(--radius-full) text-(--fg-muted) transition-all hover:bg-(--bg-muted) hover:text-(--fg)"
              >
                <Icon name={item.label as any} className="size-4" />
              </a>
            );
          })}
        </div>
      </div>
    </Container>
  </Section>
  <Section size="lg">
    <Container size="xl">
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-400">
          Artikel Terbaru
        </h2>
        <div class="h-px flex-1 mx-4 bg-zinc-100 dark:bg-zinc-900"></div>
        <span class="text-xs font-medium text-zinc-400">{authorPosts.length} artikel</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {authorPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
      {authorPosts.length === 0 && (
        <div class="py-20 text-center rounded-2xl border border-dashed border-zinc-200 dark:border-zinc-800">
          <p class="text-sm text-zinc-400">Belum ada artikel yang diterbitkan.</p>
        </div>
      )}
    </Container>
    <BackToTop align="center" />
  </Section>
</BaseLayout>
