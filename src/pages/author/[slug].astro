---
// src/pages/author/[slug].astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";
import { formatDateCompact } from "@/lib/utils";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.id },
    props: { author },
  }));
}

const { author } = Astro.props;
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const authorPosts = allPosts
  .filter((post) => post.data.author.id === author.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const siteURL = Astro.site?.toString() ?? siteConfig.url;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const seoData = {
  title: author.data.name,
  description: author.data.bio,
  type: "profile" as const
};

// JEROAN SCHEMA: Sinkron dengan entitas Person di BaseHead
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      "@id": `${canonicalURL}#profilepage`,
      "url": canonicalURL,
      "name": `Archive by ${author.data.name}`,
      "isPartOf": { "@id": `${siteURL}#website` },
      "mainEntity": {
        "@type": "Person",
        "@id": `${siteURL}#person`,
        "name": author.data.name,
        "description": author.data.bio,
        "image": author.data.avatar,
        "jobTitle": author.data.role,
        "sameAs": [
          author.data.social?.github,
          author.data.social?.twitter,
          author.data.social?.linkedin
        ].filter(Boolean)
      }
    }
  ]
};
---

<BaseLayout {...seoData}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Container size="lg" class="py-20">
    <div class="grid grid-cols-1 lg:grid-cols-[300px_1fr] gap-20">
      <aside class="lg:sticky lg:top-24 h-fit space-y-8">
        <Breadcrumb items={[{ name: 'Home', href: siteURL }, { name: 'Authors', href: '#' }, { name: author.data.name, href: canonicalURL }]} />
        <div class="space-y-6">
          <img src={author.data.avatar} alt={author.data.name} class="w-20 h-20 rounded-full grayscale border border-zinc-200 dark:border-zinc-800 p-1 object-cover" />
          <div class="space-y-1">
            <h1 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white">{author.data.name}</h1>
            <p class="text-[10px] font-mono uppercase tracking-widest text-emerald-600 dark:text-emerald-500">{author.data.role}</p>
          </div>
          <p class="text-sm text-zinc-500 leading-relaxed font-medium italic">"{author.data.bio}"</p>
          <div class="flex flex-col border-t border-zinc-100 dark:border-zinc-900 pt-4">
            <span class="text-[10px] font-mono text-zinc-400 uppercase tracking-widest">Archive Size</span>
            <span class="text-lg font-bold tabular-nums">{authorPosts.length} post(s)</span>
          </div>
        </div>
      </aside>

      <Section size="none" class="border-l border-zinc-100 dark:border-zinc-900 pl-8 md:pl-12">
        <div class="mb-12">
          <h2 class="text-xs font-mono uppercase tracking-[0.3em] text-zinc-400 underline underline-offset-8 decoration-zinc-200 dark:decoration-zinc-800">Contributions</h2>
        </div>

        <div class="space-y-px bg-zinc-100 dark:bg-zinc-900 border-y border-zinc-100 dark:border-zinc-900">
          {authorPosts.map((post) => (
            <article class="group relative bg-white dark:bg-black py-10 transition-colors">
              <div class="flex flex-col md:flex-row md:items-baseline gap-4 md:gap-12">
                <time class="text-[11px] font-mono text-zinc-400 tabular-nums shrink-0 uppercase tracking-widest">
                  {formatDateCompact(post.data.pubDate)}
                </time>
                <div class="space-y-2">
                  <a href={`/blog/${post.id}/`} class="block group/link">
                    <h3 class="text-xl font-semibold tracking-tight text-zinc-900 dark:text-white group-hover/link:text-emerald-500 transition-colors">
                      {post.data.title}
                    </h3>
                    <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400 line-clamp-2 leading-relaxed max-w-2xl italic">
                      {post.data.description}
                    </p>
                  </a>
                  <div class="flex items-center gap-2 pt-2">
                    <span class="text-[9px] font-mono px-2 py-0.5 rounded-sm bg-zinc-50 dark:bg-zinc-900 text-zinc-500 border border-zinc-200 dark:border-zinc-800 uppercase tracking-tighter">
                      {post.data.category.id}
                    </span>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </Section>
    </div>
  </Container>
</BaseLayout>