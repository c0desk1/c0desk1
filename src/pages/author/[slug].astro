---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";
import { categoryLabels } from "@/config/blog";
import { formatDateCompact } from "@/lib/utils";

export async function getStaticPaths() {
  return [{ params: { slug: siteConfig.author.slug } }];
}

const { slug } = Astro.params;

const posts = await getCollection("blog", ({ data }) => !data.draft);

const authorPosts = posts
  .filter(
    (post) =>
      (post.data.author?.slug || siteConfig.author.slug) === slug
  )
  .sort(
    (a, b) =>
      b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );

const author = siteConfig.author;

const seo = {
  title: `${author.name}`,
  description: author.bio,
  url: `${siteConfig.url}/author/${author.slug}`
};
---

<!-- JSON-LD (SEO kuat untuk author entity) -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${seo.url}#person`,
  "name": author.name,
  "url": seo.url,
  "image": `${siteConfig.url}${author.avatar}`,
  "jobTitle": author.title,
  "description": author.bio,
  "sameAs": [
    siteConfig.social.github,
    siteConfig.social.twitter,
    siteConfig.social.linkedin
  ],
  "worksFor": {
    "@type": "Organization",
    "name": siteConfig.name
  }
})} />

<BaseLayout title={seo.title} description={seo.description}>
  <Container size="md" class="py-20">

    <!-- ================= HEADER (Vercel-like minimal) ================= -->
    <header class="mb-16">
      <div class="flex items-center gap-5">

        <img
          src={author.avatar}
          alt={author.name}
          class="w-14 h-14 rounded-full object-cover"
        />

        <div class="space-y-1">
          <h1 class="text-2xl md:text-3xl font-semibold tracking-tight text-zinc-900 dark:text-white">
            {author.name}
          </h1>

          <p class="text-sm text-zinc-500 dark:text-zinc-400">
            {author.title}
          </p>
        </div>
      </div>

      <p class="mt-5 max-w-2xl text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
        {author.bio}
      </p>

      <div class="mt-6 text-xs text-zinc-400">
        {authorPosts.length} posts
      </div>
    </header>

    <!-- ================= POSTS LIST (Vercel style: no card) ================= -->
    <section class="border-t border-zinc-200 dark:border-zinc-800">

      <div class="space-y-0">
        {authorPosts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block py-6 divide-y divide-zinc-100 dark:divide-zinc-800"
          >

            <!-- meta row -->
            <div class="flex items-center justify-between text-xs text-zinc-400">
              <span>
                {categoryLabels[post.data.category] ?? post.data.category}
              </span>

              <time datetime={post.data.pubDate.toISOString()}>
                {formatDateCompact(post.data.pubDate)}
              </time>
            </div>

            <!-- title -->
            <h2 class="mt-2 text-base md:text-lg font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-black dark:group-hover:text-white transition-colors">
              {post.data.title}
            </h2>

            <!-- description -->
            <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400 line-clamp-2">
              {post.data.description}
            </p>

          </a>
        ))}
      </div>
    </section>
  </Container>
</BaseLayout>