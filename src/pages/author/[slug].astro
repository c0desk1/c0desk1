---
// src/pages/author/[slug].astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PostCard from "@/components/blog/PostCard.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import SocialLinks from "@/components/ui/SocialLinks.astro";

import { getCollection } from "astro:content";
import { Image } from 'astro:assets';
import { siteConfig } from "@/config/site";
import { cdnImage, isCdnUrl } from "@/lib/utils";

export async function getStaticPaths() {
  const authors = await getCollection("authors");

  return authors.map((author) => ({
    params: {
      slug: author.data.slug || author.id,
    },
    props: { author },
  }));
}

const { author } = Astro.props;

const siteData = siteConfig;

const homeLabel    = siteData.home;
const authorsLabel = siteData.authorPage;
const t_latestArticles = siteConfig.blog_latestPosts;
const t_articles       = siteConfig.articles;
const t_noArticles     = siteConfig.blog_noBlogPosts;

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const seoAuthor = {
  name: author.data.name ?? siteData.author.name,
  role: author.data.role ?? siteData.author.role,
  avatar: author.data.avatar ?? siteData.author.avatar,
  bio: author.data.bio ?? siteData.author.bio,
  slug: author.id ?? siteData.author.slug,
  twitter: author.data.twitter ?? siteData.author.twitter
}

const SeoBreadcrumbItems = [
  { name: homeLabel, item: '/' },
  { name: authorsLabel, item: '/author' },
  { name: seoAuthor.name, item: canonicalURL },
];

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const authorPosts = allPosts
  .filter((post) => post.data.author?.id === author.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const social = author.data.social || siteData.author.social;

const BreadcrumbsItems = SeoBreadcrumbItems.filter(
  (item) => 
    item.name === homeLabel ||
    item.name === authorsLabel
);

const optimizedAvatar = isCdnUrl(seoAuthor.avatar)
  ? cdnImage(seoAuthor.avatar, { w: 112, h: 112, q: 85 })
  : seoAuthor.avatar;

const seoData = {
  title: siteData.authorPage,
  description: seoAuthor.bio,
  type: "profile" as const,
  canonicalURL,
  author: seoAuthor,
  breadcrumbItems: SeoBreadcrumbItems
};
---

<BaseLayout {...seoData}>
  <Section id="author-profile" size="lg" aria-label={seoAuthor.name}>
    <Section size="sm">
      <Container size="xl">
        <Breadcrumb items={BreadcrumbsItems} />
      </Container>
    </Section>
    <Section size="sm">
      <Container size="xl">
        <div class="flex flex-col sm:flex-row items-center p-4 lg:p-6 gap-4 border border-(--border) rounded-xl bg-(--bg-overlay) backdrop-blur-md shadow-(--shadow-md)">
          <div class="relative overflow-hidden rounded-3xl border border-(--border) bg-subtle p-1.5 size-48 shadow-sm aspect-auto mb-4 md:mb-0">
            <Image
              src={optimizedAvatar || siteConfig.author.avatar}
              alt={seoAuthor.name || siteConfig.author.name}
              width={320}
              height={320}
              loading="eager"
              decoding="async"
              fetchpriority="low"
              class="h-auto w-full rounded-[18px] object-cover"
            />
          </div>
          <div class="flex flex-col self-end-safe">
            <div class="flex flex-row items-center text-start justify-start gap-2 mb-4">
              <h1 id="author-heading" class="text-heading-32 lg:text-heading-48 font-semibold text-(--fg)">
                {seoAuthor.name}
              </h1>
              <p class="text-heading-14 text-subtle self-end-safe">
                {seoAuthor.role}
              </p>
            </div>
            <div class="flex items-center justify-start mb-4">
              <p class="text-copy-14 text-muted">
                {seoAuthor.bio}
              </p>
            </div>
            <div class="flex items-center justify-start gap-2">
              <SocialLinks items={social} />
            </div>
          </div>
        </div>
      </Container>
    </Section>
    <Section size="none">
      <Container size="xl">
        <Section size="sm">
          <div class="flex items-center justify-between">
            <h2 class="text-heading-20 lg:text-heading-32 text-(--fg) font-semibold">
              {t_latestArticles}
            </h2>
            <span class="text-label-14 text-muted bg-(--bg) px-2.5 py-1 border border-(--border) rounded-full">
              {authorPosts.length} {t_articles}
            </span>
          </div>
        </Section>
        <Section size="sm">
          {authorPosts.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
              {authorPosts.map((post) => (
                <div class="transition-colors active:bg-muted">
                  <PostCard post={post} />
                </div>
              ))}
            </div>
            ) : (
            <div class="py-24 text-center">
              <p class="text-copy-14 text-muted">{t_noArticles}</p>
            </div>
          )}
        </Section>
      </Container>
    </Section>
  </Section>
</BaseLayout>
