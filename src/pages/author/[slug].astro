---

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon";
import PostCard from "@/components/blog/PostCard.astro";

import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import BackToTop from "@/components/ui/BackToTop.astro";

import { getCollection } from "astro:content";
import { Image } from 'astro:assets';
import { siteConfig } from "@/config/site";
import { cdnImage, cn, isCdnUrl } from "@/lib/utils";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.id },
    props: { author },
  }));
}

const { author } = Astro.props;
const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const authorPosts = allPosts
  .filter((post) => post.data.author?.id === author.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const social = author.data.social || siteConfig.author.social;

const seoData = {
  title: author.data.name,
  description: author.data.bio,
  type: "profile" as const,
  canonicalURL,
  author: {
    name: author.data.name,
    role: author.data.role,
    avatar: author.data.avatar,
    bio: author.data.bio,
    slug: author.id,
  },
};

const authorCategory = {
  name: "Author",
  slug: "author",
  description: "Daftar penulis"
};

const optimizedAvatar = isCdnUrl(author.data.avatar) ? cdnImage(author.data.avatar, { w: 112, h: 112, q: 85 }) : author.data.avatar;

const seoBreadcrumbItems = [
  { name: "Home", href: siteURL },
  { name: "Author", href: new URL("authors/", siteURL).toString() },
  { name: author.data.name, href: canonicalURL }
];

const Breadcrumbs = seoBreadcrumbItems.filter(item => 
  item.name === "Home" || item.name === "Author"
);
---

<BaseLayout {...seoData} category={authorCategory}>
  <Section size="none" class="border-b border-dashed border-(--border)">
    <div class="relative items-center">
      <div
        class={cn(
          "absolute inset-0 z-1",
          "bg-size-[20px_20px]",
          "bg-[radial-gradient(#d4d4d4_1px,transparent_1px)]",
          "dark:bg-[radial-gradient(#404040_1px,transparent_1px)]",
        )}
      />
      <div class="pointer-events-none absolute inset-0 z-1 flex items-center justify-center bg-(--bg) mask-[radial-gradient(ellipse_at_center,transparent_20%,black)]" />
      
      <Container size="lg" class="py-16">
        <section class="flex flex-col-reverse md:flex-row items-center justify-start md:justify-between gap-4" aria-labelledby="author-heading">
          <div class="flex flex-col justify-start items-start z-3">
            <Breadcrumb items={Breadcrumbs} />
            <div class="mt-5 space-y-5">
              <div class="space-y-3">
                <h1 id="author-heading" class="text-4xl md:text-5xl font-bold tracking-[-0.04em] text-(--fg)">
                  {author.data.name}
                </h1>
                <p class="text-base md:text-lg text-(--fg-subtle) tracking-tight">
                  {author.data.role}
                </p>
              </div>
              <p class="max-w-2xl text-[15px] leading-7 text-(--fg-muted)">
                {author.data.bio}
              </p>
              <div class="flex items-center gap-2 pt-2">
                {social.map((item: { href: string; label: string }) => (
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={item.label}
                    class="group flex size-9 items-center justify-center rounded-full border border-transparent text-(--fg-muted) transition-all duration-200 hover:border-(--border) hover:bg-(--bg-muted) hover:text-(--fg)"
                  >
                    <Icon
                      name={item.label as any}
                      className="size-4 transition-transform duration-200 group-hover:scale-110"
                    />
                  </a>
                ))}
              </div>
            </div>
          </div>

          <div class="flex items-center z-3">
            <div
              class="relative overflow-hidden rounded-[28px] border border-(--border) bg-(--bg-subtle) p-2 shadow-sm">
              <Image
                src={optimizedAvatar}
                alt={author.data.name}
                width={224}
                height={224}
                loading="eager"
                decoding="async"
                class="h-auto w-full md:h-full md:w-56 rounded-[22px] object-cover"
              />
            </div>
          </div>
        </section>
      </Container>
    </div>
  </Section>
  <Section size="lg">
    <Container size="xl">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-(--fg) text-2xl md:text-3xl font-semibold tracking-tighter">
          Artikel Terbaru
        </h2>
        <span class="text-[13px] md:text-sm text-(--fg-muted)">{authorPosts.length} artikel</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8">
        {authorPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
      {authorPosts.length === 0 && (
        <div class="py-20 text-center rounded-2xl border border-dashed border-(--border)">
          <p class="text-sm md:text-base text-(--fg-muted)">Belum ada artikel yang diterbitkan.</p>
        </div>
      )}
    </Container>
    <BackToTop align="center" />
  </Section>
</BaseLayout>
