---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro"; // Using your Section component
import { getCollection, getEntry } from "astro:content";
import { Image } from 'astro:assets';
import { siteConfig } from "@/config/site";
import { formatDateCompact } from "@/lib/utils";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.id },
    props: { author },
  }));
}

const { author } = Astro.props;
const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const authorPosts = allPosts
  .filter((post) => post.data.author?.id === author.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const postsWithCategory = await Promise.all(
  authorPosts.map(async (post) => {
    const category = post.data.category ? await getEntry(post.data.category) : null;
    return { ...post, categoryData: category?.data };
  })
);

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const socialLinks = author.data.social || {};

const seoData = {
  title: author.data.name,
  description: author.data.bio,
  type: "profile" as const,
  canonicalURL,
  author: {
    name: author.data.name,
    role: author.data.role,
    avatar: author.data.avatar,
    bio: author.data.bio,
    slug: author.id,
  },
};

const authorCategory = {
  name: "Author",
  slug: "author",
  description: "Daftar penulis"
};
---

<BaseLayout {...seoData} category={authorCategory}>
    {/* Profile Header Section */}
    <Section size="lg" class="border-b border-zinc-100 dark:border-zinc-900 bg-white dark:bg-black">
      <Container size="lg">
        <div class="max-w-2xl mx-auto flex flex-col items-center text-center">
          <h2 class="sr-only">Author Profile</h2>
          
          {/* Avatar */}
          <div class="mb-8">
            <Image 
              src={author.data.avatar} 
              alt={author.data.name}
              width={100}
              height={100}
              loading={"eager"}
              class="w-24 h-24 md:w-28 md:h-28 rounded-full object-cover border border-zinc-200 dark:border-zinc-800 p-1 bg-white dark:bg-black transition-colors"
            />
          </div>
          
          {/* Name & Role */}
          <h1 class="text-4xl md:text-5xl font-bold tracking-tighter text-zinc-900 dark:text-white mb-3">
            {author.data.name}
          </h1>
          <p class="text-base text-zinc-500 dark:text-zinc-400 font-medium tracking-tight mb-6">
            {author.data.role}
          </p>
          
          {/* Bio */}
          <p class="text-zinc-600 dark:text-zinc-400 max-w-md mx-auto leading-relaxed text-[17px]">
            {author.data.bio}
          </p>
          
          {/* Social Links */}
          {Object.values(socialLinks).some(Boolean) && (
            <div class="mt-8 flex justify-center gap-6">
              {Object.entries(socialLinks).map(([platform, url]) => (
                url && (
                  <a 
                    href={url} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="text-[13px] font-medium text-zinc-400 hover:text-black dark:hover:text-white transition-colors underline underline-offset-4 decoration-zinc-200 dark:decoration-zinc-800"
                  >
                    {platform.charAt(0).toUpperCase() + platform.slice(1)}
                  </a>
                )
              ))}
            </div>
          )}
          
          {/* Post count Badge */}
          <div class="mt-8 px-3 py-1 rounded-full border border-zinc-200 dark:border-zinc-800">
            <span class="text-[11px] font-bold uppercase tracking-widest text-zinc-500">{authorPosts.length} Articles</span>
          </div>
        </div>
      </Container>
    </Section>

    {/* Posts Section */}
    <Section size="lg" class="bg-white dark:bg-black">
      <Container size="lg">
        <div class="max-w-3xl mx-auto">
          <h2 class="sr-only">Published Articles by {author.data.name}</h2>
          
          <div class="divide-y divide-zinc-100 dark:divide-zinc-900">
            {postsWithCategory.map((post) => (
              <article class="group py-10 first:pt-0">
                <a href={`/blog/${post.id}/`} class="block space-y-3">
                  <div class="flex items-center gap-3">
                    <time class="text-[13px] text-zinc-400 tracking-tight">
                      {formatDateCompact(post.data.pubDate)}
                    </time>
                    {post.categoryData && (
                      <>
                        <span class="text-zinc-200 dark:text-zinc-800">/</span>
                        <span class="text-[13px] font-medium text-zinc-500 dark:text-zinc-400 tracking-tight">
                          {post.categoryData.name}
                        </span>
                      </>
                    )}
                  </div>
                  
                  <h3 class="text-2xl font-bold tracking-tighter text-zinc-900 dark:text-white group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors">
                    {post.data.title}
                  </h3>
                  
                  <p class="text-[16px] text-zinc-500 dark:text-zinc-500 leading-snug line-clamp-2 max-w-2xl">
                    {post.data.description}
                  </p>
                </a>
              </article>
            ))}
          </div>
          
          {authorPosts.length === 0 && (
            <div class="text-center py-20 border border-dashed border-zinc-200 dark:border-zinc-800 rounded-2xl">
              <p class="text-sm tracking-tight text-zinc-400 italic">No publications yet.</p>
            </div>
          )}
        </div>
      </Container>
    </Section>
</BaseLayout>