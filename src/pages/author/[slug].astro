---
// src/pages/author/[slug].astro
import { getCollection } from "astro:content";
import { Image } from 'astro:assets';
import { SITE, ROUTES, AUTHOR, buildMeta, schemaWebPage, schemaBreadcrumb } from "@/consts";
import { cdnImage, isCdnUrl } from "@/lib/utils";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PostCard from "@/components/blog/PostCard.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.data.slug || author.id },
    props: { author },
  }));
}

const { author } = Astro.props;

const authorName = author.data.name || AUTHOR.name;
const authorRole = author.data.role || '';
const authorAvatar = author.data.avatar || AUTHOR.avatar || '';
const authorBio = author.data.bio || '';
const authorTwitter = author.data.twitter || '';

const optimizedAvatar = isCdnUrl(authorAvatar)
  ? cdnImage(authorAvatar, { w: 112, h: 112, q: 85 })
  : authorAvatar;

const canonicalURL = new URL(Astro.url.pathname, SITE.url).href;

const meta = buildMeta({
  title: authorName,
  description: authorBio || `Artikel oleh ${authorName}`,
  canonical: canonicalURL,
});

const schemas = [
  schemaWebPage({
    title: authorName,
    description: authorBio || `Artikel oleh ${authorName}`,
    url: canonicalURL,
  }),
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: authorName, url: canonicalURL },
  ]),
];

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const authorPosts = allPosts
  .filter((post) => {
    const postAuthor = post.data.author;
    if (!postAuthor) return false;
    if (typeof postAuthor === "string") {
      return postAuthor === author.id || postAuthor === author.data.slug;
    }
    return postAuthor.id === author.id || postAuthor.slug === author.data.slug;
  })
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout {meta} schema={schemas}>
  <Section size="lg">
    <Container size="xl">
      <div class="mb-8">
        <Breadcrumb
          items={[
            { name: "Beranda", url: ROUTES.home },
            { name: authorName, url: canonicalURL },
          ]}
        />
      </div>
      <div class="flex flex-col sm:flex-row items-center p-6 lg:p-8 gap-6 border border-(--border) rounded-(--prose-radius-lg) bg-(--prose-surface) shadow-sm mb-12">
        <div class="relative overflow-hidden rounded-2xl border border-(--border) bg-(--bg-subtle) p-1.5 size-36 md:size-48 shrink-0">
          {authorAvatar && (
            <Image
              src={optimizedAvatar}
              alt={authorName}
              width={320}
              height={320}
              loading="eager"
              decoding="async"
              class="h-full w-full rounded-xl object-cover"
            />
          )}
        </div>
        <div class="flex flex-col text-center sm:text-left">
          <div class="flex flex-col sm:flex-row items-center sm:items-baseline gap-2 mb-3">
            <h1 class="text-heading-32 lg:text-heading-48 font-bold text-(--prose-fg-strong)">
              {authorName}
            </h1>
            {authorRole && (
              <span class="text-label-14 text-(--prose-fg-muted) uppercase tracking-wider">{authorRole}</span>
            )}
          </div>
          {authorBio && (
            <p class="text-body-16 text-(--prose-fg-muted) max-w-xl">{authorBio}</p>
          )}
          {authorTwitter && (
            <a
              href={`https://twitter.com/${authorTwitter.replace('@', '')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-label-14 text-(--prose-accent) hover:underline mt-3 inline-flex items-center gap-1"
            >
              @{authorTwitter.replace('@', '')}
            </a>
          )}
        </div>
      </div>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-heading-24 lg:text-heading-32 font-semibold text-(--prose-fg)">
          Artikel
        </h2>
        <span class="text-label-14 text-(--prose-fg-muted) bg-(--prose-surface) px-3 py-1 border border-(--prose-border) rounded-full">
          {authorPosts.length} artikel
        </span>
      </div>

      {authorPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {authorPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <div class="py-24 text-center">
          <p class="text-body-16 text-(--prose-fg-muted)">Belum ada artikel.</p>
        </div>
      )}
    </Container>
  </Section>
</Layout>