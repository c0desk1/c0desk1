---
// src/pages/offline.astro

import ErrorLayout from '@/layouts/ErrorLayout.astro';
import Container from '@/components/ui/Container.astro';
import { siteConfig } from '@/config/site';
import Icon from '@/components/ui/Icon';

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;

const seoData = {
  title: "Offline",
  description: "Koneksi internet terputus",
  noIndex: true,
  type: "website" as const,
  canonicalURL: new URL('403', siteURL).toString(),
};
---

<ErrorLayout {...seoData}>
  <Container size="md">
    <div class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4">
      <Icon name="logo" className="w-24 h-24" />
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tighter text-(--fg) mb-4">Anda Offline</h1>
      <p class="text-sm md:text-base text-(--fg-muted) max-w-[400px] mb-10 leading-relaxed">
        Koneksi internet terputus. Silakan cek kembali koneksi Anda dan coba lagi nanti.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto">
        <button 
          onclick="window.location.reload()"
          class="w-full sm:w-auto inline-flex justify-center items-center h-10 px-6 rounded-md bg-(--bg-subtle) text-(--fg) text-sm font-medium hover:bg-(--bg-muted) transition-colors"
        >
          Coba lagi
        </button>
      </div>
    </div>
  </Container>
</ErrorLayout>
