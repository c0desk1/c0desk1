---
// src/pages/blog/[slug].astro
import { 
  getCollection, 
  render, 
  getEntry 
} from "astro:content";

import { 
  SITE, 
  AUTHOR, 
  ROUTES, 
  CATEGORIES, 
  buildMeta, 
  schemaArticle, 
  schemaBreadcrumb,
  schemaPerson
} from "@/consts";

import { slugify } from "@/lib/utils";
import { components } from '@/components/layout/MDXComponents';

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PostHeader from "@/components/blog/PostHeader.astro";
import HeroImage from '@/components/blog/PostHeroImage.astro';
import ShareArticle from "@/components/blog/SharePost.astro";
import RssFeed from '@/components/blog/RssFeed.astro';
import PostNavigation from '@/components/blog/PostNavigation.astro';

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.slug || slugify(post.data.title) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const authorEntry = await getEntry(post.data.author);
const categoryEntry = await getEntry(post.data.category);

const canonicalURL = new URL(Astro.url.pathname, SITE.url).href;

const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const Author = {
  name: authorEntry?.data?.name ?? AUTHOR.name,
  role: authorEntry?.data?.role ?? AUTHOR.role,
  avatar: authorEntry?.data?.avatar ?? AUTHOR.avatar,
  slug: (post.data.author as any)?.slug || (post.data.author as any)?.id || slugify(authorEntry.data.name),
  handle: authorEntry?.data?.twitter || ''
}

const sameAs: string[] = [];
if (Author.handle) {
  sameAs.push(`https://twitter.com/${Author.handle.replace('@', '')}`);
}

const Category = {
  name: categoryEntry?.data?.name ?? CATEGORIES.find(c => c.slug === (post.data.category as any)?.slug)?.label ?? 'General',
  slug: (post.data.category as any)?.slug || (post.data.category as any)?.id || slugify(categoryEntry.data.name)
}

const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const meta = buildMeta({
  title: post.data.seo?.title || post.data.title,
  description: post.data.seo?.description || post.data.description,
  canonical: canonicalURL,
  ogImage: post.data.seo?.ogImage || post.data.heroImage?.src,
  ogType: 'article',
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.updatedDate?.toISOString(),
  authorName: Author.name,
  keywords: post.data.tags,
});

const articleSchema = schemaArticle({
  title: post.data.title,
  description: post.data.description,
  url: canonicalURL,
  image: post.data.seo?.ogImage || post.data.heroImage?.src || SITE.ogImage || '',
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.updatedDate?.toISOString() || post.data.pubDate.toISOString(),
  authorName: Author.name,
  category: Category.name,
  tags: post.data.tags,
  wordCount: 0,
  readingTime: 0,
});

const breadcrumbSchema = schemaBreadcrumb([
  { name: "Beranda", url: SITE.url },
  { name: "Blog", url: `${SITE.url}/blog` },
  { name: Category.name, url: `${SITE.url}/blog/category/${Category.slug || 'General'}` },
  { name: post.data.title, url: canonicalURL },
]);

const personSchema = schemaPerson({
    name: Author.name,
    url: `${SITE.url}/author/${Author.slug}`,
    jobTitle: Author.role || undefined,
    image: Author.avatar || undefined,
    description: authorEntry?.data?.bio || AUTHOR.bio || undefined,
    sameAs: sameAs.length > 0 ? sameAs : undefined,
  }),
---

<Layout {meta} schema={[articleSchema, breadcrumbSchema, personSchema]}>
  <Section size="none">
    <Container size="md">
      <Breadcrumb
        items={[
          { name: "Blog", url: ROUTES.blog },
          { name: Category.name, url: `${SITE.url}/blog/category/${Category.slug || 'General'}` },
        ]}
      />
    </Container>
  </Section>
  <Section size="none">
    <Container size="md">
      <article id="article">
        <Section size="sm">
          <PostHeader
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            content={post.body || ''}
            authorName={Author.name}
            authorAvatar={Author.avatar}
            authorRole={Author.role}
            authorSlug={Author.slug}
            overviewItems={post.data.overview}
          />
        </Section>
        {post.data.heroImage && (
          <HeroImage
            image={post.data.heroImage.src}
            alt={post.data.heroImage.alt || post.data.title}
          />
        )}
        <Section size="sm">
          <div class="prose">
            <Content components={components} />
          </div>
        </Section>
        <Section size="sm">
          <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
            <ShareArticle url={canonicalURL} title={post.data.title} description={post.data.description} />
            <RssFeed />
          </div>
        </Section>
        <Section size="sm">
          <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </Section>
      </article>
    </Container>
  </Section>
</Layout>