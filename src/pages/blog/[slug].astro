---
// src/pages/blog/[slug].astro
import { 
  getCollection, 
  render, 
  getEntry 
} from "astro:content";

import { 
  SITE, 
  AUTHOR, 
  ROUTES, 
  CATEGORIES, 
  buildMeta, 
  schemaArticle, 
  schemaNewsArticle,
  schemaSoftwareApplication,
  schemaBreadcrumb, 
  schemaPerson, 
IMAGE
} from "@/consts";

import { slugify } from "@/lib/utils";

import { components } from '@/components/layout/MDXComponents.astro';

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PostHeader from "@/components/blog/PostHeader.astro";
import HeroImage from '@/components/blog/PostHeroImage.astro';
import ShareArticle from "@/components/blog/SharePost.astro";
import RssFeed from '@/components/blog/RssFeed.astro';
import PostNavigation from '@/components/blog/PostNavigation.astro';
import BackToTop from "@/components/ui/BackToTop.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.slug || slugify(post.data.title) },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

const authorEntry = await getEntry(post.data.author);
const canonicalURL = new URL(Astro.url.pathname, SITE.url).href;

const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const Author = {
  name: authorEntry?.data?.name ?? AUTHOR.name,
  role: authorEntry?.data?.role ?? AUTHOR.role,
  avatar: authorEntry?.data?.avatar ?? AUTHOR.avatar,
  slug: authorEntry?.id || slugify(authorEntry?.data?.name || AUTHOR.name),
  handle: authorEntry?.data?.twitter || ''
};

const categoryData = CATEGORIES.find(c => c.slug === post.data.category);
const Category = {
  name: categoryData?.label || post.data.category,
  slug: post.data.category
};

const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const mainImage = post.data.seo?.ogImage || post.data.heroImage?.src || SITE.ogImage;
const datePub = post.data.pubDate.toISOString();
const dateMod = (post.data.updatedDate ?? post.data.pubDate).toISOString();

const isNews = post.data.tags?.some(tag => {
  const t = tag.toLowerCase();
  return ['berita', 'news', 'update', 'pengumuman'].some(keyword => t.includes(keyword));
});

const hasAppDetails = post.data.appDetails !== undefined;

const meta = buildMeta({
  title: post.data.seo?.title || post.data.title,
  description: post.data.seo?.description || post.data.description,
  canonical: canonicalURL,
  ogImage: mainImage,
  ogType: 'article',
  datePublished: datePub,
  dateModified: dateMod,
  authorName: Author.name,
  keywords: post.data.tags,
});

const schemaData = {
  title: post.data.title,
  description: post.data.description,
  url: canonicalURL,
  image: mainImage,
  datePublished: datePub,
  dateModified: dateMod,
  authorName: Author.name,
  authorUrl: new URL(`/author/${Author.slug}`, SITE.url).href,
  category: Category.name,
  tags: post.data.tags,
};

let activeArticleSchema;

if (isNews) {
  activeArticleSchema = schemaNewsArticle(schemaData);
} else if (hasAppDetails) {
  activeArticleSchema = schemaSoftwareApplication({
    name: schemaData.title,
    description: schemaData.description,
    url: schemaData.url,
    image: schemaData.image,
    operatingSystem: post.data.appDetails?.operatingSystem,
    applicationCategory: post.data.appDetails?.applicationCategory,
    price: post.data.appDetails?.price,
    priceCurrency: post.data.appDetails?.priceCurrency
  });
} else {
  activeArticleSchema = schemaArticle(schemaData);
};
---

<Layout {meta} schema={[activeArticleSchema, schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: "Blog", url: new URL(ROUTES.blog, SITE.url).href },
    { name: Category.name, url: new URL(`${ROUTES.blog}/category/${Category.slug}`, SITE.url).href },
    { name: post.data.title, url: canonicalURL },
]), schemaPerson({
    name: Author.name,
    url: new URL(`/author/${Author.slug}`, SITE.url).href,
    jobTitle: Author.role,
    image: Author.avatar,
    description: authorEntry?.data?.bio,
    sameAs: Author.handle ? [`https://twitter.com/${Author.handle.replace('@', '')}`] : undefined,
})]}>
  <Section size="sm">
    <Section size="sm">
      <Container size="md">
        <Breadcrumb
          items={[
            { name: "Blog", url: ROUTES.blog },
            { name: Category.name, url: `${ROUTES.blog}/category/${Category.slug}` },
          ]}
        />
      </Container>
    </Section>
    <Section size="sm">
      <Container size="md">
        <article id="article">
          <PostHeader
            title={post.data.title}
            pubDate={post.data.pubDate}
            content={post.body || ''}
            authorName={Author.name}
            authorAvatar={Author.avatar}
            authorRole={Author.role}
            authorSlug={Author.slug}
            overviewItems={post.data.overview}
          />
          <Section size="sm">
            {post.data.heroImage && (
              <HeroImage
                image={post.data.heroImage.src}
                alt={post.data.heroImage.alt || post.data.title}
              />
            )}
          </Section>
          <div class="prose max-w-none my-8">
            <Content components={components} />
          </div>
          <Section size="sm">
            <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between py-8 border-t border-(--border)">
              <ShareArticle url={canonicalURL} title={post.data.title} description={post.data.description} />
              <RssFeed />
            </div>
          </Section>
          <Section size="sm">
            <PostNavigation prevPost={prevPost} nextPost={nextPost} />
          </Section>
        </article>
      </Container>
    </Section>
  </Section>
  <BackToTop />
</Layout>