---
// src/pages/blog/[slug].astro
import { getCollection, render, getEntry } from "astro:content";
import { SITE, ROUTES, buildMeta, schemaArticle, schemaBreadcrumb } from "@/consts";
import { slugify } from "@/lib/utils";
import { components } from '@/components/layout/MDXComponents';

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PostHeader from "@/components/blog/PostHeader.astro";
import ShareArticle from "@/components/blog/SharePost.astro";
import RssFeed from '@/components/blog/RssFeed.astro';
import PostNavigation from '@/components/blog/PostNavigation.astro';
import HeroImage from '@/components/blog/PostHeroImage.astro';

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.slug || slugify(post.data.title) },
    props: { post },
  }));
}

const { post } = Astro.props;

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

let authorData = {
  name: SITE.author?.name || 'Unloyd',
  avatar: SITE.author?.avatar || '',
  role: '',
};
if (post.data.author && /^[a-z0-9-]+$/.test(post.data.author)) {
  try {
    const authorEntry = await getEntry('authors', post.data.author);
    if (authorEntry) {
      authorData = {
        name: authorEntry.data.name || authorData.name,
        avatar: authorEntry.data.avatar || authorData.avatar,
        role: authorEntry.data.role || '',
      };
    }
  } catch {}
}

let categoryName = '';

if (post.data.category && /^[a-z0-9-]+$/.test(post.data.category)) {
  try {
    const catEntry = await getEntry(post.data.category);
    if (catEntry) categoryName = catEntry.data.name;
  } catch {}
} else if (post.data.category) {
  categoryName = post.data.category;
}

const { Content } = await render(post);

const canonicalURL = new URL(Astro.url.pathname, SITE.url).href;

const meta = buildMeta({
  title: post.data.seo?.title || post.data.title,
  description: post.data.seo?.description || post.data.description,
  canonical: canonicalURL,
  ogImage: post.data.seo?.ogImage || post.data.heroImage?.src,
  ogType: 'article',
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.updatedDate?.toISOString(),
  authorName: authorData.name,
  keywords: post.data.tags,
});

const articleSchema = schemaArticle({
  title: post.data.title,
  description: post.data.description,
  url: canonicalURL,
  image: post.data.seo?.ogImage || post.data.heroImage?.src || SITE.defaultImage || '',
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.updatedDate?.toISOString() || post.data.pubDate.toISOString(),
  authorName: authorData.name,
  category: categoryName,
  tags: post.data.tags,
  wordCount: 0,
  readingTime: 0,
});

const breadcrumbSchema = schemaBreadcrumb([
  { name: "Beranda", url: SITE.url },
  { name: "Blog", url: `${SITE.url}/blog` },
  { name: categoryName || "Umum", url: `${SITE.url}/blog/category/${post.data.category || 'general'}` },
  { name: post.data.title, url: canonicalURL },
]);
---

<Layout {meta} schema={[articleSchema, breadcrumbSchema]}>
  <Section size="md">
    <Container size="md">
      <Section size="sm">
        <Breadcrumb
          items={[
            { name: "Beranda", url: ROUTES.home },
            { name: "Blog", url: ROUTES.blog },
            { name: categoryName || "Umum", url: `/blog/category/${post.data.category || 'general'}` },
            { name: post.data.title, url: canonicalURL },
          ]}
        />
      </Section>
      
      <article id="article" class="max-w-3xl mx-auto">
        <Section size="sm">
          <PostHeader
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            content={post.body}
            authorName={authorData.name}
            authorAvatar={authorData.avatar}
            authorRole={authorData.role}
            authorSlug={post.data.author || ''}
            overviewItems={post.data.overview}
          />
        </Section>
        {post.data.heroImage && (
          <HeroImage
            image={post.data.heroImage.src}
            alt={post.data.heroImage.alt || post.data.title}
            caption={post.data.heroImage.caption}
          />
        )}
        <Section size="sm">
          <div class="prose">
            <Content components={components} />
          </div>
        </Section>
        <Section size="sm">
          <div class="mt-12 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
            <ShareArticle url={canonicalURL} title={post.data.title} description={post.data.description} />
            <RssFeed class="sm:self-end" />
          </div>
        </Section>
        <Section size="sm">
          <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </Section>
      </article>
    </Container>
  </Section>
</Layout>