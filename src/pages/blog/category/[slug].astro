---
// src/pages/blog/category/[slug].astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import PostCard from "@/components/blog/PostCard.astro";

import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";
import { slugify } from "@/lib/utils";

const siteData = siteConfig;

const t_home = siteData.home;
const t_blog = siteData.blog;
const t_empty = siteData.noPostsInCategory;
const t_articles = siteData.articles;

export async function getStaticPaths() {
  const categories = await getCollection("categories");

  return categories.map((category) => {
    const name =
      typeof category.data.name === "string"
        ? category.data.name
        : String(category.data.name);

    return {
      params: {
        slug: category.data.slug || slugify(name),
      },
      props: { category },
    };
  });
}

const { category } = Astro.props;

const allPosts = await getCollection("blog", (post) => !post.data.draft);
const categoryName =
  typeof category.data.name === "string"
    ? category.data.name
    : String(category.data.name);
const categoryDesc = category.data.description ?? "";
const categorySlug = slugify(categoryName);
const categoryPosts = allPosts
  .filter((post) => post.data.category?.id === category.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const canonicalURL = new URL(
  `/blog/category/${categorySlug}`,
  siteData.siteUrl
).toString();

const SeoBreadcrumbItems = [
  { name: t_home, item: "/" },
  { name: t_blog, item: "/blog" },
  { name: categoryName, item: canonicalURL },
];

const BreadcrumbsItems = SeoBreadcrumbItems.filter(
  (item) => 
    item.name === t_blog ||
    item.name === categoryName
);

const seoData = {
  title: categoryName,
  description: categoryDesc || `${siteData.blog} - ${categoryName}`,
  type: "website" as const,
  canonicalURL,
  breadcrumbItems: SeoBreadcrumbItems
};
---

<BaseLayout {...seoData}>
  <Section id="category-archive" size="lg" aria-label={categoryName}>
    <Section size="sm">
      <Container size="lg">
        <div class="flex items-center justify-start md:justify-center">
          <Breadcrumb items={BreadcrumbsItems} />
        </div>
      </Container>
    </Section>
    <Section size="sm">
      <Container size="xl">
        <div class="flex flex-col items-center gap-4">
          <div class="space-y-2 self-start md:self-center">
            <h1 class="text-heading-24 lg:text-heading-48 font-semibold text-(--fg)">
              {categoryName}
            </h1>
          </div>
          {categoryDesc && (
            <p class="text-body-14 text-muted pt-4">
              {categoryDesc}
            </p>
          )}
          <div class="inline-flex self-start md:self-center items-center gap-1.5 rounded-md bg-muted px-2 py-0.5 text-label-14 text-muted border border-(--border)">
            <svg class="h-3 w-3 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <span>{siteData.filterCategory}</span>
          </div>
        </div>
      </Container>
    </Section>
    <Section size="none">
      <Container size="xl">
        <Section size="sm">
          <div class="flex items-center justify-between">
            <h2 class="text-heading-20 lg:text-heading-32 text-(--fg) font-semibold">
              {categoryName}
            </h2>
            <span class="text-label-14 text-muted bg-(--bg) px-2.5 py-1 border border-(--border) rounded-full">
              {categoryPosts.length} {t_articles}
            </span>
          </div>
        </Section>
        <Section size="sm">
          {categoryPosts.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
              {categoryPosts.map((post) => (
                <div class="transition-colors">
                  <PostCard post={post} />
                </div>
              ))}
            </div>
          ) : (
            <div class="flex flex-col items-center justify-center py-32 text-center h-full">
              <p class="text-body-14 text--muted">{t_empty}</p>
            </div>
          )}
        </Section>
      </Container>
    </Section>
  </Section>
</BaseLayout>