---
// src/pages/[...locale]/blog/category/[slug].astro
export const prerender = true;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import PostCard from "@/components/blog/PostCard.astro";

import { getCollection } from "astro:content";
import { siteConfig } from "@/config/site";
import { slugify } from "@/lib/utils";

export async function getStaticPaths() {
  const categories = await getCollection("categories");

  return categories.map((category) => {
    const name =
      typeof category.data.name === "string"
        ? category.data.name
        : String(category.data.name);

    return {
      params: {
        slug: slugify(name),
      },
      props: { category },
    };
  });
}

const siteData = siteConfig;
const { category } = Astro.props;

const allPosts = await getCollection("blog", (post) => !post.data.draft);

const categoryName =
  typeof category.data.name === "string"
    ? category.data.name
    : String(category.data.name);

const categoryDesc = category.data.description ?? "";

const categorySlug = slugify(categoryName);

const categoryPosts = allPosts
  .filter((post) => post.data.category?.id === category.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const canonicalURL = new URL(
  `/blog/category/${categorySlug}/`,
  siteConfig.siteUrl
).toString();

const seoData = {
  title: categoryName,
  description:
    categoryDesc || `${siteData.blog} - ${categoryName}`,
  type: "website" as const,
  canonicalURL,
};

const t_home = siteData.home;
const t_blog = siteData.blog;
const t_empty = siteData.noPostsInCategory;
const t_articles = siteData.articles;

const blogCategory = {
  name: t_blog,
  slug: "blog",
  description: siteData.blog_PageDescription
};

const breadcrumbItems = [
  { name: t_home, href: "/" },
  { name: siteData.blog, href: "/blog/" },
  {
    name: categoryName,
    href: `/blog/category/${categorySlug}/`,
  },
];
---

<BaseLayout 
  {...seoData} 
  category={blogCategory}>
  <Section id="category-archive" size="lg" aria-label={categoryName}>
    <Container size="xl">
      <div class="relative grid grid-cols-1 lg:grid-cols-[320px_1fr] border border-(--border)">
        <aside class="border-b lg:border-b-0 border-(--border) lg:sticky lg:top-16 self-start p-4 lg:p-6 z-10 flex flex-col gap-5">
          <div class="flex items-center self-start">
            <Breadcrumb items={breadcrumbItems} />
          </div>   
          <div class="inline-flex items-center gap-1.5 self-start rounded-md bg-(--bg-muted) px-2 py-0.5 text-xs font-mono text-(--fg-subtle) border border-(--border)">
            <svg class="h-3 w-3 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <span>{siteData.filterCategory}</span>
          </div>
          <div class="space-y-2">
            <h1 class="text-heading-24 lg:text-heading-32 font-bold tracking-tight text-(--fg) wrap-break-word">
              {categoryName}
            </h1>
            <p class="text-xs font-mono tracking-wider text-(--fg-dim) uppercase">
              {categoryPosts.length} {t_articles}
            </p>
          </div>
          {categoryDesc && (
            <p class="text-sm leading-6 text-(--fg-muted) tracking-tight border-t border-dashed border-(--border) pt-4">
              {categoryDesc}
            </p>
          )}
        </aside>
        <div class="flex flex-col min-w-0 border-0 lg:border-l border-(--border)">
          {categoryPosts.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
              {categoryPosts.map((post) => (
                <div class="transition-colors hover:bg-(--bg-muted) 
                  border-t border-(--border) first:border-t-0
                  md:nth-2:border-t-0
                  md:even:border-l md:border-(--border)
                  lg:nth-2:border-t-0 lg:nth-3:border-t-0
                  lg:nth-[3n+1]:border-l-0
                  lg:border-l lg:border-(--border)
                ">
                  <PostCard post={post} />
                </div>
              ))}
            </div>
          ) : (
            <div class="flex flex-col items-center justify-center py-32 text-center h-full">
              <p class="text-sm font-mono text-(--fg-muted)">{t_empty}</p>
            </div>
          )}
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>