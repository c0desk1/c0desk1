---
// src/pages/blog/index.astro
import { getCollection } from "astro:content";
import { cn, sortByDate } from "@/lib/utils";
import { siteConfig } from "@/config/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Hero from "@/components/ui/Hero.astro";
import BlogList from "@/components/blog/BlogList.astro";
import FeaturedPostCard from "@/components/blog/FeaturedPostCard.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = sortByDate(allPosts);
const featuredPosts = posts.filter((p) => p.data.featured);
const regularPosts = posts.filter((p) => !p.data.featured);

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const seoData = {
  title: "Blog & Insights",
  description: "Catatan dari balik layar tentang sistem, kreativitas, dan eksplorasi dunia digital modern.",
  type: "website" as const,
  canonicalURL,
};

const Herotitle = "Blog";
const HeroHighlight = "& insights.";
const HeroDescription = "Catatan dari balik layar tentang sistem, kreativitas, dan hal-hal yang gue anggap menarik. Sebuah jurnal untuk setiap fragmen yang sedang gue pelajari.";
---

<BaseLayout {...seoData}>
  <Section id="blog-hero" size="none" aria-label="Blog introduction">
    <div class="relative items-center">
      <div
        class={cn(
          "absolute inset-0",
          "bg-size-[20px_20px]",
          "bg-[radial-gradient(#d4d4d4_1px,transparent_1px)]",
          "dark:bg-[radial-gradient(#404040_1px,transparent_1px)]",
        )}
      />
      <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-white mask-[radial-gradient(ellipse_at_center,transparent_20%,black)] dark:bg-black"></div>
      <Container size="full" class="relative items-center z-20"> 
        <Hero 
          title={Herotitle}
          highlight={HeroHighlight}
          description={HeroDescription}
        />
      </Container>
    </div>
  </Section>
  <Section id="featured-posts" size="lg" aria-label="Featured articles" class="section-divider">
    <h2 class="sr-only">Featured Posts</h2>
    <Container size="xl">
      {featuredPosts.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {featuredPosts.map((post) => (
            <div class="bg-(--bg)">
              <FeaturedPostCard post={post} />
            </div>
          ))}
        </div>
      )}
    </Container>
  </Section>
  <Section id="all-posts" size="lg" aria-label="All articles">
    <h2 class="sr-only">All Posts</h2>
    <Container size="xl">
      <div class="flex items-center mb-4 md:mb-6">
        <h2 class="text-xl md:text-4xl font-semibold text-(--fg)">
          Terbaru.
        </h2>
      </div>
        <BlogList posts={regularPosts} />
    </Container>
  </Section>
</BaseLayout>
