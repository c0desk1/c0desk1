---
// src/pages/blog/index.astro

import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import BlogHero from "@/components/blog/BlogHero.astro";
import BlogList from "@/components/blog/BlogList.astro";
import { sortByDate } from "@/lib/utils";

// ================= DATA =================
const allPosts = await getCollection("blog");

const publishedPosts = allPosts.filter(
  (p: CollectionEntry<"blog">) => !p.data.draft
);

const posts = sortByDate(publishedPosts);

const featuredPosts = posts
  .filter((p) => p.data.featured)
  .slice(0, 3);

const regularPosts = posts.filter((p) => !p.data.featured);

// ================= SEO =================
const seoData = {
  title: "Blog & Insights",
  description:
    "Catatan dari balik layar tentang sistem, kreativitas, dan eksplorasi dunia digital modern.",
  type: "website" as const,
  canonicalURL: "/blog/",
};
---

<BaseLayout {...seoData}>
  <section aria-label="Blog introduction">
    <BlogHero />
  </section>
  <section aria-label="All articles">
    <Container size="lg" class="mb-16">
      <BlogList
        allPosts={regularPosts}
        featuredPosts={[]}
      />
    </Container>
  </section>
</BaseLayout>