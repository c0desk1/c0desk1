---
// src/pages/blog/index.astro

import { getCollection } from "astro:content";
import { sortByDate } from "@/lib/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import BlogHero from "@/components/blog/BlogHero.astro";
import BlogList from "@/components/blog/BlogList.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const posts = sortByDate(allPosts);

const featuredPosts = posts.filter((p) => p.data.featured);
const regularPosts = posts.filter((p) => !p.data.featured);

const seoData = {
  title: "Blog & Insights",
  description:
    "Catatan dari balik layar tentang sistem, kreativitas, dan eksplorasi dunia digital modern.",
  type: "website" as const,
  canonicalURL: "https://c0desk1.my.id/blog/"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${seoData.canonicalURL}#collectionpage`,
      "url": seoData.canonicalURL,
      "name": seoData.title,
      "description": seoData.description,
      "isPartOf": {
        "@id": `${siteConfig.url}#website`
      },
      "breadcrumb": {
        "@id": `${seoData.canonicalURL}#breadcrumb`
      },
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": posts.length,
        "itemListElement": posts.slice(0, 10).map((post, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "url": `${siteConfig.url}blog/${post.id}/`,
          "name": post.data.title
        }))
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${seoData.canonicalURL}#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteConfig.url
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog"
        }
      ]
    }
  ]
};
---

<BaseLayout {...seoData}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <Section id="blog-hero" size="xl" aria-label="Blog introduction">
    <Container size="md">
      <BlogHero />
    </Container>
  </Section>
  {featuredPosts.length > 0 && (
    <Section id="featured-posts" size="lg" aria-label="Featured articles">
      <Container size="md">
        <h2 class="sr-only">
          Featured Posts
        </h2>
        <BlogList
          posts={featuredPosts}
          variant="featured"
        />
      </Container>
    </Section>
  )}
  <Section id="all-posts" size="lg" aria-label="All articles">
    <Container size="md">
      <h2 class="sr-only">
        All Posts
      </h2>
      <BlogList
        posts={regularPosts}
        variant="default"
      />
    </Container>
  </Section>
</BaseLayout>