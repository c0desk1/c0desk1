---
// src/pages/blog/[...slug].astro
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BackToTop from '@/components/ui/BackToTop.astro';

import BlogHeader from '@/components/blog/BlogHeader.astro';
import BlogFeaturedImage from '@/components/blog/BlogFeaturedImage.astro';
import BlogTOC from '@/components/blog/BlogTOC.astro';
import BlogRelatedPosts from '@/components/blog/BlogRelatedPosts.astro';
import BlogFeedback from '@/components/blog/BlogFeedback.astro';

import { 
  getReadingTime, 
  filterHeadingsForTOC, 
  getRelatedPosts,
  formatDate
} from '@/lib/utils';
import BlogContent from '@/components/blog/BlogContent.astro';

// Generate static paths
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { 
  title, 
  description, 
  pubDate, 
  tags, 
  updatedDate, 
  readingTime: customReadingTime,
  image,
  imageAlt,
  featured,
  author,
  seo
} = post.data;

// Render konten
const { Content, headings, remarkPluginFrontmatter } = await render(post);

// Ambil semua posts untuk related posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(post, allPosts, 3);

// Hitung reading time
const readingTime = getReadingTime(
  customReadingTime,
  remarkPluginFrontmatter?.minutesRead,
  post.body
);

// SEO
const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = (() => {
  if (seo?.ogImage && typeof seo.ogImage === 'string') return seo.ogImage;
  if (image && typeof image === 'string') return image;
  return siteConfig.ogImage;
})();

// Filter headings untuk TOC
const tocHeadings = filterHeadingsForTOC(headings);

// Handle image
const displayImage = typeof image === 'string' ? image : null;

// Format last updated
const lastUpdated = formatDate(updatedDate || pubDate);
---

<BaseLayout 
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  tags={tags}
  container={false}
>
  <article>
    
    {/* Hero Section */}
    <div class="border-b border-zinc-100 dark:border-zinc-900">
      <Container size="md" class="py-8 md:py-10">
        
        {/* Breadcrumb */}
        <Breadcrumb items={[
          { name: 'home', href: '/' },
          { name: 'blog', href: '/blog' },
          { name: title, href: '#' }
        ]} />
        
        <BlogHeader 
          title={title}
          pubDate={pubDate}
          updatedDate={updatedDate}
          readingTime={readingTime}
          tags={tags}
          author={author}
          featured={featured}
        />
        
      </Container>
    </div>

    {/* Featured Image */}
    {displayImage && (
      <BlogFeaturedImage image={displayImage} alt={imageAlt || title} />
    )}

    {/* Main Content */}
    <Container size="md" class="py-10 md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8 md:gap-12">
        
        {/* Content Column */}
        <div class="min-w-0">
          <BlogContent>
            <Content />
          </BlogContent>
          
          {/* Related Posts */}
          <BlogRelatedPosts posts={relatedPosts} />
          
          {/* Feedback */}
          <BlogFeedback slug={post.id} lastUpdated={lastUpdated} />
          
          {/* Back to Top */}
          <BackToTop showBorder={true} align="left" />
        </div>

        {/* Table of Contents */}
        <BlogTOC headings={tocHeadings} />
        
      </div>
    </Container>
    
  </article>
</BaseLayout>