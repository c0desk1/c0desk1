---
// src/pages/blog/[...slug].astro

import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BlogHeader from '@/components/blog/BlogHeader.astro';
import BlogFeaturedImage from '@/components/blog/BlogFeaturedImage.astro';
import BlogContent from '@/components/blog/BlogContent.astro';
import BlogTOC from '@/components/blog/BlogTOC.astro';
import BlogRelatedPosts from '@/components/blog/BlogRelatedPosts.astro';

import {
  filterHeadingsForTOC,
  getRelatedPosts,
  formatDateCompact,
  formatDate,
  getReadingTime
} from '@/lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const {
  title,
  description,
  pubDate,
  tags,
  updatedDate,
  image,
  imageAlt,
  imageCaption,
  featured,
  author,
  seo
} = post.data;

const { Content, headings } = await render(post);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(post, allPosts, 3);

const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = seo?.ogImage || image || siteConfig.ogImage;
const tocHeadings = filterHeadingsForTOC(headings);
const displayImage = image; 
const readingTime = getReadingTime(post.body, 'id');
const lastUpdated = formatDate(updatedDate || pubDate);
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  tags={tags}
  container={false}
>
  <article>
    <Container size="sm" class="py-6 md:py-8">
      <Breadcrumb items={[
        { name: 'Home', href: '/' },
        { name: 'Blog', href: '/blog/' },
      ]} />
      <BlogHeader
        title={title}
        pubDate={pubDate}
        updatedDate={updatedDate}
        readingTime={readingTime}
        authorName={author?.name} 
        authorAvatar={author?.avatar} 
        authorTitle={author?.title}
        featured={featured}
      />
    </Container>
    {displayImage && (
      <BlogFeaturedImage
        image={displayImage}
        alt={imageAlt || title}
        caption={imageCaption || imageAlt}
      />
    )}
    <Container size="sm" class="py-10 md:py-12">
      <div class="grid grid-cols-1 gap-8 md:gap-12">
        <BlogTOC headings={tocHeadings} />
        <div class="min-w-0">
          <BlogContent>
            <Content />
          </BlogContent>
          <BlogRelatedPosts posts={relatedPosts} />
          <div id="yandex_rtb_R-A-19135204-3" class="pt-6"></div>
          
        </div>
      </div>
    </Container>
  </article>
</BaseLayout>
<script is:inline>
  window.yaContextCb.push(() => {
    Ya.Context.AdvManager.render({
      blockId: "R-A-19135204-3",
      renderTo: "yandex_rtb_R-A-19135204-3"
    });
  });
</script>
