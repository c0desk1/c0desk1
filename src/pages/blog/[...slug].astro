---
// src/pages/blog/[...slug].astro

import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';

import BlogBreadcrumb from '@/components/blog/BlogBreadcrumb.astro';
import BlogHeader from '@/components/blog/BlogHeader.astro';
import BlogFeaturedImage from '@/components/blog/BlogFeaturedImage.astro';
import BlogTOC from '@/components/blog/BlogTOC.astro';
import BlogRelatedPosts from '@/components/blog/BlogRelatedPosts.astro';
import BlogFeedback from '@/components/blog/BlogFeedback.astro';

import { 
  getReadingTime, 
  filterHeadingsForTOC, 
  getRelatedPosts 
} from '@/lib/utils';

// Generate static paths
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { 
  title, 
  description, 
  pubDate, 
  tags, 
  updatedDate, 
  readingTime: customReadingTime,
  image,
  imageAlt,
  featured,
  pinned,
  author,
  seo
} = post.data;

// Render konten
const { Content, headings, remarkPluginFrontmatter } = await render(post);

// Ambil semua posts untuk related posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(post, allPosts, 3);

// Hitung reading time
const readingTime = getReadingTime(
  customReadingTime,
  remarkPluginFrontmatter?.minutesRead,
  post.body
);

// SEO
const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = (() => {
  if (seo?.ogImage && typeof seo.ogImage === 'string') return seo.ogImage;
  if (image && typeof image === 'string') return image;
  return siteConfig.ogImage;
})();

// Filter headings untuk TOC
const tocHeadings = filterHeadingsForTOC(headings);

// Handle image
const displayImage = typeof image === 'string' ? image : null;

// Last updated
const lastUpdated = updatedDate 
  ? updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout 
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  tags={tags}
  container={false}
>
  <article>
    
    {/* Hero Section */}
    <div class="border-b border-zinc-100 dark:border-zinc-900 bg-white dark:bg-zinc-950">
      <Container size="md" class="py-8 md:py-12 lg:py-16">
        <BlogBreadcrumb slug={post.id} />
        <BlogHeader 
          title={title}
          pubDate={pubDate}
          updatedDate={updatedDate}
          readingTime={readingTime}
          tags={tags}
          author={author}
          featured={featured}
          pinned={pinned}
        />
      </Container>
    </div>

    {/* Featured Image */}
    {displayImage && (
      <BlogFeaturedImage image={displayImage} alt={imageAlt} />
    )}

    {/* Main Content + TOC Layout */}
    <Container size="md" class="py-12 md:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8 md:gap-12 items-start">
        
        {/* Content Column */}
        <div class="min-w-0">
          <div class="prose prose-zinc dark:prose-invert max-w-none
            prose-headings:font-bold prose-headings:tracking-tight
            prose-h1:text-3xl md:prose-h1:text-4xl prose-h1:mt-8 prose-h1:mb-4
            prose-h2:text-2xl md:prose-h2:text-3xl prose-h2:mt-6 prose-h2:mb-3 prose-h2:pb-2 prose-h2:border-b prose-h2:border-zinc-100 dark:prose-h2:border-zinc-800
            prose-h3:text-xl md:prose-h3:text-2xl prose-h3:mt-5 prose-h3:mb-2
            prose-h4:text-lg md:prose-h4:text-xl prose-h4:mt-4 prose-h4:mb-2
            prose-p:text-zinc-700 dark:prose-p:text-zinc-300 prose-p:leading-relaxed prose-p:mb-4
            prose-a:text-zinc-900 dark:prose-a:text-white prose-a:no-underline prose-a:border-b prose-a:border-zinc-400 dark:prose-a:border-zinc-600 hover:prose-a:border-zinc-900 dark:hover:prose-a:border-white
            prose-code:text-sm prose-code:bg-zinc-100 dark:prose-code:bg-zinc-900 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-mono
            prose-pre:bg-zinc-950 dark:prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-800 prose-pre:rounded-lg
            prose-img:rounded-lg prose-img:border prose-img:border-zinc-200 dark:prose-img:border-zinc-800
            prose-blockquote:border-l-2 prose-blockquote:border-zinc-400 dark:prose-blockquote:border-zinc-600 prose-blockquote:pl-4 prose-blockquote:italic
            prose-ul:list-disc prose-ol:list-decimal prose-li:marker:text-zinc-400
            prose-hr:border-zinc-200 dark:prose-hr:border-zinc-800
          ">
            <Content />
          </div>
          
          <BlogRelatedPosts posts={relatedPosts} />
          <BlogFeedback slug={post.id} lastUpdated={lastUpdated} />
        </div>

        {/* Table of Contents */}
        <BlogTOC headings={tocHeadings} />
        
      </div>
    </Container>
    
  </article>
</BaseLayout>