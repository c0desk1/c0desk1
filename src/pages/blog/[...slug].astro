---
// src/pages/blog/[...slug].astro

import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BackToTop from '@/components/ui/BackToTop.astro';

import BlogHeader from '@/components/blog/BlogHeader.astro';
import BlogFeaturedImage from '@/components/blog/BlogFeaturedImage.astro';
import BlogContent from '@/components/blog/BlogContent.astro';
import BlogTOC from '@/components/blog/BlogTOC.astro';
import BlogRelatedPosts from '@/components/blog/BlogRelatedPosts.astro';
import BlogFeedback from '@/components/blog/BlogFeedback.astro';

import {
  filterHeadingsForTOC,
  getRelatedPosts,
  formatDateCompact,
  getReadingTime
} from '@/lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const {
  title,
  description,
  pubDate,
  tags,
  updatedDate,
  image,
  imageAlt,
  imageCaption,
  featured,
  author,
  seo
} = post.data;

const { Content, headings } = await render(post);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(post, allPosts, 3);

const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = seo?.ogImage || image || siteConfig.ogImage;
const tocHeadings = filterHeadingsForTOC(headings);
const displayImage = image; 
const readingTime = getReadingTime(post.body, 'id');
const lastUpdated = formatDateCompact(updatedDate || pubDate);
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  tags={tags}
  container={false}
>
  <article>
    <div class="border-b border-zinc-100 dark:border-zinc-900">
      <Container size="md" class="py-8 md:py-10">
        <Breadcrumb items={[
          { name: 'Home', href: '/' },
          { name: 'Blog', href: '/blog' },
        ]} />
        <BlogHeader
          title={title}
          pubDate={pubDate}
          updatedDate={updatedDate}
          readingTime={readingTime}
          tags={tags}
          authorName={author?.name} 
          authorAvatar={author?.avatar} 
          authorTitle={author?.title}
          featured={featured}
        />
      </Container>
    </div>
    
    {displayImage && (
      <BlogFeaturedImage
        image={displayImage}
        alt={imageAlt || title}
        caption={imageCaption || imageAlt}
      />
    )}

    <Container size="md" class="py-10 md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8 md:gap-12">
        <div class="min-w-0">
          <BlogContent>
            <Content />
          </BlogContent>
          <BlogRelatedPosts posts={relatedPosts} />
          <BlogFeedback
            slug={post.id}
            lastUpdated={lastUpdated}
          />
          <BackToTop showBorder={true} align="right" />
        </div>
        <aside>
          <div class="lg:sticky lg:top-24 h-fit">
            <BlogTOC headings={tocHeadings} />
          </div>
        </aside>
      </div>
    </Container>
  </article>
</BaseLayout>
