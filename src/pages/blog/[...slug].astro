---
// src/pages/blog/[...slug].astro

import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';
import { categoryLabels } from '@/config/blog';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BlogHeader from '@/components/blog/BlogHeader.astro';
import BlogFeaturedImage from '@/components/blog/BlogFeaturedImage.astro';
import BlogContent from '@/components/blog/BlogContent.astro';
import BlogTOC from '@/components/blog/BlogTOC.astro';
import BlogRelatedPosts from '@/components/blog/BlogRelatedPosts.astro';
import BackToTop from "@/components/ui/BackToTop.astro";

import Image from "@/components/mdx/Image.astro";
import HR from "@/components/mdx/HR.astro";

import {
  filterHeadingsForTOC,
  getRelatedPosts,
  formatDate,
  getReadingTime
} from '@/lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const {
  title,
  description,
  pubDate,
  tags,
  updatedDate,
  category,
  image,
  imageAlt,
  imageCaption,
  featured,
  author,
  seo
} = post.data;

const { Content, headings } = await render(post);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(post, allPosts, 3);

const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = seo?.ogImage || image || siteConfig.ogImage;

const tocHeadings = filterHeadingsForTOC(headings);

const readingTime = getReadingTime(post.body);
const lastUpdated = formatDate(updatedDate || pubDate);
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  tags={tags}
  container={false}
>
<article>
  <Container size="md" class="pt-8 md:pt-16 pb-8">
    <Breadcrumb
      items={[
        { name: 'Blog', href: '/blog/' },
        { name: categoryLabels[category], href: `/category/${category}/` },
      ]}
    />
    <BlogHeader
      title={title}
      pubDate={pubDate}
      updatedDate={updatedDate}
      readingTime={readingTime}
      authorName={author?.name}
      authorAvatar={author?.avatar}
      authorTitle={author?.title}
      featured={featured}
    />
    {image && (
      <BlogFeaturedImage
        image={image}
        alt={imageAlt || title}
        caption={imageCaption || imageAlt}
      />
    )}
    <Container size="sm" class="pt-4 md:pt-8 pb-12">
      {tocHeadings.length > 0 && (
        <div class="mb-8 md:mb-10 px-4 md:px-8">
          <BlogTOC headings={tocHeadings} />
        </div>
      )}
      <div class="px-4 md:px-8">
        <BlogContent>
          <Content
            components={{
              img: Image,
              hr: HR
            }}
          />
        </BlogContent>
      </div>
    </Container>
    <BackToTop align="center" />
    <section class="section-divider mt-4 md:mt-8 px-4 md:px-8">
      <BlogRelatedPosts posts={relatedPosts} />
    </section>
  </Container>
</article>
</BaseLayout>