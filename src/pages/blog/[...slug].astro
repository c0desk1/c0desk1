---
// src/pages/blog/[...slug].astro

import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';
import { categoryLabels } from '@/config/blog';

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BlogHeader from '@/components/blog/BlogHeader.astro';
import BlogFeaturedImage from '@/components/blog/BlogFeaturedImage.astro';
import BlogContent from '@/components/blog/BlogContent.astro';
import BlogTOC from '@/components/blog/BlogTOC.astro';
import BlogRelatedPosts from '@/components/blog/BlogRelatedPosts.astro';
import BackToTop from "@/components/ui/BackToTop.astro";

import Image from "@/components/mdx/Image.astro";
import HR from "@/components/mdx/HR.astro";

import {
  filterHeadingsForTOC,
  getRelatedPosts,
  formatDate,
  getReadingTime
} from '@/lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const {
  title,
  description,
  pubDate,
  tags,
  updatedDate,
  category,
  image,
  imageAlt,
  imageCaption,
  featured,
  author,
  seo
} = post.data;

const { Content, headings } = await render(post);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(post, allPosts, 3);

const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = seo?.ogImage || image || siteConfig.ogImage;

const tocHeadings = filterHeadingsForTOC(headings);

const readingTime = getReadingTime(post.body);
const lastUpdated = formatDate(updatedDate || pubDate);
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  tags={tags}
  container={false}
>
<article>
  <Container size="sm" class="pt-6 md:pt-8 pb-2">
    <Breadcrumb
      items={[
        { name: 'Home', href: '/' },
        { name: 'Blog', href: '/blog/' },
        { name: categoryLabels[category], href: `/category/${category}/` },
      ]}
    />
    <BlogHeader
      title={title}
      pubDate={pubDate}
      updatedDate={updatedDate}
      readingTime={readingTime}
      authorName={author?.name}
      authorAvatar={author?.avatar}
      authorTitle={author?.title}
      featured={featured}
    />

  </Container>
  <Container size="sm">
    <!-- FEATURED IMAGE -->
    {image && (
      <BlogFeaturedImage
        image={image}
        alt={imageAlt || title}
        caption={imageCaption || imageAlt}
      />
    )}
  </Container>

  <!-- MAIN CONTENT -->
  <Container size="sm" class="pt-6 md:pt-8 pb-12">

    <!-- TOC -->
    {tocHeadings.length > 0 && (
      <div class="mb-8 md:mb-10">
        <BlogTOC headings={tocHeadings} />
      </div>
    )}

    <!-- ARTICLE BODY -->
    <div class="min-w-0">
      <BlogContent>
        <Content
          components={{
            img: Image,
            hr: HR
          }}
        />
      </BlogContent>

      <!-- RELATED POSTS -->
      <section class="section-divider mt-12 md:mt-16">
        <BlogRelatedPosts posts={relatedPosts} />
      </section>
    </div>
    <!-- Back to top -->
    <BackToTop align="center" />
  </Container>
</article>
</BaseLayout>