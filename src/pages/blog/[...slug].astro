---
// src/pages/blog/[...slug].astro

import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

import { siteConfig } from "@/config/site";
import { categoryLabels } from "@/config/blog";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";

import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import BlogHeader from "@/components/blog/BlogHeader.astro";
import BlogFeaturedImage from "@/components/blog/BlogFeaturedImage.astro";
import BlogContent from "@/components/blog/BlogContent.astro";
import BlogTOC from "@/components/blog/BlogTOC.astro";
import BlogRelatedPosts from "@/components/blog/BlogRelatedPosts.astro";
import BackToTop from "@/components/ui/BackToTop.astro";

import Image from "@/components/mdx/Image.astro";
import HR from "@/components/mdx/HR.astro";

import {
  filterHeadingsForTOC,
  getReadingTime
} from "@/lib/utils";

import {
  getSmartRelatedPosts
} from "@/lib/botEngine";
import ReadingProgress from "@/components/ui/ReadingProgress.astro";

export async function getStaticPaths() {

  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.id },
    props: { post }
  }));

}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const { Content, headings } = await render(post);

const relatedPosts = getSmartRelatedPosts(post, allPosts, 3);

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  category,
  image,
  imageAlt,
  imageCaption,
  featured,
  author,
  seo
} = post.data;

const seoTitle = seo?.title || title;
const seoDescription = seo?.description || description;
const seoImage = seo?.ogImage || image || siteConfig.ogImage;

const schemaAuthorName = author?.name || siteConfig.author.name || "c0desk1";

const tocHeadings = filterHeadingsForTOC(headings);

const readingTime = getReadingTime(post.body);

const breadcrumbItems = [
  { name: "Blog", href: "/blog/" },
  {
    name: categoryLabels[category],
    href: `/category/${category.toLowerCase()}/`
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${Astro.url.href}#breadcrumb`,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteConfig.url
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": `${siteConfig.url}blog/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": categoryLabels[category],
      "item": `${siteConfig.url}category/${category.toLowerCase()}/`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": title
    }
  ]
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  tags={tags}
  container={false}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <article class="relative my-4 md:my-8">
    <h1 class="sr-only">{title}</h1>
    <Section size="sm">
      <Container size="sm">
        <h2 class="sr-only">Article Header</h2>
        <Breadcrumb items={breadcrumbItems} />
        <BlogHeader
          title={title}
          pubDate={pubDate}
          readingTime={readingTime}
          authorName={author?.name}
          authorAvatar={author?.avatar}
          authorTitle={author?.title}
          featured={featured}
        />
        {image && (
          <BlogFeaturedImage
            image={image}
            alt={imageAlt || title}
            caption={imageCaption || imageAlt}
          />
        )}
        {tocHeadings.length > 0 && (
          <BlogTOC headings={tocHeadings} />
        )}
      </Container>
    </Section>
    <Section size="sm" class="section-divider">
      <Container size="sm">
        <h2 class="sr-only">Article Content</h2>
        <BlogContent>
          <Content
            components={{
              img: Image,
              hr: HR
            }}
          />
        </BlogContent>
      </Container>
    </Section>
    <Section size="md" class="section-divider">
      <Container size="sm">
        <h2 class="sr-only">Related Posts</h2>
        <BackToTop align="center" />
        <BlogRelatedPosts posts={relatedPosts} />
      </Container>
    </Section>
  </article>
  <ReadingProgress />
</BaseLayout>
