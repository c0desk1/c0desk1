---
// src/pages/blog/[...page].astro
import type { Page } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { 
  SITE, 
  ROUTES,
  PAGINATION,
  buildMeta, 
  schemaCollectionPage, 
  schemaBreadcrumb 
} from "@/consts";
import { 
  getPageNums, 
  getPageUrl, 
  sortByDate 
} from "@/lib/utils";

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PostCard from "@/components/blog/PostCard.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon";
import Hero from "@/components/ui/Hero.astro";

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const sortedPosts = sortByDate(allPosts);
  return paginate(sortedPosts, { pageSize: PAGINATION.postsPerPage });
}

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;

const pageTitle = page.currentPage > 1 ? `Blog - Halaman ${page.currentPage}` : "Blog";
const pageDesc = `Kumpulan artikel terbaru tentang sistem, kreativitas, dan dunia digital di ${SITE.name}.`;
const canonicalURL = new URL(page.url.current, SITE.url).href;

const meta = buildMeta({ 
  title: pageTitle,
  description: pageDesc,
  canonical: canonicalURL,
  ...(page.url.prev && { canonical: new URL(page.url.prev, SITE.url).href }), 
});

const schemas = [
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: "Blog", url: new URL(ROUTES.blog, SITE.url).href },
  ]),
  schemaCollectionPage({
    title: pageTitle,
    description: pageDesc,
    url: canonicalURL,
  }),
];

let featuredPosts: CollectionEntry<"blog">[] = [];
if (page.currentPage === 1) {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft && data.featured === true);
  featuredPosts = sortByDate(allPosts);
}

const pageNums = getPageNums(page.currentPage, page.lastPage);
---

<Layout {meta} schema={schemas}>
  <Section size="none">
    <Hero
      title="BL"
      subTitle="OG"
      description="Jelajahi postingan dan pembaruan Blog kami. Catatan di balik layar tentang sistem, kreativitas, dan menjelajahi dunia digital modern."
      cta={{ label: "Unggulan", href: "#featured" }}
      cta2={{ label: "Terbaru", href: "#latest" }}
    />
  </Section>
  {page.currentPage === 1 && featuredPosts.length > 0 && (
    <Section size="md" aria-label="Postingan unggulan">
      <Container size="xl">
        <h2 id="featured" class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold py-4 lg:py-6">
          Unggulan
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {featuredPosts.map((post) => <PostCard post={post} />)}
        </div>
      </Container>
    </Section>
  )}

  <Section size="lg" aria-label="Postingan terbaru">
    <Container size="xl">
      <h2 id="latest" class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold py-4 lg:py-6">
        Terbaru
      </h2>

      {page.data.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {page.data.map((post) => <PostCard post={post} />)}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-muted text-body-16">Belum ada postingan.</p>
        </div>
      )}

      {page.lastPage > 1 && (
        <div class="flex items-center justify-between gap-2 py-8 mt-4">
          <Button href={page.url.prev} disabled={!page.url.prev} variant="secondary" size="sm" class="gap-1.5" aria-label="Sebelumnya">
            <Icon name="arrow-left" className="w-4 h-4" />
            <span class="hidden sm:inline text-button-14">Sebelumnya</span>
          </Button>

          <ol class="hidden sm:flex items-center gap-0.5">
            {pageNums.map((n) => (
              <li>
                <a
                  href={n === 1 ? ROUTES.blog : getPageUrl(n as number)}
                  aria-current={n === page.currentPage ? "page" : undefined}
                  class:list={[
                    "flex items-center justify-center w-6 h-6 rounded-md text-label-14 transition-colors",
                    n === page.currentPage
                      ? "bg-(--fg) text-(--bg) pointer-events-none font-medium"
                      : "text-subtle hover:bg-muted hover:text-(--fg)",
                  ]}
                >
                  {n}
                </a>
              </li>
            ))}
          </ol>

          <Button href={page.url.next} disabled={!page.url.next} variant="secondary" size="sm" class="gap-1.5" aria-label="Berikutnya">
            <span class="hidden sm:inline text-button-14">Berikutnya</span>
            <Icon name="arrow-right" className="w-4 h-4" />
          </Button>
        </div>
      )}
    </Container>
  </Section>
</Layout>