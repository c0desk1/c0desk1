---
// src/pages/blog/[...page].astro
import type { Page } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { SITE, ROUTES, buildMeta, schemaCollectionPage, schemaBreadcrumb } from "@/consts";
import { getPageNums, getPageUrl, sortByDate } from "@/lib/utils";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PostCard from "@/components/blog/PostCard.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon";
import Hero from "@/components/ui/Hero.astro";

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const sortedPosts = sortByDate(allPosts);
  return paginate(sortedPosts, { pageSize: 6 });
}

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;

const title = "Blog";
const description = `Semua artikel di ${SITE.name}.`;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const meta = buildMeta({ title, description, canonical });

const breadcrumbSchema = schemaBreadcrumb([
  { name: "Home", url: SITE.url },
  { name: "Blog", url: `${SITE.url}/blog` },
]);

const collectionSchema = schemaCollectionPage({
  title: "Blog",
  description: description,
  url: canonical,
});

const schema = [breadcrumbSchema, collectionSchema];

const heroCTA = { label: "Featured", href: "#featured" };
const heroCTA2 = { label: "Latest", href: "#latest" };

let featuredPosts: CollectionEntry<"blog">[] = [];
if (page.currentPage === 1) {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft && data.featured === true);
  featuredPosts = sortByDate(allPosts);
}

const pageNums = getPageNums(page.currentPage, page.lastPage);
const prevUrl = page.currentPage <= 1 ? undefined : getPageUrl(page.currentPage - 1);
const nextUrl = page.currentPage >= page.lastPage ? undefined : getPageUrl(page.currentPage + 1);
---

<Layout {meta} {schema}>
  <Section size="none">
    <Hero
      title="BL"
      subTitle="OG"
      description={description}
      cta={heroCTA}
      cta2={heroCTA2}
    />
  </Section>
  {page.currentPage === 1 && featuredPosts.length > 0 && (
    <Section size="md" aria-label="Postingan unggulan">
      <Container size="xl">
        <h2 id="featured" class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold py-4 lg:py-6">
          Unggulan
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {featuredPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </Container>
    </Section>
  )}
  <Section size="lg" aria-label="Postingan terbaru">
    <Container size="xl">
      <h2 id="latest" class="text-heading-24 lg:text-heading-32 text-(--fg) font-semibold py-4 lg:py-6">
        Terbaru.
      </h2>

      {page.data.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {page.data.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-(--fg-muted) text-body-16">Belum ada postingan.</p>
        </div>
      )}

      {page.lastPage > 1 && (
        <div class="flex items-center justify-between gap-2 py-8 mt-4">
          <Button href={prevUrl} disabled={!prevUrl} variant="secondary" size="sm" class="gap-1.5" aria-label="Previous">
            <Icon name="arrow-left" className="w-4 h-4" />
            <span class="hidden sm:inline text-button-14">Sebelumnya</span>
          </Button>

          <ol class="hidden sm:flex items-center gap-0.5">
            {pageNums.map((n) =>
              n === "…" ? (
                <li>
                  <span class="flex items-center justify-center w-6 h-6 text-subtle select-none">…</span>
                </li>
              ) : (
                <li>
                  <a
                    href={n === 1 ? ROUTES.blog : getPageUrl(n as number)}
                    aria-current={n === page.currentPage ? "page" : undefined}
                    class:list={[
                      "flex items-center justify-center w-6 h-6 rounded-md text-label-14 transition-colors",
                      n === page.currentPage
                        ? "bg-(--fg) text-(--bg) pointer-events-none font-medium"
                        : "text-subtle hover:bg-muted hover:text-(--fg)",
                    ]}
                  >
                    {n}
                  </a>
                </li>
              )
            )}
          </ol>
          <span class="sm:hidden text-body-14 text-subtle tabular-nums select-none">
            {page.currentPage}<span class="mx-1 text-(--border)">/</span>{page.lastPage}
          </span>
          <Button href={nextUrl} disabled={!nextUrl} variant="secondary" size="sm" class="gap-1.5" aria-label="Next">
            <span class="hidden sm:inline text-button-14">Berikutnya</span>
            <Icon name="arrow-right" className="w-4 h-4" />
          </Button>
        </div>
      )}
    </Container>
  </Section>
</Layout>