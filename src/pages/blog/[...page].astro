---
export const prerender = true;

import type { GetStaticPathsOptions, Page } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { getPageNums, getPageUrl } from "@/lib/utils";
import { siteConfig } from "@/config/site";

import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PostCard from "@/components/blog/PostCard.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  const sortedPosts = posts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );

  return paginate(sortedPosts, {
    pageSize: 6,
  });
}

interface Props {
  page: Page<CollectionEntry<'blog'>>;
}

const { page } = Astro.props as Props;

const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();

const siteData = siteConfig

const seoData = {
  title: `${siteData.blog_PageTitle} | ${siteData.b_p_n} ${page.currentPage}`,
  description: siteData.blog_PageDescription,
  type: "website" as const,
  canonicalURL,
};

const localePrefix = Astro.params.locale ? `/${Astro.params.locale}` : '';
const pageNums = getPageNums(page.currentPage, page.lastPage);

const prevUrl = page.currentPage <= 1 ? undefined
  : getPageUrl(page.currentPage - 1);

const nextUrl = page.currentPage >= page.lastPage ? undefined
  : getPageUrl(page.currentPage + 1);

const title    = siteData.blog_HeroTitle;
const prevLabel = siteData.b_prevPosts;
const nextLabel = siteData.b_nextPosts;
const blog_c   = siteData.blog_browsePosts;
---

<BaseLayout {...seoData}>
  <Section id="browse-posts" size="lg" aria-label={blog_c}>
    <Container size="xl">
      <div class="relative grid grid-cols-1 lg:grid-cols-[300px_1fr] border border-(--border)">
        <aside class="border-b lg:border-b-0 border-(--border) lg:sticky lg:top-16 self-start">
          <h1 class="text-heading-24 md:text-heading-32 lg:text-heading-40 font-semibold text-(--fg) text-center md:text-start wrap-break-word p-4 lg:p-6">
            {title}
          </h1>
        </aside>
        <div class="flex flex-col min-w-0 border-0 lg:border-l border-(--border)">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-b border-(--border)">
            {page.data.map((post) => (
              <div class="transition-colors hover:bg-(--bg-muted) 
                  border-t border-(--border) first:border-t-0
                  md:nth-2:border-t-0
                  md:even:border-l md:border-(--border)
                  lg:nth-2:border-t-0 lg:nth-3:border-t-0
                  lg:nth-[3n+1]:border-l-0
                  lg:border-l lg:border-(--border)
                  ">
                <PostCard post={post} />
              </div>
            ))}
          </div>
          {page.lastPage > 1 && (
            <div class="flex items-center justify-between gap-2 p-8">
              <Button href={prevUrl} disabled={!prevUrl} variant="secondary" size="sm" class="gap-1.5" aria-label={prevLabel}>
                <Icon name="arrow-left" className="w-4 h-4" />
                <span class="hidden sm:inline text-button-14">{prevLabel}</span>
              </Button>
              <ol class="hidden sm:flex items-center gap-0.5">
                {pageNums.map((n) =>
                  n === '…' ? (
                    <li>
                      <span class="flex items-center justify-center w-6 h-6 text-label-4 text-(--fg-subtle) select-none">
                        …
                      </span>
                    </li>
                  ) : (
                    <li>
                      <a href={n === 1 ? `${localePrefix}/blog/` : getPageUrl(n as number)}
                        aria-current={n === page.currentPage ? siteData.b_p_n as any : undefined}
                        class:list={[
                          'flex items-center justify-center w-6 h-6 rounded-md text-label-14 transition-colors gap-1',
                          n === page.currentPage
                            ? 'bg-(--fg) text-(--bg) pointer-events-none font-medium'
                            : 'text-(--fg-subtle) hover:bg-(--bg-muted) hover:text-(--fg)',
                        ]}>
                        {n}
                      </a>
                    </li>
                  )
                )}
              </ol>
              <span class="sm:hidden text-copy-14 text-(--fg-subtle) tabular-nums select-none">
                {page.currentPage}
                <span class="mx-1 text-(--border)">/</span>
                {page.lastPage}
              </span>
              <Button href={nextUrl} disabled={!nextUrl} variant="secondary" size="sm" class="gap-1.5" aria-label={nextLabel}>
                <span class="hidden sm:inline text-button-14">{nextLabel}</span>
                <Icon name="arrow-right" className="w-4 h-4" />
              </Button>
            </div>
          )}
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
