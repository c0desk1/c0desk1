---
// src/pages/search.astro
import { getCollection } from "astro:content";
import {
  SITE,
  ROUTES,
  CATEGORIES,
  buildMeta,
  schemaWebPage,
} from "@/consts";
import { slugify } from "@/lib/utils";

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PostCard from "@/components/blog/PostCard.astro";
import Icon from "@/components/ui/Icon";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const catMap = Object.fromEntries(CATEGORIES.map((c) => [c.slug, c.label]));

const canonicalURL = new URL(ROUTES.search, SITE.url).href;

const meta = buildMeta({
  title:       `Pencarian - ${SITE.name}`,
  description: "Cari artikel, panduan, dan pembaruan terbaru di Unloyd.",
  canonical:   canonicalURL,
  noindex:     true,
});

const schemas = [
  schemaWebPage({
    title:       `Pencarian - ${SITE.name}`,
    description: "Cari artikel, panduan, dan pembaruan terbaru di Unloyd.",
    url:         canonicalURL,
  }),
];

const totalPosts = sortedPosts.length;
---

<Layout {meta} schema={schemas} bodyClass="bg-base">
  <Section size="lg">
    <Container size="xl">

      <header class="mb-12 max-w-2xl mx-auto w-full">
        <div class="text-center mb-8">
          <h1 class="text-heading-32 md:text-heading-48 font-extrabold tracking-tighter text-strong mb-3">
            Pencarian
          </h1>
          <p class="text-body-16 text-muted">
            Gunakan kata kunci untuk menemukan artikel, panduan, atau referensi spesifik.
          </p>
        </div>
        <div class="relative w-full group shadow-sm">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-muted group-focus-within:text-strong transition-colors">
            <Icon name="search" className="w-4 h-4" />
          </div>
          <input
            type="text"
            id="search-input"
            placeholder="Ketik judul, kategori, atau topik..."
            class="w-full bg-subtle border border-(--border) text-strong placeholder:text-muted rounded-lg py-2.5 pl-11 pr-12 text-body-14 sm:text-body-16 focus:outline-none focus:ring-2 focus:ring-(--border-strong) focus:bg-base transition-all duration-300"
            autocomplete="off"
            spellcheck="false"
          />
          <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
            <kbd class="hidden sm:inline-flex items-center justify-center bg-muted border border-(--border) rounded px-1.5 py-0.5 text-label-11 text-muted font-mono font-medium">
              /
            </kbd>
          </div>
        </div>
        <p id="search-count" class="mt-3 text-label-13 text-subtle text-center h-5"></p>
      </header>
      <div
        id="search-grid"
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8"
      >
        {sortedPosts.map((post) => {
          const catSlug = post.data.category ?? CATEGORIES[0].slug;
          const catLabel = catMap[catSlug] ?? catSlug;
          const dataSearch = [
            post.data.title,
            post.data.description ?? "",
            catLabel,
            catSlug,
          ].join(" ").toLowerCase();

          const slug = post.data.slug || slugify(post.data.title);

          return (
            <div
              class="search-item"
              data-search={dataSearch}
              data-title={post.data.title.toLowerCase()}
              data-desc={(post.data.description ?? "").toLowerCase()}
              data-cat={catLabel.toLowerCase()}
              data-cat-slug={catSlug}
            >
              <PostCard post={post} />
            </div>
          );
        })}
      </div>

      <div
        id="empty-state"
        class="hidden flex-col items-center justify-center py-32 px-4 text-center border border-dashed border-strong rounded-lg bg-subtle mt-8"
      >
        <svg class="w-10 h-10 text-dim mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <p class="text-body-16 text-muted font-medium mb-1">
          Postingan tidak ditemukan.
        </p>
        <p class="text-label-14 text-subtle">
          Coba kata kunci lain atau lihat
          <a href={ROUTES.blog} class="text-strong hover:underline">semua artikel</a>.
        </p>
      </div>

    </Container>
  </Section>
</Layout>

<script define:vars={{ totalPosts }}>
  function initSearch() {
    const input     = document.getElementById("search-input");
    const grid      = document.getElementById("search-grid");
    const empty     = document.getElementById("empty-state");
    const countEl   = document.getElementById("search-count");
    const items     = document.querySelectorAll(".search-item");

    if (!input || !grid || !empty) return;

    const score = (el, q) => {
      const title    = el.dataset.title    ?? "";
      const desc     = el.dataset.desc     ?? "";
      const cat      = el.dataset.cat      ?? "";
      const catSlug  = el.dataset.catSlug  ?? "";
      if (title === q)          return 100;
      if (title.startsWith(q)) return 80;
      if (title.includes(q))   return 60;
      if (desc.includes(q))    return 40;
      if (cat.includes(q) || catSlug.includes(q)) return 30;
      // fuzzy
      let qi = 0;
      for (let i = 0; i < title.length && qi < q.length; i++)
        if (title[i] === q[qi]) qi++;
      return qi === q.length ? 10 : 0;
    };

    const updateCount = (visible, query) => {
      if (!countEl) return;
      if (!query) {
        countEl.textContent = `${totalPosts} artikel tersedia`;
      } else if (visible === 0) {
        countEl.textContent = "";
      } else {
        countEl.textContent = `${visible} dari ${totalPosts} artikel`;
      }
    };

    const filterPosts = (query) => {
      const q = query.toLowerCase().trim();
      let visible = 0;

      if (!q) {
        items.forEach((el) => { el.style.display = "block"; });
        visible = items.length;
        grid.style.display  = "grid";
        empty.classList.add("hidden");
        empty.classList.remove("flex");
        updateCount(visible, "");
        return;
      }

      const scored = Array.from(items).map((el) => ({
        el,
        s: score(el, q),
      }));

      scored.forEach(({ el, s }) => {
        if (s > 0) {
          el.style.display = "block";
          visible++;
        } else {
          el.style.display = "none";
        }
      });

      if (visible > 0) {
        grid.style.display = "grid";
        empty.classList.add("hidden");
        empty.classList.remove("flex");
      } else {
        grid.style.display = "none";
        empty.classList.remove("hidden");
        empty.classList.add("flex");
      }

      updateCount(visible, q);
    };

    const urlParams = new URLSearchParams(window.location.search);
    const initialQuery = urlParams.get("q") ?? "";
    if (initialQuery) {
      input.value = initialQuery;
      filterPosts(initialQuery);
      setTimeout(() => {
        input.focus();
        input.setSelectionRange(input.value.length, input.value.length);
      }, 50);
    } else {
      updateCount(items.length, "");
    }

    input.addEventListener("input", (e) => {
      const q = e.target.value;
      const url = new URL(window.location.href);
      q.trim() ? url.searchParams.set("q", q) : url.searchParams.delete("q");
      window.history.replaceState({}, "", url.toString());
      filterPosts(q);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "/" && document.activeElement !== input) {
        e.preventDefault();
        input.focus();
      }
    });
  }

  document.addEventListener("astro:page-load", initSearch);
  document.addEventListener("DOMContentLoaded", initSearch);
</script>
