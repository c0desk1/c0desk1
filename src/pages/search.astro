---
// src/pages/search.astro
import { getCollection } from "astro:content";
import {
  SITE,
  ROUTES,
  CATEGORIES,
  SERIES,
  buildMeta,
  schemaWebPage,
} from "@/consts";

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import PostCard from "@/components/blog/PostCard.astro";
import GuideCard from "@/components/guide/GuideCard.astro";
import Icon from '@/components/ui/icons/Icon.astro';

const allBlogs = await getCollection("blog", ({ data }) => !data.draft);
const allGuides = await getCollection("guide", ({ data }) => !data.draft);

const allContent = [...allBlogs, ...allGuides].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const catMap = Object.fromEntries(CATEGORIES.map((c) => [c.slug, c.label]));
const seriesMap = Object.fromEntries(SERIES.map((s) => [s.slug, s.label]));

const canonicalURL = new URL(ROUTES.search, SITE.url).href;

const meta = buildMeta({
  title:       "Cari",
  description: "Cari artikel, panduan, dan pembaruan terbaru.",
  canonical:   canonicalURL,
  noindex:     true,
});

const schemas = [
  schemaWebPage({
    title:       "Cari",
    description: "Cari artikel, panduan, dan pembaruan terbaru.",
    url:         canonicalURL,
  }),
];

const totalPosts = allContent.length;
---

<Layout {meta} schema={schemas} bodyClass="bg-[var(--bg)]">
  <Section size="lg">
    <Container size="xl">

      <header class="mb-12 max-w-2xl mx-auto w-full">
        <div class="text-center mb-8">
          <h1 class="text-heading-32 md:text-heading-48 font-extrabold tracking-tighter text-(--fg-strong) mb-3">
            Pencarian
          </h1>
          <p class="text-body-16 text-(--fg-muted)">
            Gunakan kata kunci untuk menemukan artikel, panduan, atau referensi spesifik.
          </p>
        </div>
        
        <div class="relative w-full group shadow-sm transition-shadow focus-within:shadow-md rounded-lg">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-(--fg-muted) group-focus-within:text-(--fg-strong) transition-colors">
            <Icon name="search" className="w-4 h-4" />
          </div>
          <input
            type="text"
            id="search-input"
            placeholder="Ketik judul, kategori, atau topik..."
            class="w-full bg-[var(--bg-subtle)] border border-(--border) text-(--fg-strong) placeholder:text-(--fg-subtle) rounded-lg py-3 pl-11 pr-12 text-body-14 sm:text-body-16 focus:outline-none focus:ring-2 focus:ring-(--border-strong) focus:bg-[var(--bg)] transition-all duration-300"
            autocomplete="off"
            spellcheck="false"
          />
          <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
            <kbd class="hidden sm:inline-flex items-center justify-center bg-[var(--bg-muted)] border border-(--border) rounded px-1.5 py-0.5 text-label-11 text-(--fg-muted) font-mono font-medium shadow-[0_1px_0_var(--border)]">
              /
            </kbd>
          </div>
        </div>
        <p id="search-count" class="mt-3 text-label-13 text-(--fg-subtle) text-center h-5 transition-opacity duration-200"></p>
      </header>

      <div
        id="search-grid"
        class="grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8"
        style="display: none;"
      >
        {allContent.map((item) => {
          const isBlog = item.collection === "blog";
          let groupSlug = "";
          let groupLabel = "";

          if (isBlog) {
            groupSlug = item.data.category ?? CATEGORIES[0].slug;
            groupLabel = catMap[groupSlug] ?? groupSlug;
          } else {
            groupSlug = item.data.series ?? 'general';
            groupLabel = seriesMap[groupSlug] ?? groupSlug;
          }

          const dataSearch = [
            item.data.title,
            item.data.description ?? "",
            groupLabel,
            groupSlug,
          ].join(" ").toLowerCase();

          return (
            <div
              class="search-item hidden"
              data-search={dataSearch}
              data-title={item.data.title.toLowerCase()}
              data-desc={(item.data.description ?? "").toLowerCase()}
              data-cat={groupLabel.toLowerCase()}
              data-cat-slug={groupSlug}
            >
              {isBlog ? (
                <PostCard post={item as any} />
              ) : (
                <GuideCard entry={item as any} />
              )}
            </div>
          );
        })}
      </div>

      <div
        id="empty-state"
        class="flex flex-col items-center justify-center py-24 px-4 text-center border border-dashed border-(--border-strong) rounded-xl bg-[var(--bg-subtle)] mt-8"
      >
        <svg id="empty-icon" class="w-10 h-10 text-(--fg-dim) mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <p id="empty-title" class="text-body-16 text-(--fg-muted) font-medium mb-1">
          Mulai mencari...
        </p>
        <p id="empty-desc" class="text-label-14 text-(--fg-subtle)">
          Ketik kata kunci di atas untuk menampilkan hasil.
        </p>
      </div>

    </Container>
  </Section>
</Layout>

<script define:vars={{ totalPosts }}>
  function initSearch() {
    const input     = document.getElementById("search-input");
    const grid      = document.getElementById("search-grid");
    const empty     = document.getElementById("empty-state");
    const emptyTitle= document.getElementById("empty-title");
    const emptyDesc = document.getElementById("empty-desc");
    const countEl   = document.getElementById("search-count");
    const items     = Array.from(document.querySelectorAll(".search-item"));

    if (!input || !grid || !empty) return;

    const newBtn = input.cloneNode(true);
    input.parentNode.replaceChild(newBtn, input);
    const searchInput = newBtn;

    const score = (el, q) => {
      const title    = el.dataset.title    || "";
      const desc     = el.dataset.desc     || "";
      const cat      = el.dataset.cat      || "";
      const catSlug  = el.dataset.catSlug  || "";
      
      if (title === q) return 100;
      if (title.startsWith(q)) return 80;
     
      const words = q.split(/\s+/).filter(Boolean);
      const allWordsInTitle = words.every(w => title.includes(w));
      if (allWordsInTitle) return 60;

      const allWordsInDesc = words.every(w => desc.includes(w));
      if (allWordsInDesc) return 40;

      if (cat.includes(q) || catSlug.includes(q)) return 30;
      
      return 0;
    };

    const updateCount = (visible, query) => {
      if (!countEl) return;
      if (!query) {
        countEl.textContent = `Menelusuri dari ${totalPosts} total konten`;
      } else {
        countEl.textContent = `${visible} hasil ditemukan`;
      }
    };

    const filterPosts = (query) => {
      const q = query.toLowerCase().trim();

      if (!q) {
        items.forEach((el) => { el.style.display = "none"; });
        grid.style.display  = "none";
        empty.classList.remove("hidden");
        empty.classList.add("flex");
        
        emptyTitle.textContent = "Mulai mencari...";
        emptyDesc.innerHTML = "Ketik kata kunci di atas untuk menampilkan hasil.";
        updateCount(0, "");
        return;
      }

      const scoredItems = items.map((el) => ({
        el,
        s: score(el, q),
      })).filter(item => item.s > 0);

      scoredItems.sort((a, b) => b.s - a.s);

      items.forEach((el) => { el.style.display = "none"; });

      scoredItems.forEach(({ el }) => {
        el.style.display = "block";
        grid.appendChild(el);
      });

      const visible = scoredItems.length;

      if (visible > 0) {
        grid.style.display = "grid";
        empty.classList.add("hidden");
        empty.classList.remove("flex");
      } else {
        grid.style.display = "none";
        empty.classList.remove("hidden");
        empty.classList.add("flex");
        
        emptyTitle.textContent = "Konten tidak ditemukan.";
        emptyDesc.innerHTML = `Coba kata kunci lain atau periksa ejaan Anda.`;
      }

      updateCount(visible, q);
    };

    const urlParams = new URLSearchParams(window.location.search);
    const initialQuery = urlParams.get("q") ?? "";
    if (initialQuery) {
      searchInput.value = initialQuery;
      filterPosts(initialQuery);
      setTimeout(() => {
        searchInput.focus();
        searchInput.setSelectionRange(searchInput.value.length, searchInput.value.length);
      }, 50);
    } else {
      filterPosts("");
    }

    searchInput.addEventListener("input", (e) => {
      const q = e.target.value;
      const url = new URL(window.location.href);
      q.trim() ? url.searchParams.set("q", q) : url.searchParams.delete("q");
      window.history.replaceState({}, "", url.toString());
      filterPosts(q);
    });

    const handleKeydown = (e) => {
      if (e.key === "/" && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput.focus();
      }
    };
    
    document.removeEventListener("keydown", handleKeydown);
    document.addEventListener("keydown", handleKeydown);
  }

  document.addEventListener("astro:page-load", initSearch);
  if (document.readyState === 'loading') {
    document.addEventListener("DOMContentLoaded", initSearch);
  } else {
    initSearch();
  }
</script>