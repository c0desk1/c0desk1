---
// src/pages/contact/index.astro
import { 
  SITE, 
  ROUTES, 
  SOCIAL, 
  buildMeta, 
  schemaWebPage, 
  schemaOrganization, 
  schemaBreadcrumb 
} from "@/consts";

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import ContactForm from "@/components/ContactForm.astro";
import Icon from '@/components/ui/icons/Icon.astro';

const pageTitle = "Kontak";
const pageDesc = "Punya proyek atau sekadar ingin menyapa? Isi formulir di bawah dan kami akan merespons dalam 1×24 jam.";

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, SITE.url).href;

const meta = buildMeta({
  title: pageTitle,
  description: pageDesc,
  canonical: canonicalURL,
  ogType: "website", 
});

const schemas = [
  schemaWebPage({ title: pageTitle, description: pageDesc, url: canonicalURL, type: "ContactPage" }),
  schemaOrganization,
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: pageTitle, url: canonicalURL },
  ]),
];

const email = SITE.email;
---

<Layout {meta} schema={schemas}>
  <Section size="lg">
    <Section size="sm">
      <Container size="lg">
        <div class="flex items-center self-start">
          <Breadcrumb
            items={[
              { name: "Beranda", url: ROUTES.home || "/" },
              { name: pageTitle, url: currentPath },
            ]}
          />
        </div>
      </Container>
    </Section>
    <Section size="sm">
      <Container size="lg">
        <div class="max-w-2xl mb-12">
          <h1 class="text-heading-32 md:text-heading-40 lg:text-heading-56 font-bold text-balance mb-4">
            Mari bekerja sama.
          </h1>
          <p class="text-body-16 md:text-body-18 text-muted max-w-xl text-pretty">
            {pageDesc}
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[1fr_220px] gap-10 items-start">
          <ContactForm />
          <aside class="flex flex-col gap-6 p-6 rounded-md border border-(--border) bg-subtle">
            <div>
              <p class="text-overline-12 text-muted mb-3 uppercase tracking-widest">
                Status
              </p>
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-(--error) shrink-0" />
                <span class="text-body-13 text-muted">Sibuk</span>
              </div>
            </div>
            <div>
              <p class="text-overline-12 text-muted mb-3 uppercase tracking-widest">
                Email
              </p>
              <a
                href={`mailto:${email}`}
                class="text-body-14 text-(--fg) flex items-center gap-2 hover:text-(--accent) transition-colors">
                <Icon name="email" className="w-4 h-4" />
                {email}
              </a>
            </div>
            <div>
              <p class="text-overline-12 text-muted mb-3 uppercase tracking-widest">
                Sosial
              </p>
              <div class="flex flex-col gap-2.5">
                {SOCIAL.map((s) => (
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-body-14 text-muted hover:text-(--accent) transition-colors"
                    aria-label={s.name}
                  >
                    <Icon name={s.name.toLocaleLowerCase() as any} className="w-4.5 h-4.5" />
                    {s.name}
                  </a>
                ))}
              </div>
            </div>
          </aside>
        </div>
      </Container>
    </Section>
  </Section>
</Layout>