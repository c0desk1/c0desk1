---
// src/pages/[slug].astro
import { 
  getCollection, 
  render 
} from 'astro:content';

import { 
  SITE, 
  ROUTES, 
  buildMeta, 
  schemaWebPage, 
  schemaBreadcrumb,
  formatDate,
  toISOString
} from "@/consts";

import { components } from '@/components/layout/MDXComponents';

import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Section from "@/components/ui/Section.astro";
import BackToTop from '@/components/ui/BackToTop.astro';

export async function getStaticPaths() {
  const legalPages = await getCollection("legal");

  return legalPages.map((page) => ({
    params: {
      slug: page.data.slug,
    },
    props: { page },
  }));
}

const { page } = Astro.props;
if (!page) return Astro.redirect('/404');

const { Content } = await render(page);

const currentPath = Astro.url.pathname;
const canonicalURL = page.data.seo?.canonical || new URL(currentPath, SITE.url).href;

const meta = buildMeta({
  title: page.data.seo?.title || page.data.title,
  description: page.data.seo?.description || page.data.description || '',
  canonical: canonicalURL,
  ogImage: page.data.seo?.ogImage,
  noindex: page.data.seo?.noIndex,
  dateModified: page.data.lastUpdated ? toISOString(page.data.lastUpdated) : undefined,
});

const schemas = [
  schemaWebPage({
    title: page.data.seo?.title || page.data.title,
    description: page.data.seo?.description || page.data.description || '',
    url: canonicalURL,
    dateModified: page.data.lastUpdated ? toISOString(page.data.lastUpdated) : undefined,
  }),
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: page.data.title, url: canonicalURL },
  ]),
];
---

<Layout {meta} schema={schemas}>
  <Section size="lg">
    <Container size="md">
      <Section size="sm">
        <Breadcrumb
          items={[
            { name: "Beranda", url: ROUTES.home },
            { name: page.data.title, url: currentPath },
          ]}
        />
      </Section>
      <Section size="sm">
        <article class="prose max-w-none">
          <div class="text-center mb-12">
            <h1 class="text-heading-32 md:text-heading-40 lg:text-heading-56 font-semibold justify-center">
              {page.data.title}
            </h1>
            {page.data.lastUpdated && (
              <p class="text-muted! mt-4 text-body-14 justify-center">
                Terakhir Diperbarui: 
                <time datetime={toISOString(page.data.lastUpdated)}>
                  {formatDate(page.data.lastUpdated, true)}
                </time>
              </p>
            )}
          </div>
          <Section size="sm">
            <Content components={components} />
          </Section>
        </article>
      </Section>
    </Container>
  </Section>
  <BackToTop />
</Layout>
