---
export const prerender = true;

import ErrorLayout from '@/layouts/ErrorLayout.astro';
import Container from '@/components/ui/Container.astro';
import { siteConfig } from '@/config/site';
import { getCurrentLocale, getLabel, localizePath } from "@/utils/i18n";

const locale = getCurrentLocale(Astro);
const siteURL = Astro.site?.toString()?? siteConfig.siteUrl;

const serverErrorTitle = getLabel(locale, 'serverErrorTitle') || '500: Internal Server Error';
const serverErrorDesc = getLabel(locale, 'serverErrorDesc') || 'An error occurred on our server.';
const serverErrorHeading = getLabel(locale, 'serverErrorHeading') || 'Server error.';
const serverErrorMessage = getLabel(locale, 'serverErrorMessage') || 'An unexpected problem occurred on our system.';
const tryAgainLabel = getLabel(locale, 'tryAgain') || 'Try Again';
const returnHomeLabel = getLabel(locale, 'returnHome') || 'Return to Home';

const seoData = {
  title: serverErrorTitle,
  description: serverErrorDesc,
  noIndex: true,
  type: "website" as const,
  canonicalURL: new URL(Astro.url.pathname, siteURL).toString(),
};
---

<ErrorLayout {...seoData}>
  <Container size="md">
    <div class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4">

      <div class="inline-flex items-center gap-2 px-2.5 py-1 mb-8 rounded-md bg-(--bg-subtle) border-(--border) font-mono text-xs md:text-[13px] uppercase tracking-widest text-(--fg-muted) backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-sm bg-red-500"></span>
        500 Error
      </div>

      <h1 class="text-heading-24 md:text-heading-32 lg:text-heading-56 font-semibold tracking-tighter text-(--fg) mb-4">
        {serverErrorHeading}
      </h1>

      <p class="text-sm md:text-base text-(--fg-muted) max-w-[400px] mb-10 leading-relaxed">
        {serverErrorMessage}
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto">
        <button
          onclick="window.location.reload()"
          class="w-full sm:w-auto inline-flex justify-center items-center h-10 px-6 rounded-md bg-(--bg-subtle) text-(--fg) text-sm font-medium hover:bg-(--bg-muted) transition-colors"
        >
          {tryAgainLabel}
        </button>
        <a
          href={localizePath('/', locale)}
          class="w-full sm:w-auto inline-flex justify-center items-center h-10 px-6 rounded-md bg-transparent text-(--fg) text-sm font-medium border-(--border) hover:border-(--border-strong) transition-colors"
        >
          {returnHomeLabel}
        </a>
      </div>

    </div>
  </Container>
</ErrorLayout>