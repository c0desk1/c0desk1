---
// src/pages/[slug].astro
import { getCollection, render } from 'astro:content';
import { SITE, ROUTES, buildMeta, schemaWebPage, schemaBreadcrumb } from "@/consts";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Section from "@/components/ui/Section.astro";

export async function getStaticPaths() {
  const legalPages = await getCollection("legal");

  return legalPages.map((page) => ({
    params: {
      slug: page.data.slug,
    },
    props: { page },
  }));
}

const { page } = Astro.props;
if (!page) return Astro.redirect('/404');

const { Content } = await render(page);

const canonicalURL = new URL(Astro.url.pathname, SITE.url).href;
const meta = buildMeta({
  title: page.data.title,
  description: page.data.description || '',
  canonical: canonicalURL,
});

const schemas = [
  schemaWebPage({
    title: page.data.title,
    description: page.data.description || '',
    url: canonicalURL,
  }),
  schemaBreadcrumb([
    { name: "Beranda", url: SITE.url },
    { name: page.data.title, url: canonicalURL },
  ]),
];
---

<Layout {meta} schema={schemas}>
  <Section size="lg">
    <Container size="md">
      <div class="mb-8">
        <Breadcrumb
          items={[
            { name: "Beranda", url: ROUTES.home },
            { name: page.data.title, url: canonicalURL },
          ]}
        />
      </div>
      <div class="text-center mb-12">
        <h1 class="text-heading-32 md:text-heading-40 lg:text-heading-56 font-bold text-balance mb-4">
          {page.data.title}
        </h1>
      </div>
      <article class="prose max-w-none">
        <Content />
      </article>
    </Container>
  </Section>
</Layout>