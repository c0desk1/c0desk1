---
import Container from "@/components/ui/Container.astro";
import Link from "@/components/ui/Link.astro";
import { buildMeta } from "@/consts";
import Layout from "@/layouts/Layout.astro";

const meta = buildMeta({
  title: "401 - Unauthorized",
  description: "Anda perlu masuk untuk mengakses halaman ini.",
});
---

<Layout {meta} hideHeader={true} hideFooter={true}>
  <Container size="md">
    <div class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4">
      <h1 class="text-4xl md:text-7xl font-extrabold tracking-tighter text-strong mb-4">401</h1>
      <p class="text-body-16 text-muted mb-10 max-w-sm">
        Akses ditolak. Silakan masuk (login) terlebih dahulu untuk melanjutkan.
      </p>
      <Link href="/login" variant="noir" size="lg">
        Masuk Sekarang
      </Link>
    </div>
  </Container>
</Layout>