---
import ErrorLayout from '@/layouts/ErrorLayout.astro';
import Container from '@/components/ui/Container.astro';
import { siteConfig } from '@/config/site';
import { getCurrentLocale, getLabel, localizePath } from "@/utils/i18n";

const locale = getCurrentLocale(Astro);
const siteURL = Astro.site?.toString() ?? siteConfig.siteUrl;

const unauthorizedTitle = getLabel(locale, 'unauthorizedTitle') || '401: Unauthorized';
const unauthorizedDesc = getLabel(locale, 'unauthorizedDesc') || 'Access denied. Please log in first.';
const unauthorizedHeading = getLabel(locale, 'unauthorizedHeading') || 'Unauthorized.';
const unauthorizedMessage = getLabel(locale, 'unauthorizedMessage') || 'You need to authenticate to access this resource.';
const signInLabel = getLabel(locale, 'signIn') || 'Sign In';
const returnHomeLabel = getLabel(locale, 'returnHome') || 'Return to Home';

const seoData = {
  title: unauthorizedTitle,
  description: unauthorizedDesc,
  noIndex: true,
  type: "website" as const,
  canonicalURL: new URL(Astro.url.pathname, siteURL).toString(),
};
---

<ErrorLayout {...seoData}>
  <Container size="md">
    <div class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4">
      
      <div class="inline-flex items-center gap-2 px-2.5 py-1 mb-8 rounded-md bg-(--bg-subtle) border border-(--border) font-mono text-xs md:text-[13px] uppercase tracking-widest text-(--fg-muted) backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-sm bg-(--fg)"></span>
        401 Error
      </div>

      <h1 class="text-4xl md:text-5xl font-semibold tracking-tighter text-(--fg) mb-4">
        {unauthorizedHeading}
      </h1>
      
      <p class="text-sm md:text-base text-(--fg-muted) max-w-[400px] mb-10 leading-relaxed">
        {unauthorizedMessage}
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-3 w-full sm:w-auto">
        <a 
          href={new URL('login/', siteURL).toString()} 
          class="w-full sm:w-auto inline-flex justify-center items-center h-10 px-6 rounded-md bg-(--bg-subtle) text-(--fg) text-sm font-medium hover:bg-(--bg-muted) transition-colors"
        >
          {signInLabel}
        </a>
        <a 
          href={localizePath('/', locale)} 
          class="w-full sm:w-auto inline-flex justify-center items-center h-10 px-6 rounded-md bg-transparent text-(--fg) text-sm font-medium border border-(--border) hover:border-(--border-strong) transition-colors"
        >
          {returnHomeLabel}
        </a>
      </div>

    </div>
  </Container>
</ErrorLayout>