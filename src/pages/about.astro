---
// src/pages/about.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Section from '@/components/ui/Section.astro';
import { siteConfig } from '@/config/site';

const siteURL = Astro.site?.toString() ?? siteConfig.url;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();
const { author } = siteConfig;

const seoData = {
  title: "About",
  description: "Music producer, Adobe Stock contributor, dan developer. Membangun sistem otomasi kreatif dan dokumentasi teknologi.",
  type: "website" as const
};

const breadcrumbItems = [
  { name: 'Home', href: siteURL },
  { name: 'About', href: canonicalURL }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": `${canonicalURL}#aboutpage`,
      "url": canonicalURL,
      "name": `About c0desk1 - ${author.name}`,
      "description": seoData.description,
      "isPartOf": { "@id": `${siteURL}#website` },
      "breadcrumb": { "@id": `${canonicalURL}#breadcrumb` },
      "mainEntity": {
        "@type": "Person",
        "@id": `${siteURL}#person`,
        "name": author.name,
        "image": author.avatar,
        "jobTitle": author.title,
        "description": author.bio
      }
    }
  ]
};
---

<BaseLayout {...seoData}>
  {/* Suntikan JSON-LD spesifik halaman */}
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Section size="lg" class="border-b border-zinc-100 dark:border-zinc-800/50">
    <Container size="md">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-12 flex flex-col md:flex-row gap-10 items-start">
        <div class="relative group shrink-0">
          <div class="absolute -inset-0.5 bg-linear-to-r from-zinc-200 to-zinc-100 dark:from-zinc-800 dark:to-zinc-900 rounded-2xl blur-xs opacity-75 group-hover:opacity-100 transition duration-1000"></div>
          <img src={author.avatar} alt={author.name} class="relative w-24 h-24 md:w-32 md:h-32 rounded-2xl grayscale object-cover bg-white dark:bg-black" />
        </div>
        <div class="space-y-4">
          <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-zinc-900 dark:text-white">
            c0desk1<span class="text-zinc-300 dark:text-zinc-700">.</span>
          </h1>
          <p class="text-lg md:text-xl text-zinc-500 dark:text-zinc-400 max-w-2xl leading-snug tracking-tight">
            Gue {author.name}. Fokus membangun alat bantu kreatif dan sistem otomasi untuk efisiensi workflow digital.
          </p>
        </div>
      </div>
    </Container>
  </Section>

  <Section size="lg">
    <Container size="md">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-20">
        <div class="space-y-24">
          <article class="prose prose-zinc dark:prose-invert max-w-none">
            <div class="inline-flex items-center gap-2 px-2 py-1 rounded-full bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 mb-8 font-mono text-[10px] uppercase tracking-widest text-zinc-500">
              <span class="w-1.5 h-1.5 rounded-full bg-zinc-400 animate-pulse"></span>
              Origin Story
            </div>
            <p class="text-xl leading-relaxed text-zinc-800 dark:text-zinc-200">
              Lahir dari kebutuhan untuk menghentikan tugas repetitif. <span class="italic">"Do it once, automate it forever."</span>
            </p>
            <p>c0desk1 adalah manifestasi dari eksperimen teknis gue — sebuah ruang untuk mendokumentasikan kode, workflow, dan solusi bagi kreator lain.</p>
          </article>

          <div class="space-y-8">
            <h2 class="text-xs font-mono uppercase tracking-[0.3em] text-zinc-400 dark:text-zinc-600 underline decoration-zinc-200 dark:decoration-zinc-800 underline-offset-8">Expertise</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-zinc-200 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-800 overflow-hidden rounded-xl">
              {[
                { title: "Development", desc: "Astro, TypeScript, and Cloudflare Architecture." },
                { title: "Audio Engine", desc: "Sound design and score production via FL Studio." },
                { title: "Automation", desc: "Python and Shell scripting for asset batching." },
                { title: "Stock Strategy", desc: "Data-driven visual production for Adobe Stock." }
              ].map((item) => (
                <div class="p-8 bg-white dark:bg-black group hover:bg-zinc-50 dark:hover:bg-zinc-900/50 transition-colors">
                  <h3 class="text-sm font-semibold text-zinc-900 dark:text-white mb-2">{item.title}</h3>
                  <p class="text-sm text-zinc-500 dark:text-zinc-400">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <aside class="space-y-10 lg:sticky lg:top-24 h-fit">
          <div class="p-6 rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-linear-to-b from-zinc-50 to-white dark:from-zinc-950 dark:to-black">
            <h3 class="text-[10px] font-mono uppercase tracking-widest text-zinc-400 mb-6">Environment</h3>
            <div class="space-y-4">
              <div class="flex flex-col gap-1">
                <span class="text-[10px] text-zinc-400 dark:text-zinc-600 uppercase font-mono">Location</span>
                <span class="text-sm font-medium text-zinc-900 dark:text-white">Pekanbaru, ID (UTC+7)</span>
              </div>
              <div class="flex flex-col gap-1">
                <span class="text-[10px] text-zinc-400 dark:text-zinc-600 uppercase font-mono">Status</span>
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                  <span class="text-sm font-medium text-zinc-900 dark:text-white">Building in Public</span>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </Section>
</BaseLayout>