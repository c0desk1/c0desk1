---

<Layout {meta} schema={schemas}>
  <Section size="lg">
    <Section size="sm">
      <Container size="lg">
        <div class="flex items-center self-start">
          <Breadcrumb
            items={[
              { name: "Beranda", url: ROUTES.home },
              { name: pageTitle, url: ROUTES.about }
            ]}
          />
        </div>
      </Container>
    </Section>
    <Section size="lg">
      <Container size="lg">
        <Section size="none">
          <div class="max-w-2xl">
            <h1 class="text-heading-32 md:text-heading-40 lg:text-heading-56 font-bold text-balance mb-6">
              Portal kreatif untuk era otomatisasi.
            </h1>
            <p class="text-body-16 md:text-body-18 text-muted max-w-xl text-pretty mb-4">
              {SITE.name} adalah ruang untuk mengeksplorasi bagaimana kreator modern memanfaatkan *workflow* digital, *tools* AI, dan kultur di balik karya-karya di internet.
            </p>
            <p class="text-body-16 md:text-body-18 text-muted text-pretty max-w-xl mb-8">
              Dari sistem produktivitas hingga musik, anime, dan video game — di sinilah semua dunia tersebut saling terhubung.
            </p>
            <Button href={ROUTES.contact} variant="accent" size="md">
              Hubungi kami
            </Button>
          </div>
        </Section>
        <Section size="sm">
          <div class="mt-12">
            <p class="text-overline-12 text-muted mb-6 uppercase tracking-widest">
              Topik Pembahasan
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-(--border) rounded-md overflow-hidden">
              {topics.map(({ icon, label, desc }) => (
                <div class="bg-subtle p-6 flex flex-col gap-3 group hover:bg-muted transition-colors">
                  <span class="text-muted w-5 h-5" set:html={icon} aria-hidden="true" />
                  <div>
                    <p class="text-label-14 font-semibold text-(--fg) mb-1">{label}</p>
                    <p class="text-body-13 text-muted">{desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </Section>
        <Section size="sm">
          <div class="mt-12">
            <p class="text-overline-12 text-muted mb-6 uppercase tracking-widest">
              Dibangun dengan
            </p>
            <div class="marquee-root">
              <div class="marquee-track">
                {[...stack, ...stack].map(({ name, description, icon }) => (
                  <div class="marquee-item rounded-md border border-(--border) bg-subtle hover:border-(--accent) transition-colors">
                    <span class="marquee-icon text-muted" set:html={icon} />
                    <div>
                      <p class="text-label-13 text-(--fg) mb-1">{name}</p>
                      <p class="text-caption-11 text-muted">{description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </Section>
        <Section size="sm">
          <div class="border-t border-(--border) pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <a
              href={`mailto:${SITE.email}`}
              class="flex items-center gap-2 text-body-14 text-muted hover:text-(--accent) transition-colors">
              <Icon name="email" className="w-4 h-4" />
              {SITE.email}
            </a>
            <div class="flex items-center gap-4">
              {SOCIAL.map((s) => (
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-body-14 text-muted hover:text-(--accent) transition-colors"
                  aria-label={s.name}
                >
                  {s.name}
                </a>
              ))}
            </div>
          </div>
        </Section>
      </Container>
    </Section>
  </Section>
</Layout>

<style>
  .marquee-root {
    overflow: hidden;
    mask: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .marquee-track {
    display: flex;
    gap: 12px;
    width: max-content;
    animation: marquee 20s linear infinite;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .marquee-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .marquee-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>