---
// src/pages/about.astro

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import { siteConfig } from '@/config/site';
---

<BaseLayout 
  title="About"
  description="Tentang saya dan cara saya membangun pengalaman digital."
  type="website"
>
  <div class="border-b border-zinc-100 dark:border-zinc-900">
    <Container size="md" class="py-12 md:py-16">
      <Breadcrumb items={[
        { name: 'Home', href: '/' },
        { name: 'About', href: '/about/' }
      ]} />
      <div class="space-y-4 mt-6 text-center">
        <h1 class="text-4xl md:text-6xl font-semibold tracking-tight text-zinc-900 dark:text-white">
          About
        </h1>
        <p class="text-base md:text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
          {siteConfig.author.bio}
        </p>
      </div>
    </Container>
  </div>
  <Container size="md" class="py-12 md:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-16">
      <div class="space-y-12">
        <section>
          <h2 class="text-sm font-medium uppercase tracking-wide text-zinc-400 dark:text-zinc-500 mb-4">
            About
          </h2>
          <p class="text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
            Saya {siteConfig.author.name}, frontend engineer dari Indonesia. Fokus pada performa, aksesibilitas, dan UI yang jelas.
          </p>
        </section>
        
        <section>
          <h2 class="text-sm font-medium uppercase tracking-wide text-zinc-400 dark:text-zinc-500 mb-4">
            Experience
          </h2>
          <div class="space-y-6">
            <div>
              <p class="text-sm text-zinc-500 dark:text-zinc-500 mb-1">2024 — sekarang</p>
              <p class="text-base font-medium text-zinc-900 dark:text-white">Frontend Engineer</p>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">Vercel — Remote</p>
            </div>
            <div>
              <p class="text-sm text-zinc-500 dark:text-zinc-500 mb-1">2022 — 2024</p>
              <p class="text-base font-medium text-zinc-900 dark:text-white">UI/UX Designer</p>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">Creative Studio — Jakarta</p>
            </div>
            <div>
              <p class="text-sm text-zinc-500 dark:text-zinc-500 mb-1">2020 — 2022</p>
              <p class="text-base font-medium text-zinc-900 dark:text-white">Freelance Developer</p>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">Self-employed — Remote</p>
            </div>
          </div>
        </section>
        
        <section>
          <h2 class="text-sm font-medium uppercase tracking-wide text-zinc-400 dark:text-zinc-500 mb-4">
            Tools
          </h2>
          <div class="flex flex-wrap gap-2">
            {["Astro", "Tailwind CSS", "TypeScript", "React", "Figma", "Vercel"].map((t, i) => (
              <span class="px-2.5 py-1 text-sm text-zinc-600 dark:text-zinc-400 bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800">
                {t}
              </span>
            ))}
          </div>
        </section>
      </div>
      
      <aside class="space-y-8">
        <div>
          <h3 class="text-xs font-medium uppercase tracking-wide text-zinc-400 dark:text-zinc-500 mb-3">
            Contact
          </h3>
          <div class="space-y-2 text-sm">
            <a href={`mailto:${siteConfig.links.mail}`} class="block text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">
              {siteConfig.links.mail}
            </a>
            <a href={siteConfig.links.github} class="block text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">
              GitHub
            </a>
          </div>
        </div>
        
        <div>
          <h3 class="text-xs font-medium uppercase tracking-wide text-zinc-400 dark:text-zinc-500 mb-3">
            Status
          </h3>
          <div class="flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-emerald-500"></span>
            <p class="text-sm text-zinc-600 dark:text-zinc-400">
              Not available for work
            </p>
          </div>
        </div>
        
        <div>
          <h3 class="text-xs font-medium uppercase tracking-wide text-zinc-400 dark:text-zinc-500 mb-3">
            Location
          </h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">
            Indonesia <span class="text-zinc-400 dark:text-zinc-600">(UTC+7)</span>
          </p>
        </div>
      </aside>
    </div>
  </Container>
</BaseLayout>