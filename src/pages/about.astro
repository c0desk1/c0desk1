---
// src/pages/about.astro

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import { siteConfig } from '@/config/site';
---

<BaseLayout 
  title="About"
  description="Tentang saya dan cara saya membangun pengalaman digital."
  type="website"
>
  <div class="border-b border-zinc-100 dark:border-zinc-900">
    <Container size="md" class="py-8 md:py-10">
      <Breadcrumb items={[
        { name: 'Home', href: '/' },
        { name: 'About', href: '/about' }
      ]} />
      <div class="space-y-3 mt-4">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-white">
          About <span class="text-zinc-400 dark:text-zinc-600">me.</span>
        </h1>
        <p class="text-sm text-zinc-600 dark:text-zinc-400 max-w-2xl">
          Developer dan designer yang fokus pada pengalaman web yang cepat, bersih, dan fungsional.
        </p>
        <div class="h-px w-8 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
      </div>
    </Container>
  </div>
  <Container size="md" class="py-10 md:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12">
      <div class="space-y-10">
        <section>
          <h2 class="text-lg font-bold text-zinc-900 dark:text-white mb-2">$ whoami</h2>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
            Saya {siteConfig.author}, frontend engineer dari Indonesia. Fokus pada performa, aksesibilitas, dan UI yang jelas.
          </p>
        </section>
        <section>
          <h2 class="text-lg font-bold text-zinc-900 dark:text-white mb-2">$ journey</h2>
          <div class="space-y-4">
            <div class="border-l border-emerald-500 pl-4">
              <p class="text-xs text-emerald-600 dark:text-emerald-500">2024 — sekarang</p>
              <p class="text-sm text-zinc-600 dark:text-zinc-400">Frontend Engineer</p>
            </div>
            <div class="border-l border-zinc-200 dark:border-zinc-800 pl-4">
              <p class="text-xs text-zinc-500">2022 — 2024</p>
              <p class="text-sm text-zinc-600 dark:text-zinc-400">UI/UX Designer</p>
            </div>
            <div class="border-l border-zinc-200 dark:border-zinc-800 pl-4">
              <p class="text-xs text-zinc-500">2020 — 2022</p>
              <p class="text-sm text-zinc-600 dark:text-zinc-400">Freelance Developer</p>
            </div>
          </div>
        </section>
        <section>
          <h2 class="text-lg font-bold text-zinc-900 dark:text-white mb-2">$ tools</h2>
          <div class="flex flex-wrap gap-2">
            {["Astro", "Tailwind", "TypeScript", "React", "Figma"].map(t => (
              <span class="px-2 py-1 text-xs border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400">
                {t}
              </span>
            ))}
          </div>
        </section>
      </div>
      <aside class="space-y-6">
        <div class="border border-zinc-200 dark:border-zinc-800 p-5">
          <h3 class="text-sm font-bold text-zinc-500 mb-2">Contact</h3>
          <div class="space-y-2 text-sm">
            <a href={`mailto:${siteConfig.links.mail}`} class="text-zinc-600 dark:text-zinc-400">
              {siteConfig.links.mail}
            </a>
            <a href={siteConfig.links.github} class="block text-zinc-600 dark:text-zinc-400">
              GitHub
            </a>
          </div>
        </div>
        <div class="border border-zinc-200 dark:border-zinc-800 p-5">
          <h3 class="text-sm font-bold text-zinc-500 mb-2">Status</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">
            Tersedia untuk project freelance.
          </p>
        </div>
        <div class="border border-zinc-200 dark:border-zinc-800 p-5">
          <h3 class="text-sm font-bold text-zinc-500 mb-2">Lokasi</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">
            Indonesia (UTC+7)
          </p>
        </div>
      </aside>
    </div>
  </Container>
</BaseLayout>