---
import Icon from "@/components/ui/Icon";
---

<div class="flex items-center">
  
  <button 
    type="button"
    onclick="document.dispatchEvent(new Event('open-search'))"
    class="flex sm:hidden h-9 w-9 items-center justify-center rounded-full border border-(--border) text-muted hover:bg-subtle hover:text-strong transition-colors focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
    aria-label="Buka Pencarian">
    <Icon name="search" className="h-5 w-5" />
  </button>

  <button 
    type="button"
    onclick="document.dispatchEvent(new Event('open-search'))"
    class="hidden sm:flex relative items-center w-56 md:w-64 group bg-subtle hover:bg-muted border border-(--border) hover:border-strong rounded-lg py-1.5 pl-3 pr-2 transition-all focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
    aria-label="Buka Pencarian (Tekan /)">
    <Icon name="search" className="h-4 w-4 text-muted group-hover:text-strong transition-colors mr-2 shrink-0" />
    <span class="text-body-14 text-muted flex-1 text-left truncate">Cari...</span>
    
    <kbd class="inline-flex items-center justify-center bg-base border border-(--border) rounded px-1.5 py-0.5 text-label-11 text-muted font-mono font-medium shrink-0 shadow-sm">
      /
    </kbd>
  </button>

</div>

<script>
  const openSearch = () => {
    document.dispatchEvent(new CustomEvent("open-search"));
  };

  const initSearchButton = () => {
    const btn = document.getElementById("search-trigger");
    if (!btn) return;
    btn.onclick = openSearch;
  };

  initSearchButton();
  document.addEventListener("astro:page-load", initSearchButton);
  document.addEventListener("keydown", (e) => {
    const active = document.activeElement;
    const isTyping =
      active instanceof HTMLInputElement ||
      active instanceof HTMLTextAreaElement ||
      active?.getAttribute("contenteditable") === "true";

    if (isTyping) return;
    if (e.key === "/") {
      e.preventDefault();
      openSearch();
    }
  });
</script>