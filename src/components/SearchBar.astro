---
import Icon from '@/components/ui/icons/Icon.astro';
---

<div class="flex items-center">
  
  <button 
    type="button"
    class="js-search-trigger flex lg:hidden items-center justify-center rounded-full border border-(--border) text-muted hover:bg-subtle hover:text-strong active:bg-subtle active:text-strong focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
    aria-label="Buka Pencarian">
    <span class="inline-flex shrink-0 items-center w-5 h-5">
      <Icon name="search" className="h-full w-full transition-colors" />
    </span>
  </button>

  <button 
    type="button"
    class="js-search-trigger hidden lg:flex relative items-center w-56 group hover:bg-subtle border border-(--border) rounded-lg py-1.5 pl-3 pr-2 focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
    aria-label="Buka Pencarian (Tekan /)">
    <Icon name="search" className="h-4 w-4 text-muted group-hover:text-strong transition-colors mr-2 shrink-0" />
    <span class="text-body-14 text-muted flex-1 text-left truncate transition-colors">Cari...</span>
    
    <kbd class="inline-flex items-center justify-center bg-base border border-(--border) rounded px-1.5 py-0.5 text-label-11 text-muted font-mono font-medium shrink-0 shadow-sm">
      /
    </kbd>
  </button>

</div>

<script>
  //@ts-nocheck
  const initSearchButton = () => {
    const openSearch = () => {
      document.dispatchEvent(new CustomEvent("open-search"));
    };

    const btns = document.querySelectorAll(".js-search-trigger");
    btns.forEach(btn => {
      btn.removeEventListener("click", openSearch);
      btn.addEventListener("click", openSearch);
    });

    document.removeEventListener("keydown", window.__slashSearchHandler);
    window.__slashSearchHandler = (e) => {
      const active = document.activeElement;
      const isTyping =
        active instanceof HTMLInputElement ||
        active instanceof HTMLTextAreaElement ||
        active?.getAttribute("contenteditable") === "true";

      if (isTyping) return;
      if (e.key === "/") {
        e.preventDefault();
        openSearch();
      }
    };
    document.addEventListener("keydown", window.__slashSearchHandler);
  };

  initSearchButton();
  document.addEventListener("astro:page-load", initSearchButton);
</script>