<script is:inline>
  (() => {
    if (
      !import.meta.env.PROD ||
      window.__YANDEX_IMAGE_LOADED__
    ) {
      return;
    }

    window.__YANDEX_IMAGE_LOADED__ = true;

    window.addEventListener(
      "load",
      () => {
        if (!window.yaContextCb || !window.Ya) {
          return;
        }

        const render = (imageId) => {
          window.yaContextCb.push(() => {
            Ya.Context.AdvManager.render({
              renderTo: imageId,
              blockId: "R-A-19179231-2",
              type: "inImage",
            });
          });
        };

        let count = 0;

        const MAX_ADS = 2;

        const images = Array.from(
          document.querySelectorAll("article img, .prose img")
        );

        for (const image of images) {
          if (!(image instanceof HTMLImageElement)) {
            continue;
          }

          if (count >= MAX_ADS) {
            break;
          }

          const { width, height } =
            image.getBoundingClientRect();

          if (width < 600 || height < 300) {
            continue;
          }

          image.id =
            `yandex_${Math.random().toString(16).slice(2)}`;

          count++;

          if (!image.complete) {
            image.addEventListener(
              "load",
              () => render(image.id),
              { once: true }
            );
          } else {
            render(image.id);
          }
        }
      },
      { once: true }
    );
  })();
</script>
