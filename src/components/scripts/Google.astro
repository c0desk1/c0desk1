---
import { siteConfig } from "@/config/site";

const GTAG_ID = siteConfig.googleAnalyticsId || "";
const ADSENSE_ID = siteConfig.googleAdsenseId || "";
const ADSENSE_ENABLED = siteConfig.googleAdsenseEnabled ?? true;
---

<script
  is:inline
  define:vars={{
    GTAG_ID,
    ADSENSE_ID,
    ADSENSE_ENABLED,
  }}
>
  (() => {
    const GTAG_SCRIPT_ID = "gtag-script";
    const ADSENSE_SCRIPT_ID = "adsense-script";

    const loadGtag = () => {
      if (!GTAG_ID) return;
      if (document.getElementById(GTAG_SCRIPT_ID)) return;

      const script = document.createElement("script");
      script.id = GTAG_SCRIPT_ID;
      script.async = true;
      script.src = `https://www.googletagmanager.com/gtag/js?id=${GTAG_ID}`;
      document.head.appendChild(script);

      window.dataLayer = window.dataLayer || [];
      function gtag() { window.dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", GTAG_ID, { anonymize_ip: true });
    };

    const loadAdsense = () => {
      if (!ADSENSE_ENABLED || !ADSENSE_ID) return;
      if (document.getElementById(ADSENSE_SCRIPT_ID)) return;

      const script = document.createElement("script");
      script.id = ADSENSE_SCRIPT_ID;
      script.async = true;
      script.crossOrigin = "anonymous";
      script.src = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_ID}`;
      document.head.appendChild(script);
    };

    const startLoading = () => {
      loadGtag();
      loadAdsense();
    };
    const hasConsent = () => {
      if (window.ezConsent && typeof window.ezConsent.getConsentStatus === 'function') {
        const ad = window.ezConsent.getConsentStatus('ad_storage');
        const ana = window.ezConsent.getConsentStatus('analytics_storage');
        return ad === 'granted' || ana === 'granted';
      }
      return false;
    };
    if (hasConsent()) {
      startLoading();
    } else {
      document.addEventListener('ezconsent', () => {
        if (hasConsent()) startLoading();
      }, { once: true });
    }
  })();
</script>
