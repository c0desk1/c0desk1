---
interface Props {
  id?: string;
}

const { id } = Astro.props;
---

{
  import.meta.env.PROD && id && (
    <>
      <script
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${id}`}
      />

      <script is:inline define:vars={{ id }}>
        window.dataLayer = window.dataLayer || [];

        function gtag() {
          dataLayer.push(arguments);
        }

        gtag("js", new Date());

        gtag("config", id, {
          anonymize_ip: true,
        });
      </script>
    </>
  )
}
