---
// src/components/SearchModal.astro
import { ROUTES, CATEGORIES, SERIES } from "@/consts";
import Icon from '@/components/ui/icons/Icon.astro';

const searchRoute = ROUTES.search;

const topCategories = CATEGORIES.slice(0, 4);
const topSeries = SERIES.slice(0, 4);
---

<div
  id="search-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Cari postingan"
  inert
  class="fixed inset-0 z-50 hidden"
>
  <div
    id="search-backdrop"
    class="absolute inset-0 bg-overlay backdrop-blur-sm opacity-0 transition-opacity duration-200"
  ></div>
  
  <div class="relative flex min-h-full items-start justify-center p-4 sm:pt-32">
    <div
      id="search-panel"
      class="w-full max-w-2xl overflow-hidden rounded-xl border border-(--border) bg-elevated shadow-(--shadow-xl) opacity-0 scale-95 transition-all duration-200 flex flex-col max-h-[85vh]"
    >
      <form id="search-form" action={searchRoute} class="flex items-center gap-3 px-4 shrink-0">
        <Icon name="search" className="h-5 w-5 shrink-0 text-subtle" />

        <input
          id="search-input"
          type="search"
          name="q"
          placeholder="Cari sesuatu..."
          aria-label="Cari postingan"
          autocomplete="off"
          spellcheck="false"
          class="flex-1 min-w-0 border-none bg-transparent py-4 sm:py-5 text-body-16 text-strong outline-none placeholder:text-subtle [&::-webkit-search-cancel-button]:hidden"
        />
        
        <button type="submit" class="hidden" aria-hidden="true" tabindex="-1">Cari</button>
        
        <button
          id="search-clear"
          type="button"
          aria-label="Tutup atau bersihkan"
          class="hidden h-7 w-7 shrink-0 items-center justify-center rounded-md text-muted hover:bg-muted hover:text-strong transition-colors"
        >
          <Icon name="close" className="h-4 w-4" />
        </button>
        
        <kbd class="hidden sm:inline-flex items-center rounded-md border border-(--border) bg-muted px-1.5 py-0.5 text-[11px] text-muted font-mono font-medium ml-1">
          ESC
        </kbd>
      </form>

      <div id="search-suggestions" class="border-t border-(--border) p-2 overflow-y-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          
          {topCategories.length > 0 && (
            <div>
              <h3 class="px-3 py-2 text-[11px] font-semibold text-subtle uppercase tracking-wider">
                Kategori Blog
              </h3>
              <ul class="flex flex-col gap-0.5">
                {topCategories.map(c => (
                  <li>
                    <button 
                      type="button" 
                      class="suggestion-btn flex w-full items-center gap-2.5 rounded-md px-3 py-2 text-body-14 text-muted transition-colors hover:bg-muted hover:text-strong" 
                      data-query={c.label}
                    >
                      <span class="text-subtle text-lg leading-none font-mono opacity-70">#</span>
                      <span class="truncate">{c.label}</span>
                    </button>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {topSeries.length > 0 && (
            <div>
              <h3 class="px-3 py-2 text-[11px] font-semibold text-subtle uppercase tracking-wider">
                Seri Guide
              </h3>
              <ul class="flex flex-col gap-0.5">
                {topSeries.map(s => (
                  <li>
                    <button 
                      type="button" 
                      class="suggestion-btn flex w-full items-center gap-2.5 rounded-md px-3 py-2 text-body-14 text-muted transition-colors hover:bg-muted hover:text-strong" 
                      data-query={s.label}
                    >
                      <Icon name="search" className="h-3.5 w-3.5 text-subtle opacity-70" />
                      <span class="truncate">{s.label}</span>
                    </button>
                  </li>
                ))}
              </ul>
            </div>
          )}

        </div>
      </div>
      
    </div>
  </div>
</div>

<script define:vars={{ searchRoute }}>
  const initSearchModal = () => {
    const $ = (id) => document.getElementById(id);

    const modal       = $("search-modal");
    const backdrop    = $("search-backdrop");
    const panel       = $("search-panel");
    const form        = $("search-form");
    const input       = $("search-input");
    const clearBtn    = $("search-clear");
    const suggestions = $("search-suggestions");
    const suggestBtns = document.querySelectorAll(".suggestion-btn");

    if (!modal || !input || !form) return;

    let prevFocus = null;

    const onSearchPage = () => window.location.pathname === searchRoute;

    const submit = () => {
      const q = input.value.trim();
      if (!q) return;
      window.location.href = `${searchRoute}?q=${encodeURIComponent(q)}`;
    };

    const openModal = () => {
      prevFocus = document.activeElement;
      modal.style.display = "block";
      modal.removeAttribute("inert");
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => {
        backdrop.style.opacity = "1";
        panel.style.opacity    = "1";
        panel.style.transform  = "scale(1)";
        input.focus();

        if (suggestions) suggestions.style.display = input.value.trim() ? "none" : "block";
      });
    };

    const closeModal = () => {
      backdrop.style.opacity = "0";
      panel.style.opacity    = "0";
      panel.style.transform  = "scale(0.95)";
      document.body.style.overflow = "";
      setTimeout(() => {
        modal.style.display = "none";
        modal.setAttribute("inert", "");
        input.value = "";
        clearBtn?.classList.add("hidden");
        clearBtn?.classList.remove("flex");
        if (suggestions) suggestions.style.display = "block";
        prevFocus?.focus();
      }, 200);
    };

    document.removeEventListener("open-search", window.__openSearchHandler);
    window.__openSearchHandler = openModal;
    document.addEventListener("open-search", window.__openSearchHandler);

    backdrop.addEventListener("click", closeModal);

    clearBtn?.addEventListener("click", () => {
      if (input.value) {
        input.value = "";
        input.focus();

        if (suggestions) suggestions.style.display = "block";
        
        if (window.innerWidth >= 640) {
          clearBtn.classList.add("hidden");
          clearBtn.classList.remove("flex");
        }
      } else {
        closeModal();
      }
    });

    input.addEventListener("input", () => {
      const q = input.value.trim();
      
      if (q || window.innerWidth < 640) {
        clearBtn?.classList.remove("hidden");
        clearBtn?.classList.add("flex");
      } else {
        clearBtn?.classList.add("hidden");
        clearBtn?.classList.remove("flex");
      }

      if (suggestions) {
        suggestions.style.display = q ? "none" : "block";
      }
    });

    form.addEventListener("submit", (e) => {
      e.preventDefault(); 
      submit();
    });

    suggestBtns.forEach(btn => {
      btn.addEventListener("click", (e) => {
        input.value = e.currentTarget.dataset.query;
        submit();
      });
    });

    document.removeEventListener("keydown", window.__searchKeyHandler);
    window.__searchKeyHandler = (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        if (onSearchPage()) {
          $("search-input")?.focus();
          return;
        }
        modal.style.display === "none" ? openModal() : closeModal();
        return;
      }
      if (e.key === "Escape" && modal.style.display !== "none") {
        e.preventDefault(); closeModal();
      }
    };
    document.addEventListener("keydown", window.__searchKeyHandler);

    if (window.innerWidth < 640 && clearBtn) {
      clearBtn.classList.remove("hidden");
      clearBtn.classList.add("flex");
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearchModal);
  } else {
    initSearchModal();
  }
  document.addEventListener("astro:page-load", initSearchModal);
</script>