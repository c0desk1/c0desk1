---
import { ROUTES } from "@/consts";
import Icon from '@/components/ui/icons/Icon.astro';
import Link from "./ui/Link.astro";

const searchRoute = ROUTES.search;
---

<div
  id="search-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Cari postingan"
  inert
  class="fixed inset-0 z-50 hidden"
>
  <div
    id="search-backdrop"
    class="absolute inset-0 bg-[color-mix(in_srgb,var(--bg)_50%,transparent)] backdrop-blur-sm opacity-0 transition-opacity duration-200"
  ></div>
  <div class="relative flex min-h-full items-start justify-center p-4 sm:pt-20">
    <div
      id="search-panel"
      class="w-full max-w-2xl overflow-hidden rounded-xl border border-(--border) bg-base shadow-(--shadow-lg) opacity-0 scale-95 transition-all duration-200"
    >
      <div class="flex items-center gap-2 px-3.5">
        <Icon name="search" className="h-5 w-5 shrink-0 text-dim" />

        <input
          id="search-input"
          type="text"
          placeholder="Cari artikel..."
          aria-label="Cari postingan"
          autocomplete="off"
          spellcheck="false"
          class="flex-1 min-w-0 border-none bg-transparent py-4 text-body-14 sm:text-body-16 text-muted outline-none placeholder:text-dim"
        />
        <button
          id="search-clear"
          aria-label="Hapus"
          tabindex="-1"
          class="hidden h-7 w-7 shrink-0 items-center justify-center rounded-full text-muted hover:bg-muted hover:text-(--fg) transition-colors"
        >
          <Icon name="trash" className="h-5 w-5" />
        </button>
        <button
          id="search-close-mobile"
          aria-label="Tutup"
          class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-muted hover:bg-muted hover:text-(--fg) transition-colors sm:hidden"
        >
          <Icon name="close" className="h-5 w-5" />
        </button>
        <kbd class="hidden sm:inline-flex items-center rounded-md border border-(--prose-kbd-border) bg-(--prose-kbd-bg) px-1.5 py-0.5 text-xs text-(--prose-kbd-text)">
          ESC
        </kbd>
      </div>
      <div class="flex items-center justify-between border-t border-(--border) bg-subtle px-3.5 py-2">
        <span class="text-body-14 text-muted">
          Tekan
          <kbd class="mx-0.5 inline-flex items-center rounded border border-(--prose-kbd-border) bg-(--prose-kbd-bg) px-1 py-0.5 text-xs">↵</kbd>
          untuk mencari
        </span>
        <Link
          id="search-browse"
          href={searchRoute}
          variant="noir"
          size="sm">
          Lihat semua
        </Link>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ searchRoute }}>
  const initSearchModal = () => {
    const $ = (id) => document.getElementById(id);

    const modal    = $("search-modal");
    const backdrop = $("search-backdrop");
    const panel    = $("search-panel");
    const input    = $("search-input");
    const clearBtn = $("search-clear");
    const closeMob = $("search-close-mobile");

    if (!modal || !input) return;

    let prevFocus = null;

    const onSearchPage = () => window.location.pathname === searchRoute;

    const submit = () => {
      const q = input.value.trim();
      if (!q) return;
      window.location.href = `${searchRoute}?q=${encodeURIComponent(q)}`;
    };

    const openModal = () => {
      prevFocus = document.activeElement;
      modal.style.display = "block";
      modal.removeAttribute("inert");
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => {
        backdrop.style.opacity = "1";
        panel.style.opacity    = "1";
        panel.style.transform  = "scale(1)";
        input.focus();
      });
    };

    const closeModal = () => {
      backdrop.style.opacity = "0";
      panel.style.opacity    = "0";
      panel.style.transform  = "scale(0.95)";
      document.body.style.overflow = "";
      setTimeout(() => {
        modal.style.display = "none";
        modal.setAttribute("inert", "");
        input.value = "";
        clearBtn?.classList.add("hidden");
        clearBtn?.classList.remove("flex");
        prevFocus?.focus();
      }, 200);
    };

    document.removeEventListener("open-search", window.__openSearchHandler);
    window.__openSearchHandler = openModal;
    document.addEventListener("open-search", window.__openSearchHandler);

    backdrop.addEventListener("click", closeModal);
    closeMob?.addEventListener("click", closeModal);

    clearBtn?.addEventListener("click", () => {
      input.value = "";
      clearBtn.classList.add("hidden");
      clearBtn.classList.remove("flex");
      input.focus();
    });

    input.addEventListener("input", () => {
      const q = input.value.trim();
      clearBtn?.classList.toggle("hidden", !q);
      clearBtn?.classList.toggle("flex", !!q);
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") { e.preventDefault(); submit(); }
    });

    document.removeEventListener("keydown", window.__searchKeyHandler);
    window.__searchKeyHandler = (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        if (onSearchPage()) {
          document.getElementById("search-input")?.focus();
          return;
        }
        modal.style.display === "none" ? openModal() : closeModal();
        return;
      }
      if (e.key === "Escape" && modal.style.display !== "none") {
        e.preventDefault(); closeModal();
      }
    };
    document.addEventListener("keydown", window.__searchKeyHandler);
  };

  initSearchModal();
  document.addEventListener("astro:page-load", initSearchModal);
</script>