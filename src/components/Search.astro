---
// src/components/Search.astro
import { ROUTES } from "@/consts";
import Icon from '@/components/ui/icons/Icon.astro';

const searchRoute = ROUTES.search;
---

<div
  id="search-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Cari postingan"
  inert
  class="fixed inset-0 z-50 hidden"
>
  <div
    id="search-backdrop"
    class="absolute inset-0 bg-[var(--bg-overlay)] backdrop-blur-sm opacity-0 transition-opacity duration-200"
  ></div>
  
  <div class="relative flex min-h-full items-start justify-center p-4 sm:pt-32">
    <div
      id="search-panel"
      class="w-full max-w-2xl overflow-hidden rounded-xl border border-(--border) bg-[var(--bg-elevated)] shadow-[var(--shadow-xl)] opacity-0 scale-95 transition-all duration-200"
    >
      <div class="flex items-center gap-3 px-4">
        <Icon name="search" className="h-5 w-5 shrink-0 text-(--fg-subtle)" />

        <input
          id="search-input"
          type="text"
          placeholder="Cari sesuatu..."
          aria-label="Cari postingan"
          autocomplete="off"
          spellcheck="false"
          class="flex-1 min-w-0 border-none bg-transparent py-4 sm:py-5 text-body-16 text-(--fg-strong) outline-none placeholder:text-(--fg-subtle)"
        />
        
        <button
          id="search-clear"
          aria-label="Tutup atau bersihkan"
          class="hidden h-7 w-7 shrink-0 items-center justify-center rounded-md text-(--fg-muted) hover:bg-[var(--bg-muted)] hover:text-(--fg-strong) transition-colors">
          <Icon name="close" className="h-4 w-4" />
        </button>
        
        <kbd class="hidden sm:inline-flex items-center rounded-md border border-(--border) bg-[var(--bg-muted)] px-1.5 py-0.5 text-[11px] text-(--fg-muted) font-mono font-medium ml-1">
          ESC
        </kbd>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ searchRoute }}>
  const initSearchModal = () => {
    const $ = (id) => document.getElementById(id);

    const modal    = $("search-modal");
    const backdrop = $("search-backdrop");
    const panel    = $("search-panel");
    const input    = $("search-input");
    const clearBtn = $("search-clear");

    if (!modal || !input) return;

    let prevFocus = null;

    const onSearchPage = () => window.location.pathname === searchRoute;

    const submit = () => {
      const q = input.value.trim();
      if (!q) return;
      window.location.href = `${searchRoute}?q=${encodeURIComponent(q)}`;
    };

    const openModal = () => {
      prevFocus = document.activeElement;
      modal.style.display = "block";
      modal.removeAttribute("inert");
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => {
        backdrop.style.opacity = "1";
        panel.style.opacity    = "1";
        panel.style.transform  = "scale(1)";
        input.focus();
      });
    };

    const closeModal = () => {
      backdrop.style.opacity = "0";
      panel.style.opacity    = "0";
      panel.style.transform  = "scale(0.95)";
      document.body.style.overflow = "";
      setTimeout(() => {
        modal.style.display = "none";
        modal.setAttribute("inert", "");
        input.value = "";
        clearBtn?.classList.add("hidden");
        clearBtn?.classList.remove("flex");
        prevFocus?.focus();
      }, 200);
    };

    document.removeEventListener("open-search", window.__openSearchHandler);
    window.__openSearchHandler = openModal;
    document.addEventListener("open-search", window.__openSearchHandler);

    backdrop.addEventListener("click", closeModal);

    clearBtn?.addEventListener("click", () => {
      if (input.value) {
        input.value = "";
        input.focus();
      } else {
        closeModal();
      }
    });

    input.addEventListener("input", () => {
      const q = input.value.trim();
      if (q || window.innerWidth < 640) {
        clearBtn?.classList.remove("hidden");
        clearBtn?.classList.add("flex");
      } else {
        clearBtn?.classList.add("hidden");
        clearBtn?.classList.remove("flex");
      }
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") { e.preventDefault(); submit(); }
    });

    document.removeEventListener("keydown", window.__searchKeyHandler);
    window.__searchKeyHandler = (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        if (onSearchPage()) {
          $("search-input")?.focus();
          return;
        }
        modal.style.display === "none" ? openModal() : closeModal();
        return;
      }
      if (e.key === "Escape" && modal.style.display !== "none") {
        e.preventDefault(); closeModal();
      }
    };
    document.addEventListener("keydown", window.__searchKeyHandler);

    if (window.innerWidth < 640) {
      clearBtn?.classList.remove("hidden");
      clearBtn?.classList.add("flex");
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearchModal);
  } else {
    initSearchModal();
  }
  document.addEventListener("astro:page-load", initSearchModal);
</script>