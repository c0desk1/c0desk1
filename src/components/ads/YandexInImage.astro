<script is:inline>
  (() => {
    window.__adPageCount ??= 0;
    window.__lastInImagePage ??= 0;

    window.__adPageCount++;

    const current = window.__adPageCount;

    const gap = Math.floor(Math.random() * 4) + 2;

    if (current - window.__lastInImagePage < gap) {
      return;
    }

    window.__lastInImagePage = current;

    window.addEventListener(
      "load",
      () => {
        const render = (imageId) => {
          window.yaContextCb.push(() => {
            Ya.Context.AdvManager.render({
              renderTo: imageId,
              blockId: "R-A-19179231-2",
              type: "inImage",
            });
          });
        };

        let count = 0;
        const MAX_ADS = 2;

        const images = Array.from(
          document.querySelectorAll("article img, .prose img")
        );

        for (const image of images) {
          if (count >= MAX_ADS) break;

          if (!(image instanceof HTMLImageElement)) {
            continue;
          }

          const { width, height } = image.getBoundingClientRect();

          if (width < 600 || height < 300) {
            continue;
          }

          const src = image.currentSrc || image.src;

          if (
            /avatar|logo|icon|emoji|badge/i.test(src)
          ) {
            continue;
          }

          image.id =
            image.id ||
            `yandex_${Math.random().toString(16).slice(2)}`;

          count++;

          if (!image.complete) {
            image.addEventListener(
              "load",
              () => render(image.id),
              { once: true }
            );
          } else {
            render(image.id);
          }
        }
      },
      { once: true }
    );
  })();
</script>
