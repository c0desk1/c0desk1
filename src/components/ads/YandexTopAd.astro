<script is:inline>
  (() => {
    window.__adPageCount ??= 0;
    window.__lastTopAdPage ??= 0;

    window.__adPageCount++;

    const current = window.__adPageCount;

    const gap = Math.floor(Math.random() * 3) + 2;

    if (current - window.__lastTopAdPage < gap) {
      return;
    }

    window.__lastTopAdPage = current;

    window.yaContextCb ||= [];

    window.addEventListener(
      "load",
      () => {
        window.yaContextCb.push(() => {
          Ya.Context.AdvManager.render({
            blockId: "R-A-19179231-4",
            type: "topAd",
          });
        });
      },
      { once: true }
    );
  })();
</script>
