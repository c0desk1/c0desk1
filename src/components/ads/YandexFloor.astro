<script is:inline>
  (() => {
    const isMobile = window.matchMedia("(max-width: 768px)").matches;

    const CONFIG = isMobile
      ? {
          blockId: "R-A-19179231-1",
          platform: "touch",
          storageKey: "__lastMobileFloorPage",
          minGap: 2,
          maxGap: 4,
        }
      : {
          blockId: "R-A-19179231-5",
          platform: "desktop",
          storageKey: "__lastDesktopFloorPage",
          minGap: 3,
          maxGap: 6,
        };

    window.__adPageCount ??= 0;
    window[CONFIG.storageKey] ??= 0;

    window.__adPageCount++;

    const current = window.__adPageCount;

    const gap =
      Math.floor(
        Math.random() *
        (CONFIG.maxGap - CONFIG.minGap + 1)
      ) + CONFIG.minGap;

    if (
      current - window[CONFIG.storageKey] < gap
    ) {
      return;
    }

    window[CONFIG.storageKey] = current;

    window.yaContextCb ||= [];

    window.addEventListener(
      "load",
      () => {
        window.yaContextCb.push(() => {
          Ya.Context.AdvManager.render({
            blockId: CONFIG.blockId,
            type: "floorAd",
            platform: CONFIG.platform,
          });
        });
      },
      { once: true }
    );
  })();
</script>
