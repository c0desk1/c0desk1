---
// src/components/ads/YandexLoader.astro
---

<script is:inline>
  (() => {
    if (window.__YANDEX_LOADER__) {
      return;
    }

    window.__YANDEX_LOADER__ = true;

    window.yaContextCb =
      window.yaContextCb || [];

    const loadYandex = () => {
      if (
        document.getElementById(
          "yandex-context"
        )
      ) {
        return;
      }

      const script =
        document.createElement("script");

      script.id = "yandex-context";

      script.src =
        "https://yandex.ru/ads/system/context.js";

      script.async = true;
      script.defer = true;

      document.head.appendChild(script);
    };

    const trigger = () => {
      loadYandex();

      window.removeEventListener(
        "scroll",
        trigger
      );

      window.removeEventListener(
        "pointerdown",
        trigger
      );
    };

    window.addEventListener(
      "scroll",
      trigger,
      {
        once: true,
        passive: true,
      }
    );

    window.addEventListener(
      "pointerdown",
      trigger,
      {
        once: true,
      }
    );

    if ("requestIdleCallback" in window) {
      requestIdleCallback(loadYandex, {
        timeout: 4000,
      });
    } else {
      setTimeout(loadYandex, 4000);
    }
  })();
</script>
