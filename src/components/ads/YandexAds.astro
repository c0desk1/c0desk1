---
// src/components/ads/YandexAds.astro
---
<script is:inline>
  (() => {
    const isMobile = window.matchMedia("(max-width: 767px)").matches;
    
    window.yaContextCb = window.yaContextCb || [];
    window.__adPageCount ??= 0;
    window.__adPageCount++;

    const page = window.__adPageCount;

    const canShow = (key, min, max) => {
      const storageKey = `__${key}LastPage`;
      window[storageKey] ??= 0;
      const last = window[storageKey];
      
      if (last === 0) return true;
      
      const gap = Math.floor(Math.random() * (max - min + 1)) + min;
      return page - last >= gap;
    };

    const markShown = (key) => {
      window[`__${key}LastPage`] = page;
    };

    // =========================
    // DESKTOP - AKTIF
    // =========================
    if (!isMobile) {
      // 1. TOP AD
      if (canShow('topAd', 0, 0)) {
        markShown('topAd');
        window.yaContextCb.push(() => {
          Ya.Context.AdvManager.render({
            blockId: "R-A-19179231-4",
            type: "topAd"
          });
        });
      }

      // 2. FLOOR AD DESKTOP
      if (canShow('desktopFloor', 2, 3)) {
        markShown('desktopFloor');
        window.yaContextCb.push(() => {
          Ya.Context.AdvManager.render({
            blockId: "R-A-19179231-5",
            type: "floorAd",
            platform: "desktop"
          });
        });
      }
    } 
    
    // =========================
    // MOBILE - AKTIF
    // =========================
    else {
      if (canShow('mobileBanner', 1, 1)) {
        markShown('mobileBanner');
        window.yaContextCb.push(() => {
          Ya.Context.AdvManager.render({
            blockId: "R-A-19179231-6",
            renderTo: "yandex_rtb_R-A-19179231-6"
          });
        });
      }

      // 4. FULLSCREEN - NONAKTIF
      // if (canShow('fullscreen', 2, 3)) {
      //   markShown('fullscreen');
      //   window.yaContextCb.push(() => {
      //     Ya.Context.AdvManager.render({
      //       blockId: "R-A-19179231-3",
      //       type: "fullscreen",
      //       platform: "touch"
      //     });
      //   });
      // }
    }
  })();
</script>