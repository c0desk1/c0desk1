// src/components/ads/YandexAds.astro

<script is:inline>
  (() => {
    window.yaContextCb ||= [];

    const isMobile =
      window.matchMedia("(max-width: 768px)").matches;

    const randomBetween = (min, max) =>
      Math.floor(Math.random() * (max - min + 1)) + min;

    const canRender = (key, min = 2, max = 5) => {
      const storageKey = `__${key}LastPage`;

      window[storageKey] ??= 0;
      window.__adPageCount ??= 0;

      const current = window.__adPageCount;
      const last = window[storageKey];

      const gap = randomBetween(min, max);

      return current - last >= gap;
    };

    const markRendered = (key) => {
      const storageKey = `__${key}LastPage`;
      window[storageKey] = window.__adPageCount;
    };

    const render = (key, config) => {
      if (!window.Ya?.Context?.AdvManager) return;

      markRendered(key);

      window.yaContextCb.push(() => {
        Ya.Context.AdvManager.render(config);
      });
    };

    window.addEventListener(
      "load",
      () => {
        window.__adPageCount ??= 0;
        window.__adPageCount++;

        // =========================
        // PRIMARY PAGE AD
        // =========================

        if (isMobile) {
          const showFullscreen = Math.random() > 0.5;

          // MOBILE FULLSCREEN (tetap aktif)
          if (
            showFullscreen &&
            canRender("fullscreen", 3, 6)
          ) {
            render("fullscreen", {
              blockId: "R-A-19179231-3",
              type: "fullscreen",
              platform: "touch",
            });
          }

          // ❌ MOBILE FLOOR DIMATIKAN
        } else {
          const showTopAd = Math.random() > 0.5;

          // DESKTOP TOP
          if (
            showTopAd &&
            canRender("topAd", 2, 4)
          ) {
            render("topAd", {
              blockId: "R-A-19179231-4",
              type: "topAd",
            });
          }

          // DESKTOP FLOOR (tetap aktif)
          else if (
            canRender("desktopFloor", 3, 6)
          ) {
            render("desktopFloor", {
              blockId: "R-A-19179231-5",
              type: "floorAd",
              platform: "desktop",
            });
          }
        }

        // =========================
        // IN-IMAGE DIMATIKAN TOTAL
        // =========================
      },
      { once: true }
    );
  })();
</script>
