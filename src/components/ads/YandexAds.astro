---
import { siteConfig } from "@/config/site";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";

const YA_PUB_ID = siteConfig.yandexPubId || "";
const YA_METRICA_ID = siteConfig.yandexMetricaId || "";
const ADS_ENABLED = siteConfig.yandexAdsEnabled ?? true;
---

<div
  id="ya-data"
  style="display:none"
  data-pub-id={YA_PUB_ID}
  data-metrica-id={YA_METRICA_ID}
  data-ads-enabled={String(ADS_ENABLED)}
></div>

<Section size="sm">
  <Container size="xl">
    <div
      id="yandex_rtb_R-A-19179231-6"
      style="min-height:0"
    ></div>
  </Container>
</Section>

<script is:inline>
  (() => {
    const el = document.getElementById("ya-data");
    const PUB_ID = el?.dataset.pubId || "";
    const METRICA_ID = el?.dataset.metricaId || "";
    const ADS_ON = el?.dataset.adsEnabled !== "false";

    const DELAY = {
      floorAd: 3000,
      inImage: 3500,
      fullscreen: 8000,
      topAd: 1500,
      banner: 2500,
      metrica: 1000,
    };

    function waitForYa(cb, retries = 20) {
      if (window.Ya?.Context?.AdvManager && window.yaContextCb) {
        cb();
      } else if (retries > 0) {
        setTimeout(() => waitForYa(cb, retries - 1), 300);
      }
    }

    function afterDelay(ms, fn) {
      if (document.readyState === "complete") {
        setTimeout(fn, ms);
      } else {
        window.addEventListener("load", () => setTimeout(fn, ms), { once: true });
      }
    }

    function isDesktop() {
      const ua = navigator.userAgent;
      const mobileRegex = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Mobile|Tablet|Kindle|Silk/i;
      const isIPad = /Macintosh/i.test(ua) && navigator.maxTouchPoints && navigator.maxTouchPoints > 1;
      return !mobileRegex.test(ua) && !isIPad;
    }

    function isTouchDevice() {
      return !isDesktop();
    }

    // Ads functions
    function renderFloorTouch() {
      if (!isTouchDevice()) return;
      afterDelay(DELAY.floorAd, () => {
        waitForYa(() => {
          window.yaContextCb.push(() => {
            Ya.Context.AdvManager.render({
              blockId: `${PUB_ID}-1`,
              type: "floorAd",
              platform: "touch",
            });
          });
        });
      });
    }

    function renderInImage() {
      afterDelay(DELAY.inImage, () => {
        waitForYa(() => {
          const render = (imageId) => {
            window.yaContextCb.push(() => {
              Ya.Context.AdvManager.render({
                renderTo: imageId,
                blockId: `${PUB_ID}-2`,
                type: "inImage",
              });
            });
          };
          const tryImages = (images) => {
            if (!images.length) return;
            const image = images.shift();
            const { width, height } = image.getBoundingClientRect();
            if (width < 375 || height < 196) {
              return tryImages(images);
            }
            image.id = `yandex_rtb_${PUB_ID}-2-${Math.random().toString(16).slice(2)}`;
            if (image.tagName === "IMG" && !image.complete) {
              image.addEventListener("load", () => render(image.id), { once: true });
            } else {
              render(image.id);
            }
            tryImages(images);
          };
          tryImages(Array.from(document.querySelectorAll("img")));
        });
      });
    }

    function renderFullscreen() {
      if (!isTouchDevice()) return;
      afterDelay(DELAY.fullscreen, () => {
        waitForYa(() => {
          window.yaContextCb.push(() => {
            Ya.Context.AdvManager.render({
              blockId: `${PUB_ID}-3`,
              type: "fullscreen",
              platform: "touch",
            });
          });
        });
      });
    }

    function renderTopAd() {
      if (!isTouchDevice()) return;
      afterDelay(DELAY.topAd, () => {
        waitForYa(() => {
          window.yaContextCb.push(() => {
            Ya.Context.AdvManager.render({
              blockId: `${PUB_ID}-4`,
              type: "topAd",
            });
          });
        });
      });
    }

    function renderFloorDesktop() {
      if (!isDesktop()) return;
      afterDelay(DELAY.floorAd, () => {
        waitForYa(() => {
          window.yaContextCb.push(() => {
            Ya.Context.AdvManager.render({
              blockId: `${PUB_ID}-5`,
              type: "floorAd",
              platform: "desktop",
            });
          });
        });
      });
    }

    function renderBanner() {
      afterDelay(DELAY.banner, () => {
        waitForYa(() => {
          window.yaContextCb.push(() => {
            Ya.Context.AdvManager.render({
              blockId: `${PUB_ID}-6`,
              renderTo: `yandex_rtb_${PUB_ID}-6`,
            });
          });
        });
      });
    }

    // Yandex Metrica
    function initMetrica() {
      if (!METRICA_ID) return;
      afterDelay(DELAY.metrica, () => {
        (function (m, e, t, r, i, k, a) {
          m[i] = m[i] || function () { (m[i].a = m[i].a || []).push(arguments); };
          m[i].l = 1 * new Date();
          for (let j = 0; j < document.scripts.length; j++) {
            if (document.scripts[j].src === r) return;
          }
          k = e.createElement(t);
          a = e.getElementsByTagName(t)[0];
          k.async = 1;
          k.src = r;
          a.parentNode.insertBefore(k, a);
        })(window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
        ym(Number(METRICA_ID), "init", {
          clickmap: true,
          trackLinks: true,
          accurateTrackBounce: true,
          webvisor: false,
        });
        if (!document.getElementById("ya-metrica-ns")) {
          const ns = document.createElement("noscript");
          ns.id = "ya-metrica-ns";
          const img = document.createElement("img");
          img.src = `https://mc.yandex.ru/watch/${METRICA_ID}`;
          img.style.cssText = "position:absolute;left:-9999px";
          img.alt = "";
          ns.appendChild(img);
          document.body.appendChild(ns);
        }
      });
    }

    let initialized = false;
    function initAll() {
      if (initialized) return;
      initialized = true;
      if (ADS_ON && !window.__yandexAdsInitialized) {
        window.__yandexAdsInitialized = true;
        renderFloorTouch();
        renderFullscreen();
        renderTopAd();
        renderFloorDesktop();
        renderBanner();
      }
      if (METRICA_ID && !window.__yandexMetricaInitialized) {
        window.__yandexMetricaInitialized = true;
        initMetrica();
      }
    }

    // Langsung inisialisasi ketika DOM sudah siap
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initAll);
    } else {
      initAll();
    }

    document.addEventListener("astro:page-load", () => {
      window.__yandexAdsInitialized = false;
      window.__yandexMetricaInitialized = false;
      initialized = false;
      initAll();
    });
  })();
</script>