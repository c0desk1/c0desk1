---
// src/components/ui/AdsManager.astro
// Master ad orchestrator — controls Yandex RTB + Google AdSense
// Prevents collision, respects cookie consent, single source of truth
import { siteConfig } from "@/config/site";
import { getEntry } from "astro:content";

let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {}

const siteData = settings?.data || siteConfig;

// ── Provider toggles ────────────────────────────────────────────────────────
const YANDEX_ENABLED  = siteData.yandexAdsEnabled  ?? siteConfig.yandexAdsEnabled  ?? true;
const ADSENSE_ENABLED = siteData.adsenseEnabled     ?? siteConfig.adsenseEnabled     ?? false;

// ── IDs ─────────────────────────────────────────────────────────────────────
const ADSENSE_PUB_ID  = siteData.googleAdsenseId       || siteConfig.googleAdsenseId       || "";
const GA_ID           = siteData.googleAnalyticsId  || siteConfig.googleAnalyticsId  || "";
const YA_PUB_ID       = siteData.yandexPubId        || siteConfig.yandexPubId        || "R-A-19179231";
const YA_METRICA_ID   = siteData.yandexMetrikaId    || siteConfig.yandexMetricaId    || "";

// ── Priority: which provider wins when both are enabled ─────────────────────
// "yandex" | "adsense" | "both"
// "both" = Yandex gets non-overlapping slots, AdSense fills the rest
const AD_PRIORITY     = siteData.adPriority         || siteConfig.adPriority         || "yandex";
---

<!-- AdsManager config carrier -->
<div
  id="am-data"
  style="display:none"
  data-yandex-enabled={String(YANDEX_ENABLED)}
  data-adsense-enabled={String(ADSENSE_ENABLED)}
  data-adsense-pub={ADSENSE_PUB_ID}
  data-ga-id={GA_ID}
  data-ya-pub={YA_PUB_ID}
  data-ya-metrica={YA_METRICA_ID}
  data-priority={AD_PRIORITY}
></div>

<!-- Block-6 renderTo target (Yandex standard banner) -->
<div id="yandex_rtb_R-A-19179231-6" style="min-height:0"></div>

<script is:inline>
(function () {
  // ─── Read config ──────────────────────────────────────────────────────────
  const cfg = document.getElementById('am-data')?.dataset || {};

  const YANDEX_ON   = cfg.yandexEnabled  !== 'false';
  const ADSENSE_ON  = cfg.adsenseEnabled === 'true';
  const PUB_YA      = cfg.yaPub          || 'R-A-19179231';
  const PUB_AS      = cfg.adsensePub     || '';          // ca-pub-XXXXXXXXXXXXXXXX
  const METRICA_ID  = cfg.yaMetrica      || '';
  const GA_ID       = cfg.gaId           || '';
  const PRIORITY    = cfg.priority       || 'yandex';    // 'yandex' | 'adsense' | 'both'

  const CONSENT_KEY = 'cookie-consent-v2';

  // ─── State flags — prevent double-init across navigations ─────────────────
  let _yandexBooted  = false;
  let _adsenseBooted = false;
  let _metricaBooted = false;

  // ─── Delays (ms after page load) ─────────────────────────────────────────
  const DELAY = {
    topAd:      1500,
    floorAd:    2000,
    banner:     2500,
    inImage:    3500,
    adsense:    3000,
    fullscreen: 8000,
    metrica:    1000,
  };

  // ─── Helpers ──────────────────────────────────────────────────────────────
  function getConsent() {
    try { return JSON.parse(localStorage.getItem(CONSENT_KEY)); }
    catch { return null; }
  }

  function analyticsAllowed() { return getConsent()?.analytics === true; }
  function adsAllowed()        { return analyticsAllowed(); }

  function afterDelay(ms, fn) {
    if (document.readyState === 'complete') {
      setTimeout(fn, ms);
    } else {
      window.addEventListener('load', () => setTimeout(fn, ms), { once: true });
    }
  }

  function waitForYa(cb, retries = 20) {
    if (window.Ya?.Context?.AdvManager && window.yaContextCb) {
      cb();
    } else if (retries > 0) {
      setTimeout(() => waitForYa(cb, retries - 1), 300);
    }
  }

  // ─── Collision guard ──────────────────────────────────────────────────────
  // Tracks which DOM slots are already claimed so providers don't fight
  const _claimed = new Set();

  function claim(slotId) {
    if (_claimed.has(slotId)) return false;
    _claimed.add(slotId);
    return true;
  }

  // ─── Yandex RTB units ─────────────────────────────────────────────────────
  function yaRender(cfg) {
    window.yaContextCb.push(() => Ya.Context.AdvManager.render(cfg));
  }

  function bootYandex() {
    if (_yandexBooted) return;
    _yandexBooted = true;

    // Block-1: Floor touch
    if (claim('ya-floor-touch')) {
      afterDelay(DELAY.floorAd, () => waitForYa(() => yaRender({
        blockId: `${PUB_YA}-1`, type: 'floorAd', platform: 'touch',
      })));
    }

    // Block-2: In-image
    if (claim('ya-inimage')) {
      afterDelay(DELAY.inImage, () => waitForYa(() => {
        const render = (id) => yaRender({ renderTo: id, blockId: `${PUB_YA}-2`, type: 'inImage' });
        const tryImages = (imgs) => {
          if (!imgs.length) return;
          const img = imgs.shift();
          const { width, height } = img.getBoundingClientRect();
          if (width < 1200 || height < 630) return tryImages(imgs);
          img.id = `yandex_rtb_${PUB_YA}-2-${Math.random().toString(16).slice(2)}`;
          if (img.tagName === 'IMG' && !img.complete) {
            img.addEventListener('load', () => render(img.id), { once: true });
          } else {
            render(img.id);
          }
          tryImages(imgs);
        };
        tryImages(Array.from(document.querySelectorAll('img')));
      }));
    }

    // Block-3: Fullscreen touch
    if (claim('ya-fullscreen')) {
      afterDelay(DELAY.fullscreen, () => waitForYa(() => yaRender({
        blockId: `${PUB_YA}-3`, type: 'fullscreen', platform: 'touch',
      })));
    }

    // Block-4: Top ad
    if (claim('ya-top')) {
      afterDelay(DELAY.topAd, () => waitForYa(() => yaRender({
        blockId: `${PUB_YA}-4`, type: 'topAd',
      })));
    }

    // Block-5: Floor desktop
    if (claim('ya-floor-desktop')) {
      afterDelay(DELAY.floorAd, () => waitForYa(() => yaRender({
        blockId: `${PUB_YA}-5`, type: 'floorAd', platform: 'desktop',
      })));
    }

    // Block-6: Standard banner (renderTo)
    if (claim('ya-banner-6')) {
      afterDelay(DELAY.banner, () => waitForYa(() => yaRender({
        blockId: `${PUB_YA}-6`, renderTo: `yandex_rtb_${PUB_YA}-6`,
      })));
    }
  }

  // ─── Google AdSense ───────────────────────────────────────────────────────
  function bootAdSense() {
    if (_adsenseBooted || !PUB_AS) return;
    _adsenseBooted = true;

    afterDelay(DELAY.adsense, () => {
      // Inject AdSense script only once
      if (!document.getElementById('adsense-script')) {
        const s   = document.createElement('script');
        s.id      = 'adsense-script';
        s.async   = true;
        s.src     = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${PUB_AS}`;
        s.setAttribute('crossorigin', 'anonymous');
        document.head.appendChild(s);
      }

      // Push all .adsbygoogle elements that haven't been initialized
      // AdSense auto-ads handle placement automatically once script loads,
      // but manual ins elements need a push per slot.
      const slots = document.querySelectorAll('.adsbygoogle:not([data-adsbygoogle-status])');
      slots.forEach(() => {
        try { (window.adsbygoogle = window.adsbygoogle || []).push({}); }
        catch (e) { console.warn('[AdsManager] AdSense push error:', e); }
      });
    });
  }

  // ─── Yandex Metrica ───────────────────────────────────────────────────────
  function bootMetrica() {
    if (_metricaBooted || !METRICA_ID) return;
    _metricaBooted = true;

    afterDelay(DELAY.metrica, () => {
      (function(m, e, t, r, i, k, a) {
        m[i] = m[i] || function() { (m[i].a = m[i].a || []).push(arguments); };
        m[i].l = 1 * new Date();
        for (var j = 0; j < document.scripts.length; j++) {
          if (document.scripts[j].src === r) return;
        }
        k = e.createElement(t); a = e.getElementsByTagName(t)[0];
        k.async = 1; k.src = r;
        a.parentNode.insertBefore(k, a);
      })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym');

      ym(Number(METRICA_ID), 'init', {
        clickmap:            true,
        trackLinks:          true,
        accurateTrackBounce: true,
        webvisor:            false,
      });

      if (!document.getElementById('ya-metrica-ns')) {
        const ns  = document.createElement('noscript');
        ns.id     = 'ya-metrica-ns';
        const img = document.createElement('img');
        img.src   = `https://mc.yandex.ru/watch/${METRICA_ID}`;
        img.style.cssText = 'position:absolute;left:-9999px';
        img.alt   = '';
        ns.appendChild(img);
        document.body.appendChild(ns);
      }
    });
  }

  // ─── Priority router ──────────────────────────────────────────────────────
  function initAds() {
    if (!adsAllowed()) return;

    switch (PRIORITY) {
      case 'adsense':
        if (ADSENSE_ON) bootAdSense();
        // Yandex only if explicitly both
        break;

      case 'both':
        // Yandex claims its slots first (lower delays), AdSense fills around
        if (YANDEX_ON)  bootYandex();
        if (ADSENSE_ON) bootAdSense();
        break;

      case 'yandex':
      default:
        if (YANDEX_ON) bootYandex();
        // AdSense disabled when Yandex takes priority — avoids overlapping
        // floor/fullscreen units that both providers serve automatically
        break;
    }
  }

  function initAnalytics() {
    if (!analyticsAllowed()) return;
    bootMetrica();
    // GA is handled separately by your existing GA script / Cookie.astro
  }

  // ─── Consent-aware boot ───────────────────────────────────────────────────
  function boot() {
    // Reset boot flags on each navigation so re-init works correctly
    _yandexBooted  = false;
    _adsenseBooted = false;
    _metricaBooted = false;
    _claimed.clear();

    const consent = getConsent();
    if (consent !== null) {
      initAds();
      initAnalytics();
    } else {
      // Poll until user makes a choice (cookie banner)
      let attempts = 0;
      const timer = setInterval(() => {
        attempts++;
        if (getConsent() !== null || attempts >= 60) {
          clearInterval(timer);
          initAds();
          initAnalytics();
        }
      }, 1000);
    }
  }

  // ─── Entry points ─────────────────────────────────────────────────────────
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  document.addEventListener('astro:page-load', boot);

  // ─── Public API (optional, for manual control from other scripts) ─────────
  window.__AdsManager = {
    reboot:          boot,
    isYandexActive:  () => _yandexBooted,
    isAdSenseActive: () => _adsenseBooted,
    claimedSlots:    () => Array.from(_claimed),
  };
})();
</script>