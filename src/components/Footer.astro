---
// src/components/layout/Footer.astro
import { Image } from "astro:assets";
import { 
  ORG, 
  SITE, 
  IMAGE, 
  ROUTES, 
  SOCIAL 
} from "@/consts";

import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Icon from '@/components/ui/icons/Icon.astro';
import Theme from "./Theme.astro";

const currentYear = new Date().getFullYear();

const footerNav = [
  {
    title: "Konten",
    items: [
      { label: "Blog", href: ROUTES.blog },
      { label: "Panduan", href: ROUTES.guide },
      { label: "Kategori", href: `${ROUTES.blog}/category` },
    ],
  },
  {
    title: "Komunitas",
    items: [
      { label: "Tentang", href: ROUTES.about },
      { label: "Hubungi Kami", href: ROUTES.contact },
      { label: "Cari", href: ROUTES.search },
    ],
  },
  {
    title: "Legal",
    items: [
      { label: "Kebijakan Privasi", href: ROUTES.privacy },
      { label: "Ketentuan Layanan", href: ROUTES.terms },
      { label: "Kebijakan Cookie", href: ROUTES.cookie },
    ],
  },
];
---

<footer class="border-t border-(--border) bg-subtle">
  <Section size="none">
    <Container size="xl">
      <div class="py-12 lg:py-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
          <div class="flex flex-col justify-between max-w-md">
            <div>
              <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 flex items-center justify-center shrink-0">
                  <Image
                    src={ORG.logo}
                    alt={SITE.name}
                    width={IMAGE.logo.width}
                    height={IMAGE.logo.height}
                    loading="lazy"
                    fetchpriority="low"
                    class="w-10 h-10 object-contain transition-all duration-300"
                  />
                </div>
                <span class="text-heading-24 font-semibold tracking-wider uppercase text-strong">
                  {SITE.name}
                </span>
              </div>
              <p class="text-body-14 text-muted leading-relaxed mb-6">
                {SITE.description}
              </p>

              <div class="flex items-center gap-3">
                {SOCIAL.map((s) => (
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={s.name}
                    class="flex items-center justify-center w-8 h-8 rounded-md border border-(--border) text-muted hover:text-strong hover:bg-muted active:scale-95 transition-all duration-200"
                  >
                    <Icon name={s.name.toLowerCase() as any} className="w-4 h-4" />
                  </a>
                ))}
              </div>
            </div>
          </div>
          
          <div class="grid grid-cols-3 gap-8">
            {footerNav.map((group) => (
              <div>
                <h3 class="text-mono-label-13 font-semibold uppercase tracking-wider text-strong mb-4">
                  {group.title}
                </h3>
                <ul class="flex flex-col gap-2.5">
                  {group.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class="text-body-14 text-muted hover:text-strong transition-colors duration-200 no-underline"
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </Section>
  
  <Section size="none" class="border-t border-(--border)">
    <Container size="xl">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-6">
        <p class="text-label-13 text-subtle">
          &copy; {currentYear} {SITE.name}. All rights reserved.
        </p>
        <div class="flex items-center gap-4">
          <a
            href={ROUTES.sitemap}
            class="text-label-13 text-subtle hover:text-muted transition-colors duration-200 no-underline"
          >
            Sitemap
          </a>
          <a
            href={ROUTES.feed}
            class="text-label-13 text-subtle hover:text-muted transition-colors duration-200 no-underline"
          >
            Feed
          </a>
          <Theme />
        </div>
      </div>
    </Container>
  </Section>
</footer>