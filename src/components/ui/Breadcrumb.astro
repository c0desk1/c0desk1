---
// src/components/ui/Breadcrumb.astro
import { siteConfig } from '@/config/site';

interface Props {
  items: Array<{ 
    name?: string; 
    href?: string 
  }>;
}

const { items = [] } = Astro.props;
if (!items.length) return;

const siteData = siteConfig
const ariaLabel = siteData.breadcrumbAria;
---

<nav aria-label={ariaLabel} class="flex justify-center">
  <ol class="flex items-center gap-1.5 text-copy-14 flex-wrap">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && (
          <span class="text-subtle">
            /
          </span>
        )}

        {i === items.length - 1? (
          <span aria-current="page" class="text-(--fg) truncate max-w-[16rem]">
            {item.name}
          </span>
        ) : (
          <a
            href={item.href}
            class="text-muted hover:text-(--fg) active:text-(--fg) no-underline whitespace-nowrap transition-colors"
          >
            {item.name}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>
