---
// src/components/ui/Breadcrumb.astro
import Icon from './Icon';
import { getCurrentLocale, getLabel } from '@/utils/i18n';

interface Props {
  items: Array<{ name: string; href?: string }>;
}

const { items = [] } = Astro.props;
if (!items.length) return;

const locale = getCurrentLocale(Astro);
const ariaLabel = getLabel(locale, 'breadcrumbAria') || 'Breadcrumb';
---

<nav aria-label={ariaLabel} class="bc-nav">
  <ol class="bc-list">
    {items.map((item, i) => (
      <li class="bc-item">
        {i > 0 && (
          <span class="bc-sep" aria-hidden="true">
            <Icon name="chevron-right" className="w-3.5 h-3.5" />
          </span>
        )}
        {i === items.length - 1? (
          <span aria-current="page" class="bc-current">{item.name}</span>
        ) : (
          <a href={item.href} class="bc-link">{item.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
 .bc-nav {
    display: flex;
    justify-content: center;
  }

 .bc-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.225rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

 .bc-item {
    display: flex;
    align-items: center;
    gap: 0.225rem;
  }

 .bc-sep {
    display: flex;
    align-items: center;
    color: var(--fg-muted);
    opacity: 0.4;
    margin: 0 0.1rem;
  }

 .bc-sep :global(svg) {
    width: 0.5rem;
    height: 0.5rem;
  }

 .bc-link {
    font-size: 14px;
    color: var(--fg-subtle);
    text-decoration: none;
    white-space: nowrap;
  }

 .bc-link:hover {
    color: var(--fg);
  }

 .bc-current {
    font-size: 14px;
    color: var(--fg);
    font-weight: 500;
    white-space: nowrap;
    max-width: 16rem;
    overflow: hidden;
    text-overflow: ellipsis;
  }

@media (max-width: 768px) {
 .bc-nav {
    justify-content: start;
  }

 .bc-link {
    font-size: 13px;
  }

 .bc-current {
    font-size: 13px;
  }
}

@media (min-width: 767px) {
 .bc-link {
    font-size: 14px;
  }

 .bc-current {
    font-size: 14px;
  }
}
</style>