---
// src/components/ui/Breadcrumb.astro

import Icon from './Icon.astro';

interface Props {
  items: Array<{ name: string; href?: string }>;
}

const { items = [] } = Astro.props;
if (!items.length) return;
---

<nav aria-label="Breadcrumb" class="bc-nav">
  <ol class="bc-list">
    {items.map((item, i) => (
      <li class="bc-item">
        {i > 0 && (
          <span class="bc-sep" aria-hidden="true">
            <Icon name="chevron-right" class="w-3 h-3" /> 
          </span>
        )}
        {i === items.length - 1 ? (
          <span aria-current="page" class="bc-current">{item.name}</span>
        ) : (
          <a href={item.href} class="bc-link">{item.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .bc-nav {
    display: flex;
    justify-content: center;
  }

  .bc-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.125rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bc-item {
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }

  .bc-sep {
    display: flex;
    align-items: center;
    color: var(--fg-muted);
    opacity: 0.4;
    margin: 0 0.1rem;
  }

  .bc-sep Icon {
    width: 0.5rem;
    height: 0.5rem;
  }

  .bc-link {
    font-size: 13px;
    color: var(--fg-subtle);
    text-decoration: none;
    padding: 0.2rem 0.35rem;
    border-radius: var(--radius-md, 0.375rem);
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .bc-link:hover {
    color: var(--fg);
    background: var(--bg-muted);
  }

  .bc-current {
    font-size: 13px;
    color: var(--fg-muted);
    font-weight: 500;
    padding: 0.2rem 0.35rem;
    white-space: nowrap;
    max-width: 16rem;
    overflow: hidden;
    text-overflow: ellipsis;
  }

@media (max-width: 768px) {
  .bc-nav {
    justify-content: start;
  }
}
</style>