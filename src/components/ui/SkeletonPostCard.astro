---
// src/components/ui/SkeletonPostCard.astro
---

<div class="flex flex-col h-full rounded-(--radius-xl) border border-(--border) p-6">
  <!-- Header: category + date -->
  <div class="flex items-center justify-between mb-6">
    <div class="sk-line" style="width:4.5rem; height:0.8rem;"></div>
    <div class="sk-line" style="width:3.5rem; height:0.8rem;"></div>
  </div>

  <!-- Body: title + excerpt -->
  <div class="flex flex-col gap-4">
    <!-- Title: 2-3 baris -->
    <div class="flex flex-col gap-2">
      <div class="sk-line" style="width:100%; height:1.25rem;"></div>
      <div class="sk-line" style="width:85%;  height:1.25rem;"></div>
      <div class="sk-line" style="width:60%;  height:1.25rem;"></div>
    </div>

    <!-- Excerpt: 3 baris -->
    <div class="flex flex-col gap-2">
      <div class="sk-line" style="width:100%; height:0.875rem;"></div>
      <div class="sk-line" style="width:92%;  height:0.875rem;"></div>
      <div class="sk-line" style="width:75%;  height:0.875rem;"></div>
    </div>
  </div>

  <!-- Footer: avatar + author name -->
  <div class="mt-auto flex items-center gap-3 pt-6">
    <!-- Avatar bulat, matching w-6 h-6 -->
    <div class="sk-avatar"></div>
    <div class="sk-line" style="width:5rem; height:0.8rem;"></div>
  </div>
</div>

<style is:global>
  @keyframes sk-shimmer {
    0%   { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  /* Base skeleton token — dipakai oleh semua skeleton component */
  .sk-line,
  .sk-avatar,
  .sk-img {
    position: relative;
    overflow: hidden;
    background: var(--bg-muted, #e5e7eb);
  }

  .sk-line    { border-radius: 4px; }
  .sk-avatar  { width: 1.5rem; height: 1.5rem; border-radius: 999px; flex-shrink: 0; }

  /* Shimmer layer — universal */
  .sk-line::after,
  .sk-avatar::after,
  .sk-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      color-mix(in srgb, var(--bg) 55%, transparent) 50%,
      transparent 100%
    );
    animation: sk-shimmer 1.6s ease-in-out infinite;
  }
</style>