---
// src/components/ui/Listen.astro
import Icon from "./Icon.astro";
---

<button 
  id="listen-btn" 
  aria-label="Dengarkan artikel" 
  class="relative p-2 rounded-(--radius-full) text-(--fg-muted) hover:text-(--fg) hover:bg-(--bg-muted) group active:scale-95"
>
  <div class="relative w-4.5 h-4.5 flex items-center justify-center">
    <span id="icon-play" class="absolute inset-0 w-full h-full opacity-100 scale-100 transition-all duration-300">
      <Icon name="volume" class="w-4.5 h-4.5" />
    </span>
    <span id="icon-stop" class="absolute inset-0 w-full h-full transition-all duration-300 opacity-0 scale-50">
      <Icon name="volume-mute" class="w-4.5 h-4.5" />
    </span>
  </div>
  <span id="listen-tooltip" class="absolute -top-9 left-1/2 -translate-x-1/2 px-2 py-1 text-[12px] border border-(--border) font-medium bg-(--bg-subtle) text-(--fg) rounded-(--radius-md) opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-xl">
    Dengarkan
  </span>
</button>

<script>
  const initListen = () => {
    const btn = document.getElementById('listen-btn') as HTMLButtonElement | null;
    const playIcon = document.getElementById('icon-play') as HTMLElement | null;
    const stopIcon = document.getElementById('icon-stop') as HTMLElement | null;
    const tooltip = document.getElementById('listen-tooltip') as HTMLElement | null;

    if (!btn || !playIcon || !stopIcon || !tooltip) return;

    let isPlaying = false;
    let synth = window.speechSynthesis;

    const chunkText = (text: string) => {
      return text.match(/[^\.!\?]+[\.!\?]+/g) || [text];
    };

    const toggleUI = (playing: boolean) => {
      if (playing) {
        playIcon.classList.replace('opacity-100', 'opacity-0');
        playIcon.classList.replace('scale-100', 'scale-50');
        stopIcon.classList.replace('opacity-0', 'opacity-100');
        stopIcon.classList.replace('scale-50', 'scale-100');
        tooltip.textContent = 'Berhenti';
      } else {
        stopIcon.classList.replace('opacity-100', 'opacity-0');
        stopIcon.classList.replace('scale-100', 'scale-50');
        playIcon.classList.replace('opacity-0', 'opacity-100');
        playIcon.classList.replace('scale-50', 'scale-100');
        tooltip.textContent = 'Dengarkan';
      }
      isPlaying = playing;
    };

    const speakChunks = (chunks: string[]) => {
      let currentChunk = 0;

      const speakNext = () => {
        if (currentChunk < chunks.length && isPlaying) {
          const utterance = new SpeechSynthesisUtterance(chunks[currentChunk].trim());
          const voices = synth.getVoices();
          const idVoice = voices.find(v => v.lang.includes('id'));
          
          if (idVoice) utterance.voice = idVoice;
          utterance.lang = 'id-ID';
          
          utterance.onend = () => {
            currentChunk++;
            speakNext();
          };
          
          utterance.onerror = () => toggleUI(false);
          synth.speak(utterance);
        } else {
          toggleUI(false);
        }
      };
      speakNext();
    };

    btn.addEventListener('click', () => {
      if (isPlaying) {
        synth.cancel();
        toggleUI(false);
        return;
      }
      const article = document.getElementById('article-content') || 
                      document.querySelector('article') || 
                      document.querySelector('main');
      
      if (!article) return;
      article.scrollIntoView({ 
        behavior: 'smooth', 
        block: 'start' 
      });
      
      const rawText = (article as HTMLElement).innerText;
      const cleanText = rawText.replace(/\s+/g, ' ').trim();
      const chunks = chunkText(cleanText);
      
      if (chunks.length > 0 && chunks[0] !== "") {
        toggleUI(true);
        synth.cancel();
        speakChunks(chunks);
      }
    });
  };

  initListen();
  document.addEventListener('astro:after-swap', initListen);
  document.addEventListener('astro:page-load', initListen);
</script>
