---
// src/components/ui/Listen.astro
import Icon from "./Icon.astro";
---

<button
  id="listen-btn"
  aria-label="Dengarkan artikel"
  class="relative p-2 rounded-(--radius-full) text-(--fg-muted) hover:text-(--fg) hover:bg-(--bg-muted) group active:scale-95"
>
  <div class="relative w-4.5 h-4.5 flex items-center justify-center">
    <span id="icon-play" class="absolute inset-0 transition-all duration-300 opacity-100 scale-100">
      <Icon name="volume" class="w-4.5 h-4.5" />
    </span>
    <span id="icon-stop" class="absolute inset-0 transition-all duration-300 opacity-0 scale-50">
      <Icon name="volume-mute" class="w-4.5 h-4.5" />
    </span>
  </div>
  <span class="absolute -top-9 left-1/2 -translate-x-1/2 px-2 py-1 text-[12px] border border-(--border) font-medium bg-(--bg-subtle) text-(--fg) rounded-(--radius-md) opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-xl">
    Dengarkan
  </span>
</button>

<!-- TTS Player sticky bottom bar -->
<div id="tts-bar" class="tts-bar" aria-hidden="true">
  <div class="tts-bar-inner">
    <div class="tts-progress">
      <div id="tts-fill" class="tts-fill"></div>
    </div>
    <div class="tts-row">
      <span id="tts-label" class="tts-chunk-label"></span>
      <div class="tts-controls">
        <button id="tts-prev" class="tts-btn" aria-label="Sebelumnya">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5"/>
          </svg>
        </button>
        <button id="tts-playpause" class="tts-btn tts-btn--primary" aria-label="Jeda / Lanjut">
          <svg id="ic-pause" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>
          </svg>
          <svg id="ic-play" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
        </button>
        <button id="tts-next" class="tts-btn" aria-label="Berikutnya">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19"/>
          </svg>
        </button>
        <button id="tts-close" class="tts-btn tts-btn--close" aria-label="Tutup">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<style is:global>
	.tts-highlight {
		background: color-mix(in srgb, var(--fg) 12%, transparent);
		border-radius: 2px;
		padding: 2px;
		transition: background 0.25s ease, box-shadow 0.25s ease;
	}

  .tts-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 9999;
    transform: translateY(100%);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid var(--border);
  }

  .tts-bar.tts-bar--visible {
    transform: translateY(0);
  }

  .tts-bar-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1rem 0.75rem;
  }

  .tts-progress {
    height: 2px;
    background: var(--border);
    margin-bottom: 0.6rem;
  }

  .tts-fill {
    height: 100%;
    width: 0%;
    background: var(--fg);
    transition: width 0.3s ease;
  }

  .tts-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tts-chunk-label {
    flex: 1;
    font-size: 12px;
    color: var(--fg-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .tts-controls {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .tts-btn {
    display: flex; align-items: center; justify-content: center;
    width: 2rem; height: 2rem;
    border-radius: 999px; border: none;
    background: transparent; color: var(--fg-muted);
    cursor: pointer;
    transition: color 0.15s, background 0.15s, transform 0.1s;
  }

  .tts-btn svg { width: 0.875rem; height: 0.875rem; }
  .tts-btn:hover { color: var(--fg); background: var(--bg-muted); }
  .tts-btn:active { transform: scale(0.88); }

  .tts-btn--primary {
    background: var(--fg); color: var(--bg);
    width: 2.25rem; height: 2.25rem;
  }
  .tts-btn--primary:hover { background: var(--fg); color: var(--bg); opacity: 0.8; }
  .tts-btn--close { margin-left: 0.125rem; }
</style>

<script>
  (() => {
    if ((window as any).__ttsReady) return;
    (window as any).__ttsReady = true;

    const synth = window.speechSynthesis;

    // ── State
    let chunks: string[]  = [];
    let currentIdx        = 0;
    let isPlaying         = false;
    let isPaused          = false;
    let voice: SpeechSynthesisVoice | null = null;
    let highlightMark: HTMLElement | null  = null;
    let articleEl: HTMLElement | null      = null;

    // ── Voice
    const loadVoice = () => {
      const voices = synth.getVoices();
      voice = voices.find(v => v.lang.startsWith('id')) ?? voices[0] ?? null;
    };
    synth.getVoices().length
      ? loadVoice()
      : synth.addEventListener('voiceschanged', loadVoice, { once: true });

    const SKIP_SELECTORS = [
      // Elemen UI / interaktif
      'button', 'nav', 'aside', 'form', 'input', 'select', 'textarea',
      // 'figcaption',
      // Elemen dengan role non-artikel
      '[role="navigation"]', '[role="complementary"]', '[role="banner"]',
      '[role="contentinfo"]', '[role="search"]', '[role="toolbar"]',
      // Class umum komponen custom di MDX
      '.toc-container', '.tts-bar', '.listen-btn',
      // Code blocks
      'pre', 'code',
      // Script & style
      'script', 'style', 'noscript',
    ].join(', ');

    const extractArticleText = (el: HTMLElement): string => {
      const clone = el.cloneNode(true) as HTMLElement;

      clone.querySelectorAll(SKIP_SELECTORS).forEach(n => n.remove());

      const contentSelectors = 'h1, h2, h3, h4, h5, h6, p, li, blockquote, td, th, figcaption';
      const nodes = clone.querySelectorAll<HTMLElement>(contentSelectors);

      if (nodes.length === 0) {
        // Fallback
        return clone.innerText.replace(/\s+/g, ' ').trim();
      }

      return Array.from(nodes)
        .map(n => n.innerText.trim())
        .filter(t => t.length > 2)
        .join(' ');
    };

    const chunkText = (text: string): string[] =>
      text
        .split(/(?<=[.!?])\s+|(?<=[:;])\s+|\n{2,}/)
        .map(s => s.trim())
        .filter(s => s.length > 3);
        

    // ── Highlight
    let highlightedEl: HTMLElement | null = null;
    
    const clearHighlight = () => {
		highlightedEl?.classList.remove('tts-highlight');
		highlightedEl = null;
	};

    const highlightChunk = (chunk: string) => {
		if (!articleEl) return;
		
		clearHighlight();
		const needleRaw = chunk.slice(0, 40).replace(/\s+/g, ' ').trim();
		
		if (needleRaw.length < 4) return;

		const escaped = needleRaw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
		const re = new RegExp(escaped, 'i');
		const candidates = articleEl.querySelectorAll<HTMLElement>(
			'p, h1, h2, h3, h4, h5, h6, li, blockquote, td'
		);
		for (const el of candidates) {
			if (el.closest('button, nav, aside, [role="navigation"], .toc-container')) continue;
			
			const elText = (el.innerText ?? el.textContent ?? '').replace(/\s+/g, ' ');
			if (!re.test(elText)) continue;
			el.classList.add('tts-highlight');
			
			highlightedEl = el;
			el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			break;
		}
	};

    // ── DOM helpers
    const $ = <T extends HTMLElement>(id: string) =>
      document.getElementById(id) as T | null;

    const setListenBtnState = (playing: boolean) => {
      const ip = $('icon-play'), is = $('icon-stop');
      if (ip) ip.style.cssText = playing
        ? 'opacity:0;transform:scale(0.5)'
        : 'opacity:1;transform:scale(1)';
      if (is) is.style.cssText = playing
        ? 'opacity:1;transform:scale(1)'
        : 'opacity:0;transform:scale(0.5)';
    };

    const setPlayPauseIcon = (paused: boolean) => {
      const pi = $('ic-pause'), pli = $('ic-play');
      if (pi)  pi.style.display  = paused ? 'none' : '';
      if (pli) pli.style.display = paused ? ''     : 'none';
    };

    const updateBar = () => {
      const fill  = $('tts-fill');
      const label = $('tts-label');
      const pct   = chunks.length ? (currentIdx / chunks.length) * 100 : 0;
      if (fill)  fill.style.width     = `${pct}%`;
      if (label) label.textContent    = chunks[currentIdx] ?? '';
    };

    const showBar = () => {
      const bar = $('tts-bar');
      bar?.removeAttribute('aria-hidden');
      bar?.classList.add('tts-bar--visible');
    };

    const hideBar = () => {
      const bar = $('tts-bar');
      bar?.setAttribute('aria-hidden', 'true');
      bar?.classList.remove('tts-bar--visible');
    };

    // ── Core TTS
    const speakAt = (idx: number) => {
      if (idx >= chunks.length) { stopAll(); return; }
      if (idx < 0) idx = 0;

      synth.cancel();
      currentIdx = idx;
      updateBar();

      const utt = new SpeechSynthesisUtterance(chunks[idx]);
      utt.lang = 'id-ID';
      if (voice) utt.voice = voice;

      utt.onstart = () => highlightChunk(chunks[idx]);
      utt.onend   = () => { if (isPlaying) speakAt(currentIdx + 1); };
      utt.onerror = (e) => { if (e.error !== 'interrupted') stopAll(); };

      synth.speak(utt);
      isPlaying = true;
      isPaused  = false;
      setListenBtnState(true);
      setPlayPauseIcon(false);
    };

    const pauseResume = () => {
      if (!isPlaying && !isPaused) return;
      if (synth.paused || isPaused) {
        synth.resume();
        isPaused = false; isPlaying = true;
        setPlayPauseIcon(false);
      } else {
        synth.pause();
        isPaused = true; isPlaying = false;
        setPlayPauseIcon(true);
      }
    };

    const stopAll = () => {
      synth.cancel();
      isPlaying = false; isPaused = false;
      clearHighlight();
      setListenBtnState(false);
      setPlayPauseIcon(false);
      hideBar();
      updateBar();
    };

    // ── Init
    const init = () => {
      $('listen-btn')?.addEventListener('click', () => {
        if (isPlaying || isPaused) { stopAll(); return; }

        articleEl =
          document.getElementById('article-content') ??
          document.querySelector<HTMLElement>('article') ??
          document.querySelector<HTMLElement>('main');

        if (!articleEl) return;

        const text = extractArticleText(articleEl);
        chunks     = chunkText(text);
        currentIdx = 0;

        if (!chunks.length) return;
        showBar();
        speakAt(0);
      });

      $('tts-playpause')?.addEventListener('click', pauseResume);
      $('tts-prev')?.addEventListener('click',      () => speakAt(currentIdx - 1));
      $('tts-next')?.addEventListener('click',      () => speakAt(currentIdx + 1));
      $('tts-close')?.addEventListener('click',     stopAll);
    };

    init();

    document.addEventListener('astro:after-swap', () => {
      synth.cancel();
      isPlaying = false; isPaused = false;
      chunks = []; currentIdx = 0;
      clearHighlight();
      init();
    });
  })();
</script>