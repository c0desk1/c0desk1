---
// src/components/ui/Listen.astro
import Icon from "./Icon.astro";
---

<button
  id="listen-btn"
  aria-label="Dengarkan artikel"
  class="relative p-2 rounded-(--radius-full) text-(--fg-muted) hover:text-(--fg) hover:bg-(--bg-muted) group active:scale-95"
>
  <div class="relative w-4.5 h-4.5 flex items-center justify-center">
    <span id="icon-play" class="absolute inset-0 transition-all duration-300 opacity-100 scale-100">
      <Icon name="volume" class="w-4.5 h-4.5" />
    </span>
    <span id="icon-stop" class="absolute inset-0 transition-all duration-300 opacity-0 scale-50">
      <Icon name="volume-mute" class="w-4.5 h-4.5" />
    </span>
  </div>
  <span class="absolute -top-9 left-1/2 -translate-x-1/2 px-2 py-1 text-[12px] border border-(--border) font-medium bg-(--bg-subtle) text-(--fg) rounded-(--radius-md) opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-xl">
    Dengarkan
  </span>
</button>

<!-- TTS Player — sticky bottom bar -->
<div id="tts-bar" class="tts-bar" aria-hidden="true">
  <div class="tts-bar-inner">

    <!-- Progress -->
    <div class="tts-progress">
      <div id="tts-fill" class="tts-fill"></div>
    </div>

    <!-- Row: label + controls -->
    <div class="tts-row">
      <!-- Chunk label -->
      <span id="tts-label" class="tts-chunk-label">Memuat…</span>

      <!-- Controls -->
      <div class="tts-controls">
        <!-- Prev -->
        <button id="tts-prev" class="tts-btn" aria-label="Sebelumnya">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
            stroke-linecap="round" stroke-linejoin="round">
            <polygon points="19 20 9 12 19 4 19 20"/>
            <line x1="5" y1="19" x2="5" y2="5"/>
          </svg>
        </button>

        <!-- Play/Pause -->
        <button id="tts-playpause" class="tts-btn tts-btn--primary" aria-label="Jeda / Lanjut">
          <svg id="ic-pause" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="4" width="4" height="16"/>
            <rect x="14" y="4" width="4" height="16"/>
          </svg>
          <svg id="ic-play" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
        </button>

        <!-- Next -->
        <button id="tts-next" class="tts-btn" aria-label="Berikutnya">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
            stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 4 15 12 5 20 5 4"/>
            <line x1="19" y1="5" x2="19" y2="19"/>
          </svg>
        </button>

        <!-- Close -->
        <button id="tts-close" class="tts-btn tts-btn--close" aria-label="Tutup">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

  </div>
</div>

<style is:global>
  /* ── Highlight teks yang sedang dibaca ──────────────────────────────────── */
  .tts-highlight {
    background: color-mix(in srgb, var(--fg) 12%, transparent);
    border-radius: 2px;
    transition: background 0.2s;
  }

  /* ── Sticky bottom bar ──────────────────────────────────────────────────── */
  .tts-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    /* slide-in dari bawah */
    transform: translateY(100%);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    /* Backdrop blur untuk efek glass */
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid var(--border);
  }

  .tts-bar.tts-bar--visible {
    transform: translateY(0);
  }

  .tts-bar-inner {
    max-width: 48rem; /* teks artikel max-width, agar sejajar */
    margin: 0 auto;
    padding: 0 1rem 0.75rem;
  }

  /* Progress bar di atas bar */
  .tts-progress {
    height: 2px;
    background: var(--border);
    margin-bottom: 0.6rem;
  }

  .tts-fill {
    height: 100%;
    width: 0%;
    background: var(--fg);
    transition: width 0.3s ease;
  }

  /* Row konten */
  .tts-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Label kalimat aktif — flex-grow, truncate */
  .tts-chunk-label {
    flex: 1;
    font-size: 12px;
    color: var(--fg-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  /* Controls sejajar kanan, tidak shrink */
  .tts-controls {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .tts-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: none;
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    transition: color 0.15s, background 0.15s, transform 0.1s;
  }

  .tts-btn svg {
    width: 0.875rem;
    height: 0.875rem;
  }

  .tts-btn:hover {
    color: var(--fg);
    background: var(--bg-muted);
  }

  .tts-btn:active { transform: scale(0.88); }

  .tts-btn--primary {
    background: var(--fg);
    color: var(--bg);
    width: 2.25rem;
    height: 2.25rem;
  }

  .tts-btn--primary:hover {
    background: var(--fg);
    color: var(--bg);
    opacity: 0.8;
  }

  .tts-btn--close {
    color: var(--fg-muted);
    margin-left: 0.125rem;
  }
</style>

<script>
  (() => {
    // ── Guard: init hanya sekali per lifecycle ──────────────────────────────
    if ((window as any).__ttsReady) return;
    (window as any).__ttsReady = true;

    // ── State ───────────────────────────────────────────────────────────────
    const synth = window.speechSynthesis;
    let chunks: string[] = [];
    let currentIdx = 0;
    let isPlaying  = false;
    let isPaused   = false;
    let voice: SpeechSynthesisVoice | null = null;

    // Untuk highlight
    let articleEl: HTMLElement | null = null;
    let originalHTML = '';
    let highlightMark: HTMLElement | null = null;

    // ── DOM refs (re-query tiap page swap) ─────────────────────────────────
    const $ = <T extends HTMLElement>(id: string) =>
      document.getElementById(id) as T | null;

    const dom = () => ({
      listenBtn   : $<HTMLButtonElement>('listen-btn'),
      iconPlay    : $('icon-play'),
      iconStop    : $('icon-stop'),
      bar         : $('tts-bar'),
      fill        : $('tts-fill'),
      label       : $('tts-label'),
      btnPlayPause: $<HTMLButtonElement>('tts-playpause'),
      icPause     : $('ic-pause'),
      icPlay      : $('ic-play'),
      btnPrev     : $<HTMLButtonElement>('tts-prev'),
      btnNext     : $<HTMLButtonElement>('tts-next'),
      btnClose    : $<HTMLButtonElement>('tts-close'),
    });

    // ── Voice ───────────────────────────────────────────────────────────────
    const loadVoice = () => {
      const voices = synth.getVoices();
      voice = voices.find(v => v.lang.startsWith('id')) ?? voices[0] ?? null;
    };
    if (synth.getVoices().length) {
      loadVoice();
    } else {
      synth.addEventListener('voiceschanged', loadVoice, { once: true });
    }

    // ── Text chunking ───────────────────────────────────────────────────────
    const chunkText = (text: string): string[] =>
      text
        .split(/(?<=[.!?])\s+|(?<=[:;])\s+|\n{2,}/)
        .map(s => s.trim())
        .filter(s => s.length > 3);

    // ── Highlight helpers ───────────────────────────────────────────────────
    // Bungkus kata/kalimat yang sedang dibaca dengan <mark class="tts-highlight">
    // Strategi: simpan innerHTML asli, cari chunk di innerText, wrap dengan mark.
    // Hanya jalan di browser yang support onboundary (Chrome/Edge).

    const clearHighlight = () => {
      if (!highlightMark) return;
      highlightMark.replaceWith(...Array.from(highlightMark.childNodes));
      highlightMark = null;
    };

    const highlightChunk = (chunkText: string) => {
      if (!articleEl) return;
      clearHighlight();

      // Cari TextNode yang mengandung kalimat ini
      const walker = document.createTreeWalker(
        articleEl,
        NodeFilter.SHOW_TEXT,
        null
      );

      const needle = chunkText.slice(0, 40).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const re = new RegExp(needle);

      let node: Text | null;
      while ((node = walker.nextNode() as Text | null)) {
        if (!re.test(node.textContent ?? '')) continue;

        // Wrap seluruh textNode dengan <mark>
        const mark = document.createElement('mark');
        mark.className = 'tts-highlight';
        node.parentNode?.insertBefore(mark, node);
        mark.appendChild(node);
        highlightMark = mark;

        // Scroll ke highlight jika di luar viewport
        mark.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        break;
      }
    };

    // ── UI helpers ──────────────────────────────────────────────────────────
    const setListenBtnState = (playing: boolean) => {
      const d = dom();
      if (d.iconPlay) d.iconPlay.style.cssText =
        playing ? 'opacity:0;transform:scale(0.5)' : 'opacity:1;transform:scale(1)';
      if (d.iconStop) d.iconStop.style.cssText =
        playing ? 'opacity:1;transform:scale(1)' : 'opacity:0;transform:scale(0.5)';
    };

    const setPlayPauseIcon = (paused: boolean) => {
      const d = dom();
      if (d.icPause) d.icPause.style.display = paused ? 'none' : '';
      if (d.icPlay)  d.icPlay.style.display  = paused ? ''     : 'none';
    };

    const updateBar = () => {
      const d = dom();
      const pct = chunks.length ? (currentIdx / chunks.length) * 100 : 0;
      if (d.fill)  d.fill.style.width = `${pct}%`;
      if (d.label) d.label.textContent = chunks[currentIdx] ?? '';
    };

    const showBar = () => {
      const d = dom();
      d.bar?.removeAttribute('aria-hidden');
      d.bar?.classList.add('tts-bar--visible');
    };

    const hideBar = () => {
      const d = dom();
      d.bar?.setAttribute('aria-hidden', 'true');
      d.bar?.classList.remove('tts-bar--visible');
    };

    // ── Core TTS ────────────────────────────────────────────────────────────
    const speakAt = (idx: number) => {
      if (idx >= chunks.length) { stopAll(); return; }
      if (idx < 0) idx = 0;

      synth.cancel();
      currentIdx = idx;
      updateBar();

      const utt = new SpeechSynthesisUtterance(chunks[idx]);
      utt.lang = 'id-ID';
      if (voice) utt.voice = voice;

      // Auto-highlight: trigis saat utterance mulai
      utt.onstart = () => highlightChunk(chunks[idx]);

      utt.onend = () => {
        if (!isPlaying) return;
        speakAt(currentIdx + 1);
      };
      utt.onerror = (e) => {
        if (e.error === 'interrupted') return;
        stopAll();
      };

      synth.speak(utt);
      isPlaying = true;
      isPaused  = false;
      setListenBtnState(true);
      setPlayPauseIcon(false);
    };

    const pauseResume = () => {
      if (!isPlaying && !isPaused) return;
      if (synth.paused || isPaused) {
        synth.resume();
        isPaused  = false;
        isPlaying = true;
        setPlayPauseIcon(false);
      } else {
        synth.pause();
        isPaused  = true;
        isPlaying = false;
        setPlayPauseIcon(true);
      }
    };

    const stopAll = () => {
      synth.cancel();
      isPlaying = false;
      isPaused  = false;
      clearHighlight();
      setListenBtnState(false);
      setPlayPauseIcon(false);
      hideBar();
      updateBar();
    };

    // ── Init event listeners ────────────────────────────────────────────────
    const init = () => {
      const d = dom();

      d.listenBtn?.addEventListener('click', () => {
        if (isPlaying || isPaused) { stopAll(); return; }

        articleEl =
          document.getElementById('article-content') ??
          document.querySelector<HTMLElement>('article') ??
          document.querySelector<HTMLElement>('main');

        if (!articleEl) return;

        originalHTML = articleEl.innerHTML;
        const text   = articleEl.innerText.replace(/\s+/g, ' ').trim();
        chunks       = chunkText(text);
        currentIdx   = 0;

        if (!chunks.length) return;
        showBar();
        speakAt(0);
      });

      d.btnPlayPause?.addEventListener('click', pauseResume);
      d.btnPrev?.addEventListener('click',  () => speakAt(currentIdx - 1));
      d.btnNext?.addEventListener('click',  () => speakAt(currentIdx + 1));
      d.btnClose?.addEventListener('click', stopAll);
    };

    init();

    // Page swap: reset & re-attach
    document.addEventListener('astro:after-swap', () => {
      synth.cancel();
      isPlaying = false;
      isPaused  = false;
      chunks    = [];
      currentIdx = 0;
      clearHighlight();
      init();
    });
  })();
</script>