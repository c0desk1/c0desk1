---
// src/components/ui/Listen.astro
import Icon from "./Icon";
import { siteConfig } from "@/config/site";


const labels = {
  listen: siteConfig.listen,
  listening: siteConfig.listening,
  listenAria: siteConfig.listenAria,
  stopAria: siteConfig.stopAria,
  prev: siteConfig.ttsPrev,
  next: siteConfig.ttsNext,
  playPause: siteConfig.ttsPlayPause,
  close: siteConfig.ttsClose,
  ttsLang: 'en-US',
};
---

<button
  id="listen-btn"
  aria-label={labels.listenAria}
  title={labels.listenAria}
  class="relative flex items-center gap-1.5 text-muted hover:text-(--fg) group active:scale-95">
  <div class="flex shrink-0 items-center justify-center gap-1.5">
    <div class="relative w-4 h-4 items-center">
      <span id="icon-play" class="absolute inset-0 transition-all duration-300 opacity-100 scale-100">
        <Icon name="volume" className="w-4 h-4" />
      </span>
      <span id="icon-stop" class="absolute inset-0 transition-all duration-300 opacity-0 scale-100">
        <Icon name="volume-mute" className="w-4 h-4" />
      </span>
    </div>
    <span id="listen-text" class="text-button-14">
      {labels.listen}
    </span>
  </div>
</button>

<div id="tts-bar" class="tts-bar" aria-hidden="true">
  <div class="tts-bar-inner">
    <div class="tts-progress">
      <div id="tts-fill" class="tts-fill"></div>
    </div>
    <div class="tts-row">
      <span id="tts-label" class="tts-chunk-label"></span>
      <div class="tts-controls">
        <button id="tts-prev" class="tts-btn" aria-label={labels.prev} title={labels.prev}>
          <Icon name="prev" className="w-4.5 h-4.5" />
        </button>
        <button id="tts-playpause" class="tts-btn tts-btn--primary relative" aria-label={labels.playPause} title={labels.playPause}>
          <span id="ic-pause">
            <Icon name="pause" className="w-4.5 h-4.5" />
          </span>
          <span id="ic-play" style="display: none">
            <Icon name="play" className="w-4.5 h-4.5" />
          </span>
        </button>
        <button id="tts-next" class="tts-btn" aria-label={labels.next} title={labels.next}>
          <Icon name="next" className="w-4.5 h-4.5" />
        </button>
        <button id="tts-close" class="tts-btn tts-btn--close" aria-label={labels.close} title={labels.close}>
          <Icon name="close" className="w-4.5 h-4.5" />
        </button>
      </div>
    </div>
  </div>
</div>

<style is:global>
	.tts-highlight {
  	background: color-mix(in srgb, var(--fg) 6%, transparent);
  	border-radius: 6px;
  	padding: 2px 4px;
  	margin: -2px -4px;
  	box-shadow: 0 0 0 1px color-mix(in srgb, var(--fg) 12%, transparent);
  	animation: tts-pulse 1.5s ease-in-out infinite;
	}

	@keyframes tts-pulse {
  	0%, 100% {
    	background: color-mix(in srgb, var(--fg) 6%, transparent);
    	box-shadow: 0 0 0 1px color-mix(in srgb, var(--fg) 12%, transparent);
  	}
  	50% {
    	background: color-mix(in srgb, var(--fg) 10%, transparent);
    	box-shadow: 0 0 0 1px color-mix(in srgb, var(--fg) 20%, transparent);
  	}
	}
	
	@media (prefers-reduced-motion: reduce) {
  	.tts-highlight,
  	.tts-highlight::before {
    	animation: none;
    	transition: none;
  	}
	}

	.prose-custom p,
	.prose-custom li {
  	transition: background 0.2s ease;
	}

  .tts-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 9999;
    transform: translateY(100%);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid var(--border);
  }

  .tts-bar.tts-bar--visible {
    transform: translateY(0);
  }

  .tts-bar-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1rem 0.75rem;
  }

  .tts-progress {
    height: 2px;
    background: var(--border);
    margin-bottom: 0.6rem;
  }

  .tts-fill {
    height: 100%;
    width: 0%;
    background: var(--fg);
    transition: width 0.3s ease;
  }

  .tts-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tts-chunk-label {
    flex: 1;
    font-size: 12px;
    color: var(--fg-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .tts-controls {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .tts-btn {
    display: flex; align-items: center; justify-content: center;
    width: 2rem; height: 2rem;
    border-radius: 999px; border: none;
    background: transparent; color: var(--fg-muted);
    cursor: pointer;
    transition: color 0.15s, background 0.15s, transform 0.1s;
  }

  .tts-btn:hover { color: var(--fg); background: var(--bg-muted); }
  .tts-btn:active { transform: scale(0.88); }

  .tts-btn--primary {
    background: var(--fg); color: var(--bg);
    width: 2.25rem; height: 2.25rem;
  }
  .tts-btn--primary:hover { background: var(--fg); color: var(--bg); opacity: 0.8; }
  .tts-btn--close { margin-left: 0.125rem; }
</style>

<script define:vars={{ labels }}>
  (() => {
    if (window.__ttsReady) return;
    window.__ttsReady = true;

    const synth = window.speechSynthesis;

    let chunks = [];
    let currentIdx = 0;
    let isPlaying = false;
    let isPaused = false;
    let wasStoppedByBrowser = false;
    let voice = null;
    let articleEl = null;

    const loadVoice = () => {
      const voices = synth.getVoices();
      voice = voices.find(v => v.lang.startsWith(labels.ttsLang.split('-')[0]))?? voices[0]?? null;
    };
    synth.getVoices().length
     ? loadVoice()
      : synth.addEventListener('voiceschanged', loadVoice, { once: true });

    const SKIP_SELECTORS = [
      'button', 'nav', 'aside', 'form', 'input', 'select', 'textarea',
      '[role="navigation"]', '[role="complementary"]', '[role="banner"]',
      '[role="contentinfo"]', '[role="search"]', '[role="toolbar"]',
      '.toc-container', '.tts-bar', '.listen-btn',
      'pre', 'code', 'script', 'style', 'noscript',
    ].join(', ');

    const getChunksFromArticle = (el) => {
      const clone = el.cloneNode(true);
      clone.querySelectorAll(SKIP_SELECTORS).forEach(n => n.remove());
      const contentSelectors = 'h1, h2, h3, h4, h5, h6, p, li, blockquote, td, th, figcaption';
      const nodes = clone.querySelectorAll(contentSelectors);
      const chunks = [];
      nodes.forEach(n => {
        const text = n.innerText.trim().replace(/\s+/g, ' ');
        if (text.length < 3) return;
        if (n.tagName.startsWith('H') || text.length < 150) {
          chunks.push(text);
        } else {
          const sentences = text.split(/(?<=[.!?])\s+/).filter(s => s.length > 3);
          chunks.push(...sentences);
        }
      });
      return chunks;
    };

    let highlightedEl = null;
    const clearHighlight = () => {
      highlightedEl?.classList.remove('tts-highlight');
      highlightedEl = null;
    };

    const HEADER_H = 56;
    const TOC_TOP = 60;
    const TTS_OFFSET = HEADER_H + TOC_TOP + 16;

    const highlightChunk = (chunk) => {
      if (!articleEl) return;
      clearHighlight();
      const needle = chunk.trim();
      if (needle.length < 3) return;

      const candidates = articleEl.querySelectorAll('p, h1, h2, h3, h4, h5, h6, li, blockquote, td');
      let found = null;

      for (const el of candidates) {
        const elText = (el.innerText?? el.textContent?? '').trim();
        if (elText === needle) {
          found = el;
          break;
        }
      }

      if (!found) {
        const needleRaw = needle.slice(0, 40).replace(/\s+/g, ' ').trim();
        const escaped = needleRaw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const re = new RegExp(escaped, 'i');
        for (const el of candidates) {
          if (el.closest('button, nav, aside, [role="navigation"],.toc-container')) continue;
          const elText = (el.innerText?? el.textContent?? '').replace(/\s+/g, ' ');
          if (re.test(elText)) {
            found = el;
            break;
          }
        }
      }

      if (!found) return;
      found.classList.add('tts-highlight');
      highlightedEl = found;
      const rect = found.getBoundingClientRect();
      const absoluteTop = window.pageYOffset + rect.top;
      const targetY = absoluteTop - TTS_OFFSET;
      window.scrollTo({ top: targetY, behavior: 'smooth' });
    };

    const $ = (id) => document.getElementById(id);
    const listenText = $('listen-text');
    const btn = $('listen-btn');

    const setListenBtnState = (playing) => {
      const ip = $('icon-play'), is = $('icon-stop');
      if (ip) ip.style.cssText = playing? 'opacity:0;transform:scale(0.5)' : 'opacity:1;transform:scale(1)';
      if (is) is.style.cssText = playing? 'opacity:1;transform:scale(1)' : 'opacity:0;transform:scale(0.5)';
      if (listenText) listenText.textContent = playing? labels.listening : labels.listen;
      if (btn) btn.setAttribute('aria-label', playing? labels.stopAria : labels.listenAria);
    };

    const setPlayPauseIcon = (paused) => {
      const pi = $('ic-pause'), pli = $('ic-play');
      if (pi) pi.style.display = paused? 'none' : '';
      if (pli) pli.style.display = paused? '' : 'none';
    };

    const updateBar = () => {
      const fill = $('tts-fill');
      const label = $('tts-label');
      const pct = chunks.length? (currentIdx / chunks.length) * 100 : 0;
      if (fill) fill.style.width = `${pct}%`;
      if (label) label.textContent = chunks[currentIdx]?? '';
    };

    const showBar = () => {
      const bar = $('tts-bar');
      bar?.removeAttribute('aria-hidden');
      bar?.classList.add('tts-bar--visible');
    };

    const hideBar = () => {
      const bar = $('tts-bar');
      bar?.setAttribute('aria-hidden', 'true');
      bar?.classList.remove('tts-bar--visible');
    };

    const speakAt = (idx) => {
      if (idx >= chunks.length) { stopAll(); return; }
      if (idx < 0) idx = 0;
      
      synth.cancel();
      currentIdx = idx;
      updateBar();

      const RATE = 0.95;
      const PAUSE_BETWEEN = 250;

      const utt = new SpeechSynthesisUtterance(chunks[idx]);
      utt.lang = labels.ttsLang;
      utt.rate = RATE;

      if (voice) utt.voice = voice;

      utt.onstart = () => {
        highlightChunk(chunks[idx]);
        isPlaying = true;
        isPaused = false;
        wasStoppedByBrowser = false;
        setListenBtnState(true);
        setPlayPauseIcon(false);
      };
      utt.onend = () => {
        if (isPlaying) {
          setTimeout(() => {
            if (isPlaying) speakAt(currentIdx + 1);
          }, PAUSE_BETWEEN);
        }
      };
      utt.onerror = (e) => {
        if (e.error === 'interrupted' || e.error === 'canceled') {
          wasStoppedByBrowser = true;
          isPlaying = false;
          isPaused = true;
          setListenBtnState(false);
          setPlayPauseIcon(true);
        } else {
          stopAll();
        }
      };
      synth.speak(utt);
    };

    const playPause = () => {
      if (isPlaying) {
        synth.cancel();
        isPlaying = false;
        setListenBtnState(false);
        setPlayPauseIcon(false);
      } else {
        speakAt(currentIdx);
      }
    };

    document.addEventListener('visibilitychange', () => {
      if (document.hidden && isPlaying) {
        synth.cancel();
        isPlaying = false;
        setListenBtnState(false);
        setPlayPauseIcon(false);
      }
    });

    const stopAll = () => {
      synth.cancel();
      isPlaying = false;
      isPaused = false;
      wasStoppedByBrowser = false;
      clearHighlight();
      setListenBtnState(false);
      setPlayPauseIcon(false);
      hideBar();
      updateBar();
    };

    const init = () => {
      $('listen-btn')?.addEventListener('click', () => {
        if (isPlaying || isPaused) { stopAll(); return; }
        articleEl = document.getElementById('article-content')?? document.querySelector('article')?? document.querySelector('main');
        if (!articleEl) return;
        chunks = getChunksFromArticle(articleEl);
        currentIdx = 0;
        if (!chunks.length) return;
        showBar();
        speakAt(0);
      });
      $('tts-playpause')?.addEventListener('click', playPause);
      $('tts-prev')?.addEventListener('click', () => speakAt(currentIdx - 1));
      $('tts-next')?.addEventListener('click', () => speakAt(currentIdx + 1));
      $('tts-close')?.addEventListener('click', stopAll);
    };

    init();
    document.addEventListener('astro:after-swap', () => {
      synth.cancel();
      isPlaying = false; isPaused = false;
      chunks = []; currentIdx = 0;
      clearHighlight();
      init();
    });
  })();
</script>
