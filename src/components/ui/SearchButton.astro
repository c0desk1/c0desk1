---
// src/components/ui/SearchButton.astro
import Icon from "./Icon.astro";
---

<button
  id="search-trigger"
  type="button"
  aria-label="Search"
  class="group relative flex items-center justify-center sm:justify-between gap-2 p-2 sm:px-3 sm:py-1.5 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white sm:bg-zinc-100/50 sm:dark:bg-zinc-800/50 sm:border sm:border-zinc-200/60 sm:dark:border-zinc-800 rounded-md sm:rounded-xl hover:bg-zinc-100 dark:hover:bg-zinc-800/80 sm:hover:border-zinc-300 dark:sm:hover:border-zinc-700 transition-all duration-200 cursor-pointer"
>
  <div class="flex items-center gap-2">
    <Icon name="search" class="w-4 h-4" />
    <span class="hidden sm:inline text-sm text-zinc-400 dark:text-zinc-500">Cari...</span>
  </div>
  <kbd class="hidden sm:inline-flex items-center px-1.5 py-0.5 text-xs font-mono text-zinc-400 bg-white dark:bg-black border border-zinc-200/60 dark:border-zinc-800 rounded-sm">
    ⌘+K
  </kbd>
</button>

<script>
  const openSearch = () => {
    document.dispatchEvent(new CustomEvent("open-search"));
  };

  document.getElementById("search-trigger")?.addEventListener("click", openSearch);

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      openSearch();
    }
  });
</script>