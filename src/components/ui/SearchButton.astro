---
// src/components/ui/SearchButton.astro
import Icon from "./Icon";
---

<button
  id="search-trigger"
  type="button"
  aria-label="Search"
  class="group flex items-center justify-center sm:justify-between gap-2
       w-auto sm:w-[280px] md:w-[360px]
       p-2 sm:px-3 sm:py-2
       rounded-(--radius-lg)
       sm:border sm:border-(--border-strong)
       sm:hover:bg-(--bg-muted)
       backdrop-blur-md
  focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--border-strong)"
>
  <div class="flex items-center gap-2 text-(--fg-muted)">
    <Icon name="search" class="w-5 h-5" />
    <span class="hidden sm:inline text-sm">Search...</span>
  </div>

  <kbd class="hidden sm:inline-flex items-center gap-1 px-2 py-0.5 text-xs font-mono
               text-(--fg)
               bg-(--bg-muted)
               border border-(--border-strong) rounded-md">
    ⌘K
  </kbd>
</button>

<script>
  const openSearch = () => {
    document.dispatchEvent(new CustomEvent("open-search"));
  };

  const btn = document.getElementById("search-trigger");
  btn?.addEventListener("click", openSearch);

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      openSearch();
    }
  });
</script>
