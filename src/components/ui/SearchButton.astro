---
// src/components/ui/SearchButton.astro
import Icon from "./Icon";
---

<button
  id="search-trigger"
  type="button"
  aria-label="Search"
  class="group flex items-center justify-center sm:justify-between gap-2 w-auto sm:w-[280px] md:w-[360px] p-2 sm:px-3 sm:py-2 rounded-full border border-(--border) sm:rounded-(--radius-lg) sm:border-(--border-strong)/50 sm:hover:bg-(--bg-muted) transition-all duration-200">
  <div class="flex items-center gap-2 text-(--fg) sm:text-(--fg-muted)">
    <Icon name="search" className="w-5 h-5" />
    <span class="hidden sm:inline text-sm">Cari...</span>
  </div>

  <kbd class="hidden sm:inline-flex items-center gap-1 px-2 py-0.5 text-[13px] font-mono text-(--fg) bg-(--bg-muted) border border-(--border-strong) rounded-md">
    ⌘K
  </kbd>
</button>

<script>
  const openSearch = () => {
    document.dispatchEvent(new CustomEvent("open-search"));
  };

  const btn = document.getElementById("search-trigger");
  btn?.addEventListener("click", openSearch);

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      openSearch();
    }
  });
</script>
