---
// src/components/ui/SearchButton.astro
import Icon from "./Icon.astro";
---

<button
  id="search-trigger"
  type="button"
  aria-label="Search"
  class="group flex items-center justify-center sm:justify-between gap-2
       w-auto sm:w-[280px] md:w-[360px]
       p-2 sm:px-3 sm:py-2
       rounded-xl
       sm:bg-white/70 sm:dark:bg-black/40
       sm:border sm:border-neutral-200 sm:dark:border-neutral-800
       sm:hover:bg-white sm:dark:hover:bg-neutral-900
       backdrop-blur-md"
>
  <div class="flex items-center gap-2 text-neutral-500 dark:text-neutral-400">
    <Icon name="search" class="w-4 h-4" />
    <span class="hidden sm:inline text-sm">Search...</span>
  </div>

  <kbd class="hidden sm:inline-flex items-center gap-1 px-2 py-0.5 text-xs font-mono
               text-neutral-500 dark:text-neutral-400
               bg-neutral-100 dark:bg-neutral-900
               border border-neutral-200 dark:border-neutral-800 rounded-md">
    ⌘K
  </kbd>
</button>

<script>
  const openSearch = () => {
    document.dispatchEvent(new CustomEvent("open-search"));
  };

  const btn = document.getElementById("search-trigger");
  btn?.addEventListener("click", openSearch);

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      openSearch();
    }
  });
</script>