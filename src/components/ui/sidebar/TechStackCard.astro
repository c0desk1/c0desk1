---
// src/components/ui/sidebar/TechStackCard.astro

interface Props {
  techs: string[];
}

const { techs } = Astro.props;
---

{techs.length > 0 && (
  <div>

    <div class="flex items-center gap-2 mb-3">
      <div class="h-1.5 w-1.5 rounded-full bg-emerald-500"></div>
      <h3 class="text-sm font-bold tracking-wider text-zinc-500 dark:text-zinc-400">
        Tech Stack
      </h3>
    </div>

    <div class="flex flex-wrap gap-1.5">
      {techs.map(tech => (
        <span class="px-2 py-1 text-xs border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-400">
          {tech}
        </span>
      ))}
    </div>

  </div>
)}