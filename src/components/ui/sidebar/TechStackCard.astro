---
// src/components/ui/sidebar/TechStackCard.astro
interface Props {
  techs: string[];
}

const { techs } = Astro.props;
---

{techs.length > 0 && (
  <div>
    <div class="flex items-center gap-2 mb-3">
      <div class="h-1.5 w-1.5 rounded-full bg-emerald-500"></div>
      <h3 class="text-[11px] font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
        Tech stack
      </h3>
    </div>
    <div class="flex flex-wrap gap-1.5">
      {techs.map(tech => (
        <span 
          class="px-2 py-1 text-[11px] font-mono bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 font-medium"
        >
          {tech}
        </span>
      ))}
    </div>
  </div>
)}