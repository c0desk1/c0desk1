---
// src/components/blog/sidebar/TagsCard.astro

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <div>
    <div class="flex items-center gap-2 mb-3">
      <div class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-500"></div>
      <h2 class="text-sm text-zinc-500 dark:text-zinc-400">
        Tag
      </h2>
    </div>
    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <a 
          href={`/blog/tags/${encodeURIComponent(tag)}`}
          class="px-2 py-1 text-xs border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-900 hover:border-zinc-300 dark:hover:border-zinc-700 transition-all"
        >
          #{tag}
        </a>
      ))}
    </div>
  </div>
)}