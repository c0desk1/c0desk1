---
// src/components/blog/sidebar/TagsCard.astro

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <span
        class="
          font-mono
          font-semibold
          text-emerald-600 dark:text-emerald-500
        "
        aria-hidden="true"
      >
        ▼
      </span>
      <h2
        class="
          text-xs
          font-medium
          tracking-wide
          text-zinc-500 dark:text-zinc-400
        "
      >
        Tag
      </h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <a 
          href={`/blog/tags/${encodeURIComponent(tag)}`}
          class="
            inline-flex
            items-center
            px-2 py-1
            text-xs
            font-medium
            text-zinc-500
            dark:text-zinc-400
            hover:text-zinc-950
            dark:hover:text-zinc-100
            transition-colors
          "
        >
          #{tag}
        </a>
      ))}
    </div>
  </div>
)}