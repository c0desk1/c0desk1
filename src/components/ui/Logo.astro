---
// src/components/ui/Logo.astro
import { siteConfig } from "@/config/site";
import Icon from "./Icon";
import { SITE } from "@/consts";


const siteData = siteConfig;
const homeHref = '/';
const homeLabel = siteData.home;
---

<a href={homeHref} class="nav-logo group flex items-center justify-center gap-2.5 transition-all duration-200 hover:opacity-80" aria-label={homeLabel}>
  <div class="flex items-center gap-4">
    <Icon name="logo" className="logo-icon text-(--fg)" />
    {SITE.name}
  </div>
</a>

<style is:global>
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .logo-icon {
    width: 28px;
    height: 28px;
  }
</style>