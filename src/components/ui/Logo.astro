---
// src/components/ui/Logo.astro
import Icon from "./Icon";
import { siteConfig } from "@/config/site";
import { getEntry } from 'astro:content';


let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {
  console.warn('Settings not found, using siteConfig fallback');
}
const siteData = settings?.data || siteConfig;
---

<a 
  href="/" 
  class="group flex items-center justify-center gap-2.5 transition-all duration-200 hover:opacity-80"
  aria-label="Home"
>
  <div class="relative">
    <Icon name="logo" className="w-5 h-5 text-(--fg)" />
    <div class="absolute inset-0 blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <Icon name="logo" className="w-5 h-5 text-(--fg)" />
    </div>
  </div>
  <span class="text-xl font-semibold tracking-tight text-(--fg) hidden sm:inline">
    {siteData.siteName}
  </span>
</a>
