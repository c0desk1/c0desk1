---
// src/components/ui/Logo.astro
import Icon from "./Icon";
import { siteConfig } from "@/config/site";
import { getCurrentLocale, localizePath, getLabel } from "@/utils/i18n";

const siteData = siteConfig;
const locale = getCurrentLocale(Astro);
const homeHref = localizePath('/', locale);
const homeLabel = getLabel(locale, 'home');
---

<a 
  href={homeHref} 
  class="group flex items-center justify-center gap-2.5 transition-all duration-200 hover:opacity-80"
  aria-label={homeLabel}
>
  <div class="relative">
    <Icon name="logo" className="w-5 h-5 text-(--fg)" />
    <div class="absolute inset-0 blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <Icon name="logo" className="w-5 h-5 text-(--fg)" />
    </div>
  </div>
  <span class="text-xl font-semibold font-mono tracking-tight text-(--fg) hidden sm:inline">
    {siteData.siteName}
  </span>
</a>