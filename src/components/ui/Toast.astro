---
// src/components/ui/Toast.astro
---

<script>
  (() => {
    type ToastType = 'success' | 'error' | 'info';

    interface ToastOptions {
      duration?: number;
      type?: ToastType;
    }

    let root: HTMLElement | null = null;

    const getRoot = (): HTMLElement => {
      if (root && root.isConnected) return root;

      root = document.getElementById('toast-root') as HTMLElement | null;

      if (!root) {
        root = document.createElement('div');
        root.id = 'toast-root';
        document.body.appendChild(root);
      }

      return root;
    };

    const ICONS: Record<ToastType, string> = {
      success: `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      `,

      error: `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      `,

      info: `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="9"/>
          <path d="M12 8v4M12 16v.01" stroke-linecap="round"/>
        </svg>
      `,
    };

    const DOT_COLOR: Record<ToastType, string> = {
      success: '#22c55e',
      error: '#ef4444',
      info: '#3b82f6',
    };

    const show = (message: string, opts: ToastOptions = {}) => {
      const { duration = 3500, type = 'info' } = opts;

      const r = getRoot();

      const toast = document.createElement('div');

      toast.className = 'ck-toast';

      toast.setAttribute('role', 'alert');
      toast.setAttribute('aria-live', 'polite');
      toast.setAttribute('tabindex', '0');

      toast.innerHTML = `
        <div class="ck-toast-icon" style="color:${DOT_COLOR[type]}">
          ${ICONS[type]}
        </div>

        <span class="ck-toast-msg">${message}</span>

        <button class="ck-toast-close" aria-label="Tutup notifikasi">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>

        <div class="ck-toast-progress">
          <div
            class="ck-toast-bar"
            style="animation-duration:${duration}ms"
          ></div>
        </div>
      `;

      r.appendChild(toast);

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          toast.classList.add('ck-toast--in');
        });
      });

      let dismissed = false;

      const dismiss = () => {
        if (dismissed) return;

        dismissed = true;

        toast.classList.remove('ck-toast--in');
        toast.classList.add('ck-toast--out');

        toast.addEventListener(
          'transitionend',
          () => toast.remove(),
          { once: true }
        );

        setTimeout(() => {
          if (toast.isConnected) toast.remove();
        }, 400);
      };

      toast
        .querySelector('.ck-toast-close')
        ?.addEventListener('click', dismiss);

      let timeoutId = setTimeout(dismiss, duration);

      toast.addEventListener('mouseenter', () => {
        clearTimeout(timeoutId);

        toast.querySelector<HTMLElement>(
          '.ck-toast-bar'
        )!.style.animationPlayState = 'paused';
      });

      toast.addEventListener('mouseleave', () => {
        toast.querySelector<HTMLElement>(
          '.ck-toast-bar'
        )!.style.animationPlayState = 'running';

        clearTimeout(timeoutId);

        timeoutId = setTimeout(dismiss, 800);
      });

      let startX = 0;

      toast.addEventListener(
        'touchstart',
        (e) => {
          startX = e.touches[0].clientX;
        },
        { passive: true }
      );

      toast.addEventListener(
        'touchend',
        (e) => {
          if (
            Math.abs(
              e.changedTouches[0].clientX - startX
            ) > 60
          ) {
            dismiss();
          }
        },
        { passive: true }
      );
    };

    (window as any).toast = { show };

    if (!document.getElementById('ck-toast-style')) {
      const s = document.createElement('style');

      s.id = 'ck-toast-style';

      s.textContent = `
        #toast-root {
          position: fixed;
          top: 1.25rem;
          left: 1.25rem;
          right: auto;

          z-index: 10100;

          display: flex;
          flex-direction: column;
          align-items: flex-start;
          gap: 0.5rem;

          max-height: calc(100vh - 2rem);
          overflow-y: auto;

          pointer-events: none;
        }

        #toast-root::-webkit-scrollbar {
          display: none;
        }

        .ck-toast {
          position: relative;

          display: flex;
          align-items: center;
          gap: 0.625rem;

          width: min(20rem, calc(100vw - 2.5rem));

          padding: 0.75rem 0.875rem;
          padding-bottom: 0.875rem;

          overflow: hidden;

          background: var(--bg);
          border: 1.5px solid var(--border);
          border-radius: var(--radius-lg, 0.75rem);

          box-shadow:
            0 4px 6px -1px rgba(0,0,0,.06),
            0 12px 24px -4px rgba(0,0,0,.1);

          pointer-events: all;
          cursor: default;

          opacity: 0;

          transform:
            translateX(-1.5rem)
            scale(0.97);

          transition:
            opacity 0.25s ease,
            transform 0.3s cubic-bezier(0.34, 1.4, 0.64, 1);
        }

        .ck-toast--in {
          opacity: 1;

          transform:
            translateX(0)
            scale(1);
        }

        .ck-toast--out {
          opacity: 0;

          transform:
            translateX(-2rem)
            scale(0.96);

          transition:
            opacity 0.2s ease,
            transform 0.2s ease;
        }

        .ck-toast-icon {
          width: 1.125rem;
          height: 1.125rem;

          flex-shrink: 0;

          display: flex;
          align-items: center;
          justify-content: center;
        }

        .ck-toast-icon svg {
          width: 100%;
          height: 100%;
        }

        .ck-toast-msg {
          flex: 1;

          min-width: 0;

          font-size: 0.8125rem;
          line-height: 1.4;

          color: var(--fg);
        }

        .ck-toast-close {
          width: 1.25rem;
          height: 1.25rem;

          flex-shrink: 0;

          display: flex;
          align-items: center;
          justify-content: center;

          padding: 0;

          background: transparent;
          border: none;
          border-radius: 4px;

          color: var(--fg-muted);

          cursor: pointer;

          transition:
            color 0.15s,
            background 0.15s;
        }

        .ck-toast-close:hover {
          color: var(--fg);
          background: var(--bg-muted);
        }

        .ck-toast-close svg {
          width: 0.75rem;
          height: 0.75rem;
        }

        .ck-toast-progress {
          position: absolute;

          left: 0;
          right: 0;
          bottom: 0;

          height: 2px;

          background: var(--border);
        }

        .ck-toast-bar {
          height: 100%;

          background: var(--fg);

          opacity: 0.35;

          transform-origin: left;

          animation:
            ck-toast-drain linear forwards;
        }

        @keyframes ck-toast-drain {
          from {
            transform: scaleX(1);
          }

          to {
            transform: scaleX(0);
          }
        }

        @media (max-width: 480px) {
          #toast-root {
            top: auto;
            left: 0;
            right: 0;
            bottom: 1.25rem;

            padding:
              0
              0.75rem
              0.75rem;

            align-items: stretch;

            gap: 0.375rem;
          }

          .ck-toast {
            width: 100%;

            transform:
              translateY(0.75rem)
              scale(0.97);
          }

          .ck-toast--in {
            transform:
              translateY(0)
              scale(1);
          }

          .ck-toast--out {
            transform:
              translateY(1rem)
              scale(0.96);
          }
        }
      `;

      document.head.appendChild(s);
    }
  })();
</script>
