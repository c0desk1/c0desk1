---
// src/components/ui/Section.astro

type ElementTag = 'section' | 'div';

type Size = 'sm' | 'md' | 'lg' | 'xl' | 'none';

interface Props {
  as?: ElementTag;
  size?: Size;
  class?: string;
}

const props = Astro.props as Props;

const {
  as: Component = 'section',
  size = 'lg',
  class: className = '',
} = props;

// Vertical spacing scale
const sizeClasses: Record<Size, string> = {
  none: '',
  sm: 'py-8',
  md: 'py-12',
  lg: 'py-16',
  xl: 'py-24',
};

const spacingClass = sizeClasses[size];

const classes = [
  spacingClass,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Component class={classes}>
  <slot />
</Component>