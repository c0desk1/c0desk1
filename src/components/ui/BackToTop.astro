---
// src/components/ui/BackToTop.astro

interface Props {
  showBorder?: boolean;
  align?: 'left' | 'center' | 'right';
}

const { showBorder = true, align = 'left' } = Astro.props;

const alignClasses = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right'
};
---

<div class:list={[
  showBorder ? 'section-divider pt-4 md:pt-8' : '',
  alignClasses[align]
]}>
  <a 
    href="#top" 
    class="inline-flex items-center gap-2 text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:text-black dark:hover:text-white transition-colors group"
  >
    <span class="transition-transform duration-200 group-hover:-translate-y-0.5">
      ↑
    </span>

    <span>
      Kembali ke atas
    </span>
  </a>
</div>