---
// src/components/ui/BackToTop.astro
import Button from './Button.astro';
import Icon from './Icon';
import { getCurrentLocale, getLabel } from "@/utils/i18n";

interface Props {
  showBorder?: boolean;
  align?: 'left' | 'center' | 'right';
}

const { showBorder = true, align = 'left' } = Astro.props;

const locale = getCurrentLocale(Astro);
const backToTop = getLabel(locale, 'backToTop');

const alignClasses = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right'
};
---

<div class:list={[
  showBorder? 'py-4 md:py-6 text-(--fg-muted) hover:text-(--fg)' : '',
  alignClasses[align]
]}>
  <Button href="#top" variant='secondary' aria-label={backToTop} title={backToTop}>
    <span class="group-hover:-translate-y-0.5">
      <Icon name="arrow-up" className="w-5 h-5" />
    </span>
    <span>
      {backToTop}
    </span>
  </Button>
</div>