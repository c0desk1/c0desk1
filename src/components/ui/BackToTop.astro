---
// src/components/ui/BackToTop.astro
import { siteConfig } from '@/config/site';
import Icon from './Icon';

const backToTop = siteConfig.backToTop || "Back to Top";
---

<button
  id="back-to-top"
  aria-label={backToTop}
  title={backToTop}
  class="fixed mb-[env(safe-area-inset-bottom)] bottom-12 right-8 z-50 group
         flex items-center justify-center
         w-12 h-12 p-2
         rounded-full bg-base backdrop-blur-sm
         border border-(--border) shadow-lg
         text-muted text-label-12
         hover:bg-muted hover:text-(--fg) active:text-(--fg)
         transition-all duration-300
         opacity-0 invisible translate-y-4
         focus-visible:opacity-100 focus-visible:visible
         focus-visible:translate-y-0">
  <svg 
    id="progress-svg"
    class="absolute top-0 left-0 w-full h-full pointer-events-none -rotate-90"
    viewBox="0 0 48 48"
  >
    <circle
      id="progress-ring-bg"
      class="stroke-(--border)/10"
      stroke-width="2"
      fill="none"
      cx="24"
      cy="24"
      r="23"
    />
    <circle
      id="progress-ring"
      class="stroke-accent-dim"
      stroke-width="2"
      fill="none"
      cx="24"
      cy="24"
      r="23"
      stroke-dasharray="0 289"
      stroke-linecap="round"
      style="transition: stroke-dasharray 0.15s ease-out;"
    />
  </svg>
  <div class="absolute inset-0 rounded-full overflow-hidden pointer-events-none">
    <div class="absolute inset-0 bg-noise opacity-20 mix-blend-overlay"></div>
  </div>
  <span class="relative z-10 transition-transform duration-300 group-hover:-translate-y-1 active:-translate-y-1 flex items-center">
    <Icon name="arrow-up" className="w-5 h-5" />
  </span>
</button>

<style is:global>
  .bg-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='1' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.5'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 80px;
  }
  
  .scroll-show {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
  }
</style>

<script>
  const initBackToTop = () => {
    const btn = document.getElementById('back-to-top');
    const ring = document.getElementById('progress-ring');
    const content = document.querySelector('article') || document.querySelector('main');
    
    if (!btn) return;

    const circumference = 2 * Math.PI * 23;
    if (ring) {
      ring.style.strokeDasharray = `0 ${circumference}`;
    }

    let ticking = false;

    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          if (window.scrollY > 300) {
            btn.classList.add('scroll-show');
          } else {
            btn.classList.remove('scroll-show');
          }

          if (ring && content) {
            const rect = content.getBoundingClientRect();
            const windowHeight = window.innerHeight;
            const scrolled = windowHeight - rect.top;
            const total = content.offsetHeight;    
            const progress = Math.min(Math.max(scrolled / total, 0), 1);
            const dash = progress * circumference;
            
            ring.style.strokeDasharray = `${dash} ${circumference}`;
          }
          
          ticking = false;
        });
        ticking = true;
      }
    };

    window.removeEventListener('scroll', (window as any).__bttScrollHandler);
    (window as any).__bttScrollHandler = onScroll;
    window.addEventListener('scroll', (window as any).__bttScrollHandler, { passive: true });

    btn.removeEventListener('click', (window as any).__bttClickHandler);
    (window as any).__bttClickHandler = (e: MouseEvent) => {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    };
    btn.addEventListener('click', (window as any).__bttClickHandler);

    onScroll();
  };

  initBackToTop();
  document.addEventListener("astro:page-load", initBackToTop);
</script>