---
// src/components/ui/BackToTop.astro

import Button from './Button.astro';
import Icon from './Icon.astro';

interface Props {
  showBorder?: boolean;
  align?: 'left' | 'center' | 'right';
}

const { showBorder = true, align = 'left' } = Astro.props;

const alignClasses = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right'
};
---

<div class:list={[
  showBorder ? 'pt-4 md:pt-8' : '',
  alignClasses[align]
]}>
  <Button href="#top" variant='secondary'>
    <span class="group-hover:-translate-y-0.5">
      <Icon name="arrow-up" class="w-5 h-5" />
    </span>
    <span class="text-(--fg)">
      Kembali ke atas
    </span>
  </Button>
</div>
