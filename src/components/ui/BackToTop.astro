---
// src/components/ui/FloatingScrollToTop.astro
---

<button
  id="floating-scroll-top"
  aria-label="Scroll to top"
  class="fixed bottom-6 right-6 z-50 flex items-center gap-2 px-3 py-2 rounded-md border border-(--border) bg-base text-muted hover:text-strong active:text-strong hover:bg-subtle active:bg-subtle shadow-sm opacity-0 translate-y-2 pointer-events-none transition-all duration-300"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="w-4 h-4 shrink-0"
    aria-hidden="true"
  >
    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
    <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" />
    <path d="M12 8l-4 4" />
    <path d="M12 8v8" />
    <path d="M16 12l-4 -4" />
  </svg>
  <span class="text-label-14 font-medium">Kembali ke atas</span>
</button>

<script>
  const initFloatingScrollTop = () => {
    const btn = document.getElementById("floating-scroll-top");
    if (!btn) return;

    const toggle = () => {
      if (window.scrollY > 300) {
        btn.classList.remove("opacity-0", "translate-y-2", "pointer-events-none");
        btn.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
      } else {
        btn.classList.add("opacity-0", "translate-y-2", "pointer-events-none");
        btn.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
      }
    };

    const scrollToTop = () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    };

    window.addEventListener("scroll", toggle, { passive: true });
    btn.addEventListener("click", scrollToTop);

    toggle();

    return () => {
      window.removeEventListener("scroll", toggle);
      btn.removeEventListener("click", scrollToTop);
    };
  };

  let cleanup: (() => void) | undefined;

  const runSetup = () => {
    cleanup?.();
    cleanup = initFloatingScrollTop();
  };

  runSetup();
  document.addEventListener("astro:page-load", runSetup);
</script>