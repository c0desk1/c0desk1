---
// src/components/ui/ReadingProgress.astro
---

<div class="fixed top-0 left-0 w-full h-[2px] z-100 pointer-events-none">
  <div
    id="reading-bar"
    class="h-full w-0 bg-black dark:bg-white transition-[width,opacity] duration-150 ease-linear"
  ></div>
</div>

<script>
  let scrollHandler: ((this: Window, ev: Event) => any) | null = null;

  function initReadingProgress() {
    const bar = document.getElementById('reading-bar');
    const article = document.querySelector('article');

    if (!bar || !article) return;

    const updateProgress = () => {
      const rect = article.getBoundingClientRect();
      const articleHeight = article.scrollHeight;
      const windowHeight = window.innerHeight;
      const max = articleHeight - windowHeight;

      const progress = max > 0
        ? Math.min(100, Math.max(0, (-rect.top / max) * 100))
        : 100;

      bar.style.width = `${progress}%`;
      bar.style.opacity = (progress >= 100 || rect.top > 0) ? '0' : '1';
    };

    if (scrollHandler) {
      window.removeEventListener('scroll', scrollHandler);
    }
    scrollHandler = updateProgress;
    window.addEventListener('scroll', scrollHandler, { passive: true });

    updateProgress();
  }

  initReadingProgress();
  document.addEventListener('astro:page-load', initReadingProgress);
</script>
