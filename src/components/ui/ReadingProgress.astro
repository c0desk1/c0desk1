---
// src/components/ui/ReadingProgress.astro
---

<div class="reading-progress-container sticky top-[64px] z-40 w-full h-1 bg-(--border)/30 pointer-events-none">
    <div 
        id="reading-bar" 
        class="h-full bg-blue-600 w-0 transition-all duration-75 ease-linear shadow-[0_0_8px_rgba(37,99,235,0.5)]"
    ></div>
</div>

<script>
    function initReadingProgress() {
        const bar = document.getElementById('reading-bar');
        const article = document.querySelector('article');

        if (!bar || !article) return;

        const updateProgress = () => {
            const rect = article.getBoundingClientRect();
            const articleHeight = article.offsetHeight;
            
            const progress = Math.max(0, Math.min(100, ((-rect.top) / (articleHeight - window.innerHeight)) * 100));
            
            bar.style.width = `${progress}%`;

            if (progress >= 100 || rect.top > 0) {
                bar.style.opacity = '0';
            } else {
                bar.style.opacity = '1';
            }
        };

        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress();
    }
    initReadingProgress();
    document.addEventListener('astro:page-load', initReadingProgress);
</script>

<style>
    .reading-progress-container {
        margin-top: -1px; 
    }
    #reading-bar {
        transition: width 0.1s ease-out, opacity 0.3s ease-in-out;
    }
</style>