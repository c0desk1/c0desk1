---
// src/components/ui/SocialLinks.astro
import Icon from "./Icon";

interface SocialItem {
  href: string;
  label: string;
}

interface Props {
  items: readonly SocialItem[];
  class?: string;
  iconClass?: string;
  showLabel?: boolean;
}

const {
  items,
  class: className = "",
  iconClass = "h-4 w-4",
  showLabel = false,
} = Astro.props;
---

<ul class:list={["flex items-center gap-2", className]} role="list">
  {items.map((item) => (
    <li>
      <a
        href={item.href}
        aria-label={item.label}
        title={item.label}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full px-1.5 py-1 text-muted transition-colors hover:bg-muted hover:text-(--fg) active:text-(--fg) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--accent)"
      >
        <Icon
          name={item.label as any}
          className={iconClass}
          aria-hidden="true"
        />

        {showLabel && (
          <span class="capitalize text-copy-13">
            {item.label}
          </span>
        )}
      </a>
    </li>
  ))}
</ul>
