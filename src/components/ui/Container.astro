---
// src/components/ui/Container.astro

type ElementTag = 'div' | 'section' | 'article' | 'main';

type Size = 'sm' | 'md' | 'lg' | 'xl' | 'full';

interface Props {
  as?: ElementTag;
  size?: Size;
  center?: boolean;
  class?: string;
}

const props = Astro.props as Props;

const {
  as: Component = 'div',
  size = 'xl',
  center = false,
  class: className = '',
} = props;

const sizeClasses: Record<Size, string> = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-6xl',
  xl: 'max-w-7xl',
  full: 'max-w-none',
};

const sizeClass = sizeClasses[size];

const paddingClass =
  'px-4';

const centerClass =
  center ? 'mx-auto text-center' : 'mx-auto';

const classes = [
  centerClass,
  paddingClass,
  sizeClass,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Component class={classes}>
  <slot />
</Component>
