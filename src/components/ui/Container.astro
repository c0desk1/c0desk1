---
// src/components/ui/Container.astro
interface Props {
  as?: 'div' | 'section' | 'main';
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl' | 'full';
  class?: string;
}

const { as: Component = 'div', size = 'xl', class: className = '' } = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'max-w-screen-sm',
  md: 'max-w-screen-md',
  lg: 'max-w-screen-lg',
  xl: 'max-w-screen-xl',
  '2xl': 'max-w-screen-2xl',
  full: 'max-w-none',
};

const classes = [
  "mx-auto w-full px-4 sm:px-6 lg:px-8",
  sizeClasses[size],
  className,
].filter(Boolean).join(" ");
---

<Component class={classes}>
  <slot />
</Component>
