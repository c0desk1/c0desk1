---
import type { HTMLAttributes } from 'astro/types';
import { buildClasses } from '../../lib/ui';
import type { Variant, Size } from '../../lib/ui';

type BaseProps = {
  variant?: Variant;
  size?: Size;
  loading?: boolean;
  disabled?: boolean;
  class?: string;
  "swg-standard-button"?: "contribution" | "subscription";
};

type AnchorProps = HTMLAttributes<'a'> & BaseProps & {
  href: string;
  type?: never;
};

type ButtonProps = HTMLAttributes<'button'> & BaseProps & {
  href?: never;
  type?: 'button' | 'submit' | 'reset';
};

type Props = AnchorProps | ButtonProps;

const {
  href,
  variant = 'secondary',
  size = 'md',
  loading = false,
  disabled = false,
  class: className,
  type,
  ...rest
} = Astro.props as Props;

const isLink = !!href;
const resolvedType = type ?? 'button';
const classes = buildClasses(variant, size, className);
---

{isLink ? (
  <a
    href={href}
    class={classes}
    data-loading={loading}
    aria-disabled={disabled || loading}
    {...rest}
  >
    {loading && <span class="h-3.5 w-3.5 shrink-0 animate-spin border-2 border-current border-t-transparent rounded-full" aria-hidden="true" />}
    <slot />
  </a>
) : (
  <button
    type={resolvedType}
    class={classes}
    data-loading={loading}
    disabled={disabled || loading}
    aria-disabled={disabled || loading}
    {...rest}
  >
    {loading && <span class="h-3.5 w-3.5 shrink-0 animate-spin border-2 border-current border-t-transparent rounded-full" aria-hidden="true" />}
    <slot />
  </button>
)}