---
// src/components/layout/MenuButton.astro
import Icon from "./Icon";
---

<button
  id="mnav-btn"
  aria-label="Buka menu"
  aria-expanded="false"
  class="md:hidden p-2 rounded-full text-(--fg) border border-(--border) hover:bg-(--bg-muted)
         focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--border-strong)
         transition active:scale-95"
>
  <Icon name="menu" class="w-5 h-5" />
</button>

<script>
  (() => {
    const btn = document.getElementById('mnav-btn');
    if (!btn) return;
    
    btn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('mnav:open'));
    });
  })();
</script>
