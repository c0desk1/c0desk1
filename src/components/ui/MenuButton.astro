---
// src/components/layout/MenuButton.astro
import { siteConfig } from "@/config/site";
import Icon from "./Icon";

const siteData = siteConfig
const menuLabel = siteData.openMenu;
---

<button
  id="mnav-btn"
  aria-label={menuLabel}
  aria-expanded="false"
  class="inline-flex sm:hidden p-2 rounded-full text-muted active:text-(--fg) border border-(--border) hover:bg-muted
         focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--focus-ring)
         transition active:scale-95"
>
  <Icon name="menu" className="w-5 h-5" />
</button>

<script>
  (() => {
    const btn = document.getElementById('mnav-btn');
    if (!btn) return;
    
    btn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('mnav:open'));
    });
  })();
</script>
