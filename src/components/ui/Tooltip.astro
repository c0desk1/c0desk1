---
// src/components/ui/Tooltip.astro
//
// Props:
//   text      — teks tooltip (wajib)
//   position  — arah munculnya: 'top' | 'bottom' | 'left' | 'right' (default: 'top')
//   delay?    — delay sebelum muncul dalam ms (default: 400)
//
interface Props {
  text     : string;
  position?: 'top' | 'bottom' | 'left' | 'right';
  delay?   : number;
  class?   : string;
}

const {
  text,
  position = 'top',
  delay    = 400,
  class: cls = '',
} = Astro.props;
---

<span
  class:list={['tt-wrap', cls]}
  data-tip={text}
  data-pos={position}
  data-delay={delay}
>
  <slot />
  <span class="tt-bubble" role="tooltip">{text}</span>
</span>

<style is:global>
  /* ── Wrapper ────────────────────────────────────────────────────────────── */
  .tt-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Bubble ─────────────────────────────────────────────────────────────── */
  .tt-bubble {
    position: absolute;
    z-index: 9000;
    pointer-events: none;

    /* Visual — sama vibe dengan cookie & toast */
    background: var(--bg);
    color: var(--fg);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md, 0.5rem);
    box-shadow:
      0 4px 6px -1px rgba(0,0,0,.06),
      0 10px 20px -4px rgba(0,0,0,.1);
    padding: 0.35rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.35;
    white-space: nowrap;
    max-width: 14rem;
    white-space: normal;
    text-align: center;

    /* Hidden state */
    opacity: 0;
    transform: scale(0.92);
    transition:
      opacity 0.15s ease,
      transform 0.18s cubic-bezier(0.34, 1.4, 0.64, 1);
    transition-delay: 0s;   /* delay diset via JS saat hover */
  }

  /* ── Posisi default: top ─────────────────────────────────────────────────── */
  .tt-wrap[data-pos='top']    .tt-bubble { bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%) scale(0.92); }
  .tt-wrap[data-pos='bottom'] .tt-bubble { top:    calc(100% + 6px); left: 50%; transform: translateX(-50%) scale(0.92); }
  .tt-wrap[data-pos='left']   .tt-bubble { right:  calc(100% + 6px); top:  50%; transform: translateY(-50%) scale(0.92); }
  .tt-wrap[data-pos='right']  .tt-bubble { left:   calc(100% + 6px); top:  50%; transform: translateY(-50%) scale(0.92); }

  /* ── Visible state ───────────────────────────────────────────────────────── */
  .tt-wrap[data-pos='top'].tt-open    .tt-bubble { opacity: 1; transform: translateX(-50%) scale(1); }
  .tt-wrap[data-pos='bottom'].tt-open .tt-bubble { opacity: 1; transform: translateX(-50%) scale(1); }
  .tt-wrap[data-pos='left'].tt-open   .tt-bubble { opacity: 1; transform: translateY(-50%) scale(1); }
  .tt-wrap[data-pos='right'].tt-open  .tt-bubble { opacity: 1; transform: translateY(-50%) scale(1); }

  /* ── Caret (segitiga kecil) ──────────────────────────────────────────────── */
  .tt-bubble::before {
    content: '';
    position: absolute;
    width: 0.5rem;
    height: 0.5rem;
    background: var(--bg);
    border: 1.5px solid var(--border);
    transform: rotate(45deg);
  }

  .tt-wrap[data-pos='top']    .tt-bubble::before { bottom: -5px;  left: 50%; margin-left: -4px; border-top: none; border-left: none; }
  .tt-wrap[data-pos='bottom'] .tt-bubble::before { top:    -5px;  left: 50%; margin-left: -4px; border-bottom: none; border-right: none; }
  .tt-wrap[data-pos='left']   .tt-bubble::before { right:  -5px;  top:  50%; margin-top: -4px;  border-left: none; border-top: none; }
  .tt-wrap[data-pos='right']  .tt-bubble::before { left:   -5px;  top:  50%; margin-top: -4px;  border-right: none; border-bottom: none; }
</style>

<script>
  (() => {
    // Gunakan event delegation — satu listener untuk semua tooltip di halaman
    const ATTR_DELAY = 'data-delay';

    let openWrap: HTMLElement | null = null;
    let showTimer: ReturnType<typeof setTimeout>;
    let hideTimer: ReturnType<typeof setTimeout>;

    const open = (wrap: HTMLElement) => {
      clearTimeout(hideTimer);
      const delay = parseInt(wrap.getAttribute(ATTR_DELAY) ?? '400', 10);
      showTimer = setTimeout(() => {
        // Tutup tooltip sebelumnya
        openWrap?.classList.remove('tt-open');
        wrap.classList.add('tt-open');
        openWrap = wrap;
      }, delay);
    };

    const close = (wrap: HTMLElement) => {
      clearTimeout(showTimer);
      hideTimer = setTimeout(() => {
        wrap.classList.remove('tt-open');
        if (openWrap === wrap) openWrap = null;
      }, 80); // sedikit grace agar tidak flickering
    };

    // Mouse
    document.addEventListener('mouseover', (e) => {
      const wrap = (e.target as HTMLElement).closest<HTMLElement>('.tt-wrap');
      if (wrap) open(wrap);
    });

    document.addEventListener('mouseout', (e) => {
      const wrap = (e.target as HTMLElement).closest<HTMLElement>('.tt-wrap');
      if (wrap) close(wrap);
    });

    // Focus (keyboard accessible)
    document.addEventListener('focusin', (e) => {
      const wrap = (e.target as HTMLElement).closest<HTMLElement>('.tt-wrap');
      if (wrap) open(wrap);
    });

    document.addEventListener('focusout', (e) => {
      const wrap = (e.target as HTMLElement).closest<HTMLElement>('.tt-wrap');
      if (wrap) close(wrap);
    });

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && openWrap) {
        openWrap.classList.remove('tt-open');
        openWrap = null;
      }
    });

    // Touch: tap untuk toggle, tap luar untuk tutup
    document.addEventListener('touchstart', (e) => {
      const wrap = (e.target as HTMLElement).closest<HTMLElement>('.tt-wrap');
      if (wrap) {
        e.preventDefault();
        wrap.classList.contains('tt-open') ? close(wrap) : open(wrap);
      } else if (openWrap) {
        close(openWrap);
      }
    }, { passive: false });
  })();
</script>
