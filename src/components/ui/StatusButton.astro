---
// src/components/ui/StatusButton.astro

---

<button id="status-toggle"
    class="group flex items-center gap-2.5 px-3 py-1.5 transition-all active:scale-95"
    >
    <span class="relative flex h-2.5 w-2.5">
        <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full bg-zinc-400 opacity-75"></span>
        <span id="status-dot" class="relative inline-flex h-2.5 w-2.5 bg-zinc-400"></span>
    </span>
    <span id="status-label" class="text-[13px] md:text-sm font-medium text-(--fg-muted) group-hover:text-(--fg) transition-colors">
        Memuat Sistem...
    </span>
</button>
