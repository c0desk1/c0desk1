---
// src/components/ui/TOC.astro
import { filterHeadingsForTOC } from '@/lib/utils';
import Icon from '@/components/ui/Icon.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = filterHeadingsForTOC(headings);
---

{tocHeadings.length > 0 && (
  <aside class="toc-container">
    <nav class="toc-nav">
      <button
        class="toc-trigger"
        aria-expanded="false"
        aria-controls="toc-list"
      >
        <span class="toc-trigger-text text-sm md:text-[13px] font-semibold">Daftar Isi</span>
        <Icon name="chevron-down" class="toc-chevron w-4 h-4" />
      </button>

      <div id="toc-list" class="toc-content" hidden>
        <ul class="toc-ul">
          {tocHeadings.map(h => (
            <li class:list={["toc-li", h.depth === 3 ? "pl-4" : ""]}>
              <a href={`#${h.slug}`} class="toc-link">
                <span class="toc-dot"></span>
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </aside>
)}

<style is:global>
  :target {
    scroll-margin-top: 4.5rem;
  }

  .prose-custom h2,
  .prose-custom h3 {
    scroll-margin-top: 4.5rem;
  }

  .toc-container {
    position: sticky;
    top: 4.5rem;
    z-index: 40;
    width: 100%;
    margin-bottom: 0 !important;
  }

  .toc-nav {
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-height: calc(100vh - 6rem);
    display: flex;
    flex-direction: column;
  }

  .toc-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--fg);
  }

  .toc-trigger-text {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 80%;
    transition: opacity 0.15s ease-in-out;
  }

  .toc-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .toc-trigger[aria-expanded="true"] .toc-chevron {
    transform: rotate(180deg);
  }

  .toc-content {
    border-top: 1px solid var(--border);
    overflow-y: auto;
  }

  .toc-content[hidden] { display: none; }

  .toc-ul {
    padding: 1rem;
    list-style: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .toc-link {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    text-decoration: none;
    font-size: 13px;
    color: var(--fg-muted);
    transition: color 0.2s;
  }

  .toc-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--fg-muted);
    flex-shrink: 0;
    margin-top: 4px;
    transition: background 0.2s, transform 0.2s;
  }

  .active-link {
    color: var(--fg) !important;
    font-weight: 600;
  }

  .active-link .toc-dot {
    background: var(--fg) !important;
    transform: scale(1.5);
  }
</style>

<script>
  const HEADER_H = 56; // h-14 = 56px

  const initTOC = () => {
    const trigger     = document.querySelector<HTMLButtonElement>('.toc-trigger');
    const triggerText = trigger?.querySelector<HTMLElement>('.toc-trigger-text');
    const content     = document.getElementById('toc-list');
    const links       = content?.querySelectorAll<HTMLAnchorElement>('.toc-link');

    if (!trigger || !content || !links?.length || !triggerText) return;

    const DEFAULT_TEXT = 'Daftar Isi';

    // ── Panel toggle ────────────────────────────────────────────────────────
    const closePanel = () => {
      trigger.setAttribute('aria-expanded', 'false');
      content.hidden = true;
    };

    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!expanded));
      content.hidden = expanded;
    });

    links.forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 1024) closePanel();
      });
    });

    // ── Heading elements ────────────────────────────────────────────────────
    const headingEls: HTMLElement[] = Array.from(links)
      .map(l => {
        const id = l.getAttribute('href')?.slice(1);
        return id ? document.getElementById(id) : null;
      })
      .filter((el): el is HTMLElement => el !== null);

    if (!headingEls.length) return;

    // ── Active label fade ───────────────────────────────────────────────────
    let fadeTimer: ReturnType<typeof setTimeout>;
    let currentActive: HTMLElement | null = null;

    const setLabel = (text: string) => {
      clearTimeout(fadeTimer);
      triggerText.style.opacity = '0';
      fadeTimer = setTimeout(() => {
        triggerText.textContent = text;
        triggerText.style.opacity = '1';
      }, 80);
    };

    // ── Core detection ──────────────────────────────────────────────────────
    //
    // DETECTION_LINE: titik di mana heading dianggap "aktif".
    
    const getDetectionLine = () => HEADER_H + 40 //window.innerHeight * 0.35;

    const getActiveHeading = (): HTMLElement | null => {
      const line = getDetectionLine();
      let active: HTMLElement | null = null;
      for (const h of headingEls) {
        if (h.getBoundingClientRect().top <= line) {
          active = h;
        } else {
          break;
        }
      }
      return active;
    };

    const updateTOC = () => {
      const active = getActiveHeading();

      if (active === currentActive) return;
      currentActive = active;

      links.forEach(l => l.classList.remove('active-link'));

      if (!active) {
        setLabel(DEFAULT_TEXT);
        return;
      }

      const id   = active.getAttribute('id');
      const link = id ? content.querySelector<HTMLAnchorElement>(`[href="#${id}"]`) : null;
      if (!link) return;

      link.classList.add('active-link');
      setLabel(link.innerText);
    };

    updateTOC();
    window.addEventListener('scroll', updateTOC, { passive: true });
  };

  initTOC();
  document.addEventListener('astro:after-swap', initTOC);
</script>