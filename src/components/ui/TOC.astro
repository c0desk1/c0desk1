---
// src/components/ui/TOC.astro
import { filterHeadingsForTOC } from '@/lib/utils';
import Icon from '@/components/ui/Icon.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = filterHeadingsForTOC(headings);
---

{tocHeadings.length > 0 && (
  <aside class="toc-container">
    <nav class="toc-nav">
      <button 
        class="toc-trigger" 
        aria-expanded="false" 
        aria-controls="toc-list"
      >
        <span class="text-sm md:text-[13px] font-semibold">Daftar Isi</span>
        <Icon name="chevron-down" class="toc-chevron w-4 h-4" />
      </button>
      
      <div id="toc-list" class="toc-content" hidden>
        <ul class="toc-ul">
          {tocHeadings.map(h => (
            <li class:list={["toc-li", h.depth === 3 ? "pl-4" : ""]}>
              <a href={`#${h.slug}`} class="toc-link">
                <span class="toc-dot"></span>
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </aside>
)}

<style is:global>
  /* Solusi Bug 2: Tambahkan jarak agar heading tidak tertutup header h-14 */
  :target {
    scroll-margin-top: 5.5rem; 
  }
  
  /* Atau jika menggunakan class prose */
  .prose-custom h2, .prose-custom h3 {
    scroll-margin-top: 5.5rem;
  }

  .toc-container {
    position: sticky;
    top: 4.5rem;
    z-index: 40;
    width: 100%;
    margin-bottom: 0px !important;
  }

  .toc-nav {
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-height: calc(100vh - 6rem);
    display: flex;
    flex-direction: column;
  }

  .toc-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--fg);
  }

  .toc-trigger span {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 80%;
    transition: opacity 0.15s ease-in-out;
  }

  .toc-trigger[aria-expanded="true"] .toc-chevron {
    transform: rotate(180deg);
  }

  .toc-content {
    border-top: 1px solid var(--border);
    overflow-y: auto;
  }
  
  .toc-content[hidden] { display: none; }

  .toc-ul {
    padding: 1rem;
    list-style: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .toc-link {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    text-decoration: none;
    font-size: 13px;
    color: var(--fg-muted);
    transition: color 0.2s;
  }

  .active-link {
    color: var(--fg) !important;
    font-weight: 600;
  }
  
  .active-link .toc-dot {
    background: var(--fg) !important;
    transform: scale(1.5);
  }
</style>

<script>
  const initTOC = () => {
    const trigger = document.querySelector('.toc-trigger');
    const triggerText = trigger?.querySelector('span');
    const content = document.getElementById('toc-list');
    const links = content?.querySelectorAll('.toc-link');
    
    if (!trigger || !content || !links || !triggerText) return;
    
    const defaultText = "Daftar Isi";

    const closePanel = () => {
      trigger.setAttribute('aria-expanded', 'false');
      content.hidden = true;
    };

    trigger.addEventListener('click', () => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', (!isExpanded).toString());
      content.hidden = isExpanded;
    });

    links.forEach(link => {
      link.addEventListener('click', (e) => {
        if (window.innerWidth < 1024) closePanel();
      });
    });

    // Reset ke "Daftar Isi" hanya jika benar-benar di paling atas
    window.addEventListener('scroll', () => {
      if (window.scrollY < 40) {
        triggerText.innerText = defaultText;
        links.forEach(l => l.classList.remove('active-link'));
      }
    }, { passive: true });

    const headingElements = Array.from(links).map(link => {
      const id = link.getAttribute('href')?.replace('#', '');
      return document.getElementById(id || '');
    }).filter(h => h !== null) as HTMLElement[];

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        // Solusi Bug 1: Area deteksi dibuat pas di bawah header h-14 (top: 80px - 100px)
        if (entry.isIntersecting && window.scrollY >= 40) {
          const id = entry.target.getAttribute('id');
          const correspondingLink = content.querySelector(`[href="#${id}"]`);

          if (correspondingLink) {
            triggerText.style.opacity = "0";
            setTimeout(() => {
              triggerText.innerText = (correspondingLink as HTMLElement).innerText;
              triggerText.style.opacity = "1";
            }, 50);
            
            links.forEach(l => l.classList.remove('active-link'));
            correspondingLink.classList.add('active-link');
          }
        }
      });
    }, {
      // Menaikkan batas atas (-80px) agar teks berganti tepat saat menyentuh header
      rootMargin: '-80px 0px -80% 0px',
      threshold: 0
    });

    headingElements.forEach(h => observer.observe(h));
  };

  initTOC();
  document.addEventListener('astro:after-swap', initTOC);
</script>
