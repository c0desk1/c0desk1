---
// src/components/ui/TOC.astro
import { filterHeadingsForTOC } from '@/lib/utils';
import Icon from '@/components/ui/Icon.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = filterHeadingsForTOC(headings);
---

{tocHeadings.length > 0 && (
  <aside class="toc-container">
    <nav class="toc-nav">
      <button 
        class="toc-trigger" 
        aria-expanded="false" 
        aria-controls="toc-list"
        id="toc-btn"
      >
        <span class="toc-current-text text-sm md:text-[13px] font-semibold">Daftar Isi</span>
        <Icon name="chevron-down" class="toc-chevron w-4 h-4" />
      </button>
      
      <div id="toc-list" class="toc-content" hidden aria-labelledby="toc-btn">
        <ul class="toc-ul">
          {tocHeadings.map(h => (
            <li class:list={["toc-li", h.depth === 3 ? "pl-4" : ""]}>
              <a href={`#${h.slug}`} class="toc-link group">
                <span class="toc-dot"></span>
                <span class="toc-text">{h.text}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </aside>
)}

<style is:global>
  :target {
    scroll-margin-top: 6rem;
  }
  
  .prose-custom h2, .prose-custom h3 {
    scroll-margin-top: 6rem;
  }

  .toc-container {
    position: sticky;
    top: 5rem;
    z-index: 40;
    width: 100%;
    margin-bottom: 0 !important;
  }

  .toc-nav {
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-height: calc(100vh - 7rem);
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 12px -2px rgba(0, 0, 0, 0.05);
  }

  .toc-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--fg);
  }

  .toc-current-text {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 85%;
    text-align: left;
    transition: opacity 0.2s ease;
  }

  .toc-chevron { transition: transform 0.3s ease; }
  .toc-trigger[aria-expanded="true"] .toc-chevron { transform: rotate(180deg); }

  .toc-content {
    border-top: 1px solid var(--border);
    overflow-y: auto;
    background: var(--bg-subtle);
  }
  
  .toc-content[hidden] { display: none; }

  .toc-ul {
    padding: 1rem;
    margin: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .toc-link {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 13px;
    color: var(--fg-muted);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .toc-dot {
    margin-top: 6px;
    height: 4px;
    width: 4px;
    border-radius: 99px;
    background: var(--border);
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  /* Active State */
  .toc-link.is-active {
    color: var(--fg);
    font-weight: 600;
  }

  .toc-link.is-active .toc-dot {
    background: var(--fg);
    transform: scale(1.5);
  }
</style>

<script>
  const setupTOC = () => {
    const container = document.querySelector('.toc-container');
    const trigger = document.querySelector('.toc-trigger') as HTMLButtonElement;
    const triggerText = trigger?.querySelector('.toc-current-text');
    const content = document.getElementById('toc-list');
    const links = document.querySelectorAll('.toc-link');
    
    if (!trigger || !content || !links.length || !triggerText) return;

    const DEFAULT_TITLE = "Daftar Isi";

    // --- ACCORDION ---
    const toggleTOC = (forceClose = false) => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      if (forceClose || isExpanded) {
        trigger.setAttribute('aria-expanded', 'false');
        content.hidden = true;
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        content.hidden = false;
      }
    };

    trigger.addEventListener('click', () => toggleTOC());

    links.forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 1024) toggleTOC(true);
      });
    });

    // --- SCROLLSPY & AUTO-TITLE ---
    const headings = Array.from(links).map(link => {
      const id = link.getAttribute('href')?.substring(1);
      return document.getElementById(id || '');
    }).filter(Boolean) as HTMLElement[];

    const updateActiveState = () => {
      const scrollPosition = window.scrollY;

      if (scrollPosition < 100) {
        triggerText.innerText = DEFAULT_TITLE;
        links.forEach(l => l.classList.remove('is-active'));
        return;
      }

      let currentHeadingId = "";

      headings.forEach(heading => {
        const top = heading.offsetTop - 200;
        if (scrollPosition >= top) {
          currentHeadingId = heading.id;
        }
      });

      if (currentHeadingId) {
        links.forEach(link => {
          const isActive = link.getAttribute('href') === `#${currentHeadingId}`;
          link.classList.toggle('is-active', isActive);
          
          if (isActive) {

            if (triggerText.innerText !== (link as HTMLElement).innerText.trim()) {
              triggerText.innerText = (link as HTMLElement).innerText.trim();
            }
          }
        });
      }
    };

    window.addEventListener('scroll', updateActiveState, { passive: true });
    updateActiveState();
  };

  setupTOC();
  document.addEventListener('astro:after-swap', setupTOC);
</script>