---
// src/components/ui/TOC.astro
import { filterHeadingsForTOC } from '@/lib/utils';
import Icon from '@/components/ui/Icon.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = filterHeadingsForTOC(headings);
---

{tocHeadings.length > 0 && (
  <aside class="toc-container">
    <nav class="toc-nav">
      <button 
        class="toc-trigger" 
        aria-expanded="false" 
        aria-controls="toc-list"
      >
        <span class="toc-trigger-text text-sm md:text-[13px] font-semibold">Daftar Isi</span>
        <Icon name="chevron-down" class="toc-chevron w-4 h-4" />
      </button>
      
      <div id="toc-list" class="toc-content" hidden>
        <ul class="toc-ul">
          {tocHeadings.map(h => (
            <li class:list={["toc-li", h.depth === 3 ? "pl-4" : ""]}>
              <a href={`#${h.slug}`} class="toc-link">
                <span class="toc-dot"></span>
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </aside>
)}

<style is:global>
  /*
   * FIX BUG 1: scroll-margin-top harus cukup untuk header (h-14 = 3.5rem)
   * ditambah sedikit breathing room. Nilai 4rem sudah cukup.
   * Jangan set terlalu besar karena TOC sticky tidak ikut menambah offset saat scroll-to.
   */
  :target {
    scroll-margin-top: 4.5rem;
  }

  .prose-custom h2,
  .prose-custom h3 {
    scroll-margin-top: 4.5rem;
  }

  .toc-container {
    position: sticky;
    top: 4.5rem;
    z-index: 40;
    width: 100%;
    margin-bottom: 0px !important;
  }

  .toc-nav {
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-height: calc(100vh - 6rem);
    display: flex;
    flex-direction: column;
  }

  .toc-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--fg);
  }

  .toc-trigger-text {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 80%;
    transition: opacity 0.15s ease-in-out;
  }

  .toc-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .toc-trigger[aria-expanded="true"] .toc-chevron {
    transform: rotate(180deg);
  }

  .toc-content {
    border-top: 1px solid var(--border);
    overflow-y: auto;
  }

  .toc-content[hidden] {
    display: none;
  }

  .toc-ul {
    padding: 1rem;
    list-style: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .toc-link {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    text-decoration: none;
    font-size: 13px;
    color: var(--fg-muted);
    transition: color 0.2s;
  }

  .toc-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--fg-muted);
    flex-shrink: 0;
    margin-top: 4px;
    transition: background 0.2s, transform 0.2s;
  }

  .active-link {
    color: var(--fg) !important;
    font-weight: 600;
  }

  .active-link .toc-dot {
    background: var(--fg) !important;
    transform: scale(1.5);
  }
</style>

<script>
  const HEADER_HEIGHT = 56; // h-14 = 3.5rem = 56px

  const initTOC = () => {
    const trigger = document.querySelector<HTMLButtonElement>('.toc-trigger');
    const triggerText = trigger?.querySelector<HTMLElement>('.toc-trigger-text');
    const content = document.getElementById('toc-list');
    const links = content?.querySelectorAll<HTMLAnchorElement>('.toc-link');

    if (!trigger || !content || !links || !triggerText) return;

    const DEFAULT_TEXT = 'Daftar Isi';

    // ─── Panel toggle ────────────────────────────────────────────────────────
    const closePanel = () => {
      trigger.setAttribute('aria-expanded', 'false');
      content.hidden = true;
    };

    trigger.addEventListener('click', () => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!isExpanded));
      content.hidden = isExpanded;
    });

    links.forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 1024) closePanel();
      });
    });

    // ─── Heading elements ────────────────────────────────────────────────────
    const headingElements: HTMLElement[] = Array.from(links)
      .map(link => {
        const id = link.getAttribute('href')?.replace('#', '');
        return id ? document.getElementById(id) : null;
      })
      .filter((el): el is HTMLElement => el !== null);

    if (headingElements.length === 0) return;

    // ─── Helper: set active link dengan fade ─────────────────────────────────
    const setActiveLink = (link: Element | null) => {
      links.forEach(l => l.classList.remove('active-link'));

      if (!link) {
        // FIX BUG 3: Kembalikan ke default saat tidak ada heading aktif
        triggerText.style.opacity = '0';
        setTimeout(() => {
          triggerText.innerText = DEFAULT_TEXT;
          triggerText.style.opacity = '1';
        }, 80);
        return;
      }

      link.classList.add('active-link');
      triggerText.style.opacity = '0';
      setTimeout(() => {
        triggerText.innerText = (link as HTMLElement).innerText;
        triggerText.style.opacity = '1';
      }, 80);
    };

    // ─── FIX BUG 2 & 3: Scroll-based detection menggunakan getBoundingClientRect ──
    //
    // IntersectionObserver sulit untuk kasus "heading pertama belum terlewat"
    // dan "scroll balik ke atas". Solusi yang lebih andal: pakai scroll event
    // dengan getBoundingClientRect untuk menentukan heading mana yang paling
    // dekat dengan bagian atas viewport (tepat di bawah header).
    //
    const DETECTION_LINE = HEADER_HEIGHT + 8; // px dari top viewport — tepat di bawah header

    const getActiveHeading = (): HTMLElement | null => {
      // Cari heading terakhir yang sudah melewati garis deteksi (sudah di atas garis)
      let active: HTMLElement | null = null;
      for (const heading of headingElements) {
        const rect = heading.getBoundingClientRect();
        if (rect.top <= DETECTION_LINE) {
          active = heading;
        } else {
          break;
        }
      }
      return active;
    };

    const updateTOC = () => {
      const activeHeading = getActiveHeading();

      if (!activeHeading) {
        // FIX BUG 3: Tidak ada heading yang aktif → reset ke default
        setActiveLink(null);
        return;
      }

      const id = activeHeading.getAttribute('id');
      const correspondingLink = id
        ? content.querySelector<HTMLAnchorElement>(`[href="#${id}"]`)
        : null;

      // Hanya update jika memang berubah (hindari flicker)
      if (correspondingLink && !correspondingLink.classList.contains('active-link')) {
        setActiveLink(correspondingLink);
      }
    };

    // Jalankan sekali saat mount (untuk kasus deep link / page sudah ter-scroll)
    updateTOC();

    window.addEventListener('scroll', updateTOC, { passive: true });
  };

  initTOC();
  document.addEventListener('astro:after-swap', () => {
    // Cleanup listener lama sebelum reinit tidak perlu karena page swap
    // mengganti DOM, tapi untuk keamanan kita tetap reinit
    initTOC();
  });
</script>