---
// src/components/ui/TOC.astro
import { filterHeadingsForTOC } from '@/lib/utils';
import Icon from '@/components/ui/Icon.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = filterHeadingsForTOC(headings);
---

{tocHeadings.length > 0 && (
  <aside class="toc-container">
    <nav class="toc-nav">
      <button 
        class="toc-trigger" 
        aria-expanded="false" 
        aria-controls="toc-list"
      >
        <span class="text-sm md:text-[13px] font-semibold">Daftar Isi</span>
        <Icon name="chevron-down" class="toc-chevron w-4 h-4" />
      </button>
      
      <div id="toc-list" class="toc-content" hidden>
        <ul class="toc-ul">
          {tocHeadings.map(h => (
            <li class:list={["toc-li", h.depth === 3 ? "pl-4" : ""]}>
              <a href={`#${h.slug}`} class="toc-link">
                <span class="toc-dot"></span>
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </aside>
)}

<style is:global>
  .toc-container {
    position: sticky;
    top: 4.5rem;
    z-index: 40;
    width: 100%;
    margin-bottom: 0px !important;
  }

  .toc-nav {
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-height: calc(100vh - 6rem);
    display: flex;
    flex-direction: column;
  }

  .toc-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--fg);
  }

  .toc-trigger:hover {
    background-color: var(--bg-subtle);
  }

  .toc-chevron {
    transition: transform 0.3s ease;
  }
  .toc-trigger[aria-expanded="true"] .toc-chevron {
    transform: rotate(180deg);
  }

  .toc-content {
    border-top: 1px solid var(--border);
    overflow-y: auto;
  }
  
  .toc-content[hidden] {
    display: none;
  }

  .toc-ul {
    padding: 1rem;
    list-style: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .toc-link {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    text-decoration: none;
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.4;
    transition: color 0.2s;
  }

  .toc-link:hover {
    color: var(--fg);
  }

  .toc-dot {
    margin-top: 6px;
    height: 4px;
    width: 4px;
    border-radius: 99px;
    background: var(--border);
    flex-shrink: 0;
  }
  
  .toc-link.text-\(--fg\) .toc-dot {
    background: var(--fg);
    transform: scale(1.5);
    transition: all 0.2s;
  }
  
  .toc-trigger span {
	display: block;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
	max-width: 80%;
}


  @media (min-width: 1024px) {
    .toc-container {}
  }
</style>

<script>
  const initTOC = () => {
    const trigger = document.querySelector('.toc-trigger');
    const triggerText = trigger?.querySelector('span');
    const content = document.getElementById('toc-list');
    const links = content?.querySelectorAll('.toc-link');
    
    if (!trigger || !content || !links || !triggerText) return;

    const defaultText = "Daftar Isi";

    trigger.addEventListener('click', () => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', (!isExpanded).toString());
      content.hidden = isExpanded;
    });

    window.addEventListener('scroll', () => {
      if (window.scrollY < 200) {
        triggerText.innerText = defaultText;
        links.forEach(l => l.classList.remove('active-link'));
      }
    }, { passive: true });

    const headingElements = Array.from(links).map(link => {
      const id = link.getAttribute('href')?.replace('#', '');
      return document.getElementById(id || '');
    }).filter(h => h !== null) as HTMLElement[];

    const observerOptions = {
      root: null,
      rootMargin: '-100px 0px -80% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          const correspondingLink = content.querySelector(`[href="#${id}"]`);

          if (correspondingLink) {
            triggerText.innerText = (correspondingLink as HTMLElement).innerText;
            
            links.forEach(l => l.classList.remove('active-link'));
            correspondingLink.classList.add('active-link');
          }
        }
      });
    }, observerOptions);

    headingElements.forEach(h => observer.observe(h));
  };

  initTOC();
  document.addEventListener('astro:after-swap', initTOC);
</script>