---
// src/components/ui/Hero.astro

import { siteConfig } from "@/config/site";
import Container from "./Container.astro";

---
<section class="py-10 md:py-14">
   <Container size="md">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
      <div class="space-y-2">
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white">
          Frontend.<span class="text-zinc-400 dark:text-zinc-600">engineer</span>
        </h1> 
        <p class="max-w-md text-sm text-zinc-600 dark:text-zinc-400">
          Sistematis, berkinerja tinggi, mudah diakses.
        </p>
      </div>
      <div class="flex items-center gap-3 text-sm">
        <a href="/blog" class="px-3 py-1.5 bg-zinc-900 dark:bg-white rounded-sm text-white dark:text-zinc-900 hover:opacity-90">
          Blog
        </a>
        <a href="/portfolio" class="px-3 py-1.5 border border-zinc-200 rounded-sm dark:border-zinc-800 hover:border-zinc-300 dark:hover:border-zinc-700">
          Portfolio
        </a>
      </div> 
    </div>
  </Container>
</section>