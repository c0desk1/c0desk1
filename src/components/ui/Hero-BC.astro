---
// src/components/ui/Hero.astro

import { siteConfig } from "@/config/site";
import Container from "./Container.astro";

---
<section class="py-10 md:py-14">
   <Container size="md">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
      <div class="space-y-2">
        <div class="flex items-center gap-2 text-xs text-zinc-500 dark:text-zinc-400">
          <span class=" font-semibold font-mono text-emerald-600 dark:text-emerald-500" aria-hidden="true">$</span>
          <span>whoami</span>
          <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">/</span>
          <span class="text-emerald-600 dark:text-emerald-500">{siteConfig.author}</span>
        </div>
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white">
          Frontend.<span class="text-zinc-400 dark:text-zinc-600">engineer</span>
        </h1> 
        <p class="max-w-md text-sm text-zinc-600 dark:text-zinc-400">
          Sistematis, berkinerja tinggi, mudah diakses.
        </p>
      </div>
      <div class="flex items-center gap-3 text-sm">
        <a href="/blog" class="px-3 py-1.5 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 hover:opacity-90 transition-colors">
          Blog
        </a>
        <a href="/portfolio" class="px-3 py-1.5 border border-zinc-200 dark:border-zinc-800 hover:border-zinc-300 dark:hover:border-zinc-700 transition-colors">
          Portfolio
        </a>
      </div> 
    </div>
  </Container>
</section>