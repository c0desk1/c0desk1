---
// src/components/ui/NavLink.astro

interface Props {
  href: string;
  current?: boolean;
}

const { href, current = false } = Astro.props;
---

<a
  href={href}
  aria-current={current ? "page" : undefined}
  class:list={[

    "relative inline-flex items-center rounded-full px-3 py-2 text-sm font-medium transition-colors duration-150",

    current
      ? "text-zinc-900 dark:text-zinc-100"
      : "text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 hover:bg-black/10 dark:hover:bg-zinc-800/30"

  ]}
>
  <span class="relative z-10">
    <slot />
  </span>
  {current && (
    <span
      class="absolute inset-x-1 -bottom-[3px] h-[2px] rounded-full bg-zinc-900 dark:bg-zinc-100"
    ></span>
  )}
</a>