---
// src/components/ui/NavLink.astro
import { siteConfig } from '@/config/site';
import Icon from '@/components/ui/Icon';

interface Props {
  href: string;
  current?: boolean;
  target?: string;
  rel?: string;
  class?: string;
  isExternal?: boolean;
}

const {
  href,
  current = false,
  target,
  rel,
  class: className,
  isExternal = false,
} = Astro.props;

const ariaCurrentValue = (siteConfig.b_p_n || "page") as "page";
---

<a
  href={href}
  target={target}
  rel={rel}
  aria-current={current ? ariaCurrentValue : undefined}
  class:list={[
    "relative inline-flex items-center gap-1 px-4 py-1.5 text-label-14 font-medium rounded-full transition-all duration-200",
    current
      ? "text-(--fg) bg-muted ring-1 ring-(--border-strong)"
      : "text-muted hover:text-(--fg) hover:bg-subtle",
    className,
  ]}
>
  <slot />
  {isExternal && (
    <Icon
      name="external"
      className="w-3 h-3 opacity-40 group-hover:opacity-100 transition-opacity duration-200"
    />
  )}
</a>