---
// src/components/ui/NavLink.astro

interface Props {
  href: string;
  current?: boolean;

  target?: string;
  rel?: string;

  class?: string;
}

const {
  href,
  current = false,
  target,
  rel,
  class: className,
} = Astro.props;
---

<a
  href={href}
  target={target}
  rel={rel}
  aria-current={current ? "page" : undefined}
  class:list={[
    "group relative inline-flex items-center gap-1 rounded-full px-3 py-1.5 text-label-14 transition-colors",
    
    current
      ? "text-(--fg)"
      : "text-(--fg-muted) hover:text-(--fg) hover:bg-(--bg-subtle)",

    className
  ]}
>
  {current && (
    <span class="absolute inset-0 rounded-full bg-(--bg-muted) z-0"></span>
  )}

  <span class="relative z-10 inline-flex items-center gap-1">
    <slot />
  </span>
</a>