---
// src/components/ui/NavLink.astro

interface Props {
  href: string;
  current?: boolean;
}

const { href, current = false } = Astro.props;
---

<a
  href={href}
  aria-current={current ? "page" : undefined}
  class:list={[
    "relative inline-flex items-center rounded-full px-3 py-1.5 text-[14px] font-medium",
    current
      ? "text-(--fg)"
      : "text-(--fg-muted) hover:text-(--fg) hover:bg-(--bg-subtle)"
  ]}
>
  {current && (
    <span class="absolute inset-0 rounded-full bg-(--bg-muted) z-0"></span>
  )}
  <span class="relative z-10">
    <slot />
  </span>
</a>
