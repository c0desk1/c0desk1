---
// src/components/ui/NavLink.astro
const { href, current = false } = Astro.props;
---

<a 
  href={href}
  class="relative px-3 py-2 text-sm focus:outline-none
    ${current 
      ? 'text-black dark:text-white' 
      : 'text-black hover:text-emerald-600 dark:text-zinc-400 dark:hover:text-white'
    }"
  aria-current={current ? 'page' : undefined}
>
  <slot />
  
  {current && (
    <span class="absolute -bottom-px left-3 right-3 h-0.5 bg-zinc-900 dark:bg-white" aria-hidden="true"></span>
  )}
  
  {!current && (
    <span class="absolute -bottom-px left-3 right-3 h-px w-0 bg-zinc-400 dark:bg-zinc-500 group-hover:w-[calc(100%-24px)]" aria-hidden="true"></span>
  )}
</a>