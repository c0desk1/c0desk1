---
// src/components/ui/NavLink.astro

interface Props {
  href: string;
  current?: boolean;
}

const { href, current = false } = Astro.props;
---

<a
  href={href}
  aria-current={current ? "page" : undefined}
  class:list={[

    "relative inline-flex items-center rounded-full px-3 py-2 text-[13px] font-medium",

    current
      ? "text-(--fg)"
      : "text-(--fg-subtle) hover:text-(--fg) hover:bg-(--bg-subtle)"

  ]}
>
  <span class="relative z-10">
    <slot />
  </span>
  {current && (
    <span
      class="absolute inset-x-1 -bottom-[3px] h-[2px] rounded-full bg-(--fg)"
    ></span>
  )}
</a>