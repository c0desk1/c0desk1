---
// src/components/ui/NavLink.astro

const { href, current = false } = Astro.props;
---

<a
  href={href}
  aria-current={current ? 'page' : undefined}
  class:list={[
    "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-full",
    "transition-all duration-200",

    current
      ? "text-zinc-900 dark:text-zinc-100 bg-zinc-100/60 dark:bg-zinc-800/60"
      : "text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100/30 dark:text-zinc-400 dark:hover:text-zinc-100 dark:hover:bg-zinc-800/30"
  ]}
>
  <slot />
</a>