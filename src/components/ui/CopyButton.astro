---
// src/components/ui/CopyLink.astro
import Icon from "./Icon.astro";
---

<button
  id="copy-link-btn"
  aria-label="Salin tautan artikel"
  aria-live="polite"
  class="relative p-1.5 rounded-(--radius-md) text-(--accent) hover:bg-(--bg-muted) group active:scale-95 disabled:opacity-60 disabled:cursor-not-allowed transition-all duration-200"
  data-url={Astro.url.href}>
  <div class="flex items-center justify-center gap-1.5">
    <div class="relative w-3.5 h-3.5 items-center">
      <span id="icon-copy" class="absolute inset-0 w-full h-full transition-all duration-200">
        <Icon name="link" class="w-3.5 h-3.5" />
      </span>
      <span id="icon-check" class="absolute inset-0 w-full h-full opacity-0 scale-75 transition-all duration-200">
        <Icon name="check" class="w-3.5 h-3.5" />
      </span>
    </div>
    <span id="copy-text" class="text-xs font-medium">
      Salin URL
    </span>
  </div>
  
  <!-- Tooltip - compact version -->
  <span 
    id="copy-tooltip" 
    role="tooltip" 
    class="absolute -top-8 left-1/2 -translate-x-1/2 px-2 py-0.5 text-[11px] font-medium border border-(--border) bg-(--bg) text-(--fg-muted) rounded-(--radius-md) opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-sm">
    Salin tautan
  </span>
</button>

<script>
  import { copyToClipboard } from '@/lib/utils';

  (() => {
    if ((window as any).__copyLinkReady) return;
    (window as any).__copyLinkReady = true;

    const btn = document.getElementById('copy-link-btn') as HTMLButtonElement;
    const copyIcon = document.getElementById('icon-copy');
    const checkIcon = document.getElementById('icon-check');
    const text = document.getElementById('copy-text');
    const tooltip = document.getElementById('copy-tooltip');

    if (!btn || !copyIcon || !checkIcon || !text || !tooltip) return;

    let timeoutId: number;
    let isCopying = false;

    const showToastMessage = (success: boolean) => {
      if (success) {
        toast.show('Link copied to clipboard!', { type: 'success', duration: 2000 });
      } else {
        toast.show('Failed to copy link. Please try again.', { type: 'error', duration: 2000 });
      }
    };

    const setState = (success: boolean) => {
      clearTimeout(timeoutId);
      btn.disabled = true;

      if (success) {
        copyIcon.style.cssText = 'opacity:0;transform:scale(0.75)';
        checkIcon.style.cssText = 'opacity:1;transform:scale(1)';
        text.textContent = 'Copied!';
        tooltip.textContent = 'Tersalin!';
        btn.setAttribute('aria-label', 'Link copied successfully');
        showToastMessage(true);
      } else {
        text.textContent = 'Failed';
        tooltip.textContent = 'Gagal';
        btn.setAttribute('aria-label', 'Failed to copy link');
        showToastMessage(false);
      }

      timeoutId = window.setTimeout(() => {
        copyIcon.style.cssText = 'opacity:1;transform:scale(1)';
        checkIcon.style.cssText = 'opacity:0;transform:scale(0.75)';
        text.textContent = 'Salin URL';
        tooltip.textContent = 'Salin tautan';
        btn.setAttribute('aria-label', 'Copy article link');
        btn.disabled = false;
        isCopying = false;
      }, 1500);
    };

    const handleCopy = async () => {
      if (isCopying) return;
      isCopying = true;

      const url = btn.getAttribute('data-url') || window.location.href;
      const success = await copyToClipboard(url);
      setState(success);
    };

    btn.addEventListener('click', handleCopy);

    document.addEventListener('astro:after-swap', () => {
      clearTimeout(timeoutId);
      btn.disabled = false;
      isCopying = false;
      btn.setAttribute('data-url', window.location.href);
      copyIcon.style.cssText = 'opacity:1;transform:scale(1)';
      checkIcon.style.cssText = 'opacity:0;transform:scale(0.75)';
      text.textContent = 'Salin URL';
      tooltip.textContent = 'Salin tautan';
      btn.setAttribute('aria-label', 'Copy article link');
    });
  })();
</script>