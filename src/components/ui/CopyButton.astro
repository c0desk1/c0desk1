---
// src/components/ui/CopyLink.astro
import Icon from "./Icon.astro";
---

<button 
  id="copy-link-btn" 
  aria-label="Copy page link" 
  class="relative p-2 rounded-full text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800/50 transition-all duration-200 group active:scale-95"
  data-url={Astro.url.href}
>
  <div class="flex items-center justify-center gap-1.5">
    <div class="relative w-5 h-5">
      <!-- Icon Copy (default) -->
      <span id="icon-copy" class="absolute inset-0 flex items-center justify-center transition-all duration-200 opacity-100 scale-100">
        <Icon name="link" class="w-4 h-4" />
      </span>
      <!-- Icon Check (success) -->
      <span id="icon-check" class="absolute inset-0 flex items-center justify-center transition-all duration-200 opacity-0 scale-75">
        <Icon name="check" class="w-4 h-4" />
      </span>
    </div>
    <span class="text-[13px] font-medium text-zinc-700 dark:text-zinc-300">
      Salin URL
    </span>
  </div>
  
  <!-- Tooltip -->
  <span class="absolute -top-9 left-1/2 -translate-x-1/2 px-2 py-1 text-[11px] font-mono text-white bg-zinc-800 dark:bg-zinc-900 rounded-md opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-lg z-10">
    Salin tautan
  </span>
</button>

<script>
  import { copyToClipboard } from '@/lib/utils';

  (function() {
    const btn = document.getElementById('copy-link-btn');
    const copyIcon = document.getElementById('icon-copy');
    const checkIcon = document.getElementById('icon-check');
    const tooltip = btn?.querySelector('.group-hover\\:opacity-100');

    if (!btn || !copyIcon || !checkIcon) return;

    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const url = btn.getAttribute('data-url');
      if (!url) return;
      
      const success = await copyToClipboard(url);
      
      if (success) {
        // Hide copy icon, show check icon
        copyIcon.style.opacity = '0';
        copyIcon.style.transform = 'scale(0.5)';
        checkIcon.style.opacity = '1';
        checkIcon.style.transform = 'scale(1)';
        
        // Update tooltip text temporarily
        const tooltipSpan = btn.querySelector('span:last-child');
        const originalText = tooltipSpan.textContent;
        tooltipSpan.textContent = 'Tersalin!';
        
        setTimeout(() => {
          // Restore copy icon
          copyIcon.style.opacity = '1';
          copyIcon.style.transform = 'scale(1)';
          checkIcon.style.opacity = '0';
          checkIcon.style.transform = 'scale(0.75)';
          
          // Restore tooltip text
          tooltipSpan.textContent = originalText;
        }, 2000);
      }
    });
  })();
</script>