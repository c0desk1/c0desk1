---
// src/components/ui/CopyLink.astro
// @ts-nocheck
import { copyToClipboard } from '@/lib/utils';
---

<button 
  id="copy-link-btn" 
  aria-label="Salin tautan halaman" 
  class="relative p-2 rounded-md text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800/50 transition-all duration-200 group"
  data-url={Astro.url.href}
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
  </svg>
  <span class="absolute -top-8 left-1/2 -translate-x-1/2 px-2 py-1 text-[10px] font-mono bg-zinc-800 text-white rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">
    Salin tautan
  </span>
</button>

<script>
  import { copyToClipboard } from '@/lib/utils';

  (function() {
    const btn = document.getElementById('copy-link-btn');
    if (!btn) return;

    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      
      const success = await copyToClipboard(url);
      if (success) {
        const originalHTML = btn.innerHTML;
        btn.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`;
        setTimeout(() => {
          btn.innerHTML = originalHTML;
        }, 2000);
      } else {
        console.error('Gagal menyalin tautan');
      }
    });
  })();
</script>