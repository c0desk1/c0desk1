---
// src/components/ui/CopyLink.astro
import Icon from "./Icon.astro";
---

<button 
  id="copy-link-btn" 
  aria-label="Copy page link" 
  class="relative p-2 rounded-(--radius-full) text-(--fg-muted) hover:text-(--fg) hover:bg-(--bg-muted) group active:scale-95"
  data-url={Astro.url.href}
>
  <div class="relative w-4 h-4 items-center">
    <span id="icon-copy" class="absolute inset-0 w-full h-full opacity-100 scale-100 transition-all duration-300">
      <Icon name="link" class="w-4 h-4" />
    </svg>
    <span id="icon-check" class="absolute inset-0 w-full h-full transition-all duration-300 opacity-0 scale-50">
      <Icon name="check" class="w-4 h-4" />
    </svg>
  </div>

  <span id="copy-tooltip" class="absolute -top-9 left-1/2 -translate-x-1/2 px-2 py-1 text-[12px] border border-(--border) font-medium bg-(--bg-subtle) text-(--fg) rounded-(--radius-md) opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-xl">
    Salin tautan
  </span>
</button>

<script>
  import { copyToClipboard } from '@/lib/utils';

  const initCopy = () => {
    const btn = document.getElementById('copy-link-btn');
    const copyIcon = document.getElementById('icon-copy');
    const checkIcon = document.getElementById('icon-check');
    const tooltip = document.getElementById('copy-tooltip');

    if (!btn || !copyIcon || !checkIcon || !tooltip) return;

    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url');
      if (!url) return;
      
      const success = await copyToClipboard(url);
      
      if (success) {
        copyIcon.classList.replace('opacity-100', 'opacity-0');
        copyIcon.classList.replace('scale-100', 'scale-50');
        
        checkIcon.classList.replace('opacity-0', 'opacity-100');
        checkIcon.classList.replace('scale-50', 'scale-100');
        
        tooltip.textContent = 'Tersalin!';

        setTimeout(() => {
          copyIcon.classList.replace('opacity-0', 'opacity-100');
          copyIcon.classList.replace('scale-50', 'scale-100');
          
          checkIcon.classList.replace('opacity-100', 'opacity-0');
          checkIcon.classList.replace('scale-100', 'scale-50');
          
          tooltip.textContent = 'Salin tautan';
        }, 2000);
      }
    });
  };

  initCopy();
</script>
