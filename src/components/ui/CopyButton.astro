// src/components/ui/CopyLink.astro
import Icon from "./Icon.astro";
---

<button
  id="copy-link-btn"
  aria-label="Salin tautan artikel"
  aria-live="polite"
  class="relative p-2 rounded-(--radius-full) text-(--accent) hover:bg-(--bg-muted) group active:scale-95 disabled:opacity-60 disabled:cursor-not-allowed"
  data-url={Astro.url.href}>
  <div class="flex items-center justify-center gap-1">
    <div class="relative w-5 h-5 items-center">
      <span id="icon-copy" class="absolute inset-0 w-full h-full transition-all duration-300">
        <Icon name="link" class="w-4.5 h-4.5" />
      </span>
      <span id="icon-check" class="absolute inset-0 w-full h-full opacity-0 scale-75 transition-all duration-300">
        <Icon name="check" class="w-4.5 h-4.5" />
      </span>
    </div>
    <span id="copy-text" class="text-[13px] md:text-sm text-(--accent) font-medium">
      Salin URL
    </span>
  </div>
  <span id="copy-tooltip" role="tooltip" class="absolute -top-9 left-1/2 -translate-x-1/2 px-2 py-1 text-[12px] border border-(--border) font-medium bg-(--bg-subtle) text-(--fg) rounded-(--radius-md) opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-xl">
    Salin tautan
  </span>
</button>

<script>
  import { copyToClipboard } from '@/lib/utils';

  (() => {
    if ((window as any).__copyLinkReady) return;
    (window as any).__copyLinkReady = true;

    const btn = document.getElementById('copy-link-btn') as HTMLButtonElement;
    const copyIcon = document.getElementById('icon-copy');
    const checkIcon = document.getElementById('icon-check');
    const tooltip = document.getElementById('copy-tooltip');
    const text = document.getElementById('copy-text');

    if (!btn ||!copyIcon ||!checkIcon ||!tooltip ||!text) return;

    let timeoutId: number;
    let isCopying = false;

    const setState = (success: boolean) => {
      clearTimeout(timeoutId);
      btn.disabled = true;

      if (success) {
        copyIcon.style.cssText = 'opacity:0;transform:scale(0.75)';
        checkIcon.style.cssText = 'opacity:1;transform:scale(1)';
        text.textContent = 'Tersalin!';
        tooltip.textContent = 'Tersalin!';
        btn.setAttribute('aria-label', 'Tautan berhasil disalin');
      } else {
        text.textContent = 'Gagal';
        tooltip.textContent = 'Gagal menyalin';
        btn.setAttribute('aria-label', 'Gagal menyalin tautan');
      }

      timeoutId = window.setTimeout(() => {
        copyIcon.style.cssText = 'opacity:1;transform:scale(1)';
        checkIcon.style.cssText = 'opacity:0;transform:scale(0.75)';
        text.textContent = 'Salin URL';
        tooltip.textContent = 'Salin tautan';
        btn.setAttribute('aria-label', 'Salin tautan artikel');
        btn.disabled = false;
        isCopying = false;
      }, 2000);
    };

    const handleCopy = async () => {
      if (isCopying) return;
      isCopying = true;

      const url = btn.getAttribute('data-url') || window.location.href;
      const success = await copyToClipboard(url);
      setState(success);
    };

    btn.addEventListener('click', handleCopy);

    document.addEventListener('astro:after-swap', () => {
      clearTimeout(timeoutId);
      btn.disabled = false;
      isCopying = false;
      btn.setAttribute('data-url', window.location.href);
      setState(true);
      setTimeout(() => setState(false), 0);
    });
  })();
</script>