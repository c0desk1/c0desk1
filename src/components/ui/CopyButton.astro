---
// src/components/ui/CopyLink.astro
import Icon from "./Icon.astro";
import { getCurrentLocale, getLabel } from '@/utils/i18n';

const locale = getCurrentLocale(Astro);

const labels = {
  copy: getLabel(locale, 'copyUrl') || 'Copy URL',
  copied: getLabel(locale, 'copied') || 'Copied!',
  failed: getLabel(locale, 'copyFailed') || 'Failed',
  ariaDefault: getLabel(locale, 'copyUrlAria') || 'Copy article URL',
  ariaSuccess: getLabel(locale, 'copiedAria') || 'URL copied successfully',
  ariaFailed: getLabel(locale, 'copyFailedAria') || 'Failed to copy URL',
  toastSuccess: getLabel(locale, 'copyToastSuccess') || 'URL copied to clipboard!',
  toastFailed: getLabel(locale, 'copyToastFailed') || 'Failed to copy URL, please try again.',
};
---

<button
  id="copy-link-btn"
  aria-label={labels.ariaDefault}
  aria-live="polite"
  class="relative text-(--accent-dim) hover:text-(--accent) group active:scale-95 disabled:opacity-60 disabled:cursor-not-allowed transition-all duration-200"
  data-url={Astro.url.href}
>
  <div class="flex shrink-0 items-center justify-center gap-1.5">
    <div class="relative w-4 h-4 items-center">
      <span id="icon-copy" class="absolute inset-0 w-full h-full transition-all duration-200">
        <Icon name="link" className="w-4 h-4" />
      </span>
      <span id="icon-check" class="absolute inset-0 w-full h-full opacity-0 scale-75 transition-all duration-200">
        <Icon name="check" className="w-4 h-4" />
      </span>
    </div>
    <span id="copy-text" class="text-[13px] md:text-sm font-medium leading-none">
      {labels.copy}
    </span>
  </div>
</button>

<script define:vars={{ labels }}>
  import { copyToClipboard } from '@/lib/utils';

  (() => {
    if (window.__copyLinkReady) return;
    window.__copyLinkReady = true;

    const btn = document.getElementById('copy-link-btn');
    const copyIcon = document.getElementById('icon-copy');
    const checkIcon = document.getElementById('icon-check');
    const text = document.getElementById('copy-text');

    if (!btn || !copyIcon || !checkIcon || !text) return;

    let timeoutId;
    let isCopying = false;

    const showToastMessage = (success) => {
      const toast = window.toast;
      if (!toast) return;
      toast.show(
        success ? labels.toastSuccess : labels.toastFailed,
        { type: success ? 'success' : 'error', duration: 2000 }
      );
    };

    const setState = (success) => {
      clearTimeout(timeoutId);
      btn.disabled = true;

      if (success) {
        copyIcon.style.cssText = 'opacity:0;transform:scale(0.75)';
        checkIcon.style.cssText = 'opacity:1;transform:scale(1)';
        text.textContent = labels.copied;
        btn.setAttribute('aria-label', labels.ariaSuccess);
        showToastMessage(true);
      } else {
        text.textContent = labels.failed;
        btn.setAttribute('aria-label', labels.ariaFailed);
        showToastMessage(false);
      }

      timeoutId = window.setTimeout(() => {
        copyIcon.style.cssText = 'opacity:1;transform:scale(1)';
        checkIcon.style.cssText = 'opacity:0;transform:scale(0.75)';
        text.textContent = labels.copy;
        btn.setAttribute('aria-label', labels.ariaDefault);
        btn.disabled = false;
        isCopying = false;
      }, 1500);
    };

    const handleCopy = async () => {
      if (isCopying) return;
      isCopying = true;
      const url = btn.getAttribute('data-url') || window.location.href;
      const success = await copyToClipboard(url);
      setState(success);
    };

    btn.addEventListener('click', handleCopy);

    document.addEventListener('astro:after-swap', () => {
      clearTimeout(timeoutId);
      btn.disabled = false;
      isCopying = false;
      btn.setAttribute('data-url', window.location.href);
      copyIcon.style.cssText = 'opacity:1;transform:scale(1)';
      checkIcon.style.cssText = 'opacity:0;transform:scale(0.75)';
      text.textContent = labels.copy;
      btn.setAttribute('aria-label', labels.ariaDefault);
    });
  })();
</script>