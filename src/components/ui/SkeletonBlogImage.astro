---
// src/components/ui/SkeletonBlogImage.astro
// Matching struktur BlogFeaturedImage.astro:
//   figure > div.border > Image (aspect 16/9, max-w-3xl)
---

<figure
  class="prose-custom mx-auto max-w-3xl my-4 md:my-8 overflow-hidden"
  aria-hidden="true"
>
  <div class="flex items-center border-2 border-(--border) rounded-(--radius-md) overflow-hidden">
    <!-- Aspect video 16/9, matching width=1280 height=720 -->
    <div
      class="sk-img w-full"
      style="aspect-ratio: 16/9;"
    ></div>
  </div>
</figure>