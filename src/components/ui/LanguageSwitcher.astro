---
// src/components/LanguageSwitcher.astro
import { siteConfig } from '@/config/site';
import { getCurrentLocale, localizePath } from '@/utils/i18n';

interface Props {
  alternateSlugs?: Record<string, string>;
  basePath?: 'blog' | 'legal' | ''; // tambah ini
}

const { alternateSlugs, basePath = '' } = Astro.props;
const locale = getCurrentLocale(Astro);

const isPostPage =!!alternateSlugs;
const currentPath = Astro.url.pathname.replace(/^\/(en|ru)/, '') || '/';
---

<div class="flex gap-2">
  {siteConfig.locales.map(loc => {
    let href;

    if (isPostPage && alternateSlugs?.[loc]) {
      // Ada alternate, pake basePath
      const prefix = basePath? `/${basePath}/` : '/';
      href = localizePath(`${prefix}${alternateSlugs[loc]}/`, loc);
    } else {
      // Ga ada alternate, fallback ke currentPath
      href = localizePath(currentPath, loc);
    }

    return (
      <a
        href={href}
        class={`px-3 py-1 rounded text-sm ${
          loc === locale
          ? 'bg-(--bg) text-(--fg) font-bold'
            : 'bg-(--bg-subtle) text-(--fg) hover:bg-(--bg-muted)'
        }`}
      >
        {loc.toUpperCase()}
      </a>
    );
  })}
</div>