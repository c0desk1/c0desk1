---
// src/components/ui/hero.astro
import { siteConfig } from "@/config/site";
import type { ImageMetadata } from "astro";

import { Image } from "astro:assets";
import Container from './Container.astro';
import Button from './Button.astro';

export interface Props {
  bgImage: ImageMetadata;
  title?: string;
  subTitle?: string;
  description: string;
  overlayOpacity?: number;
  cta?: { label: string; href: string };
  cta2?: { label: string; href: string };
}

const { bgImage, title, subTitle, description, overlayOpacity = 0.5, cta, cta2 } = Astro.props;
const overlayStyle = `background-color: rgba(0,0,0,${overlayOpacity})`;

let bgImageUrl: string;

if (typeof bgImage === 'string') {
  bgImageUrl = bgImage;
} else {
  bgImageUrl = bgImage.src;
}
---

<section class="relative w-full overflow-hidden bg-muted">
  <Image
    src={bgImage}
    alt={title || siteConfig.siteName}
    loading="eager"
    decoding="async"
    quality={80}
    widths={[768, 1280, 1920, 2560]}
    sizes="100vw"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover transition-opacity duration-700 ease-out opacity-0"
    onload="this.style.opacity='1'"
  />
  <div class="absolute inset-0" style={overlayStyle}></div>
  <div class="absolute inset-0 z-10 bg-linear-to-b from-(--bg)/10 via-(--bg)/40 to-(--bg)" />
  <Container size="xl">
    <div class="relative z-10 flex flex-col justify-between min-h-125 md:min-h-150 py-4 md:py-10 lg:py-12">
      <div class="self-center sm:self-start">
        <h1 class="text-heading-32 lg:text-heading-56 font-medium text-zinc-50 drop-shadow-lg max-w-xl">
          {title}
        </h1>
      </div>
      <div class="flex flex-wrap justify-between items-end gap-6">
        <div class="flex flex-col gap-8 self-center md:justify-end">
          <h2 class="text-heading-24 lg:text-heading-32 font-normal mt-0! text-(--fg) drop-shadow-lg max-w-xl">
            {subTitle}
          </h2>
        </div>
        <div class="max-w-md">
          <p class="text-(--fg) text-copy-12 sm:text-copy-14 drop-shadow mt-0!">
            {description}
          </p>
          <div class="flex items-center gap-4">
            {cta && (
              <Button 
                variant='primary'
                size='sm'
                class="text-button-14">
                <a href={cta.href}>{cta.label}</a>
              </Button>
            )}
            {cta2 && (
              <Button 
                variant='secondary'
                size='sm'
                class="text-button-14">
                <a href={cta2.href}>{cta2.label}</a>
              </Button>
            )}
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style is:global>
  .noise-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    position: relative;
    overflow: hidden;
  }
  .noise-pill::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='1' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.4'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 100px;
    opacity: 0.15;
    pointer-events: none;
    mix-blend-mode: overlay;
  }
  @media (prefers-reduced-motion: no-preference) {
    .noise-pill::before {
      animation: grain 8s steps(10) infinite;
    }
  }
  @keyframes grain {
    0%, 100% { transform: translate(0, 0); }
    10% { transform: translate(-2%, -1%); }
    20% { transform: translate(1%, -2%); }
    30% { transform: translate(-1%, 2%); }
    40% { transform: translate(2%, 1%); }
    50% { transform: translate(-2%, -1%); }
    60% { transform: translate(1%, 1%); }
    70% { transform: translate(-1%, -2%); }
    80% { transform: translate(2%, -1%); }
    90% { transform: translate(-2%, 2%); }
  }
</style>
