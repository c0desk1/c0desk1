---
// src/components/ui/Hero.astro

import Container from "./Container.astro";

---
<Container size="md" class="py-8 md:py-16">   
  <div class="flex flex-col items-center gap-4 p-4 md:p-8">
    <div class="space-y-2 text-center">
      <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold text-zinc-900 dark:text-white leading-tight">
        Creative.<span class="text-zinc-400 dark:text-zinc-600">engineer</span>
      </h1> 
      <p class="text-sm text-zinc-600 dark:text-zinc-400">
        Eksplorasi workflow digital, AI tools, musik, anime, dan game dari perspektif kreator modern di era otomatisasi.
      </p>
    </div>
  </div>
</Container>