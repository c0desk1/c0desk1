---
// src/components/ui/Hero.astro - Single Line Compact
import { siteConfig } from "@/config/site";
---

<section class="py-8 md:py-12">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      
      {/* Left - identity */}
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3">
        <h1 class="text-xl sm:text-2xl md:text-3xl font-bold font-mono tracking-tight text-zinc-900 dark:text-white">
          {siteConfig.author}
        </h1>
        <span class="text-sm font-mono text-zinc-400 dark:text-zinc-500 hidden sm:inline">/</span>
        <p class="text-sm font-mono text-zinc-500 dark:text-zinc-400">
          frontend.engineer
        </p>
      </div>
      
      {/* Right - tactical status & CTA */}
      <div class="flex items-center gap-3 font-mono text-xs">
        <div class="flex items-center gap-1.5">
          <div class="h-1.5 w-1.5 rounded-full bg-emerald-500"></div>
          <span class="text-zinc-500 dark:text-zinc-400">ready</span>
        </div>
        <div class="h-3 w-px bg-zinc-200 dark:bg-zinc-800"></div>
        <a href="/blog" class="text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">
          Blog
        </a>
        <a href="/portfolio" class="text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">
          Work
        </a>
      </div>
      
    </div>
    
  </div>
</section>