---
// src/components/ui/Hero.astro
// @ts-nocheck
import { siteConfig } from "@/config/site";
---

<section class="py-6 md:py-8" aria-label="Hero section">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      
      {/* Left - identity */}
      <div class="flex flex-wrap items-baseline gap-2 sm:gap-3">
        <div class="flex items-baseline gap-2">
          <span class="text-emerald-600 dark:text-emerald-500 font-mono text-sm" aria-hidden="true">$</span>
          <h1 class="text-xl sm:text-2xl md:text-3xl font-bold font-mono tracking-tight text-zinc-900 dark:text-white">
            {siteConfig.author}
          </h1>
        </div>
        <span class="text-sm font-mono text-zinc-400 dark:text-zinc-500 hidden sm:inline" aria-hidden="true">/</span>
        <p class="text-sm font-mono text-zinc-500 dark:text-zinc-400">
          frontend.engineer
        </p>
      </div>
      
      {/* Right - tactical status & CTA */}
      <div class="flex items-center gap-3 font-mono text-xs">
        <div class="flex items-center gap-1.5">
          <div class="relative">
            <div class="h-1.5 w-1.5 rounded-full bg-emerald-500" aria-hidden="true"></div>
            <div class="absolute inset-0 h-1.5 w-1.5 rounded-full bg-emerald-500 animate-ping opacity-75"></div>
          </div>
          <span class="text-zinc-500 dark:text-zinc-400">ready</span>
        </div>
        <div class="h-3 w-px bg-zinc-200 dark:bg-zinc-800" aria-hidden="true"></div>
        <a 
          href="/blog" 
          class="group relative text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-600 rounded-sm px-1 -mx-1"
          aria-label="Read my blog posts"
        >
          Blog
          <span class="absolute -bottom-0.5 left-1 right-1 h-px w-0 bg-zinc-400 dark:bg-zinc-500 group-hover:w-[calc(100%-8px)] transition-all duration-300"></span>
        </a>
        <a 
          href="/portfolio" 
          class="group relative text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-600 rounded-sm px-1 -mx-1"
          aria-label="View my portfolio work"
        >
          Work
          <span class="absolute -bottom-0.5 left-1 right-1 h-px w-0 bg-zinc-400 dark:bg-zinc-500 group-hover:w-[calc(100%-8px)] transition-all duration-300"></span>
        </a>
      </div>
      
    </div>
    
    {/* Industrial separator line */}
    <div class="mt-4 pt-2">
      <div class="h-px w-12 bg-linear-to-r from-emerald-500/50 to-transparent"></div>
    </div>
    
  </div>
</section>