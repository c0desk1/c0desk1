---
// src/components/ui/hero.astro
import { SITE } from '@/consts';
import Container from './Container.astro';
import Link from './Link.astro';
import Section from './Section.astro';

export interface Props {
  title?: string;
  subTitle?: string;
  description?: string;
  cta?: { label: string; href: string };
  cta2?: { label: string; href: string };
}

const { title, subTitle, description, cta, cta2 } = Astro.props;
---
<Container size="xl">
  <div class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4">
    <Section size="none">
      <p class="text-mono-label-13 text-subtle uppercase mb-4 font-semibold text-start sm:text-center hero-tag">{SITE.tagline}</p>
      <div class="flex items-center justify-start sm:justify-center">
        <h1 class="flex flex-wrap hero-title text-heading-32 lg:text-heading-56 font-extrabold mb-6">
          {title}<span>{subTitle}</span>
        </h1>
      </div>
      <p class="hero-sub text-body-16 lg:text-body-18 text-start sm:text-center text-pretty text-muted mb-6 mx-auto max-w-xl">
        {description}
      </p>
      <div class="hero-cta flex items-center justify-start sm:justify-center gap-6">
        {cta && (
          <Link 
            href={cta.href}
            variant="noir"
            size='lg'
            class="text-button-14">
            {cta.label}
          </Link>
        )}
        {cta2 && (
          <Link 
            href={cta2.href}
            variant='secondary'
            size='lg'
            class="text-button-14">
            {cta2.label}
          </Link>
        )}
      </div>
    </Section>
  </div>
</Container>

<style is:global>
  .hero-tag {
    opacity: 0;
    animation: fadeUp 0.8s ease forwards;
  }

  .hero-title {
    font-size: clamp(72px, 12vw, 160px);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.03em;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.1s forwards;
  }

  .hero-title span {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1px var(--border-strong);
  }

  .hero-sub {
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }

  .hero-cta {
    opacity: 0;
    animation: fadeUp 0.8s ease 0.3s forwards;
  }
</style>
