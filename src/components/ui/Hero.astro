---
// src/components/ui/Hero.astro
---

<div class="flex flex-col items-center text-center" aria-labelledby="hero-title">
  <div class="max-w-2xl space-y-4">
    <h1 
      id="hero-title"
      class="text-4xl md:text-6xl font-semibold tracking-tight text-(--fg)"
    >
      Creative.
      <span class="text-(--accent)">
        engineer
      </span>
    </h1>
    <p class="text-base md:text-lg leading-relaxed text-(--fg-muted)">
      Eksplorasi workflow digital, AI tools, musik, anime, dan game dari perspektif kreator modern di era otomatisasi.
    </p>
  </div>
</div>