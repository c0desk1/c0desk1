---
// src/components/ui/hero.astro
import { SITE } from '@/consts';
import Container from './Container.astro';
import Button from './Button.astro';

export interface Props {
  title?: string;
  subTitle?: string;
  description?: string;
  cta?: { label: string; href: string };
  cta2?: { label: string; href: string };
}

const { title, subTitle, description, cta, cta2 } = Astro.props;
---

<section class="hero">
  <Container size="xl">
    <p class="hero-tag">{SITE.tagline}</p>
    <h1 class="hero-title text-heading-32 lg:text-heading-56">
      {title}<span>{subTitle}</span>
    </h1>
    <p class="hero-sub text-body-14">
      {description}
    </p>
    <div class="hero-cta">
      {cta && (
        <Button 
          variant='primary'
          size='lg'
          class="text-button-14">
          <a href={cta.href}>{cta.label}</a>
        </Button>
      )}
      {cta2 && (
        <Button 
          variant='secondary'
          size='lg'
          class="text-button-14">
          <a href={cta2.href}>{cta2.label}</a>
        </Button>
      )}
    </div>
  </Container>
</section>

<style is:global>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.04);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(45deg);
    width: 600px;
    height: 1px;
    background: rgba(255,255,255,0.04);
    pointer-events: none;
  }

  .hero-tag {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--gray-3);
    text-transform: uppercase;
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards;
  }

  .hero-title {
    font-size: clamp(72px, 12vw, 160px);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.03em;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.1s forwards;
  }

  .hero-title span {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.25);
  }

  .hero-sub {
    margin-top: 48px;
    max-width: 480px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--fg-muted);
    font-weight: 400;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }

  .hero-cta {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.3s forwards;
  }
</style>
