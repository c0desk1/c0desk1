---
interface Props {
  title: string;
  highlight?: string;
  description: string;
}

const { title, highlight, description } = Astro.props;
---

<div class="w-full h-full justify-center flex flex-col items-center text-center py-16" aria-labelledby="hero-title">
  <div class="space-y-4">
    <h1 
      id="hero-title"
      class="text-4xl md:text-6xl font-semibold tracking-tight text-(--fg)"
    >
      {title}
      {highlight && (
        <span class="text-(--accent-dim)">
          {highlight}
        </span>
      )}
    </h1>
    <p class="text-base md:text-lg leading-relaxed text-(--fg-muted)">
      {description}
    </p>
  </div>
</div>
