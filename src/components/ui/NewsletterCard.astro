---
// src/components/ui/NewsletterCard.astro
---

<div class="border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 p-5">
  <div class="flex items-center gap-2 mb-3">
    <span class="text-emerald-600 dark:text-emerald-500 font-mono font-semibold text-sm">$</span>
    <h2 class="text-sm text-zinc-500 dark:text-zinc-400">
      Buletin
    </h2>
  </div>
  <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4">
    Dapatkan notifikasi saat saya menerbitkan artikel baru.
  </p>
  <form class="space-y-3">
    <input 
      type="email" 
      placeholder="nama@email.com"
      class="w-full px-3 py-2 text-sm border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 text-zinc-900 dark:text-white placeholder:text-zinc-400 focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-600 transition-colors"
      aria-label="Alamat Email"
    />
    <button 
      type="submit"
      class="w-full px-3 py-2 text-sm font-medium border border-zinc-200 dark:border-zinc-800 hover:border-zinc-400 dark:hover:border-zinc-600 hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-all"
    >Berlangganan
    </button>
  </form>
  <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-3">
    Tidak ada spam. Anda dapat berhenti berlangganan kapan saja.
  </p>
</div>