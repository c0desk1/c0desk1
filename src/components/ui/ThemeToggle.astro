---
// src/components/ui/ThemeToggle.astro
import Icon from "./Icon";
---

<div
  id="theme-toggle"
  role="group"
  aria-label="Pilih tema"
  class="relative inline-flex items-center
         rounded-full border border-(--border)"
>
  {([
    { mode: "system", label: "Ikuti sistem" },
    { mode: "light", label: "Tema terang" },
    { mode: "dark", label: "Tema gelap" },
  ] as const).map(({ mode, label }) => (
    <button
      type="button"
      data-mode={mode}
      aria-label={label}
      title={label}
      class="tt-btn relative flex items-center justify-center
             rounded-full cursor-pointer
             text-(--fg-subtle) border border-transparent
             transition-all duration-150
             hover:text-(--fg) hover:bg-(--bg-subtle)/50
             focus-visible:outline-none focus-visible:ring-1
             focus-visible:ring-(--border-strong)
             data-[active=true]:text-(--fg)
             data-[active=true]:bg-(--bg-subtle)
             data-[active=true]:border-(--border)
             size-6 p-1">

      {mode === "system" && <Icon name="system" className="size-3.5" />}
      {mode === "light" && <Icon name="sun" className="size-3.5" />}
      {mode === "dark" && <Icon name="moon" className="size-3.5" />}

    </button>
  ))}
</div>

<script>
  type Mode = "system" | "light" | "dark";
  const KEY = "theme-mode";

  function getMode(): Mode {
    const v = localStorage.getItem(KEY);
    return v === "light" || v === "dark" || v === "system"? v : "system";
  }

  function apply(mode: Mode) {
    const dark =
      mode === "dark" ||
      (mode === "system" &&
        window.matchMedia("(prefers-color-scheme: dark)").matches);
    document.documentElement.classList.toggle("dark", dark);
    document.documentElement.setAttribute("data-theme", mode);
    localStorage.setItem(KEY, mode);
  }

  function mark(mode: Mode) {
    document.querySelectorAll<HTMLElement>(".tt-btn").forEach((b) => {
      const active = b.dataset.mode === mode;
      b.setAttribute("aria-pressed", String(active));
      b.dataset.active = String(active);
    });
  }

  function boot() {
    const mode = getMode();
    apply(mode);
    mark(mode);
  }

  function wire() {
    document.querySelectorAll<HTMLButtonElement>(".tt-btn").forEach((btn) => {
      const fresh = btn.cloneNode(true) as HTMLButtonElement;
      btn.replaceWith(fresh);
      fresh.addEventListener("click", () => {
        const mode = fresh.dataset.mode as Mode;
        apply(mode);
        mark(mode);
      });
    });

    window
   .matchMedia("(prefers-color-scheme: dark)")
   .addEventListener("change", () => {
        if (getMode() === "system") apply("system");
      });
  }

  boot();
  wire();

  document.addEventListener("astro:page-load", () => {
    boot();
    wire();
  });
</script>
