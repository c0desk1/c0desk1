---
// src/components/Menu.astro
import Icon from '@/components/ui/icons/Icon.astro';

const menuLabel = "Buka Menu";
---

<button
  id="mnav-btn"
  aria-label={menuLabel}
  aria-expanded="false"
  class="inline-flex sm:hidden shrink:0 h-8 w-8 p-1.5 items-center justify-center rounded-full border border-(--border) text-muted hover:bg-subtle active:bg-subtle hover:text-strong active:text-strong focus:outline-none focus:ring-2 focus:ring-(--border-strong)">
  <Icon name="menu" className="w-full h-full transition-colors" />
</button>

<script>
  //@ts-nocheck
  const initMenuButton = () => {
    const btn = document.getElementById('mnav-btn');
    if (!btn) return;
    
    btn.removeEventListener('click', window.__menuBtnHandler);
    
    window.__menuBtnHandler = () => {
      document.dispatchEvent(new CustomEvent('mnav:open'));
    };
    
    btn.addEventListener('click', window.__menuBtnHandler);
  };

  initMenuButton();
  document.addEventListener('astro:page-load', initMenuButton);
</script>