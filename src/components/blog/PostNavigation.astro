---
import { siteConfig } from '@/config/site';
import { slugify } from '@/lib/utils';
import Icon from '@/components/ui/icons/Icon.astro';

interface Props {
  prevPost?: any;
  nextPost?: any;
}

const { prevPost, nextPost } = Astro.props;

const prevUrl = prevPost ? `/blog/${prevPost.data.slug || slugify(prevPost.data.title)}` : null;
const nextUrl = nextPost ? `/blog/${nextPost.data.slug || slugify(nextPost.data.title)}` : null;
---

{(prevPost || nextPost) && (
  <nav aria-label="Pagination">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        {prevPost ? (
          <a href={prevUrl} class="group block text-left">
            <span class="flex items-center gap-1.5 text-label-12 text-(--prose-fg-muted) uppercase tracking-widest mb-2">
              <Icon name="arrow-left" className="w-3.5 h-3.5" />
              {siteConfig.b_prevPosts}
            </span>
            <span class="text-body-14 md:text-body-16 font-medium text-(--prose-fg) group-hover:text-(--prose-accent) transition-colors duration-200 line-clamp-2">
              {prevPost.data.title}
            </span>
          </a>
        ) : (
          <div class="hidden md:block" />
        )}
      </div>
      <div class="text-right md:text-right">
        {nextPost && (
          <a href={nextUrl} class="group block">
            <span class="flex items-center justify-end gap-1.5 text-label-12 text-(--prose-fg-muted) uppercase tracking-widest mb-2">
              {siteConfig.b_nextPosts}
              <Icon name="arrow-right" className="w-3.5 h-3.5" />
            </span>
            <span class="text-body-14 md:text-body-16 font-medium text-(--prose-fg) group-hover:text-(--prose-accent) transition-colors duration-200 line-clamp-2">
              {nextPost.data.title}
            </span>
          </a>
        )}
      </div>
    </div>
  </nav>
)}