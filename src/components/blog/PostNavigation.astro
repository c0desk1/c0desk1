---
import Icon from '@/components/ui/Icon';

interface Props {
  prevPost?: any;
  nextPost?: any;
}

const { prevPost, nextPost } = Astro.props;
---

{(prevPost || nextPost) && (
  <div class="flex flex-col sm:flex-row gap-4 w-full">
    <div class="flex-1">
      {prevPost && (
        <a href={`/blog/${prevPost.id}/`} class="group flex w-full flex-col p-4 transition-all duration-200">
          <div class="flex items-center gap-2 text-[13px] md:text-sm text-(--fg-muted) mb-2">
            <Icon name="arrow-left" className="w-4 h-4" />
            <span>Sebelumnya</span>
          </div>
          <span class="text-sm md:text-base font-semibold text-(--fg-muted) group-hover:text-(--fg) line-clamp-2 text-left">
            {prevPost.data.title}
          </span>
        </a>
      )}
    </div>
    <div class="flex-1">
      {nextPost && (
        <a href={`/blog/${nextPost.id}/`} class="group flex w-full flex-col p-4 transition-all duration-200">
          <div class="flex items-center justify-end gap-2 text-[13px] md:text-sm text-(--fg-muted) mb-2">
            <span>Selanjutnya</span>
            <Icon name="arrow-right" className="w-4 h-4" />
          </div>
          <span class="text-sm md:text-base font-semibold text-(--fg-muted) group-hover:text-(--fg) line-clamp-2 text-right">
            {nextPost.data.title}
          </span>
        </a>
      )}
    </div>
  </div>
)}
