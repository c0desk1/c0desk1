---
import { slugify } from '@/lib/utils';
import Icon from '@/components/ui/icons/Icon.astro';

interface Props {
  prevPost?: any;
  nextPost?: any;
}

const { prevPost, nextPost } = Astro.props;

const prevUrl = prevPost ? `/blog/${prevPost.data.slug || slugify(prevPost.data.title)}` : null;
const nextUrl = nextPost ? `/blog/${nextPost.data.slug || slugify(nextPost.data.title)}` : null;
---

{(prevPost || nextPost) && (
  <nav aria-label="Pagination">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        {prevPost ? (
          <a href={prevUrl} class="group block text-left truncate">
            <span class="flex items-center gap-1.5 justify-start text-label-13 text-subtle mb-2">
              <Icon name="arrow-left" className="w-3.5 h-3.5" />
              {'Sebelumnya'}
            </span>
            <span class="text-body-14 md:text-body-16 font-medium text-(--fg) group-hover:text-strong transition-colors duration-200 truncate">
              {prevPost.data.title}
            </span>
          </a>
        ) : (
          <div class="hidden md:block" />
        )}
      </div>
      <div class="text-right md:text-right">
        {nextPost && (
          <a href={nextUrl} class="group block truncate">
            <span class="flex items-center justify-end gap-1.5 text-label-13 text-subtle mb-2">
              {'Selanjutnya'}
              <Icon name="arrow-right" className="w-3.5 h-3.5" />
            </span>
            <span class="text-body-14 md:text-body-16 font-medium text-(--fg) group-hover:text-strong transition-colors duration-200 truncate">
              {nextPost.data.title}
            </span>
          </a>
        )}
      </div>
    </div>
  </nav>
)}
