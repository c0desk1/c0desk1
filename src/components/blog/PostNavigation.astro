---
import Icon from '@/components/ui/Icon';
import { getCurrentLocale, localizePath, getLabel } from '@/utils/i18n';
import { slugify } from '@/lib/utils';

interface Props {
  prevPost?: any;
  nextPost?: any;
}

const { prevPost, nextPost } = Astro.props;
const locale = getCurrentLocale(Astro);

const prevUrl = prevPost ? localizePath(`/blog/${slugify(prevPost.data.title)}/`, locale) : null;
const nextUrl = nextPost ? localizePath(`/blog/${slugify(nextPost.data.title)}/`, locale) : null;
---

{(prevPost || nextPost) && (
  <div class="flex flex-col sm:flex-row gap-4 w-full">
    <div class="flex-1">
      {prevPost && (
        <a 
          href={prevUrl} 
          class="group flex w-full flex-col py-4 transition-all duration-200"
          aria-label={`${getLabel(locale, 'previousArticle')}: ${prevPost.data.title}`}
        >
          <div class="flex items-center gap-2 text-[13px] md:text-sm text-(--fg-muted) mb-2">
            <Icon name="arrow-left" className="w-4 h-4" />
            <span>{getLabel(locale, 'previous')}</span>
          </div>
          <span class="text-sm md:text-base font-semibold text-(--fg-muted) group-hover:text-(--fg) line-clamp-2 text-left">
            {prevPost.data.title}
          </span>
        </a>
      )}
    </div>
    <div class="flex-1">
      {nextPost && (
        <a 
          href={nextUrl} 
          class="group flex w-full flex-col py-4 transition-all duration-200"
          aria-label={`${getLabel(locale, 'nextArticle')}: ${nextPost.data.title}`}
        >
          <div class="flex items-center justify-end gap-2 text-[13px] md:text-sm text-(--fg-muted) mb-2">
            <span>{getLabel(locale, 'next')}</span>
            <Icon name="arrow-right" className="w-4 h-4" />
          </div>
          <span class="text-sm md:text-base font-semibold text-(--fg-muted) group-hover:text-(--fg) line-clamp-2 text-right">
            {nextPost.data.title}
          </span>
        </a>
      )}
    </div>
  </div>
)}