---
import { siteConfig } from '@/config/site';
import { slugify } from '@/lib/utils';
import Icon from '@/components/ui/Icon';

interface Props {
  prevPost?: any;
  nextPost?: any;
}

const { prevPost, nextPost } = Astro.props;

const prevUrl = prevPost ? `/blog/${prevPost.data.slug || slugify(prevPost.data.title)}` : null;
const nextUrl = nextPost ? `/blog/${nextPost.data.slug || slugify(nextPost.data.title)}` : null;
---

{(prevPost || nextPost) && (
  <div class="relative grid grid-cols-1 md:grid-cols-2 w-full">
    <div class="w-full">
      {prevPost ? (
        <a href={prevUrl} class="group flex w-full flex-col py-4 lg:py-6 transition-colors">
          <div class="flex items-center gap-1.5 text-label-14 text-(--fg) mb-2">
            <Icon name="arrow-left" className="w-4 h-4" />
            <span>{siteConfig.b_prevPosts}</span>
          </div>
          <span class="text-heading-14 md:text-heading-16 font-medium text-muted group-hover:text-(--fg) active:text-(--fg) line-clamp-2 text-left">
            {prevPost.data.title}
          </span>
        </a>
      ) : (
        <div class="hidden md:block w-full h-full min-h-25" />
      )}
    </div>
    <div class="w-full">
      {nextPost && (
        <a href={nextUrl} class="group flex w-full flex-col py-4 lg:py-6 transition-colors">
          <div class="flex items-center justify-end gap-1.5 text-label-14 text-(--fg) mb-2">
            <span>{siteConfig.b_nextPosts}</span>
            <Icon name="arrow-right" className="w-4 h-4" />
          </div>
          <span class="text-heading-14 md:text-heading-16 font-medium text-muted group-hover:text-(--fg) active:text-(--fg) line-clamp-2 text-right">
            {nextPost.data.title}
          </span>
        </a>
      )}
    </div>
    
  </div>
)}
