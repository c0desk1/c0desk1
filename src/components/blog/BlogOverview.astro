---
// src/components/blog/BlogOverview.astro
interface Props {
  items?: string[];
}

const { items } = Astro.props;
---

{items && items.length > 0 && (
  <aside class="overview">
    <div class="overview-header">
      <h3 class="text-heading-20 lg:text-heading-24 font-semibold">Key Takeaways</h3>
    </div>
    <ul class="overview-list">
      {items.map((item) => (
        <li class="text-copy-16 lg:text-copy-18 text-(--prose-fg)/90">{item}</li>
      ))}
    </ul>
  </aside>
)}

<style>
  .overview {
    margin: 1.5rem 0;
  }
  .overview-header {
    display: flex;
    align-items: start;
    gap: 0.5rem;
    margin-bottom: 1rem;
    color: var(--prose-fg);
  }
  .overview-list {
    list-style: none;
    align-items: start;
    text-align: start;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .overview-list li {
    position: relative;
    padding-left: 1.5rem;
  }
  .overview-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--prose-list-marker);
  }
  .overview-list li::before:hover {
    color: var(--prose-list-marker-hover);
  }
</style>
