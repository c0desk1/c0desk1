---
// src/components/blog/sidebar/ArchivesCard.astro

interface Props {
  counts: Record<number, number>;
}

const { counts } = Astro.props;
---

{Object.keys(counts).length > 0 && (
  <div>
    <div class="flex items-center gap-2 mb-3">
      <div class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-500"></div>
      <h3 class="text-[12px] font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
        Archives
      </h3>
    </div>
    <div class="space-y-1">
      {Object.entries(counts)
        .sort((a, b) => Number(b[0]) - Number(a[0]))
        .map(([year, count]) => (
          <a 
            href={`/blog/archive/${year}`}
            class="flex items-center justify-between py-1.5 text-[12px] font-mono text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-600 rounded-sm px-1 -mx-1"
            aria-label={`View posts from ${year} (${count} posts)`}
          >
            <span>{year}</span>
            <span class="text-zinc-400 dark:text-zinc-500" aria-hidden="true">[{count}]</span>
          </a>
        ))}
    </div>
  </div>
)}