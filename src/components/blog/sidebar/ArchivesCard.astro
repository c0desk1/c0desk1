---
// src/components/blog/sidebar/ArchivesCard.astro

interface Props {
  counts: Record<number, number>;
}

const { counts } = Astro.props;
---

{Object.keys(counts).length > 0 && (
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <span class="font-mono font-semibold text-emerald-600 dark:text-emerald-500">
        ▼
      </span>
      <h2 class="text-xs font-medium tracking-wide text-zinc-500 dark:text-zinc-400">
        Archives
      </h2>
    </div>
    <div class="space-y-1">
      {Object.entries(counts)
        .sort((a, b) => Number(b[0]) - Number(a[0]))
        .map(([year, count]) => (
          <a href={`/blog/archive/${year}`} class="flex items-center justify-between py-1.5 px-1 -mx-1 text-sm font-mono text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors" aria-label={`View posts from ${year} (${count} posts)`}>
            <span class="opacity-90">
              {year}
            </span>
            <span
              class="text-xs text-zinc-400 dark:text-zinc-500"
              aria-hidden="true">
              [{count}]
            </span>
          </a>
        ))}
    </div>
  </div>
)}