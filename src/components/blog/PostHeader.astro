---
// src/components/blog/postHeader.astro
import PostMeta from './PostMeta.astro';
import Overview from '../blog/BlogOverview.astro';
import PostAuthor from './PostAuthor.astro';

interface Props {
  title: string;
  pubDate: Date;
  content?: string;
  authorName?: string;
  authorAvatar?: string;
  authorRole?: string;
  authorSlug: string;
  overviewItems?: string[];
}

const {
  title,
  pubDate,
  content = '',
  authorName,
  authorAvatar,
  authorRole,
  authorSlug,
  overviewItems
} = Astro.props;
---

<header class="w-full max-w-5xl mx-auto">
  <div class="flex flex-col items-center text-center gap-4 md:gap-6">
    <h1 class="text-heading-24 md:text-heading-32 lg:text-heading-40 font-semibold text-balance">
      {title}
    </h1>
    <div class="flex flex-col items-center gap-4 w-full">
      {authorName && (
        <PostAuthor
          name={authorName}
          avatar={authorAvatar}
          role={authorRole}
          slug={authorSlug}
        />
      )}
      {content && (
        <div class="w-full">
          <PostMeta pubDate={pubDate} content={content} />
        </div>
      )}
    </div>
    {overviewItems && overviewItems.length > 0 && (
      <div class="w-full mt-2">
        <Overview items={overviewItems} />
      </div>
    )}
    <hr class="w-16 border-t-4 border-(--border) rounded-full opacity-40" />
  </div>
</header>