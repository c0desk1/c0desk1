---
// src/components/blog/postHeader.astro
import PostMeta from './PostMeta.astro';
import Overview from '../blog/BlogOverview.astro';
import PostAuthor from './PostAuthor.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  content?: string;
  authorName?: string;
  authorAvatar?: string;
  authorRole?: string;
  authorSlug: string;
  overviewItems?: string[];
}

const {
  title,
  description,
  pubDate,
  content = '',
  authorName,
  authorAvatar,
  authorRole,
  authorSlug,
  overviewItems
} = Astro.props;
---

<header class="w-full max-w-3xl mx-auto">
  <div class="flex flex-col items-center text-center gap-5 md:gap-6">
    <h1 class="text-heading-32 md:text-heading-40 lg:text-heading-48 font-bold text-balance tracking-tight">
      {title}
    </h1>
    {description && (
      <p class="lead text-body-18 md:text-body-20 text-(--prose-fg-muted) max-w-2xl">{description}</p>
    )}
    <div class="flex flex-col items-center gap-4 w-full">
      {authorName && (
        <PostAuthor
          name={authorName}
          avatar={authorAvatar}
          role={authorRole}
          slug={authorSlug}
        />
      )}
      {content && (
        <div class="w-full">
          <PostMeta pubDate={pubDate} content={content} />
        </div>
      )}
    </div>
    {overviewItems && overviewItems.length > 0 && (
      <div class="w-full mt-2">
        <Overview items={overviewItems} />
      </div>
    )}
    <hr class="w-16 border-t-4 border-(--border) rounded-full opacity-40" />
  </div>
</header>