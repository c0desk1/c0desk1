---
// src/components/blog/BlogTOC.astro
// @ts-nocheck
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <aside class="hidden lg:block">
    <div class="sticky top-24">
      <div class="space-y-3">
        <div class="flex items-center gap-2">
          <div class="h-2 w-2 rounded-full bg-zinc-400 dark:bg-zinc-500"></div>
          <h3 class="text-[12px] font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
            On this page
          </h3>
        </div>
        
        <nav class="space-y-1.5 border-l border-zinc-200 dark:border-zinc-800 pl-3">
          {headings.map(h => (
            <a 
              key={h.slug}
              href={`#${h.slug}`} 
              class:list={[
                "block text-[13px] font-mono text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors",
                { "pl-3": h.depth === 3 }
              ]}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </aside>
)}