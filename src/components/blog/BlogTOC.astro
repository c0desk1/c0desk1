---
// src/components/blog/BlogTOC.astro

import { filterHeadingsForTOC } from '@/lib/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = filterHeadingsForTOC(headings);
---

{tocHeadings.length > 0 && (
  <aside class="hidden lg:block">
    <div class="sticky top-24">
      <div class="space-y-3">
        <div class="flex items-center gap-1.5">
          <div class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-500"></div>
          <h3 class="text-xs font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
            On this page
          </h3>
        </div>
        
        <nav class="space-y-1.5 border-l border-zinc-100 dark:border-zinc-900 pl-3">
          {tocHeadings.map(h => (
            <a
              href={`#${h.slug}`} 
              class:list={[
                "block text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors",
                { "pl-3": h.depth === 3 }
              ]}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </aside>
)}