---
// src/components/blog/BlogTOC.astro

import { filterHeadingsForTOC } from '@/lib/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = filterHeadingsForTOC(headings);
---

{tocHeadings.length > 0 && (
  <aside class="hidden lg:block">
    <div class="sticky top-24">
      <div class="mb-4 flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400">
        <span class="font-mono text-zinc-400 dark:text-zinc-600">
          //
        </span>
        <span>
          Di halaman ini
        </span>
      </div>
      <nav class="space-y-1 border-l border-zinc-200 dark:border-zinc-800 pl-3">
        {tocHeadings.map(h => (
          <a
            href={`#${h.slug}`}
            class:list={[
              "block text-sm text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors leading-relaxed",
              { "pl-4 text-xs opacity-90": h.depth === 3 }
            ]}
          >
            {h.text}
          </a>
        ))}
      </nav>
    </div>
  </aside>
)}