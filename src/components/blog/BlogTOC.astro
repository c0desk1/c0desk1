---
// src/components/blog/BlogTOC.astro

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <aside class="hidden lg:block sticky top-24">
    <div class="space-y-4">
      <div class="flex items-center gap-2">
        <div class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-500"></div>
        <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
          On this page
        </h3>
      </div>
      
      <nav class="space-y-2 border-l border-zinc-200 dark:border-zinc-800 pl-4">
        {headings.map(h => (
          <a 
            href={`#${h.slug}`} 
            class:list={[
              "block text-sm font-mono text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors",
              { "pl-4 text-xs": h.depth === 3 }
            ]}
          >
            {h.text}
          </a>
        ))}
      </nav>
      
      <a 
        href="#top" 
        class="inline-flex items-center gap-2 text-xs font-mono text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors pt-4"
      >
        <span>↑</span>
        <span>[back to top]</span>
      </a>
    </div>
  </aside>
)}