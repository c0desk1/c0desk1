---
// src/components/blog/BlogTOC.astro
import { filterHeadingsForTOC } from '@/lib/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = filterHeadingsForTOC(headings);
---

{tocHeadings.length > 0 && (
  <nav class="not-prose my-10 rounded-xl border border-zinc-200 bg-zinc-50/50 p-6 dark:border-zinc-800 dark:bg-zinc-900/50">
    <div class="mb-4">
      <h2 class="text-[12px] font-bold uppercase tracking-[0.2em] text-zinc-500 dark:text-zinc-400">
        Daftar Isi
      </h2>
    </div>
    
    <ul class="grid grid-cols-1 gap-x-8 gap-y-2 md:grid-cols-2">
      {tocHeadings.map(h => (
        <li class:list={[
          "flex items-start transition-all duration-200",
          h.depth === 3 ? "ml-4" : "" 
        ]}>
          <a
            href={`#${h.slug}`}
            class="group flex items-center gap-2 text-[14px] text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100"
          >
            <span class="h-1 w-1 shrink-0 rounded-full bg-zinc-300 transition-colors group-hover:bg-emerald-500 dark:bg-zinc-700"></span>
            
            <span class="relative overflow-hidden">
              {h.text}
              <span class="absolute bottom-0 left-0 h-px w-0 bg-zinc-900 transition-all duration-300 group-hover:w-full dark:bg-zinc-100"></span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}