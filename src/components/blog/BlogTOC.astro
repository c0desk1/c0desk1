---
// src/components/blog/BlogTOC.astro
import { filterHeadingsForTOC } from '@/lib/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = filterHeadingsForTOC(headings);
---

{tocHeadings.length > 0 && (
  <aside class="block">
    <div class="sticky top-24">
      <div class="mb-3">
        <span class="text-xs md:text-sm font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">
          Di halaman ini
        </span>
      </div>
      <nav class="space-y-2">
        {tocHeadings.map(h => (
          <a
            href={`#${h.slug}`}
            class="group block text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
          >
            <span class="relative inline-block">
              {h.text}
              <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-zinc-400 dark:bg-zinc-500 group-hover:w-full transition-all duration-200"></span>
            </span>
          </a>
        ))}
      </nav>
    </div>
  </aside>
)}