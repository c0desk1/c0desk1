---
// src/components/blog/BlogHero.astro
import Container from '@/components/ui/Container.astro';
import Breadcrumb from '../ui/Breadcrumb.astro';
---

<div class="border-b border-zinc-100 dark:border-zinc-900">
  <Container size="lg" class="py-8 md:py-10">
    <Breadcrumb items={[
      { name: 'home', href: '/' },
      { name: 'blog', href: '/blog' }
    ]} />
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-white leading-tight">
      Thoughts & 
      <span class="text-zinc-400 dark:text-zinc-600">insights.</span>
    </h1>
    <p class="text-sm text-zinc-600 dark:text-zinc-400 max-w-2xl font-mono mt-2">
      Exploring web development, design systems, and industrial tactical design.
    </p>
    <div class="mt-4">
      <div class="h-px w-8 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
    </div>
    
  </Container>
</div>