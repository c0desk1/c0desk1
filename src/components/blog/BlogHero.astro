---
// src/components/blog/BlogHero.astro
import Container from '@/components/ui/Container.astro';
---


  <Container size="md" class="py-10 md:py-14">   
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end gap-4">
      <div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-zinc-900 dark:text-white leading-tight">
          Thoughts
          <span class="text-zinc-400 dark:text-zinc-500">
            & insights
          </span>
        </h1>
        <p class="mt-3 max-w-xl text-sm md:text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed">
          Catatan dari balik layar tentang sistem, kreativitas, dan hal-hal yang gue anggap menarik. Sebuah jurnal untuk setiap fragmen yang sedang gue pelajari.
        </p>
      </div>
      
    </div>
  </Container>
