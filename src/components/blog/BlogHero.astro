---
// src/components/blog/BlogHero.astro

import Container from '@/components/ui/Container.astro';
---

<div class="border-b border-zinc-200 dark:border-zinc-800">
  <Container size="md" class="py-10 md:py-14">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 leading-[1.15]">
      Thoughts  
      <span class="text-zinc-400 dark:text-zinc-600 font-normal">
        & insights
      </span>

    </h1>
    <p class="mt-4 max-w-xl text-sm md:text-base text-zinc-600 dark:text-zinc-500 leading-relaxed">
      Menjelajahi pengembangan web modern, sistem desain, dan pendekatan teknis yang berfokus pada efisiensi dan kejelasan struktur.
    </p>
    <div class="mt-6">
      <div class="h-px w-10 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
    </div>
  </Container>
</div>