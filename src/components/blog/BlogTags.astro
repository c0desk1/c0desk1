---
// src/components/blog/BlogTags.astro
interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;
---

{tags.length > 0 && (
  <div class="flex flex-wrap items-center gap-x-1 text-xs text-zinc-500 dark:text-zinc-400 pt-1">
    <span class="text-zinc-400 dark:text-zinc-500">Tags:</span>
    {tags.map((tag, index) => (
      <span>
        {index > 0 && <span class="text-zinc-300 dark:text-zinc-600">, </span>}
        <a
          href={`/blog/tags/${encodeURIComponent(tag)}`}
          class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
        >
          {tag}
        </a>
      </span>
    ))}
  </div>
)}