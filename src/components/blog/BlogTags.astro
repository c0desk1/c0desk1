---
// src/components/blog/BlogTags.astro

interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;
---

{tags.length > 0 && (
  <div class="flex flex-wrap gap-2 pt-1">
    {tags.map(tag => (
      <span 
        class="px-2 py-0.5 text-[12px] font-mono border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-400 hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors"
      >
        #{tag}
      </span>
    ))}
  </div>
)}