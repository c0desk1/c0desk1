---
// src/components/blog/BlogTags.astro

interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;
---

{tags.length > 0 && (
  <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs pt-1">
    {tags.map(tag => (
      <span
        class="
          text-zinc-500
          dark:text-zinc-400
          hover:text-zinc-900
          dark:hover:text-zinc-100
          transition-colors
          cursor-default">
        #{tag}
      </span>
    ))}
  </div>
)}