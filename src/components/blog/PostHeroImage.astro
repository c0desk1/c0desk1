---
// src/components/blog/HeroImage.astro
import { Image } from 'astro:assets';
import { IMAGE } from '@/consts';

import { 
  cdnImage, 
  isCdnUrl 
} from '@/lib/utils';

interface Props {
  image?: any;
  alt?: string;
}

const { 
  image, 
  alt = '' 
} = Astro.props;

const isPlaceholder = !image || image === '';

const optimizedSrc = !isPlaceholder && isCdnUrl(image)
  ? cdnImage(image, { 
    w: IMAGE.thumbnail.width, 
    h: IMAGE.thumbnail.height, 
    q: IMAGE.thumbnail.quality 
  })
  : image || IMAGE.thumbnail.placeholder;
---

<figure class="w-full max-w-4xl mx-auto">
  <div class:list={[
    "relative overflow-hidden rounded-(--prose-radius-lg)",
    isPlaceholder ? "bg-muted/10 border border-(--border)" : "bg-base"
  ]}>
    
    {!isPlaceholder && (
      <div class="absolute inset-0 bg-base animate-pulse" aria-hidden="true"></div>
    )}

    <Image
      src={optimizedSrc}
      alt={isPlaceholder ? "No image available" : alt}
      width={IMAGE.thumbnail.width}
      height={IMAGE.thumbnail.height}
      loading="eager"
      decoding="async"
      fetchpriority='high'
      class:list={[
        "relative z-10 h-full w-full object-cover aspect-video transition duration-500",
        isPlaceholder ? "opacity-100" : "opacity-0"
      ]}
      onload={!isPlaceholder ? "this.classList.remove('opacity-0')" : undefined}
    />
  </div>
</figure>