---
// src/components/blog/HeroImage.astro
import { Image } from 'astro:assets';
import { 
  cdnImage, 
  isCdnUrl 
} from '@/lib/utils';
import { IMAGE } from '@/consts';

interface Props {
  image?: any;
  alt?: string;
}

const { image, alt = '' } = Astro.props;

const optimizedSrc = image && isCdnUrl(image)
  ? cdnImage(image, { w: IMAGE.thumbnail.width, h: IMAGE.thumbnail.height, q: IMAGE.thumbnail.quality })
  : image ?? '';
---

<figure class="w-full max-w-4xl mx-auto my-8 md:my-10">
  <div class="relative overflow-hidden rounded-(--prose-radius-lg) shadow-2xl">
    <div class="absolute inset-0 bg-base animate-pulse" aria-hidden="true"></div>
    <Image
      src={optimizedSrc || IMAGE.thumbnail.placeholder}
      alt={alt}
      width={IMAGE.thumbnail.width}
      height={IMAGE.thumbnail.height}
      loading="eager"
      decoding="async"
      fetchpriority='high'
      class="relative z-10 h-full w-full object-cover aspect-video transition duration-500 opacity-0"
      onload="this.classList.remove('opacity-0')"
    />
  </div>
</figure>