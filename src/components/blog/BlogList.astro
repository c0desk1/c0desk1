---
// src/components/blog/BlogList.astro

import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  featuredPost?: CollectionEntry<'blog'>;
  regularPosts: CollectionEntry<'blog'>[];
}
const { featuredPost, regularPosts } = Astro.props;
---

<div class="min-w-0">
  {featuredPost && (
    <div class="mb-10 pb-8">
      <div class="flex items-center gap-2 text-xl">
        <h2 class="text-amber-600 dark:text-amber-500 font-semibold">Unggulan</h2>
        <div class="h-px flex-1 bg-linear-to-r from-amber-500/50 to-transparent"></div>
      </div>
		  <PostCard post={featuredPost} />
    </div>
  )}
  
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-2 text-xl">
      <h2 class="text-zinc-900 dark:text-zinc-100 font-semibold">Semua postingan</h2>
      <div class="h-px flex-1 bg-linear-to-r from-emerald-500/50 to-transparent"></div>
    </div>
  </div>
  
  <div id="yandex_rtb_R-A-19135204-3"></div>
  
  {regularPosts.length > 0 ? (
    <div class="space-y-0 divide-y divide-zinc-100 dark:divide-zinc-900">
      {regularPosts.map(post => (
        <PostCard post={post} />
      ))}
    </div>
  ) : (
    <div class="py-12 text-center border border-zinc-100 dark:border-zinc-900">
      <p class="text-zinc-500 dark:text-zinc-400 text-md">▼ Tidak ada postingan yang ditemukan.</p>
    </div>
  )}
</div>