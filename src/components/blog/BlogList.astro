---
import type { CollectionEntry } from "astro:content";
import PostCard from "@/components/blog/PostCard.astro";

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-8">
  {posts.map((post) => (
    <div class="divide-x divie-(--border)">
      <PostCard post={post} />
    </div>
  ))}
</div>
