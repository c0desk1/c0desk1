---
// src/components/blog/BlogList.astro

import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  regularPosts: CollectionEntry<'blog'>[];
}
const { regularPosts } = Astro.props;
---

<section class="section-divider">
  <div class="flex items-center justify-between my-6">
    <div class="flex items-center gap-2 text-lg md:text-xl">
      <h2 class="text-zinc-900 dark:text-zinc-100 font-semibold">Semua postingan</h2>
    </div>
    <div class="flex items-center gap-1">
        <a 
          href="/rss.xml" 
          class="p-2 text-zinc-500 hover:text-zinc-900 rounded-lg dark:text-zinc-400 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800/50 transition-all duration-200"
          aria-label="Langganan RSS Feed"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" />
          </svg>
        </a>
      </div>
  </div>
  {regularPosts.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-3">
      {regularPosts.map(post => (
<div
      class="
        py-6 px-4

        border-b border-zinc-100
        dark:border-zinc-900

        md:border-r
        md:[&:nth-child(3n)]:border-r-0
        md:[&:nth-last-child(-n+3)]:border-b-0
      "
    >
        <PostCard post={post} />
</div>
      ))}
    </div>
  ) : (
    <div class="py-12 text-center border border-zinc-100 dark:border-zinc-900">
      <p class="text-zinc-500 dark:text-zinc-400 text-md">▼ Tidak ada postingan yang ditemukan.</p>
    </div>
  )}
</section>