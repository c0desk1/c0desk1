---
// src/components/blog/BlogList.astro

import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  featuredPost?: CollectionEntry<'blog'>;
  regularPosts: CollectionEntry<'blog'>[];
  totalCount: number;
}
const { featuredPost, regularPosts, totalCount } = Astro.props;
---

<div class="min-w-0">
  {featuredPost && (
    <div class="mb-10 pb-8">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-[11px] font-mono text-amber-600 dark:text-amber-500 font-bold">[featured]</span>
        <div class="h-px flex-1 bg-linear-to-r from-amber-500/50 to-transparent"></div>
      </div>
      <div class="bg-amber-50/30 dark:bg-amber-950/10 border-l-2 border-amber-500 p-5 -mx-5">
        <PostCard post={featuredPost} showTags={true} />
      </div>
    </div>
  )}
  
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-2">
      <span class="text-[11px] font-mono text-zinc-400 dark:text-zinc-500">$</span>
      <span class="text-[11px] font-mono text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">
        All posts ({totalCount})
      </span>
    </div>
    <div class="text-[11px] font-mono text-zinc-400 dark:text-zinc-500">
      [list view]
    </div>
  </div>
  
  {regularPosts.length > 0 ? (
    <div class="space-y-0">
      {regularPosts.map(post => (
        <PostCard post={post} showTags={true} />
      ))}
    </div>
  ) : (
    <div class="py-12 text-center border border-zinc-200 dark:border-zinc-800">
      <p class="text-zinc-500 dark:text-zinc-400 font-mono text-sm">$ No posts found.</p>
    </div>
  )}
</div>