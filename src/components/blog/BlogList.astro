---
// src/components/blog/BlogList.astro

import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  featuredPost?: CollectionEntry<'blog'>;
  regularPosts: CollectionEntry<'blog'>[];
  totalCount: number;
}
const { featuredPost, regularPosts, totalCount } = Astro.props;
---

<div class="min-w-0">
  {featuredPost && (
    <div class="mb-10 pb-8">
      <div class="flex items-center gap-2 mb-4">
        <h2 class="text-sm text-amber-600 dark:text-amber-500 font-bold">Featured</h2>
        <div class="h-px flex-1 bg-linear-to-r from-amber-500/50 to-transparent"></div>
      </div>
		<PostCard post={featuredPost} showTags={true} />
    </div>
  )}
  
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400">
      <span>$</span>
      <h2>
        All posts (<span class="font-mono">{totalCount}</span>)
      </h2>
    </div>
  </div>
  
  {regularPosts.length > 0 ? (
    <div class="space-y-0 divide-y divide-zinc-100 dark:divide-zinc-900">
      {regularPosts.map(post => (
        <PostCard post={post} showTags={true} />
      ))}
    </div>
  ) : (
    <div class="py-12 text-center border border-zinc-100 dark:border-zinc-900">
      <p class="text-zinc-500 dark:text-zinc-400 text-sm">$ No posts found.</p>
    </div>
  )}
</div>