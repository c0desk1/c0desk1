---
// src/components/blog/BlogList.astro

import type { CollectionEntry } from "astro:content";
import PostCard from "./PostCard.astro";
import FeaturedPostCard from "./FeaturedPostCard.astro";
import { formatDateCompact, getReadingTime } from "@/lib/utils";

interface Props {
  posts: CollectionEntry<"blog">[];
  variant?: "featured" | "default";
}

const { posts, variant = "default" } = Astro.props;

const postsData = posts.map((post) => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  pubDate: post.data.pubDate.toISOString(),
  formattedDate: formatDateCompact(post.data.pubDate),

  readingTime: getReadingTime(post.body || post.data.description || ""),

  author: post.data.author?.name,
  authorAvatar: post.data.author?.avatar,
  category: post.data.category
}));
---

<div class="border border-black/20 dark:border-white/5 overflow-hidden">

  {variant === "featured" && (
    <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-black/20 dark:divide-white/5">
      {posts.map((post) => (
        <FeaturedPostCard post={post} />
      ))}
    </div>
  )}

  {variant === "default" && (
    <>
      <div class="mb-8 flex items-center justify-between">
        <h2 class="text-3xl md:text-4xl font-semibold">Terbaru.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 divide-black/20 dark:divide-white/5">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </>
  )}

</div>

<script type="application/json" id="posts-data">
  {JSON.stringify(postsData)}
</script>