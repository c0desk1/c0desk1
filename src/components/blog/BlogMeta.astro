---
import { formatDate } from '@/lib/utils';

interface Props {
  pubDate: Date;
  readingTime: string;
}

const { pubDate, readingTime = false } = Astro.props;

const formattedDate = formatDate(pubDate);
---

<div class="flex flex-wrap justify-center items-center gap-x-2 gap-y-1 text-[13px] md:text-sm text-zinc-500 dark:text-zinc-400">
  <span class="whitespace-nowrap">
    {readingTime}
  </span>
  <span class="text-zinc-300 dark:text-zinc-600">
    •
  </span>
  <time
    datetime={pubDate.toISOString()}
    class="whitespace-nowrap"
  >
    {formattedDate}
  </time>
</div>