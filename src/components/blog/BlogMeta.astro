---
// src/components/blog/BlogMeta.astro

import { formatDateCompact } from '@/lib/utils';

interface Props {
  pubDate: Date;
  updatedDate?: Date;
  readingTime: string;
  featured?: boolean;
}

const { pubDate, updatedDate, readingTime, featured = false } = Astro.props;

const formattedDate = formatDateCompact(pubDate);
const formattedUpdateDate = updatedDate ? formatDateCompact(updatedDate) : undefined;
---

<div class="flex flex-wrap items-center gap-2 text-xs text-zinc-500 dark:text-zinc-400">
  <span class="text-emerald-600 dark:text-emerald-500 font-bold shrink-0">$</span>
  <time class="font-mono" datetime={pubDate.toISOString()}>{formattedDate}</time>
  {updatedDate && (
    <>
      <span class="text-zinc-300 dark:text-zinc-700">/</span>
      <span>Updated</span>
      <time class="font-mono" datetime={updatedDate.toISOString()}>{formattedUpdateDate}</time>
    </>
  )}
  <span class="text-zinc-300 dark:text-zinc-700">/</span>
  <div class="flex items-center gap-0.5">
    <span>[</span>
    <span>{readingTime}</span>
    <span>]</span>
  </div>
  {featured && (
    <>
      <span class="text-zinc-300 dark:text-zinc-700">/</span>
      <span class="text-amber-600 dark:text-amber-500">[featured]</span>
    </>
  )}
</div>