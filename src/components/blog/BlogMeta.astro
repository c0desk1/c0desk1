---
// src/components/blog/BlogMeta.astro
import { formatDate } from '@/lib/utils';

interface Props {
  pubDate: Date;
  readingTime: string;
}

const { pubDate, readingTime } = Astro.props;

const formattedDate = formatDate(pubDate);
---

<div class="flex flex-wrap justify-center items-center gap-x-2 gap-y-1 text-[13px] md:text-sm text-(--fg-muted)">
  {readingTime && (
    <>
      <span class="whitespace-nowrap">
        {readingTime}
      </span>
      <span class="text-(--fg-subtle)" aria-hidden="true">
        •
      </span>
    </>
  )}
  
  <time
    datetime={pubDate.toISOString()}
    class="whitespace-nowrap"
  >
    {formattedDate}
  </time>
</div>