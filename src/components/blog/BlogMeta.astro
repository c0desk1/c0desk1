---
import { formatDate } from '@/lib/utils';

interface Props {
  pubDate: Date;
  readingTime: string;
  featured?: boolean;
}

const { pubDate, readingTime, featured = false } = Astro.props;

const formattedDate = formatDate(pubDate);
---

<div class="flex flex-wrap justify-center items-center gap-x-2 gap-y-1 text-[12px] md:text-sm text-zinc-500 dark:text-zinc-400">
  {featured && (
    <span class="inline-flex items-center px-1.5 py-0.5 rounded-md text-[10px] font-medium uppercase tracking-wide bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
      Unggulan
    </span>
  )}
  <span class="whitespace-nowrap">
    {readingTime}
  </span>
  <span class="text-zinc-300 dark:text-zinc-600">
    •
  </span>
  <time
    datetime={pubDate.toISOString()}
    class="whitespace-nowrap"
  >
    {formattedDate}
  </time>
</div>