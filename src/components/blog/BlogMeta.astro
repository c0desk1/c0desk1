---
// src/components/blog/BlogMeta.astro

import { formatDateCompact } from '@/lib/utils';

interface Props {
  pubDate: Date;
  updatedDate?: Date;
  readingTime: string;
  featured?: boolean;
}

const { pubDate, updatedDate, readingTime, featured = false } = Astro.props;

const formattedDate = formatDateCompact(pubDate);
const formattedUpdateDate = updatedDate ? formatDateCompact(updatedDate) : undefined;
---

<div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-zinc-500 dark:text-zinc-400">
  <span class="font-mono font-semibold text-emerald-600 dark:text-emerald-500 shrink-0">
    $
  </span>
  <time 
    class="font-mono text-zinc-600 dark:text-zinc-400"
    datetime={pubDate.toISOString()}
  >
    {formattedDate}
  </time>
  {updatedDate && (
    <span class="flex items-center gap-1 text-zinc-400 dark:text-zinc-500">
      <span class="opacity-40">•</span>
      <span class="text-[11px] opacity-80">
        diperbarui
      </span>
      <time 
        class="font-mono"
        datetime={updatedDate.toISOString()}
      >
        {formattedUpdateDate}
      </time>
    </span>
  )}
  <span class="flex items-center gap-1 text-zinc-400 dark:text-zinc-500">
    <span class="opacity-40">•</span>
    <span class="font-mono">
      {readingTime}
    </span>
  </span>
  {featured && (
    <span class="flex items-center gap-1 text-amber-600 dark:text-amber-500">
      <span class="opacity-40 text-zinc-400">•</span>
      <span class="font-mono">
        ▼
      </span>
    </span>
  )}
</div>