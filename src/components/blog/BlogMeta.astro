---
// src/components/blog/BlogMeta.astro

import { formatDate } from '@/lib/utils';

interface Props {
  pubDate: Date;
  readingTime: string;
  featured?: boolean;
}

const { pubDate, readingTime, featured = false } = Astro.props;

const formattedDate = formatDate(pubDate);
---

<div class="flex flex-wrap justify-between items-center text-xs md:text-sm text-zinc-500 dark:text-zinc-400">
  <section class="flex items-center gap-2">
    {featured && (
      <span class="items-center gap-1 text-amber-600 dark:text-amber-500">
        ▼
      </span>
    )}
    <span>
      {readingTime}
    </span>
  </span>
  </section>
  <section class="flex items-center gap-1">
    <time 
      class="text-zinc-600 dark:text-zinc-400"
      datetime={pubDate.toISOString()}
    >
      {formattedDate}
    </time>
  </section>
</div>