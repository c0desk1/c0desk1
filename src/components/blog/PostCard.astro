---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets'; 
import { siteConfig } from '@/config/site';
import { formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;
const { title, description, pubDate, category, author } = data;

const categoryEntry = await getEntry(category);

const authorEntry = author ? await getEntry(author) : null;
const authorName = authorEntry?.data.name || siteConfig.author.name;
const authorAvatar = authorEntry?.data.avatar || siteConfig.author.avatar;

const optimizedAvatar = isCdnUrl(authorAvatar) ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 }) : authorAvatar;
---

<a 
  href={`/blog/${id}/`} 
  aria-label={`Read article: ${title}`} 
  class="group flex flex-col h-full rounded-(--radius-xl) border border-(--border) p-6 hover:border-(--border-strong) focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
>
  <div class="flex items-center justify-between mb-6">
    <span class="text-[13px] text-(--fg-subtle) tracking-tight group-hover:text-(--fg)">
      {categoryEntry?.data.name || "General"}
    </span>
    <time datetime={pubDate.toISOString()} class="text-[13px] text-(--fg-subtle)">
      {formatDateCompact(pubDate)}
    </time>
  </div>

  <div class="flex flex-col gap-4">
    <h2 class="text-lg md:text-xl font-semibold tracking-tighter text-(--fg) leading-[1.15] line-clamp-3">
      {title}
    </h2>
    <p class="text-sm text-(--fg-muted) leading-relaxed line-clamp-3 group-hover:text-(--fg)">
      {description}
    </p>
  </div>

  <div class="mt-auto flex items-center gap-3 pt-6">
    {authorAvatar && (
      <Image
        src={optimizedAvatar}
        alt={authorName}
        width={48}
        height={48}
        class="w-6 h-6 rounded-full border border-(--border) object-cover"
      />
    )}
    <span class="text-[13px] text-(--fg-subtle)">
      {authorName}
    </span>
  </div>
</a>