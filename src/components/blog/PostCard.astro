---
// src/components/blog/PostCard.astro
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  post?: CollectionEntry<'blog'>;
  loading?: boolean;
}

const { post } = Astro.props;

let title = '', excerpt = '', categoryName = '', pubDateISO = '', pubDateDisplay = '';
let authorName = '', authorAvatar = '', optimizedAvatar = '', postUrl = '';

if (post) {
  const { data, id } = post;
  const { title: t, pubDate, category, author } = data;
  title = t;
  excerpt = generateExcerpt(post.body || '', 140);

  const categoryEntry = await getEntry(category);
  const authorEntry   = author ? await getEntry(author) : null;

  categoryName    = categoryEntry?.data.name || 'General';
  pubDateISO      = pubDate.toISOString();
  pubDateDisplay  = formatDateCompact(pubDate);
  authorName      = authorEntry?.data.name   || siteConfig.author.name;
  authorAvatar    = authorEntry?.data.avatar || siteConfig.author.avatar;
  optimizedAvatar = isCdnUrl(authorAvatar)
    ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 })
    : authorAvatar;
  postUrl = `/blog/${id}/`;
}
---

<a
  href={postUrl}
  aria-label={`Baca artikel: ${title}`}
  class="group flex flex-col gap-4 rounded-xl border border-transparent p-4 transition-all hover:border-(--border-strong) hover:shadow-xs focus:outline-none focus:ring-2 focus:ring-(--accent)"
>
  <!-- Header: kategori & tanggal -->
  <div class="flex items-center justify-between text-xs uppercase tracking-wide text-(--fg-subtle) transition-colors group-hover:text-(--fg)">
    <span>{categoryName}</span>
    <time datetime={pubDateISO}>{pubDateDisplay}</time>
  </div>

  <!-- Konten utama -->
  <div class="flex flex-col gap-2">
    <h2 class="text-lg font-semibold tracking-tight text-(--fg) line-clamp-3 md:text-xl">
      {title}
    </h2>
    <p class="text-sm leading-relaxed text-(--fg-muted) line-clamp-3 transition-colors group-hover:text-(--fg)">
      {excerpt}
    </p>
  </div>

  <!-- Footer: author -->
  <div class="mt-2 flex items-center gap-2.5">
    {authorAvatar && (
      <Image
        src={optimizedAvatar}
        alt={authorName}
        width={48}
        height={48}
        loading="eager"
        decoding="auto"
        class="h-6 w-6 rounded-full border border-(--border-strong) object-cover"
      />
    )}
    <span class="text-xs text-(--fg-subtle)">{authorName}</span>
  </div>
</a>