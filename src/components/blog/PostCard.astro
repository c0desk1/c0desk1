---
// src/components/blog/PostCard.astro
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  post?: CollectionEntry<'blog'>;
  loading?: boolean;
}

const { post } = Astro.props;

let title = '', excerpt = '', categoryName = '', pubDateISO = '', pubDateDisplay = '';
let authorName = '', authorAvatar = '', optimizedAvatar = '', postUrl = '';

if (post) {
  const { data, id } = post;
  const { title: t, pubDate, category, author } = data;
  title = t;

excerpt = generateExcerpt(post.body || '', 140);

  const categoryEntry = await getEntry(category);

  const authorEntry   = author ? await getEntry(author) : null;

  categoryName    = categoryEntry?.data.name || 'General';
  pubDateISO      = pubDate.toISOString();
  pubDateDisplay  = formatDateCompact(pubDate);
  authorName      = authorEntry?.data.name   || siteConfig.author.name;
  authorAvatar    = authorEntry?.data.avatar || siteConfig.author.avatar;
  optimizedAvatar = isCdnUrl(authorAvatar)
    ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 })
    : authorAvatar;
  postUrl = `/blog/${id}/`;
}
---

<a
  href={postUrl}
  aria-label={`Baca artikel: ${title}`}
  class="group flex flex-col h-full rounded-(--radius-xl) gap-4 border-0 border-(--border) hover:border-(--border-strong) focus:outline-none focus:ring-2 focus:ring-(--border-strong)">
  <div class="flex items-center justify-between mb-6 text-[13px] text-(--fg-subtle) group-hover:text-(--fg)">
    <span>
      {categoryName}
    </span>
    <time datetime={pubDateISO}>
      {pubDateDisplay}
    </time>
  </div>
  <div class="flex flex-col gap-4">
    <h2 class="text-lg md:text-xl font-semibold tracking-tighter text-(--fg) leading-[1.15] line-clamp-3">
      {title}
    </h2>
    <p class="text-sm text-(--fg-muted) leading-relaxed line-clamp-3 group-hover:text-(--fg)">
      {excerpt}
    </p>
  </div>
  <div class="mt-auto flex items-center gap-2 pt-6">
    {authorAvatar && (
      <Image
        src={optimizedAvatar}
        alt={authorName}
        width={48}
        height={48}
        loading= eager
        decoding= auto
        class="w-6 h-6 rounded-full border border-(--border-strong) object-cover"
      />
    )}
    <span class="text-[13px] text-(--fg-subtle)">{authorName}</span>
  </div>
</a>
