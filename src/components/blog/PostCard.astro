---
import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';
import { categoryLabels } from '@/config/blog';
import { formatDateCompact } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;

const { title, description, pubDate, category, author } = data;

const formattedDate = formatDateCompact(pubDate);
const authorName = author?.name || siteConfig.author;
const authorAvatar = author?.avatar || siteConfig.authorAvatar;
---

<a
  href={`/blog/${id}`}
  class="group flex flex-col h-full p-4 md:p-8 transition-all duration-200 overflow-hidden"
  aria-label={`Read article: ${title}`}
>
  <div class="flex items-center justify-between mb-8">
    <span class="text-[13px] group-hover:text-zinc-900 dark:group-hover:text-white transition-colors text-zinc-500 tracking-tight">
      {categoryLabels[category]}
    </span>
    <time datetime={pubDate.toISOString()} class="text-[13px] text-zinc-500">
      {formattedDate}
    </time>
  </div>

  <div class="flex flex-col gap-4">
    <h3 class="text-lg md:text-xl font-semibold tracking-tighter text-zinc-900 dark:text-white leading-[1.1] line-clamp-3 group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-colors">
      {title}
    </h3>
    
    <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-3 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">
      {description}
    </p>
  </div>

  <div class="mt-auto pt-10 flex items-center gap-3">
    {authorAvatar && (
      <img
        src={authorAvatar}
        alt={authorName}
        class="w-6 h-6 rounded-full object-cover"
        loading="eager"
      />
    )}
    <span class="text-[13px] font-medium text-zinc-500 dark:text-zinc-400">
      {authorName}
    </span>
  </div>
</a>