---
// src/components/blog/PostCard.astro
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  post?: CollectionEntry<'blog'>;
  loading?: boolean;
}

const { post } = Astro.props;

let title = '', excerpt = '', categoryName = '', pubDateISO = '', pubDateDisplay = '';
let authorName = '', authorAvatar = '', optimizedAvatar = '', postUrl = '';

if (post) {
  const { data, id } = post;
  const { title: t, pubDate, category, author } = data;
  title = t;
  excerpt = generateExcerpt(post.body || '', 140);

  const categoryEntry = await getEntry(category);
  const authorEntry   = author ? await getEntry(author) : null;

  categoryName    = categoryEntry?.data.name || 'General';
  pubDateISO      = pubDate.toISOString();
  pubDateDisplay  = formatDateCompact(pubDate);
  authorName      = authorEntry?.data.name   || siteConfig.author.name;
  authorAvatar    = authorEntry?.data.avatar || siteConfig.author.avatar;
  optimizedAvatar = isCdnUrl(authorAvatar)
    ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 })
    : authorAvatar;
  postUrl = `/blog/${id}/`;
}
---

<a
  href={postUrl}
  aria-label={`Baca artikel: ${title}`}
  class="group relative flex flex-col gap-4 border-b border-(--border) py-8 pl-5 transition-all first:pt-0 last:border-none hover:border-(--border-strong) hover:pl-6"
>
  <!-- Industrial left accent bar (garis vertikal kiri) -->
  <div class="absolute left-0 top-0 h-full w-0.5 bg-(--accent) opacity-0 transition-all group-hover:opacity-100"></div>

  <!-- Header: kategori (industrial: badge mode kotak) & tanggal -->
  <div class="flex items-center justify-between text-sm">
    <span class="inline-block border border-(--border) px-2 py-0.5 text-xs font-medium text-(--fg-subtle) group-hover:border-(--accent) group-hover:text-(--accent) transition-colors">
      {categoryName}
    </span>
    <time datetime={pubDateISO} class="text-(--fg-subtle) group-hover:text-(--fg)">
      {pubDateDisplay}
    </time>
  </div>

  <!-- Judul -->
  <h2 class="text-xl font-semibold tracking-tight text-(--fg) line-clamp-3 md:text-2xl group-hover:text-(--accent) transition-colors">
    {title}
  </h2>

  <!-- Excerpt -->
  <p class="text-base text-(--fg-muted) leading-relaxed line-clamp-3 group-hover:text-(--fg)">
    {excerpt}
  </p>

  <!-- Author (tanpa avatar kalau ingin lebih clean industrial) -->
  <div class="flex items-center gap-2 text-sm text-(--fg-subtle) group-hover:text-(--fg)">
    <span>{authorName}</span>
  </div>
</a>