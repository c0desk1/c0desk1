---
// src/components/blog/PostCard.astro

import type { CollectionEntry } from 'astro:content';
import { formatDateCompact, getReadingTime } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
  showTags?: boolean;
}

const { post, showTags = true } = Astro.props;
const { data, id, body } = post;
const { title, description, pubDate, tags, featured } = data;

const formattedDate = formatDateCompact(pubDate);
const readingTime = getReadingTime(undefined, undefined, body);
---

<a 
  href={`/blog/${id}`} 
  class="group block py-4 border-b border-zinc-100 dark:border-zinc-800 transition-all duration-200 hover:border-zinc-300 dark:hover:border-zinc-700"
  aria-label={`Read article: ${title}`}
>
  {/* Date */}
  <div class="flex items-center gap-2 font-mono text-[12px] tracking-wide text-zinc-500 dark:text-zinc-400 mb-1.5">
    <span class="text-emerald-600 dark:text-emerald-500 font-bold" aria-hidden="true">$</span>
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">/</span>
    <div class="flex items-center gap-0.5">
      <span aria-hidden="true">[</span>
      <span>{readingTime}</span>
      <span aria-hidden="true">]</span>
    </div>
  </div>
  
  {/* Title */}
  <h3 class="font-semibold text-zinc-900 dark:text-white group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-colors text-base md:text-lg leading-tight mb-1.5">
    {title}
    {featured && (
      <span class="ml-2 text-[11px] font-mono text-amber-600 dark:text-amber-500" aria-label="Featured post">[★]</span>
    )}
  </h3>
  
  {/* Description */}
  <p class="text-sm md:text-base text-zinc-600 dark:text-zinc-400 leading-relaxed line-clamp-2 mb-3">
    {description}
  </p>
  
  {/* Tags & Arrow */}
  <div class="flex items-center justify-between">
    <div class="flex flex-wrap items-center gap-2 text-[12px] font-mono text-zinc-400 dark:text-zinc-500">
      {showTags && tags && tags.length > 0 && (
        <>
          {tags.slice(0, 2).map(tag => (
            <span class="hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">
              #{tag}
            </span>
          ))}
          {tags.length > 2 && (
            <span class="text-zinc-400 dark:text-zinc-600">+{tags.length - 2}</span>
          )}
        </>
      )}
    </div>
    
    <div class="flex items-center gap-1 text-zinc-400 dark:text-zinc-600 group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-all duration-200 group-hover:translate-x-0.5">
      <span class="text-[12px] font-mono">[baca]</span>
      <span class="text-xs" aria-hidden="true">→</span>
    </div>
  </div>
</a>