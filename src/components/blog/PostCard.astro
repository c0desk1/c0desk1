---
// src/components/blog/PostCard.astro
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  post?: CollectionEntry<'blog'>;
  loading?: boolean;
}

const { post } = Astro.props;

let title = '', excerpt = '', categoryName = '', pubDateISO = '', pubDateDisplay = '';
let authorName = '', authorAvatar = '', optimizedAvatar = '', postUrl = '';

if (post) {
  const { data, id } = post;
  const { title: t, pubDate, category, author } = data;
  title = t;
  excerpt = generateExcerpt(post.body || '', 140);

  const categoryEntry = await getEntry(category);
  const authorEntry   = author ? await getEntry(author) : null;

  categoryName    = categoryEntry?.data.name || 'General';
  pubDateISO      = pubDate.toISOString();
  pubDateDisplay  = formatDateCompact(pubDate);
  authorName      = authorEntry?.data.name   || siteConfig.author.name;
  authorAvatar    = authorEntry?.data.avatar || siteConfig.author.avatar;
  optimizedAvatar = isCdnUrl(authorAvatar)
    ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 })
    : authorAvatar;
  postUrl = `/blog/${id}/`;
}
---

<div class="post-card rounded-xl border border-(--border) bg-(--bg) hover:bg-(--bg-muted) transition-colors">
  <a href={postUrl} class="group flex flex-col h-full px-4 py-5 md:px-5 md:py-6">
    <div class="flex items-center justify-between mb-3 md:mb-4 text-xs md:text-sm text-(--fg-subtle) shrink-0">
      <span class="tracking-tight font-medium">{categoryName}</span>
      <time datetime={pubDateISO}>{pubDateDisplay}</time>
    </div>
    
    <div class="flex flex-col gap-2 md:gap-3 flex-1 min-w-0 min-h-0">
      <h2 class="text-base md:text-xl font-semibold tracking-tight text-(--fg) leading-snug line-clamp-2">
        {title}
      </h2>
      <p class="text-xs md:text-sm text-(--fg-muted) leading-relaxed line-clamp-2 md:line-clamp-3 group-hover:text-(--fg)">
        {excerpt}
      </p>
    </div>
    
    <div class="mt-3 md:mt-auto flex items-center gap-2 text-xs md:text-sm text-(--fg-subtle) shrink-0">
      {authorAvatar && (
        <Image
          src={optimizedAvatar}
          alt=""
          width={24}
          height={24}
          class="w-5 h-5 md:w-6 md:h-6 object-cover rounded-full shrink-0"
        />
      )}
      <span class="truncate font-medium">{authorName}</span>
    </div>
  </a>
</div>

<style>
  @media (min-width: 768px) {
    .post-card {
      aspect-ratio: 3 / 2;
    }
  }
</style>