---
// src/components/blog/PostCard.astro

import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  post?: CollectionEntry<'blog'>;
  loading?: boolean;
}

const { post } = Astro.props;

let title = '', excerpt = '', categoryName = '', pubDateISO = '', pubDateDisplay = '';
let authorName = '', authorAvatar = '', optimizedAvatar = '', postUrl = '';

if (post) {
  const { data, id } = post;
  const { title: t, pubDate, category, author } = data;
  title = t;
  excerpt = generateExcerpt(post.body || '', 140);

  const categoryEntry = await getEntry(category);
  const authorEntry   = author ? await getEntry(author) : null;

  categoryName    = categoryEntry?.data.name || 'General';
  pubDateISO      = pubDate.toISOString();
  pubDateDisplay  = formatDateCompact(pubDate);
  authorName      = authorEntry?.data.name   || siteConfig.author.name;
  authorAvatar    = authorEntry?.data.avatar || siteConfig.author.avatar;
  optimizedAvatar = isCdnUrl(authorAvatar)
    ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 })
    : authorAvatar;
  postUrl = `/blog/${id}/`;
}
---

<a href={postUrl} class="group flex flex-col h-full w-full py-8">
  <div class="flex items-center justify-between mb-4 text-[13px] md:text-sm text-(--fg-subtle) group-hover:text-(--fg) font-medium">
    <span class="tracking-tight">{categoryName}</span>
    <time datetime={pubDateISO}>{pubDateDisplay}</time>
  </div>
  <div class="flex flex-col gap-4 flex-1">
    <h2 class="text-xl md:text-2xl font-semibold tracking-tight text-(--fg) leading-tight line-clamp-3">
      {title}
    </h2>
    <p class="text-[13px] md:text-sm font-medium text-(--fg-muted) leading-relaxed line-clamp-3 group-hover:text-(--fg)">
      {excerpt}
    </p>
    <div class="mt-auto flex items-center gap-2 text-[13px] md:text-sm text-(--fg-subtle) group-hover:text-(--fg) font-medium">
      {authorAvatar && (
        <Image
          src={optimizedAvatar}
          alt={`Author ${authorName}`}
          width={48}
          height={48}
          decoding="async"
          class="w-5 h-5 object-cover rounded-full"
        />
      )}
      <span>{authorName}</span>
    </div>
  </div>
</a>
