---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets'; 
import { siteConfig } from '@/config/site';
import { formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;
const { title, description, pubDate, category, author } = data;

const categoryEntry = await getEntry(category);

const authorEntry = author ? await getEntry(author) : null;
const authorName = authorEntry?.data.name || siteConfig.author.name;
const authorAvatar = authorEntry?.data.avatar || siteConfig.author.avatar;

const optimizedAvatar = isCdnUrl(authorAvatar) ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 }) : authorAvatar;
---

<a 
  href={`/blog/${id}/`} 
  aria-label={`Read article: ${title}`} 
  class="group flex flex-col h-full rounded-2xl border border-black/10 dark:border-white/10 p-6 hover:border-black/20 dark:hover:border-white/20 focus:outline-none focus:ring-2 focus:ring-black/20 dark:focus:ring-white/20"
>
  <div class="flex items-center justify-between mb-6">
    <span class="text-[13px] text-zinc-500 tracking-tight group-hover:text-zinc-900 dark:group-hover:text-white">
      {categoryEntry?.data.name || "General"}
    </span>
    <time datetime={pubDate.toISOString()} class="text-[13px] text-zinc-500">
      {formatDateCompact(pubDate)}
    </time>
  </div>

  <div class="flex flex-col gap-4">
    <h2 class="text-lg md:text-xl font-semibold tracking-tighter text-zinc-900 dark:text-white leading-[1.15] line-clamp-3 group-hover:text-zinc-600 dark:group-hover:text-zinc-300">
      {title}
    </h2>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-3 group-hover:text-zinc-900 dark:group-hover:text-white">
      {description}
    </p>
  </div>

  <div class="mt-auto flex items-center gap-3 pt-6">
    {authorAvatar && (
      <Image
        src={optimizedAvatar}
        alt={authorName}
        width={48}
        height={48}
        class="w-6 h-6 rounded-full object-cover"
      />
    )}
    <span class="text-[13px] text-zinc-500 dark:text-zinc-400">
      {authorName}
    </span>
  </div>
</a>