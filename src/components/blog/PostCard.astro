---
// src/components/blog/PostCard.astro

import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';
import { categoryLabels } from '@/config/blog';
import { formatDateCompact, getReadingTime } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id, body } = post;

const {
  title,
  description,
  pubDate,
  category,
  featured,
  author
} = data;

const formattedDate = formatDateCompact(pubDate);
const readingTime = getReadingTime(body, 'id');

const authorName = author?.name || siteConfig.author;
const authorAvatar = author?.avatar || siteConfig.authorAvatar;
---

<a
  href={`/blog/${id}`}
  class="group block"
  aria-label={`Read article: ${title}`}
>
  <div class="flex flex-col gap-3 my-4">
    <div class="flex items-center justify-between text-xs md:text-sm text-zinc-500 dark:text-zinc-400">
      <div class="flex items-center gap-2">
        {featured && (
          <span class="text-amber-600 dark:text-amber-500 px-1.5 py-0.5 bg-amber-50 dark:bg-amber-950/30 rounded">
            Unggulan
          </span>
        )}
        <time datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
      </div>
      <span>
        {readingTime}
      </span>
    </div>
    <h3 class="text-base font-semibold mb-2 text-zinc-900 dark:text-white group-hover:text-zinc-600 dark:group-hover:text-zinc-300 line-clamp-3">
      {title}
    </h3>
    <p class="text-sm text-zinc-600 dark:text-zinc-400 line-clamp-3">
      {description}
    </p>
    <div class="flex justify-between items-center">
      <div class="flex items-center gap-2 pt-1">
        {authorAvatar && (
          <img
            src={authorAvatar}
            alt={authorName}
            class="w-4 h-4 rounded-full object-cover"
            loading="eager"
          />
        )}
        <span class="text-xs md:text-sm text-zinc-500 dark:text-zinc-400">
          {authorName}
        </span>
      </div>
      <div
        class="text-xs md:text-sm
        text-zinc-500 dark:text-zinc-400
        group-hover:text-zinc-900 dark:group-hover:text-white
        transition-colors"
      >
        {categoryLabels[category]}
      </div>
    </div>
  </div>
</a>