---
// src/components/blog/PostCard.astro
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  post?: CollectionEntry<'blog'>;
  loading?: boolean;
}

const { post } = Astro.props;

let title = '', excerpt = '', categoryName = '', pubDateISO = '', pubDateDisplay = '';
let authorName = '', authorAvatar = '', optimizedAvatar = '', postUrl = '';

if (post) {
  const { data, id } = post;
  const { title: t, pubDate, category, author } = data;
  title = t;
  excerpt = generateExcerpt(post.body || '', 140);

  const categoryEntry = await getEntry(category);
  const authorEntry   = author ? await getEntry(author) : null;

  categoryName    = categoryEntry?.data.name || 'General';
  pubDateISO      = pubDate.toISOString();
  pubDateDisplay  = formatDateCompact(pubDate);
  authorName      = authorEntry?.data.name   || siteConfig.author.name;
  authorAvatar    = authorEntry?.data.avatar || siteConfig.author.avatar;
  optimizedAvatar = isCdnUrl(authorAvatar)
    ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 })
    : authorAvatar;
  postUrl = `/blog/${id}/`;
}
---

<a
  href={postUrl}
  aria-label={`Baca artikel: ${title}`}
  class="group flex flex-col gap-5 border-b border-(--border) py-8 first:pt-0 last:border-none hover:border-(--border-strong) transition-colors"
>
  <!-- Header: kategori & tanggal (tanpa uppercase) -->
  <div class="flex items-center justify-between text-sm text-(--fg-subtle) group-hover:text-(--fg)">
    <span>{categoryName}</span>
    <time datetime={pubDateISO}>{pubDateDisplay}</time>
  </div>

  <!-- Judul: line-clamp-3 -->
  <h2 class="text-xl md:text-2xl font-semibold tracking-tight text-(--fg) group-hover:text-(--accent) transition-colors line-clamp-3">
    {title}
  </h2>

  <!-- Deskripsi: line-clamp-3 -->
  <p class="text-base text-(--fg-muted) leading-relaxed line-clamp-3 group-hover:text-(--fg)">
    {excerpt}
  </p>

  <!-- Author info -->
  <div class="flex items-center gap-2.5 pt-2">
    {authorAvatar && (
      <Image
        src={optimizedAvatar}
        alt={authorName}
        width={48}
        height={48}
        loading="eager"
        decoding="auto"
        class="h-6 w-6 rounded-full border border-(--border-strong) object-cover"
      />
    )}
    <span class="text-sm text-(--fg-subtle)">{authorName}</span>
  </div>
</a>