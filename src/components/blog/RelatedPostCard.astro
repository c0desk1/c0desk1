---
// src/components/blog/RelatedPostCard.astro

import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';
import { categoryLabels } from '@/config/blog';
import { formatDateCompact } from '@/lib/utils';

interface Props { post: CollectionEntry<'blog'>; }

const { post } = Astro.props;
const { data, id } = post;
const { title, pubDate, category, description, author } = data;

const formattedDate = formatDateCompact(pubDate);

// author sudah structured entity
const authorName = author?.name || siteConfig.author.name;
const authorAvatar = author?.avatar || siteConfig.author.avatar;
const authorSlug = author?.slug || siteConfig.author.slug;
---

<a
  href={`/blog/${id}/`}
  class="group flex flex-col h-full py-4 md:py-8 transition-all duration-200 overflow-hidden"
  aria-label={`Read article: ${title}`}
>

  <!-- CATEGORY + DATE -->
  <div class="flex items-center justify-between mb-8">
    <span class="text-[13px] group-hover:text-zinc-900 dark:group-hover:text-white transition-colors text-zinc-500 tracking-tight">
      {categoryLabels[category]}
    </span>

    <time datetime={pubDate.toISOString()} class="text-[13px] text-zinc-500">
      {formattedDate}
    </time>
  </div>

  <!-- CONTENT -->
  <div class="flex flex-col gap-4">
    <h3 class="text-base font-semibold text-black dark:text-white line-clamp-3">
      {title}
    </h3>

    <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-3 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">
      {description}
    </p>
  </div>

  <!-- AUTHOR -->
  <a
    href={`/author/${authorSlug}`}
    class="mt-auto pt-10 flex items-center gap-3 group/author"
  >
    {authorAvatar && (
      <img
        src={authorAvatar}
        alt={authorName}
        class="w-6 h-6 rounded-full object-cover grayscale border border-zinc-200 dark:border-zinc-800 group-hover/author:grayscale-0 transition"
      />
    )}
    <span class="text-[13px] font-medium text-zinc-500 dark:text-zinc-400 group-hover/author:text-zinc-900 dark:group-hover/author:text-white transition">
      {authorName}
    </span>
  </a>
</a>