---
// src/components/blog/RelatedPostCard.astro

import type { CollectionEntry } from 'astro:content';
import { formatDateCompact, getReadingTime } from '@/lib/utils';

interface Props { post: CollectionEntry<'blog'>; }

const { post } = Astro.props;
const { data, id } = post;
const { title, pubDate, featured, description } = data;

const formattedDate = formatDateCompact(pubDate);
const readingTime = getReadingTime(post.body);
---

<a
  href={`/blog/${id}`}
  class="group block py-4 transition-colors"
  aria-label={`Read article: ${title}`}
>
  <div class="flex flex-col gap-2">
    <div class="flex items-center justify-between text-xs text-zinc-500 dark:text-zinc-400">
      <div class="flex items-center gap-2">
        {featured && (
          <span class="font-mono font-semibold text-amber-600 dark:text-amber-500">▼</span>
        )}
        <time class="font-mono opacity-80" datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
        <span class="opacity-40">/</span>
        <span class="opacity-80">
          {readingTime}
        </span>
      </div>
      <span class="opacity-0 group-hover:opacity-100 translate-x-0 group-hover:translate-x-1 transition-all duration-200">
        →
      </span>
    </div>
    <h4 class="text-[16px] font-medium text-zinc-800 dark:text-zinc-200 leading-snug group-hover:text-zinc-950 dark:group-hover:text-white transition-colors line-clamp-2">
      {title}
    </h4>
    {description && (
      <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed line-clamp-2">
        {description}
      </p>
    )}
  </div>
</a>