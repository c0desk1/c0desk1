---
// src/components/blog/RelatedPostCard.astro

import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';
import { categoryLabels } from '@/config/blog';
import { formatDateCompact } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;

const { title, pubDate, category, description } = data;

const formattedDate = formatDateCompact(pubDate);

const author = siteConfig.author;
---

<a
  href={`/blog/${id}/`}
   class="group flex flex-col h-full rounded-2xl border border-black/10 dark:border-white/10 p-6 transition-all duration-200 hover:border-black/20 dark:hover:border-white/20 focus:outline-none focus:ring-2 focus:ring-black/20 dark:focus:ring-white/20"
  aria-label={`Read article: ${title}`}
>
  <div class="flex items-center justify-between text-[12px] text-zinc-500 mb-2">
    <span class="tracking-tight">
      {categoryLabels[category]}
    </span>
    <time datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
  </div>
  <h3 class="text-base md:text-lg font-semibold text-black dark:text-white line-clamp-3 tracking-tight transition-colors group-hover:text-black dark:group-hover:text-white">
    {title}
  </h3>
  <p class="mt-3 text-[13px] text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-3 transition-colors group-hover:text-zinc-900 dark:group-hover:text-zinc-200">
    {description}
  </p>
  <div class="mt-5 flex items-center gap-2 opacity-70 group-hover:opacity-100 transition">
    <img
      src={author.avatar}
      alt={author.name}
      class="w-4 h-4 rounded-full object-cover"
      loading="lazy"
    />
    <span class="text-[13px] text-zinc-600 dark:text-zinc-500">
      {author.name}
    </span>
  </div>
</a>