---
// src/components/blog/RelatedPostCard.astro

import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl, slugify } from '@/lib/utils';
import { getCurrentLocale, getLabel, localizePath } from '@/utils/i18n';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const locale = getCurrentLocale(Astro);

const { title, pubDate, category, author } = post.data;

const excerpt = generateExcerpt(post.body || '', 140);

const dateLocale =
  locale === 'en' ? 'en-US' :
  locale === 'ru' ? 'ru-RU' :
  locale === 'jp' ? 'ja-JP' :
  'id-ID';
  
const formattedDate = formatDateCompact(pubDate, dateLocale);

const categoryEntry = await getEntry(category);
const categoryName = categoryEntry?.data.name[locale] || categoryEntry?.data.name.id;

const authorEntry = await getEntry(author);
const authorName = authorEntry?.data.name || siteConfig.author.name;
const authorAvatar = authorEntry?.data.avatar || siteConfig.author.avatar;
const optimizedAvatar = isCdnUrl(authorAvatar) ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 }) : authorAvatar;

const autoSlug = slugify(title);
const postUrl = localizePath(`/blog/${autoSlug}/`, locale);
---

<a
  href={postUrl}
  class="group flex flex-col h-full rounded-(--radius-xl) p-4 my-4 border border-(--border) hover:border-(--border-strong) focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
  aria-label={`${getLabel(locale, 'readArticle')}: ${title}`}>
  <div class="flex items-center justify-between text-label-13 text-(--fg-subtle) mb-2">
    <span>{categoryName}</span>
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
  </div>

  <h3 class="text-heading-16 md:text-heading-20 text-(--fg) line-clamp-3">
    {title}
  </h3>

  <p class="mt-3 text-copy-14 text-(--fg-muted) line-clamp-3 group-hover:text-(--fg)">
    {excerpt}
  </p>

  <div class="mt-5 flex items-center gap-2">
    {authorAvatar && (
      <span aria-hidden="true" aria-label="" role="img" class="w-6 h-6 shrink-0 rounded-full inline-block overflow-hidden leading-0 align-top relative transition-[background] duration-200 ease-in-out">
        <Image
          src={optimizedAvatar}
          alt={`${avatarOfLabel} ${authorName}`}
          width={40}
          height={40}
          class="h-full w-full object-cover"
          loading="eager"
          decoding="async"
        />
        <span class="absolute inset-0 rounded-full border-(--border)"></span>
      </span>
    )}
    <span class="text-label-13 text-(--fg-subtle)">
      {authorName}
    </span>
  </div>
</a>