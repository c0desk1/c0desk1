---
// src/components/blog/RelatedPostCard.astro

import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';
import { categoryLabels } from '@/config/blog';
import { formatDateCompact } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;
const { title, pubDate, category, description } = data;

const formattedDate = formatDateCompact(pubDate);

const author = siteConfig.author;
---

<a
  href={`/blog/${id}/`}
  class="group block py-6"
  aria-label={`Read article: ${title}`}
>
  <div class="flex items-center justify-between text-[13px] text-zinc-500 mb-3">
    <span class="tracking-tight">
      {categoryLabels[category]}
    </span>
    <time datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
  </div>
  <h3 class="text-base md:text-lg font-semibold text-zinc-900 dark:text-zinc-100 line-clamp-3 group-hover:text-black dark:group-hover:text-white transition-colors tracking-tight">
    {title}
  </h3>
  <p class="mt-4 text-[14px] text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-3 group-hover:text-zinc-900 dark:group-hover:text-zinc-200 transition-colors">
    {description}
  </p>
  <div class="mt-8 flex items-center gap-2 opacity-80 group-hover:opacity-100 transition">
    <img
      src={author.avatar}
      alt={author.name}
      class="w-5 h-5 rounded-full object-cover grayscale group-hover:grayscale-0 transition"
    />
    <span class="text-[13px] text-zinc-500 dark:text-zinc-400">
      {author.name}
    </span>
  </div>
</a>