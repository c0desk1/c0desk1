---
// src/components/blog/RelatedPostCard.astro

import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets'; 

import { siteConfig } from '@/config/site';
import { formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;

const { title, pubDate, category, description, author } = data;

const authorEntry = await getEntry(author);
const categoryEntry = await getEntry(category);

const formattedDate = formatDateCompact(pubDate);

const authorName = authorEntry?.data.name || siteConfig.author.name;
const authorAvatar = authorEntry?.data.avatar || siteConfig.author.avatar;
const optimizedAvatar = isCdnUrl(authorAvatar) ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 }) : authorAvatar;

const categoryName = categoryEntry?.data.name || category;
---

<a
  href={`/blog/${id}/`}
   class="group flex flex-col h-full rounded-2xl border border-black/10 dark:border-white/10 p-6 transition-all duration-200 hover:border-black/20 dark:hover:border-white/20 focus:outline-none focus:ring-2 focus:ring-black/20 dark:focus:ring-white/20"
  aria-label={`Read article: ${title}`}
>
  <div class="flex items-center justify-between text-[13px] text-zinc-500 mb-2">
    <span class="tracking-tight">
      {categoryName}
    </span>
    <time datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
  </div>
  <h3 class="text-base md:text-lg font-semibold text-black dark:text-white line-clamp-3 tracking-tight group-hover:text-black dark:group-hover:text-white">
    {title}
  </h3>
  <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-3 group-hover:text-zinc-900 dark:group-hover:text-zinc-200">
    {description}
  </p>
  <div class="mt-5 flex items-center gap-2">
    <Image
      src={optimizedAvatar}
      alt={authorName}
      width={18}
      height={18}
      class="w-4 h-4 rounded-full object-cover"
      loading="lazy"
    />
    <span class="text-[13px] text-zinc-600 dark:text-zinc-500">
      {authorName}
    </span>
  </div>
</a>