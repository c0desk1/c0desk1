---
// src/components/blog/RelatedPostCard.astro
import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';
import { formatDateCompact, getReadingTime } from '@/lib/utils';

interface Props { post: CollectionEntry<'blog'>; }

const { post } = Astro.props;
const { data, id, body } = post;
const { title, pubDate, featured, description, author } = data;

const formattedDate = formatDateCompact(pubDate);
const readingTime = getReadingTime(body, 'id');

const authorName = author?.name || siteConfig.author;
const authorAvatar = author?.avatar || siteConfig.authorAvatar;
---

<a
  href={`/blog/${id}`}
  class="group block h-full border border-zinc-200 dark:border-zinc-900 rounded-lg p-5 transition-all duration-200 hover:border-zinc-300 dark:hover:border-zinc-700 hover:shadow-sm"
  aria-label={`Read article: ${title}`}
>
  <div class="flex flex-col gap-3 my-4">
    <div class="flex items-center justify-between text-xs md:text-sm text-zinc-500 dark:text-zinc-400">
      <div class="flex items-center gap-2">
        <time datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
        {featured && (
          <span class="text-amber-600 dark:text-amber-500 text-[10px] font-medium px-1.5 py-0.5 bg-amber-50 dark:bg-amber-950/30 rounded">
            Featured
          </span>
        )}
      </div>
      <span class="text-xs md:text-sm">
        {readingTime}
      </span>
    </div>
    <h4 class="text-base font-semibold text-zinc-900 dark:text-white group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-colors line-clamp-3">
      {title}
    </h4>
    {description && (
      <p class="text-sm text-zinc-600 dark:text-zinc-400 line-clamp-3">
        {description}
      </p>
    )}
    <div class="flex justify-between items-center">
      <div class="flex items-center gap-2 pt-1">
        {authorAvatar && (
          <img
            src={authorAvatar}
            alt={authorName}
            class="w-4 h-4 rounded-full object-cover"
            loading="lazy"
          />
        )}
        <span class="text-xs md:text-sm text-zinc-500 dark:text-zinc-400">
          {authorName}
        </span>
      </div>
      <div class="mt-2 text-sm font-medium text-zinc-500 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">
        Baca <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
      </div>
    </div>
  </div>
</a>