---
// src/components/blog/RelatedPostCard.astro

import type { CollectionEntry } from 'astro:content';
import { formatDateCompact, getReadingTime } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
  showDate?: boolean;
  showReadingTime?: boolean;
}

const { post, showDate = true, showReadingTime = true } = Astro.props;
const { data, id, body } = post;
const { title, pubDate, featured } = data;

const formattedDate = formatDateCompact(pubDate);
const readingTime = getReadingTime(undefined, undefined, body);
---

<a 
  href={`/blog/${id}`} 
  class="group block py-3 border-b border-zinc-100 dark:border-zinc-900 transition-all duration-200 hover:pl-2"
  aria-label={`Read article: ${title}`}
>
  <div class="flex flex-col gap-1.5">
    
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2 text-xs text-zinc-400 dark:text-zinc-500">
        {showDate && (
          <time class="font-mono" datetime={pubDate.toISOString()}>{formattedDate}</time>
        )}
        {showDate && showReadingTime && <span class="text-zinc-300 dark:text-zinc-700">/</span>}
        {showReadingTime && (
          <div class="flex items-center gap-0.5">
            <span>[</span>
            <span>{readingTime}</span>
            <span>]</span>
          </div>
        )}
        {featured && (
          <span class="text-amber-600 dark:text-amber-500 text-xs">[★]</span>
        )}
      </div>
      
      <div class="flex items-center gap-0.5 text-xs text-zinc-400 dark:text-zinc-500 group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-all group-hover:translate-x-0.5">
        <span>Read</span>
        <span>→</span>
      </div>
    </div>
    
    <h4 class="text-md text-zinc-700 dark:text-zinc-300 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors leading-snug">
      {title}
    </h4>
    
  </div>
</a>