---
// src/components/blog/PostCardMinimal.astro
// @ts-nocheck
import type { CollectionEntry } from 'astro:content';
import { formatDate, getReadingTime } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
  showDate?: boolean;
  showReadingTime?: boolean;
}

const { post, showDate = true, showReadingTime = true } = Astro.props;
const { data, id, body } = post;
const { title, pubDate, featured } = data;

const formattedDate = formatDate(pubDate);
const readingTime = getReadingTime(undefined, undefined, body);
---

<a 
  href={`/blog/${id}`} 
  class="group flex items-center justify-between py-2 border-b border-zinc-100 dark:border-zinc-900 hover:pl-2 transition-all duration-200"
>
  <div class="flex items-center gap-3 flex-1 min-w-0">
    {/* Tactical dot */}
    <div class="w-1 h-1 rounded-full bg-zinc-300 dark:bg-zinc-700 group-hover:bg-emerald-500 transition-colors"></div>
    
    {/* Date (optional) */}
    {showDate && (
      <span class="hidden sm:inline text-[10px] font-mono text-zinc-400 dark:text-zinc-500 shrink-0">
        {formattedDate}
      </span>
    )}
    
    {/* Title */}
    <h3 class="font-mono text-sm text-zinc-700 dark:text-zinc-300 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors truncate">
      {title}
    </h3>
    
    {/* Featured indicator */}
    {featured && (
      <span class="text-[9px] font-mono text-amber-600 dark:text-amber-500 shrink-0">[★]</span>
    )}
  </div>
  
  {/* Reading time */}
  {showReadingTime && (
    <div class="text-[9px] font-mono text-zinc-400 dark:text-zinc-600 shrink-0 ml-2">
      {readingTime}
    </div>
  )}
</a>