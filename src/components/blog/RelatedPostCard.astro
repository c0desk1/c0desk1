---
// src/components/blog/RelatedPostCard.astro

import type { CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config/site';
import { categoryLabels } from '@/config/blog';
import { formatDateCompact } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;

const { title, pubDate, category, description } = data;

const formattedDate = formatDateCompact(pubDate);

const author = siteConfig.author;
---

<a
  href={`/blog/${id}/`}
  class="group block py-6 border-b md:border-b-0 border-black/10 dark:border-white/10 last:border-none transition-colors hover:bg-black/2 dark:hover:bg-white/2"
  aria-label={`Read article: ${title}`}
>
  <div class="flex items-center justify-between text-[12px] text-zinc-500 mb-2">
    <span class="tracking-tight">
      {categoryLabels[category]}
    </span>
    <time datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
  </div>
  <h3 class="text-base md:text-lg font-semibold text-zinc-900 dark:text-zinc-100 line-clamp-2 tracking-tight transition-colors group-hover:text-black dark:group-hover:text-white">
    {title}
  </h3>
  <p class="mt-3 text-[14px] text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-2 transition-colors group-hover:text-zinc-900 dark:group-hover:text-zinc-200">
    {description}
  </p>
  <div class="mt-5 flex items-center gap-2 opacity-70 group-hover:opacity-100 transition">
    <img
      src={author.avatar}
      alt={author.name}
      class="w-4 h-4 rounded-full object-cover grayscale group-hover:grayscale-0 transition"
      loading="lazy"
    />
    <span class="text-[12px] text-zinc-500 dark:text-zinc-400">
      {author.name}
    </span>
  </div>
</a>