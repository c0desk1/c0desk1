---
// src/components/blog/RelatedPostCard.astro

import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl, slugify } from '@/lib/utils';
import { getCurrentLocale, localizePath } from '@/utils/i18n';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const locale = getCurrentLocale(Astro);

const { data } = post;
const { title, pubDate, category, author } = data;

const excerpt = generateExcerpt(post.body || '', 140);

const authorEntry = await getEntry(author);
const categoryEntry = await getEntry(category);

const dateLocale = locale === 'en'? 'en-US' : locale === 'ru'? 'ru-RU' : 'id-ID';
const formattedDate = formatDateCompact(pubDate, dateLocale);

const authorName = authorEntry?.data.name || siteConfig.author.name;
const authorAvatar = authorEntry?.data.avatar || siteConfig.author.avatar;
const optimizedAvatar = isCdnUrl(authorAvatar) ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 }) : authorAvatar;

const categoryName = categoryEntry?.data.name || category.id || 'Uncategoized';

const autoSlug = slugify(title);
const postUrl = localizePath(`/blog/${autoSlug}/`, locale);
---

<a
  href={postUrl}
   class="group flex flex-col h-full rounded-(--radius-xl) p-4 my-4 border border-(--border) hover:border-(--border-strong) focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
  aria-label={`Read article: ${title}`}
>
  <div class="flex items-center justify-between text-[13px] text-(--fg-subtle) mb-2">
    <span class="tracking-tight">
      {categoryName}
    </span>
    <time datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
  </div>
  <h3 class="text-base md:text-lg font-semibold text-(--fg) line-clamp-3 tracking-tight">
    {title}
  </h3>
  <p class="mt-3 text-sm text-(--fg-muted) leading-relaxed line-clamp-3 group-hover:text-(--fg)">
    {excerpt}
  </p>
  <div class="mt-5 flex items-center gap-2">
    <Image
      src={optimizedAvatar}
      alt={authorName}
      width={48}
      height={48}
      class="w-6 h-6 rounded-full border border-(--border) object-cover"
      loading="lazy"
    />
    <span class="text-[13px] text-(--fg-subtle)">
      {authorName}
    </span>
  </div>
</a>