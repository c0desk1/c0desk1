---
// src/components/blog/PostCardFeatured.astro
import { 
  getEntry, 
  type CollectionEntry 
} from 'astro:content';

import { 
  AUTHOR, 
  ROUTES, 
  IMAGE, 
  CATEGORIES, 
  formatDate, 
  toISOString
} from '@/consts';

import { 
  generateExcerpt, 
  cdnImage, 
  isCdnUrl, 
  slugify 
} from '@/lib/utils';

import { Image } from 'astro:assets';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data } = post;

const title = data.title;
const excerpt = generateExcerpt(post.body || '', 140);
const categoryName = CATEGORIES.find(c => c.slug === data.category)?.label || '';
const pubDateISO = toISOString(data.pubDate);
const pubDateDisplay = formatDate(data.pubDate, true);

const authorEntry = data.author ? await getEntry(data.author) : null;
const authorName = authorEntry?.data?.name || AUTHOR.name;
const rawAvatar = authorEntry?.data?.avatar;
const isAvatarPlaceholder = !rawAvatar || rawAvatar === '';
const optimizedAvatar = !isAvatarPlaceholder && isCdnUrl(rawAvatar)
  ? cdnImage(rawAvatar, { w: IMAGE.avatar.width, h: IMAGE.avatar.height, q: IMAGE.avatar.quality })
  : rawAvatar || IMAGE.avatar.placeholder;

const autoSlug = data.slug || slugify(title);
const postUrl = `${ROUTES.blog}/${autoSlug}`;

const rawImage = data.heroImage?.src || data.seo?.ogImage;

const isPlaceholder = !rawImage || rawImage === '';

const optimizedImage = !isPlaceholder && isCdnUrl(rawImage)
  ? cdnImage(rawImage, { w: IMAGE.thumbnail.width, h: IMAGE.thumbnail.height, q: IMAGE.thumbnail.quality })
  : rawImage || IMAGE.thumbnail.placeholder;

const imageAlt = data.heroImage?.alt || title;
---

<a href={postUrl} class="group flex flex-col rounded-xl border border-(--border) bg-base overflow-hidden hover:shadow-md transition-all duration-300 no-underline">
  <div class="relative aspect-video overflow-hidden bg-muted">
    {!isPlaceholder && (
      <div class="absolute inset-0 bg-base animate-pulse" aria-hidden="true"></div>
    )}
    <Image
      src={optimizedImage}
      alt={imageAlt}
      width={IMAGE.thumbnail.width}
      height={IMAGE.thumbnail.height}
      class:list={[
        "relative z-10 w-full h-full object-cover transition duration-500",
        isPlaceholder ? "opacity-100" : "opacity-0"
      ]}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      onload={!isPlaceholder ? "this.classList.remove('opacity-0')" : undefined}
    />
  </div>

  <div class="flex flex-col flex-1 p-4">
    <div class="flex items-center justify-between mb-4 text-label-14 text-muted group-hover:text-(--fg) active:text-(--fg)">
      <span>{categoryName}</span>
      <time datetime={pubDateISO}>{pubDateDisplay}</time>
    </div>
    <div class="flex flex-col gap-4 flex-1">
      <h3 class="text-heading-16 lg:text-heading-18 text-(--fg) font-semibold line-clamp-3">
        {title}
      </h3>
      <p class="text-body-14 md:text-body-16 font-medium text-muted line-clamp-3 group-hover:text-(--fg) active:text-(--fg)">
        {excerpt}
      </p>
      <div class="mt-auto flex items-center gap-2 text-label-14 text-muted group-hover:text-(--fg) active:text-(--fg)">
        <div class="w-5 h-5 shrink-0 rounded-full overflow-hidden flex items-center justify-center border border-(--border) bg-muted/50">
          <Image
            src={optimizedAvatar}
            alt={`Avatar ${authorName}`}
            width={IMAGE.avatar.width}
            height={IMAGE.avatar.height}
            loading="eager"
            decoding="async"
            fetchpriority="low"
            class:list={[
              "h-full w-full object-cover transition duration-300",
              isAvatarPlaceholder ? "opacity-100 grayscale" : "opacity-0"
            ]}
            onload={!isAvatarPlaceholder ? "this.classList.remove('opacity-0')" : undefined}
          />
        </div>
        <span>{authorName}</span>
      </div>
    </div>
  </div>
</a>