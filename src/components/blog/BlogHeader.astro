---
// BlogHeader.astro

import BlogMeta from './BlogMeta.astro';
import BlogAuthor from './BlogAuthor.astro';

interface Props {
  title: string;
  pubDate: Date;
  readingTime: string;
  authorName?: string;
  authorAvatar?: string;
  authorTitle?: string;
  featured?: boolean;
}

const {
  title,
  pubDate,
  readingTime,
  authorName,
  authorAvatar,
  authorTitle,
  featured
} = Astro.props;
---

<header class="mx-auto max-w-3xl text-center">
  <h1
    class="
      text-3xl sm:text-3xl md:text-4xl lg:text-5xl
      font-semibold
      text-zinc-900 dark:text-zinc-100
      leading-[1.2]
      text-balance
      mb-6 md:mb-8
    "
  >
    {title}
  </h1>
  <div class="mb-6">
    <BlogMeta
      pubDate={pubDate}
      readingTime={readingTime}
    />
  </div>
  {authorName && (
    <div class="opacity-80">
      <BlogAuthor
        name={authorName}
        avatar={authorAvatar}
        title={authorTitle}
      />
    </div>
  )}
</header>