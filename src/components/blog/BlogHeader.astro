---
// src/components/blog/BlogHeader.astro

import BlogMeta from './BlogMeta.astro';
import BlogAuthor from './BlogAuthor.astro';
import BlogTags from './BlogTags.astro';

interface Props {
  title: string;
  pubDate: Date;
  updatedDate?: Date;
  readingTime: string;
  tags?: string[];
  author?: {
    name: string;
    avatar?: string;
    title?: string;
  };
  featured?: boolean;

}

const { title, pubDate, updatedDate, readingTime, tags = [], author, featured } = Astro.props;
---

<header class="space-y-3">
  
  <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-zinc-900 dark:text-white leading-tight">
    {title}
  </h1>
  
  <BlogAuthor author={author} />
  
  <BlogTags tags={tags} />

  <BlogMeta 
    pubDate={pubDate}
    updatedDate={updatedDate}
    readingTime={readingTime}
    featured={featured}
  />
  
  <div class="pt-3">
    <div class="h-px w-8 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
  </div>
  
</header>