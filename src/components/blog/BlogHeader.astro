---
// src/components/blog/BlogHeader.astro

import BlogMeta from './BlogMeta.astro';
import BlogAuthor from './BlogAuthor.astro';
import BlogTags from './BlogTags.astro';

interface Props {
  title: string;
  pubDate: Date;
  updatedDate?: Date;
  readingTime: string;
  tags?: string[];
  author?: {
    name: string;
    avatar?: string;
    title?: string;
  };
  featured?: boolean;
}

const { title, pubDate, updatedDate, readingTime, tags = [], author, featured } = Astro.props;
---

<header class="pt-6 pb-8 space-y-5">
  <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 leading-[1.1]">
    {title}
  </h1>
  {author && (
    <div class="pt-1">
      <BlogAuthor author={author} />
    </div>
  )}
  {tags.length > 0 && (
    <div class="pt-1">
      <BlogTags tags={tags} />
    </div>
  )}
  <div class="pt-1">
    <BlogMeta 
      pubDate={pubDate}
      updatedDate={updatedDate}
      readingTime={readingTime}
      featured={featured}
    />
  </div>
  <div class="pt-4">
    <div class="h-px w-10 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
  </div>
</header>