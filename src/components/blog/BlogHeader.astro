---
// src/components/blog/BlogHeader.astro

import BlogMeta from './BlogMeta.astro';
import BlogAuthor from './BlogAuthor.astro';

interface Props {
  title: string;
  pubDate: Date;
  updatedDate?: Date;
  readingTime: string;
  authorName?: string;
  authorAvatar?: string;
  authorTitle?: string;
  featured?: boolean;
}

const {
  title,
  pubDate,
  readingTime,
  authorName,
  authorAvatar,
  authorTitle,
  featured
} = Astro.props;
---

<header class="w-full mx-auto text-center">
  <h1
    class="
      text-2xl sm:text-3xl md:text-4xl lg:text-5xl
      font-semibold tracking-tight
      text-zinc-900 dark:text-zinc-100
      leading-[1.15]
      mb-6
    "
  >
    {title}
  </h1>
  <div class="mb-4">
    <BlogMeta 
      pubDate={pubDate}
      readingTime={readingTime}
      featured={featured}
    />
  </div>
  {authorName && (
    <div>
      <BlogAuthor 
        name={authorName}
        avatar={authorAvatar}
        title={authorTitle}
      />
    </div>
  )}

</header>