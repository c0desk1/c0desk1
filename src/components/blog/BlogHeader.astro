---
// src/components/blog/BlogHeader.astro
import BlogMeta from './BlogMeta.astro';
import BlogAuthor from './BlogAuthor.astro';
import Listen from "@/components/ui/ListenButton.astro";

interface Props {
  title: string;
  pubDate: Date;
  readingTime: string;
  authorName?: string;
  authorAvatar?: string;
  authorTitle?: string;
  authorSlug: string;
}

const {
  title,
  pubDate,
  readingTime,
  authorName,
  authorAvatar,
  authorTitle,
  authorSlug
} = Astro.props;
---

<header class="mx-auto max-w-3xl text-center">
  <h1
    class="
      text-3xl sm:text-4xl md:text-5xl
      font-semibold tracking-tight
      text-(--prose-black) dark:text-(--prose-white)
      leading-[1.15]
      text-balance
      mb-6 md:mb-8
    "
  >
    {title}
  </h1>

  <div class="mb-6">
    <BlogMeta pubDate={pubDate} readingTime={readingTime} />
  </div>

  {authorName && (
    <div class="flex items-center text-center gap-2">
      <BlogAuthor
        name={authorName}
        avatar={authorAvatar}
        title={authorTitle}
        slug={authorSlug}
      />
      <Listen />
    </div>
  )}
</header>
