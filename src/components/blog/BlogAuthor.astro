---
// src/components/blog/BlogAuthor.astro

interface Author {
  name: string;
  avatar?: string;
  title?: string;
}

interface Props {
  author?: Author;
}

const { author } = Astro.props;
---

{author && (
  <div class="flex items-center gap-3 pt-2">
    {author.avatar && (
      <img 
        src={author.avatar} 
        alt={author.name}
        class="w-8 h-8 md:w-10 md:h-10 rounded-full border border-zinc-200 dark:border-zinc-800"
      />
    )}
    <div class="font-mono text-sm md:text-base">
      <div class="text-zinc-900 dark:text-white font-medium">{author.name}</div>
      {author.title && (
        <div class="text-zinc-500 dark:text-zinc-400 text-xs md:text-sm">{author.title}</div>
      )}
    </div>
  </div>
)}