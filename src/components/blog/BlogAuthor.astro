---
// src/components/blog/BlogAuthor.astro

interface Author {
  name: string;
  avatar?: string;
  title?: string;
}

interface Props {
  author?: Author;
}

const { author } = Astro.props;
---

{author && (
  <div class="flex items-center gap-3 pt-1" aria-label={`Author: ${author.name}`}>
    {author.avatar && (
      <img 
        src={author.avatar} 
        alt={`Avatar of ${author.name}`}
        class="w-8 h-8 rounded-full border border-zinc-200 dark:border-zinc-800"
        loading="lazy"
      />
    )}
    <div class="font-mono text-sm">
      <div class="text-zinc-900 dark:text-white font-medium">{author.name}</div>
      {author.title && (
        <div class="text-zinc-500 dark:text-zinc-400 text-xs">{author.title}</div>
      )}
    </div>
  </div>
)}