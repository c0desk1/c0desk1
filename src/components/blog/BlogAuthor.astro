---
// src/components/blog/BlogAuthor.astro

import { siteConfig } from '@/config/site';

interface Props {
  name?: string;
  avatar?: string;
  title?: string;
  slug?: string;
}

const { name, avatar, title, slug } = Astro.props;

const authorName = name || siteConfig.author.name;
const authorAvatar = avatar || siteConfig.author.avatar;
const authorTitle = title || siteConfig.author.title;
const authorSlug = slug || siteConfig.author.slug;
---

<a
  href={`/author/${authorSlug}/`}
  class="flex justify-center items-center gap-2 text-[13px] md:text-sm group"
  aria-label={`Author: ${authorName}`}
>
  {authorAvatar && (
    <img
      src={authorAvatar}
      alt={`Avatar of ${authorName}`}
      class="w-6 h-6 rounded-full object-cover"
      loading="lazy"
    />
  )}
  <div class="flex items-center gap-1 leading-tight">
    <span class="text-black dark:text-white">
      {authorName}
    </span>
    {authorTitle && (
      <span class="text-zinc-500 dark:text-zinc-400">
        {authorTitle}
      </span>
    )}
  </div>
</a>