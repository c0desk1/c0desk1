---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets'; 
import { getCurrentLocale, localizePath, getLabel } from '@/utils/i18n';
import {
  generateExcerpt,
  formatDateCompact,
  cdnImage,
  isCdnUrl,
  slugify
} from '@/lib/utils';
import { siteConfig } from '@/config/site';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const locale = getCurrentLocale(Astro);

let title = '', excerpt = '', pubDateISO = '', pubDateDisplay = '';
let authorName = '', authorAvatar = '', optimizedAvatar = '', postUrl = '';

if (post) {
  const { data } = post;
  const { title: t, pubDate, category, author } = data;
  const dateLocale =
    locale === 'en' ? 'en-US' :
    locale === 'ru' ? 'ru-RU' :
    locale === 'jp' ? 'ja-JP' :
    'id-ID';

  const authorEntry   = author ? await getEntry(author) : null;
  title = t;
  excerpt = generateExcerpt(post.body || '', 250);
  pubDateISO      = pubDate.toISOString();
  pubDateDisplay  = formatDateCompact(pubDate, dateLocale);
  authorName      = authorEntry?.data.name   || siteConfig.author.name;
  authorAvatar    = authorEntry?.data.avatar || siteConfig.author.avatar;
  optimizedAvatar = isCdnUrl(authorAvatar)
    ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 })
    : authorAvatar;
    
  const autoSlug = slugify(title);
  postUrl = localizePath(`/blog/${autoSlug}/`, locale);
}

const icons = ["lines", "brackets", "grid"];
const iconType = icons[Math.floor(Math.random() * icons.length)];
---

<a 
  href={postUrl} 
  class="group flex flex-col h-full px-6 py-8 rounded-xl border border-(--border) bg-(--bg) hover:bg-(--bg-muted)"
  aria-label={`${getLabel(locale, 'readArticle')}: ${title}`}
>
  <div class="mb-4 md:mb-6 shrink-0">
    <div class="size-7 md:size-13 flex items-center justify-center rounded-full border border-(--border) bg-(--bg-subtle)">
      {iconType === "lines" && (
        <svg viewBox="0 0 24 24" class="w-6 h-6 text-(--accent)">
          <path d="M4 6h6M4 12h10M4 18h8" stroke="currentColor" stroke-width="1.5" fill="none"/>
        </svg>
      )}
      {iconType === "brackets" && (
        <svg viewBox="0 0 24 24" class="w-6 h-6 text-(--accent)">
          <path d="M8 5L3 12L8 19M16 5L21 12L16 19" stroke="currentColor" stroke-width="1.5" fill="none"/>
        </svg>
      )}
      {iconType === "grid" && (
        <svg viewBox="0 0 24 24" class="w-6 h-6 text-(--accent)">
          <rect x="4" y="4" width="6" height="6" stroke="currentColor" fill="none"/>
          <rect x="14" y="4" width="6" height="6" stroke="currentColor" fill="none"/>
          <rect x="4" y="14" width="6" height="6" stroke="currentColor" fill="none"/>
          <rect x="14" y="14" width="6" height="6" stroke="currentColor" fill="none"/>
        </svg>
      )}
    </div>
  </div>
  <div class="mb-4 shrink-0">
    <time datetime={pubDateISO} class="text- md:text-sm text-(--fg-subtle) font-medium">
      {pubDateDisplay}
    </time>
  </div>
  <div class="flex flex-col gap-3 md:gap-6 flex-1 min-h-0">
    <h2 class="text-xl md:text-2xl lg:text-3xl font-semibold tracking-tight text-(--fg) leading-tight line-clamp-3 md:line-clamp-4">
      {title}
    </h2>
    <p class="post-excerpt mb-4 text-sm md:text-base font-medium text-(--fg-muted) leading-relaxed line-clamp-4 md:line-clamp-8 group-hover:text-(--fg)">
      {excerpt}
    </p>
  </div>
  <div class="mt-auto flex items-center gap-2 shrink-0">
    {authorAvatar && (
      <Image
        src={optimizedAvatar}
        alt={`${getLabel(locale, 'author')}: ${authorName}`}
        width={48}
        height={48}
        loading="lazy"
        decoding="async"
        class="w-5 h-5 object-cover rounded-full"
      />
    )}
    <span class="text- md:text-sm text-(--fg-subtle) font-medium">
      {authorName}
    </span>
  </div>
</a>

<style is:global>
  .post-excerpt {
    -webkit-mask-image: linear-gradient(
      to bottom,
      var(--bg) 30%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      var(--bg) 30%,
      transparent 100%
    );
  }
</style>