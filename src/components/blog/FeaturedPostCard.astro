---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets'; 

import { formatDateCompact } from '@/lib/utils';
import { siteConfig } from '@/config/site';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;

const { title, description, pubDate, author } = data;

const authorEntry = await getEntry(author);

const formattedDate = formatDateCompact(pubDate);

const authorName = authorEntry?.data.name || siteConfig.author.name;
const authorAvatar = authorEntry?.data.avatar || siteConfig.author.avatar;
---

<a
  href={`/blog/${id}/`}
  class="group flex flex-col h-full rounded-2xl border border-black/10 dark:border-white/10 p-6 transition-all duration-200 hover:bg-black/2 dark:hover:bg-white/2 hover:border-black/20 dark:hover:border-white/20 focus:outline-none focus:ring-2 focus:ring-black/20 dark:focus:ring-white/20"
>
  <div class="mb-6">
    <div class="w-12 h-12 flex items-center justify-center rounded-full border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-black group-hover:border-zinc-400 dark:group-hover:border-zinc-600">
      <span class="text-sm md:text-lg font-semibold text-zinc-900 dark:text-white">
        {title.charAt(0)}
      </span>
    </div>
  </div>
  <div class="mb-6">
    <time
      datetime={pubDate.toISOString()}
      class="text-[13px] text-zinc-500 tracking-tight"
    >
      {formattedDate}
    </time>
  </div>
  <div class="flex flex-col gap-5 mb-8">
    <h2 class="text-lg md:text-2xl font-semibold tracking-tighter text-zinc-900 dark:text-white leading-[1.1] line-clamp-4 group-hover:text-zinc-600 dark:group-hover:text-zinc-300">
      {title}
    </h2>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-6 group-hover:text-zinc-900 dark:group-hover:text-white">
      {description}
    </p>
  </div>
  <div class="mt-auto flex items-center gap-3 pt-4">
    {authorAvatar && (
      <Image
        src={authorAvatar}
        alt={`Author ${authorName}`}
        width={24}
        height={24}
        class="w-6 h-6 rounded-full object-cover"
        loading="lazy"
      />
    )}
    <span class="text-[13px] text-zinc-500 dark:text-zinc-400">
      {authorName}
    </span>
  </div>
</a>