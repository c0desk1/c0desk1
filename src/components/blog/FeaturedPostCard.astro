---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets'; 
import { getCurrentLocale, localizePath, getLabel } from '@/utils/i18n';
import {
  generateExcerpt,
  formatDateCompact,
  cdnImage,
  isCdnUrl,
  slugify
} from '@/lib/utils';
import { siteConfig } from '@/config/site';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const locale = getCurrentLocale(Astro);

let title = '', excerpt = '', pubDateISO = '', pubDateDisplay = '';
let authorName = '', authorAvatar = '', optimizedAvatar = '', postUrl = '';

if (post) {
  const { data } = post;
  const { title: t, pubDate, category, author } = data;
  const dateLocale =
    locale === 'en' ? 'en-US' :
    locale === 'ru' ? 'ru-RU' :
    locale === 'jp' ? 'ja-JP' :
    'id-ID';

  const authorEntry   = author ? await getEntry(author) : null;
  title = t;
  excerpt = generateExcerpt(post.body || '', 250);
  pubDateISO      = pubDate.toISOString();
  pubDateDisplay  = formatDateCompact(pubDate, dateLocale);
  authorName      = authorEntry?.data.name   || siteConfig.author.name;
  authorAvatar    = authorEntry?.data.avatar || siteConfig.author.avatar;
  optimizedAvatar = isCdnUrl(authorAvatar)
    ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 })
    : authorAvatar;
    
  const autoSlug = slugify(title);
  postUrl = localizePath(`/blog/${autoSlug}/`, locale);
}
---

<a 
  href={postUrl} 
  class="group flex flex-col h-full px-6 py-8 rounded-xl border border-(--border) bg-(--bg) hover:bg-(--bg-muted)"
  aria-label={`${getLabel(locale, 'readArticle')}: ${title}`}>
  <div class="mb-4 shrink-0">
    <time datetime={pubDateISO} class="text-label-13 md:text-label-14 text-(--fg-subtle)">
      {pubDateDisplay}
    </time>
  </div>

  <div class="flex flex-col gap-3 md:gap-6 flex-1 min-h-0">
    <h2 class="text-heading-20 md:text-heading-24 lg:text-heading-32 text-(--fg) line-clamp-3 md:line-clamp-4 font-semibold">
      {title}
    </h2>
    <p class="post-excerpt text-copy-14 md:text-copy-16 font-medium text-(--fg-muted) line-clamp-4 md:line-clamp-8 group-hover:text-(--fg)">
      {excerpt}
    </p>
  </div>

  <div class="mt-auto flex items-center gap-2 shrink-0">
    {authorAvatar && (
      <div class="w-5 h-5 shrink-0 rounded-full overflow-hidden flex items-center justify-center border border(--border)">
        <Image
          src={optimizedAvatar}
          alt={`${getLabel(locale, 'author')}: ${authorName}`}
          width={48}
          height={48}
          loading="eager"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    )}
    <span class="text-label-13 md:text-label-14 text-(--fg-subtle)">
      {authorName}
    </span>
  </div>
</a>

<style is:global>
  .post-excerpt {
    -webkit-mask-image: linear-gradient(
      to bottom,
      var(--bg) 30%,
      transparent 100%
    );
    mask-image: linear-gradient(to bottom, var(--bg) 30%, transparent 100%);
  }
</style>
