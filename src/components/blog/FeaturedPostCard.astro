---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets'; 

import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';
import { siteConfig } from '@/config/site';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

let title = '', excerpt = '', categoryName = '', pubDateISO = '', pubDateDisplay = '';
let authorName = '', authorAvatar = '', optimizedAvatar = '', postUrl = '';

if (post) {
  const { data, id } = post;
  const { title: t, pubDate, category, author } = data;
  title = t;
  excerpt = generateExcerpt(post.body || '', 250);

  const categoryEntry = await getEntry(category);
  const authorEntry   = author ? await getEntry(author) : null;

  categoryName    = categoryEntry?.data.name || 'General';
  pubDateISO      = pubDate.toISOString();
  pubDateDisplay  = formatDateCompact(pubDate);
  authorName      = authorEntry?.data.name   || siteConfig.author.name;
  authorAvatar    = authorEntry?.data.avatar || siteConfig.author.avatar;
  optimizedAvatar = isCdnUrl(authorAvatar)
    ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 })
    : authorAvatar;
  postUrl = `/blog/${id}/`;
}

const icons = ["lines", "brackets", "grid"];
const iconType = icons[Math.floor(Math.random() * icons.length)];
---


<div class="aspect-2/3 rounded-xl border border-(--border) bg-(--bg) hover:bg-(--bg-muted) transition-colors">
  <a href={postUrl} class="group flex flex-col h-full px-6 py-8">
    <div class="mb-6 shrink-0">
      <div class="w-12 h-12 flex items-center justify-center border border-(--border) bg-(--bg-subtle)">
      
        {iconType === "lines" && (
          <svg viewBox="0 0 24 24" class="w-6 h-6 text-(--accent)">
            <path d="M4 6h6M4 12h10M4 18h8" stroke="currentColor" stroke-width="1.5" fill="none"/>
          </svg>
        )}
        {iconType === "brackets" && (
          <svg viewBox="0 0 24 24" class="w-6 h-6 text-(--accent)">
            <path d="M8 5L3 12L8 19M16 5L21 12L16 19" stroke="currentColor" stroke-width="1.5" fill="none"/>
          </svg>
        )}
        {iconType === "grid" && (
          <svg viewBox="0 0 24 24" class="w-6 h-6 text-(--accent)">
            <rect x="4" y="4" width="6" height="6" stroke="currentColor" fill="none"/>
            <rect x="14" y="4" width="6" height="6" stroke="currentColor" fill="none"/>
            <rect x="4" y="14" width="6" height="6" stroke="currentColor" fill="none"/>
            <rect x="14" y="14" width="6" height="6" stroke="currentColor" fill="none"/>
          </svg>
        )}
      </div>
    </div>

    <div class="mb-6 shrink-0">
      <time datetime={pubDateISO} class="text-[13px] md:text-sm text-(--fg-subtle)">
        {pubDateDisplay}
      </time>
    </div>

    <div class="flex flex-col gap-5 flex-1 min-h-0">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-(--fg) leading-tight line-clamp-4">
        {title}
      </h2>

      <p class="post-excerpt text-sm md:text-base text-(--fg-muted) leading-relaxed line-clamp-8 group-hover:text-(--fg)">
        {excerpt}
      </p>
    </div>

    <div class="mt-auto flex items-center gap-2 shrink-0">
      {authorAvatar && (
        <Image
          src={optimizedAvatar}
          alt={`Author ${authorName}`}
          width={48}
          height={48}
          loading="lazy"
          decoding="async"
          class="w-7 h-7 object-cover rounded-full"
        />
      )}
      <span class="text-[13px] md:text-sm text-(--fg-subtle)">
        {authorName}
      </span>
    </div>

  </a>
</div>

<style is:global>
  .post-excerpt {
    -webkit-mask-image: linear-gradient(
      to bottom,
      black 30%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      black 30%,
      transparent 100%
    );
  }
</style>
