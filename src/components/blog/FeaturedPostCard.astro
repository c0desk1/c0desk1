---
import type { CollectionEntry } from 'astro:content';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets'; 

import { generateExcerpt, formatDateCompact, cdnImage, isCdnUrl } from '@/lib/utils';
import { siteConfig } from '@/config/site';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;

const { title, pubDate, author } = data;

const excerpt = generateExcerpt(post.body || '', 300);

const authorEntry = await getEntry(author);

const formattedDate = formatDateCompact(pubDate);

const authorName = authorEntry?.data.name || siteConfig.author.name;
const authorAvatar = authorEntry?.data.avatar || siteConfig.author.avatar;
const optimizedAvatar = isCdnUrl(authorAvatar) ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 }) : authorAvatar;
---

<a
  href={`/blog/${id}/`}
  class="group flex flex-col h-full rounded-(--radius-xl) border border-(--border) p-3 md:p-6 hover:bg-(--bg-muted) hover:border-(--border-strong) focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
>
  <div class="mb-6">
    <div class="w-12 h-12 flex items-center justify-center rounded-full border border-(--border) bg-(--bg-subtle) group-hover:border-(--border-strong)">
      <span class="text-sm md:text-lg font-semibold text-(--accent)">
        {title.charAt(0)}
      </span>
    </div>
  </div>
  <div class="mb-6">
    <time
      datetime={pubDate.toISOString()}
      class="text-[13px] text-(--fg-subtle) tracking-tight"
    >
      {formattedDate}
    </time>
  </div>
  <div class="flex flex-col gap-5 mb-8">
    <h2 class="text-lg md:text-2xl font-semibold tracking-tighter text-(--fg) leading-[1.1] line-clamp-4">
      {title}
    </h2>
    <p class="text-sm text-(--fg-muted) leading-relaxed line-clamp-6 group-hover:text-(--fg)">
      {excerpt}
    </p>
  </div>
  <div class="mt-auto flex items-center gap-3 pt-4">
    {authorAvatar && (
      <Image
        src={optimizedAvatar}
        alt={`Author ${authorName}`}
        width={48}
        height={48}
        class="w-6 h-6 rounded-full border border-(--border) object-cover"
        loading="lazy"
      />
    )}
    <span class="text-[13px] text-(--fg-subtle)">
      {authorName}
    </span>
  </div>
</a>
