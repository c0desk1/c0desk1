---
import type { CollectionEntry } from 'astro:content';
import { formatDateCompact } from '@/lib/utils';
import { siteConfig } from '@/config/site';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data, id } = post;
const { title, description, pubDate, author } = data;

const formattedDate = formatDateCompact(pubDate);
const authorName = author?.name || siteConfig.author;
const authorAvatar = author?.avatar || siteConfig.authorAvatar;
---

<a
  href={`/blog/${id}`}
  class="group flex flex-col h-full p-4 md:p-8 transition-colors duration-200 hover:bg-black/5 dark:hover:bg-white/5 overflow-hidden"
>
  <div class="mb-6">
    <div class="w-12 h-12 flex items-center justify-center border border-zinc-200 dark:border-zinc-800 rounded-lg bg-white dark:bg-black group-hover:border-zinc-400 dark:group-hover:border-zinc-600 transition-colors">
       <span class="text-sm md:text-lg font-semibold text-zinc-900 dark:text-white">
        {title.charAt(0)}
       </span>
    </div>
  </div>

  <div class="mb-6">
    <time datetime={pubDate.toISOString()} class="text-[13px] text-zinc-500 tracking-tight">
      {formattedDate}
    </time>
  </div>

  <div class="flex flex-col gap-6 mb-10">
    <h3 class="text-lg md:text-2xl font-semibold tracking-tighter text-zinc-900 dark:text-white leading-[1.05]">
      {title}
    </h3>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-8">
      {description}
    </p>
  </div>

  <div class="mt-auto flex items-center gap-3">
    {authorAvatar && (
      <img
        src={authorAvatar}
        alt={authorName}
        class="w-6 h-6 rounded-full object-cover"
        loading="eager"
      />
    )}
    <span class="text-[13px] font-medium text-zinc-500 dark:text-zinc-400">
      {authorName}
    </span>
  </div>
</a>