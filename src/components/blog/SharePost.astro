---
// src/components/blog/ShareArticle.astro
import { siteConfig } from "@/config/site";
import Icon from "@/components/ui/Icon";

interface Props {
  url: string;
  title: string;
  description?: string;
}

const { url, title, description = "" } = Astro.props;
const shareLabel = siteConfig.share;
---

<button
  class="sa-btn not-prose"
  data-url={url}
  data-title={title}
  data-description={description}
  aria-label={shareLabel}
  title={shareLabel}
  hidden
>
  <Icon name="share" className="w-4 h-4" />
  <span>{shareLabel}</span>
</button>

<style>
  .sa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--fg-strong);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .sa-btn:not([hidden]) {
    display: inline-flex;
  }

  .sa-btn:hover {
    background: var(--bg-dim);
    color: var(--fg-dim);
  }
</style>

<script>
  const initShareButtons = () => {
    if (!navigator.share) return;

    document.querySelectorAll<HTMLButtonElement>(".sa-btn").forEach((btn) => {
      btn.removeAttribute("hidden");
    });

    const handleShareClick = async (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('.sa-btn') as HTMLButtonElement | null;
      
      if (!btn) return;

      try {
        await navigator.share({
          title: btn.dataset.title || document.title,
          text: btn.dataset.description || "",
          url: btn.dataset.url || window.location.href,
        });
      } catch (error) {}
    };
    document.removeEventListener("click", (window as any).__shareBtnHandler);
    (window as any).__shareBtnHandler = handleShareClick;
    document.addEventListener("click", (window as any).__shareBtnHandler);
  };

  initShareButtons();
  document.addEventListener("astro:page-load", initShareButtons);
</script>