---
// src/components/blog/ShareArticle.astro
import { siteConfig } from "@/config/site";
import Icon from "@/components/ui/Icon";

interface Props {
  url: string;
  title: string;
  description?: string;
  variant?: "row" | "card";
}


const {
  url,
  title,
  description = "",
  variant = "row",
} = Astro.props;

const shareLabel =siteConfig.share;
const shareArticleLabel = siteConfig.shareArticle;
---

<div
  class:list={["sa-wrap not-prose", variant === "card" ? "sa-wrap--card" : "sa-wrap--row"]}
  data-url={url}
  data-title={title}
  data-description={description}
>
  <button class="sa-native text-button-14" aria-label={shareArticleLabel} title={shareLabel} hidden>
    <Icon name="share" className="w-4 h-4" />
    <span>{shareLabel}</span>
  </button>

  {variant === "card" && (
    <p class="sa-label text-label-13 font-semibold tracking-wide">{shareArticleLabel}</p>
  )}
</div>

<style>
  .sa-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .sa-wrap--card {
    flex-direction: column;
    align-items: flex-start;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: var(--bg-muted);
    width: 100%;
  }

  .sa-label {
    margin: 0;
  }

  .sa-native {
    display: none;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.875rem 0.4rem 0.625rem;
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .sa-native:not([hidden]) { display: inline-flex; }
  .sa-native:hover { background: var(--bg-muted); border-color: var(--border-strong); }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".sa-wrap").forEach((wrap) => {
    const btn = wrap.querySelector<HTMLButtonElement>(".sa-native");
    if (!btn || !navigator.share) return;
    btn.removeAttribute("hidden");
    btn.addEventListener("click", async () => {
      try {
        await navigator.share({
          title: wrap.dataset.title || document.title,
          text: wrap.dataset.description || "",
          url: wrap.dataset.url || location.href,
        });
      } catch {}
    });
  });
</script>
