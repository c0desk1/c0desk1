---
// src/components/blog/ShareArticle.astro
import Icon from "@/components/ui/Icon";
import { getShareUrls } from "@/lib/utils";
import { getCurrentLocale, getLabel } from "@/utils/i18n";

interface Props {
  url: string;
  title: string;
  description?: string;
  tags?: string[];
  via?: string;
  variant?: "row" | "card";
}

const locale = getCurrentLocale(Astro);

const {
  url,
  title,
  description = "",
  tags = [],
  via = "",
  variant = "row",
} = Astro.props;

const shareLabel = getLabel(locale, 'share');
const shareArticleLabel = getLabel(locale, 'shareArticle');
const otherPlatformsLabel = getLabel(locale, 'otherPlatforms');
const moreLabel = getLabel(locale, 'more');
const shareToLabel = getLabel(locale, 'shareTo');

const baseUrls = getShareUrls(url, title);

const enc = encodeURIComponent;

const allUrls = {
  ...baseUrls,
  x: `https://x.com/intent/tweet?text=${enc(title)}&url=${enc(url)}${tags.length ? `&hashtags=${enc(tags.join(','))}` : ''}${via ? `&via=${enc(via)}` : ''}`,
  whatsapp: `https://wa.me/?text=${enc(`${title} ${url}`)}`,
  telegram: `https://t.me/share/url?url=${enc(url)}&text=${enc(title)}`,
  threads: `https://www.threads.net/intent/post?text=${enc(`${title} ${url}`)}`,
  reddit: `https://www.reddit.com/submit?url=${enc(url)}&title=${enc(title)}`,
};

const primary = [
  { id: "x", label: "X / Twitter", href: allUrls.x },
  { id: "whatsapp", label: "WhatsApp", href: allUrls.whatsapp },
  { id: "telegram", label: "Telegram", href: allUrls.telegram },
  { id: "facebook", label: "Facebook", href: allUrls.facebook },
  { id: "linkedin", label: "LinkedIn", href: allUrls.linkedin },
  { id: "threads", label: "Threads", href: allUrls.threads },
];

const overflow = [
  { id: "reddit", label: "Reddit", href: allUrls.reddit },
  { id: "email", label: "Email", href: allUrls.email },
];
---

<div
  class:list={["sa-wrap not-prose", variant === "card" ? "sa-wrap--card" : "sa-wrap--row"]}
  data-url={url}
  data-title={title}
  data-description={description}
>
  <button class="sa-native text-button-14" aria-label={shareArticleLabel} title={shareLabel} hidden>
    <Icon name="share" class="w-4 h-4" />
    <span>{shareLabel}</span>
  </button>

  {variant === "card" && (
    <p class="sa-label text-label-13 font-semibold tracking-wide">{shareArticleLabel}</p>
  )}

  <div class="sa-links" aria-label={otherPlatformsLabel}>

    {primary.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${shareToLabel} ${link.label}`}
        title={link.label}
        class="sa-link"
        data-platform={link.id}
      >
        {link.id === "x" && <Icon name="twitter" class="w-4 h-4" />}
        {link.id === "facebook" && <Icon name="facebook" class="w-4 h-4" />}
        {link.id === "linkedin" && <Icon name="linkedin" class="w-4 h-4" />}
        {link.id === "whatsapp" && <Icon name="whatsapp" class="w-4 h-4" />}
        {link.id === "telegram" && <Icon name="telegram" class="w-4 h-4" />}
        {link.id === "threads" && <Icon name="threads" class="w-4 h-4" />}
      </a>
    ))}

    <div class="sa-overflow-wrap">
      <button
        class="sa-link sa-overflow-trigger"
        aria-label={otherPlatformsLabel}
        title={moreLabel}
        aria-expanded="false"
        aria-haspopup="menu">
        <Icon name="more" class="w-3.5 h-3.5" />
      </button>

      <div class="sa-overflow-menu" role="menu" hidden>
        {overflow.map((link) => (
          <a
            href={link.href}
            target={link.id !== "email" ? "_blank" : undefined}
            rel={link.id !== "email" ? "noopener noreferrer" : undefined}
            role="menuitem"
            class="sa-overflow-item text-button-12"
            data-platform={link.id}
          >
            {link.id === "email" && <Icon name="email" class="w-3.5 h-3.5 shrink-0" />}
            {link.id === "reddit" && <Icon name="reddit" class="w-3.5 h-3.5" />}
            <span>{link.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .sa-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .sa-wrap--card {
    flex-direction: column;
    align-items: flex-start;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: var(--bg-muted);
  }

  .sa-label {
    margin: 0;
  }

  .sa-native {
    display: none;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.875rem 0.4rem 0.625rem;
    color: var(--fg);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .sa-native:not([hidden]) { display: inline-flex; }
  .sa-native:hover { background: var(--bg-muted); border-color: var(--border-strong); }

  .sa-links {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .sa-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg-muted);
    cursor: pointer;
    text-decoration: none;
    transition: color 0.13s, background 0.13s, border-color 0.13s, transform 0.1s;
    flex-shrink: 0;
  }
  .sa-link:hover {
    color: var(--fg);
    background: var(--bg-muted);
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }
  .sa-link:active { transform: translateY(0) scale(0.95); }

  .sa-link[data-platform="x"]:hover { color: #000; }
  .sa-link[data-platform="whatsapp"]:hover { color: #25d366; }
  .sa-link[data-platform="telegram"]:hover { color: #2aabee; }
  .sa-link[data-platform="facebook"]:hover { color: #1877f2; }
  .sa-link[data-platform="linkedin"]:hover { color: #0a66c2; }
  .sa-link[data-platform="reddit"]:hover { color: #ff4500; }
  @media (prefers-color-scheme: dark) {
    .sa-link[data-platform="x"]:hover { color: #fff; }
  }

  .sa-overflow-wrap { position: relative; }

  .sa-overflow-menu {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    box-shadow: 0 4px 16px rgba(0,0,0,.1);
    padding: 0.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 8rem;
    z-index: 50;
    animation: sa-menu-in 0.15s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .sa-overflow-menu[hidden] { display: none; }

  @keyframes sa-menu-in {
    from { opacity: 0; transform: translateX(-50%) translateY(4px); }
    to { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .sa-overflow-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    border-radius: 0.5rem;
    color: var(--fg-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.1s, color 0.1s;
    cursor: pointer;
  }
  .sa-overflow-item:hover { background: var(--bg-muted); color: var(--fg); }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".sa-wrap").forEach((wrap) => {
    const btn = wrap.querySelector<HTMLButtonElement>(".sa-native");
    if (!btn || !navigator.share) return;
    btn.removeAttribute("hidden");
    btn.addEventListener("click", async () => {
      try {
        await navigator.share({
          title: wrap.dataset.title || document.title,
          text: wrap.dataset.description || "",
          url: wrap.dataset.url || location.href,
        });
      } catch {}
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".sa-overflow-trigger").forEach((trigger) => {
    const menu = trigger.nextElementSibling as HTMLElement;
    if (!menu) return;
    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = !menu.hasAttribute("hidden");
      menu.toggleAttribute("hidden", isOpen);
      trigger.setAttribute("aria-expanded", String(!isOpen));
    });
  });

  document.addEventListener("click", () => {
    document.querySelectorAll<HTMLElement>(".sa-overflow-menu").forEach((m) =>
      m.setAttribute("hidden", "")
    );
    document.querySelectorAll<HTMLButtonElement>(".sa-overflow-trigger").forEach((b) =>
      b.setAttribute("aria-expanded", "false")
    );
  });

  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    document.querySelectorAll<HTMLElement>(".sa-overflow-menu").forEach((m) =>
      m.setAttribute("hidden", "")
    );
  });
</script>