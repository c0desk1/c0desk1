---
// src/components/blog/BlogRelatedPosts.astro

import type { CollectionEntry } from 'astro:content';
import RelatedPostCard from './RelatedPostCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="mt-14 pt-8 border-t border-zinc-200 dark:border-zinc-800">
    <div class="flex items-center gap-3 mb-6">
      <h2 class="text-sm font-medium text-zinc-500 dark:text-zinc-400 tracking-wide">
        Lebih lanjut
      </h2>
      <div class="h-px flex-1 bg-linear-to-l from-zinc-200 to-transparent dark:from-zinc-800"></div>
    </div>
    <div class="divide-y divide-zinc-200 dark:divide-zinc-800">
      {posts.map(post => (
        <RelatedPostCard post={post} />
      ))}
    </div>
  </section>
)}