---
// src/components/blog/BlogFeaturedImage.astro

interface Props {
  image: string;
  alt?: string;
  caption?: string;
}

const { image, alt, caption } = Astro.props;

const finalCaption = caption || alt;
---

<div class="mx-auto my-4 md:my-8">
  <figure class="overflow-hidden rounded-xl">
    <div class="relative aspect-video overflow-hidden">
      <div
        class="absolute inset-0 animate-pulse bg-zinc-100 dark:bg-zinc-900"
        aria-hidden="true"
      ></div>
      <img
        src={image}
        alt={alt || caption}
        class="relative z-10 w-full h-full object-cover opacity-0 transition-opacity duration-500"
        loading="eager"
        decoding="async"
        onload="this.style.opacity='1'; this.previousElementSibling.style.display='none';"
      />
    </div>
    {finalCaption && (
      <figcaption class="px-4 py-3 text-[13px] text-center text-zinc-500 dark:text-zinc-400 leading-snug">
        {finalCaption}
      </figcaption>
    )}
  </figure>
</div>