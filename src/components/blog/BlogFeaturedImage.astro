---
// src/components/blog/BlogFeaturedImage.astro
import { Image } from 'astro:assets';
import { cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  image?: string;
  alt?: string;
  caption?: string;
  loading?: boolean;
}

const { image, alt = '', caption } = Astro.props;

const optimizedSrc  = image && isCdnUrl(image)
  ? cdnImage(image, { w: 1280, h: 720, q: 85 })
  : image ?? '';
const finalCaption  = caption || '';
---

<figure>
  <div class="hidden relative overflow-hidden">
    <div class="absolute aspect-video inset-0 bg-base animate-pulse" aria-hidden="true"></div>
    <Image
      src={optimizedSrc}
      alt={alt}
      width={1280}
      height={720}
      loading="eager"
      decoding="async"
      class="relative z-10 h-full w-full object-cover aspect-video rounded-none transition duration-500 opacity-0"
      onload="this.classList.remove('opacity-0')"
    />
  </div>
  {finalCaption && <figcaption class="text-body-14 text-(--prose-fg-subtle) mt-4">{finalCaption}</figcaption>}
</figure>