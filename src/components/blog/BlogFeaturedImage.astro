---
// src/components/blog/BlogFeaturedImage.astro
import { Image } from 'astro:assets';
import { cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  image: string;
  alt?: string;
  caption?: string;
}

const { image, alt, caption } = Astro.props;
const optimizedSrc = isCdnUrl(image) ? cdnImage(image, { w: 1280, h: 720, q: 85 }) : image;
const finalCaption = caption || alt;
---

<figure class="prose-custom mx-auto max-w-3xl my-4 md:my-8 overflow-hidden">
	<Image
        src={optimizedSrc}
        alt={alt}
        width={1280}
        height={720}
        loading="eager"
        decoding="async"
        class="block w-full h-auto object-cover"
      />
    {finalCaption && (
      <figcaption>{finalCaption}</figcaption>
    )}
</figure>