---
// src/components/ui/ThemeToggle.astro

import { siteConfig } from "@/config/site";
import Icon from "./ui/Icon";

const siteData = siteConfig

const labels = {
  group: siteData.themeToggleGroup,
  system: siteData.themeSystem,
  light: siteData.themeLight,
  dark: siteData.themeDark,
};
---

<div
  id="theme-toggle"
  role="group"
  aria-label={labels.group}
  class="tt-root">
  {([
    { mode: "system", label: labels.system },
    { mode: "light",  label: labels.light },
    { mode: "dark",   label: labels.dark },
  ] as const).map(({ mode, label }) => (
    <button
      type="button"
      data-mode={mode}
      aria-label={label}
      title={label}
      class="tt-btn"
    >
      {mode === "system" && <Icon name="system" className="tt-icon" />}
      {mode === "light"  && <Icon name="sun"    className="tt-icon" />}
      {mode === "dark"   && <Icon name="moon"   className="tt-icon" />}
    </button>
  ))}
</div>

<style>
  .tt-root {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: var(--bg);
    padding: 2px;
    gap: 1px;
  }

  .tt-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    padding: 0.25rem;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    background: transparent;
    color: var(--fg-subtle);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }

  .tt-btn:hover {
    color: var(--fg);
    background-color: var(--bg-subtle);
  }

  .tt-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .tt-btn[data-active="true"] {
    color: var(--fg);
    background-color: var(--bg-muted);
    border-color: var(--border);
  }

  :global(.tt-icon) {
    width: 0.875rem;
    height: 0.875rem;
    display: block;
  }
</style>

<script>
  type Mode = "system" | "light" | "dark";
  const KEY = "theme-mode";

  const getMode = (): Mode => {
    const v = localStorage.getItem(KEY);
    return v === "light" || v === "dark" || v === "system" ? v : "system";
  };

  const apply = (mode: Mode) => {
    const dark =
      mode === "dark" ||
      (mode === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
    document.documentElement.classList.toggle("dark", dark);
    document.documentElement.setAttribute("data-theme", mode);
    localStorage.setItem(KEY, mode);
  };

  const mark = (mode: Mode) => {
    document.querySelectorAll<HTMLElement>(".tt-btn").forEach((b) => {
      const active = b.dataset.mode === mode;
      b.setAttribute("aria-pressed", String(active));
      b.dataset.active = String(active);
    });
  };

  const initThemeToggle = () => {
    mark(getMode());

    document.removeEventListener("click", (window as any).__themeClickHandler);
    (window as any).__themeClickHandler = (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('.tt-btn') as HTMLElement;
      if (!btn) return;
      
      const mode = btn.dataset.mode as Mode;
      apply(mode);
      mark(mode);
    };
    document.addEventListener("click", (window as any).__themeClickHandler);

    const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
    if ((window as any).__mediaQueryHandler) {
      mediaQuery.removeEventListener("change", (window as any).__mediaQueryHandler);
    }
    (window as any).__mediaQueryHandler = () => {
      if (getMode() === "system") apply("system");
    };
    mediaQuery.addEventListener("change", (window as any).__mediaQueryHandler);
  };

  initThemeToggle();
  
  document.addEventListener("astro:page-load", () => {
    mark(getMode()); 
  });
</script>