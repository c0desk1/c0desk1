---
// src/components/home/HomeBlogSection.astro

import PostCard from '@/components/blog/PostCard.astro';
import Container from '../ui/Container.astro';

interface Props {
  posts: any[];
}

const { posts } = Astro.props;
---

<section class="section-divider">
  <Container size="md" class="py-10 md:py-12">
    <div class="flex items-end justify-between mb-6">
      <div class="space-y-1">
        <h2 class="text-lg md:text-xl text-zinc-900 dark:text-zinc-50">
           Terbaru
        </h2>
      </div>
      <a
        href="/blog"
        class="group flex items-center gap-1 text-center text-xs md:text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors"
      >
        <span>Lihat semua</span>
        <span class="group-hover:translate-x-0.5 transition-transform">→</span>
      </a>
    </div>
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-3">
		{posts.map(post => (
    		<div class="py-6 border-b border-zinc-100 dark:border-zinc-900 md:border-r md:[&:nth-child(3n)]:border-r-0 md:[&:nth-last-child(-n+3)]:border-b-0">
      		<PostCard post={post} />
    		</div>
  		))}
	</div>
    ) : (
      <div class="py-10 text-center">
        <p class="text-zinc-500 dark:text-zinc-400 text-sm">
          Belum ada postingan blog.
        </p>
      </div>
    )}
  </Container>
</section>