---
// src/components/home/HomeBlogSection.astro

import PostCard from '@/components/blog/PostCard.astro';
import Container from '../ui/Container.astro';

interface Props {
  posts: any[];
}

const { posts } = Astro.props;
---

<section>
  <Container size="md" class="py-10 md:py-12">
    <div class="flex items-end justify-between mb-6">
      <div class="space-y-1">
        <div class="flex items-center gap-2">
          <div class="h-1.5 w-1.5 rounded-full bg-emerald-500"></div>
          <h2 class="text-sm text-zinc-900 dark:text-zinc-50">
            Postingan terbaru
          </h2>
        </div>
      </div>
      <a
        href="/blog"
        class="group flex items-center gap-1 text-center text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors"
      >
        <span>Lihat semua</span>
        <span class="group-hover:translate-x-0.5 transition-transform">→</span>
      </a>
    </div>
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map(post => (
          <div class="border-b border-zinc-100 dark:border-zinc-900 pb-4">
            <PostCard post={post} showTags={true} />
          </div>
        ))}
      </div>
    ) : (
      <div class="py-10 text-center">
        <p class="text-zinc-500 dark:text-zinc-400 text-sm">
          Belum ada postingan blog.
        </p>
      </div>
    )}
  </Container>
</section>
