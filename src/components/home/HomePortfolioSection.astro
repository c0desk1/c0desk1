---
// src/components/home/HomePortfolioSection.astro

import Container from '../ui/Container.astro';
import ProjectCard from '@/components/portfolio/ProjectCard.astro';

interface Props {
  projects: any[];
}

const { projects } = Astro.props;
---

<section class="section-divider">
  <Container size="md" class="py-10 md:py-12">

    <div class="flex items-center justify-between mb-5">
      <div class="flex items-center gap-2">
        <h2 class="text-lg md:text-xl text-zinc-900 dark:text-zinc-50">
          Portfolio
        </h2>
      </div>

      <a
        href="/portfolio"
        class="group flex items-center gap-1 text-center text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors"
      >
        <span>Lihat semua</span>
        <span class="group-hover:translate-x-0.5 transition-transform">→</span>
      </a>
    </div>

    {projects.length > 0 ? (
      <div class="space-y-0 divide-y divide-black/5 dark:divide-white/5">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    ) : (
      <div class="text-center py-8">
        <p class="text-zinc-500 dark:text-zinc-400 text-sm">
          ▼ Belum ada proyek.
        </p>
      </div>
    )}

  </Container>
</section>