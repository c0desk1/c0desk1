---
// src/components/home/HomeCTA.astro
import Container from '../ui/Container.astro';
---

<section class="py-10 md:py-12">
  <Container size="md">
    <div class="relative p-6 md:p-8 border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 overflow-hidden">

      <div class="absolute top-3 left-3 w-5 h-5 border-l border-t border-zinc-300 dark:border-zinc-700"></div>
      <div class="absolute bottom-3 right-3 w-5 h-5 border-r border-b border-zinc-300 dark:border-zinc-700"></div>

      <div class="text-center max-w-2xl mx-auto space-y-4">

        <h2 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900 dark:text-white">
          Mari kita bangun sesuatu <span class="text-zinc-400 dark:text-zinc-600">yang hebat bersama.</span>
        </h2>

        <p class="text-zinc-600 dark:text-zinc-400 text-sm">
          Saat ini saya tidak tersedia untuk pekerjaan lepas dan kolaborasi.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center pt-2 font-semibold">
          <a 
            href="/blog"
            class="px-4 py-2 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 text-sm hover:opacity-90 transition-opacity"
          >
            Baca blog
          </a>

          <a 
            href="/portfolio"
            class="px-4 py-2 border border-zinc-200 dark:border-zinc-800 text-sm hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-all"
          >
            Lihat portfolio
          </a>
        </div>

      </div>
    </div>
  </Container>
</section>
