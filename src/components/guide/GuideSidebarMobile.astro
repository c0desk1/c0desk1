---
// src/components/guide/mobile/GuideSidebarMobile.astro
import type { CollectionEntry } from "astro:content";

import { 
  SERIES, 
  ROUTES 
} from "@/consts";

import Icon from "../ui/icons/Icon.astro";
import Breadcrumb from "../Breadcrumb.astro";

interface Props {
  entries:      CollectionEntry<"guide">[];
  currentId?:   string;
  headings:     { depth: number; text: string; slug: string }[];
  series: string;
}

const { 
  entries, 
  currentId, 
  headings, 
  series 
} = Astro.props;

const filteredToc = headings.filter(h => h.depth >= 2 && h.depth <= 3);
const seriesLabel = SERIES.find(c => c.slug === series)?.label || series;
---

<div class="lg:hidden sticky top-(--header-height) z-40 flex items-center justify-between w-full h-12 bg-base border-b border-(--border) px-4">
  <div class="flex items-center py-1.5">
    <button id="m-sidebar-open" type="button" class="flex items-center p-1.5 gap-1.5 text-muted hover:text-strong active:text-strong hover:bg-subtle active:bg-subtle rounded-md transition-colors" aria-label="Open Menu">
      <Icon name="expanded-open" className="w-5 h-5" />
      <span class="inline-flex text-left font-medium text-(--fg) text-body-13">
        {seriesLabel}
      </span>
    </button>
  </div>
  {filteredToc.length > 0 && (
    <details id="m-toc-details" class="group/toc relative">
      <summary class="flex items-center gap-2 cursor-pointer list-none select-none [&::-webkit-details-marker]:hidden text-body-14 font-medium text-muted hover:text-strong py-1.5 px-3 border border-(--border) rounded-md hover:bg-subtle active:bg-subtle transition-colors">
        <span class="inline-flex shrink-0 items-center justify-center">
          <svg role="progressbar" viewBox="0 0 24 24" class="w-4 h-4 shrink-0" fill="none">
            <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="2" opacity="0.25" />
            <circle id="m-toc-progress-ring" cx="12" cy="12" r="11" stroke="currentColor" stroke-width="2" stroke-dasharray="69.115" stroke-dashoffset="69.115" stroke-linecap="round" transform="rotate(-90 12 12)" class="transition-all duration-150 text-(--accent)" />
          </svg>
        </span>
        <span id="m-toc-active-text" class="truncate max-w-32 text-right block font-medium text-body-13">
          Di Halaman Ini
        </span>
        <span class="inline-flex shrink-0 items-center justify-center">
          <Icon name="up-down" className="transition-transform duration-300 group-open/toc:rotate-180 text-dim/70 w-4 h-4 shrink-0" />
        </span>
      </summary>
      <nav class="absolute top-full right-0 mt-2 w-[calc(100vw-2rem)] max-w-sm bg-base rounded-lg border border-(--border) max-h-[60vh] overflow-y-auto px-5 py-4 shadow-lg origin-top-right animate-in fade-in zoom-in-95 duration-200">
        <div class="flex items-center gap-1.5 text-subtle mb-2">
          <Icon name="toc" className="w-4 h-4" />
          <p class="text-body-13 font-semibold">Dihalaman ini</p>
        </div>
        <div id="m-toc-list-container" class="relative pb-2">
          <svg class="absolute inset-0 pointer-events-none text-(--border)" style="width: 100%; height: 100%; z-index: 0;">
            <path id="m-toc-bg-path" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round" stroke-linecap="round" />
          </svg>
          <div id="m-toc-progress-mask" class="absolute top-0 left-0 w-full overflow-hidden transition-[height] duration-300 ease-out" style="height: 0px; z-index: 1;">
            <svg id="m-toc-fg-svg" class="absolute top-0 left-0 pointer-events-none text-(--accent)" style="width: 100%;">
              <path id="m-toc-fg-path" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round" stroke-linecap="round" />
            </svg>
          </div>
          <ul id="m-toc-list" class="flex flex-col relative z-10" role="list">
            {filteredToc.map((h) => {
              const isSubHeading = h.depth === 3;
              return (
                <li class="relative">
                  <a 
                    href={`#${h.slug}`} 
                    class:list={[
                      "toc-mobile-link block py-1.5 transition-all duration-200 no-underline",
                      isSubHeading 
                        ? "pl-9 text-body-13 font-normal text-muted hover:text-strong" 
                        : "pl-6 text-body-13 font-medium text-muted hover:text-strong"
                    ]}
                    data-toc-mobile-slug={h.slug}
                    data-is-sub={isSubHeading.toString()}
                  >
                    {h.text}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </nav>
    </details>
  )}
</div>
<div id="m-sidebar-backdrop" class="fixed inset-0 z-40 bg-base/60 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300 ease-in-out"></div>
<aside id="m-sidebar" class="fixed top-(--header-height) inset-y-0 left-0 z-50 w-72 bg-base transform -translate-x-full transition-transform duration-300 ease-in-out flex flex-col border-r border-(--border) shadow-2xl">
  <div class="flex items-center justify-between px-4 py-2 border-b border-(--border) shrink-0 bg-subtle/30">
    <div class="flex items-center text-body-13 font-medium">
      <Breadcrumb
        items={[
          { name: "Guide", url: ROUTES.guide },
          { name: seriesLabel },
        ]}
      />
    </div>
    <button id="m-sidebar-close" class="p-1.5 rounded-md text-muted hover:text-strong hover:bg-subtle active:text-strong active:bg-subtle transition-colors" aria-label="Close Menu">
      <Icon name="expanded-close" className="w-5 h-5" />
    </button>
  </div>
  <nav class="flex-1 overflow-y-auto py-6 flex flex-col gap-0.5" style="scrollbar-width: thin;">
    <ul class="flex flex-col gap-0.5 px-4">
      {entries.map(entry => {
        const isActive = entry.id === currentId;
        return (
          <li>
            <a 
              href={`/guide/${entry.id}`} 
              class:list={[
                "flex items-center justify-between gap-2 pl-4 pr-3 py-2 text-body-14 no-underline transition-all border-l-2 -ml-px rounded-r-md", 
                isActive 
                  ? "text-strong bg-muted/50 font-medium border-(--accent)"
                  : "text-muted hover:text-strong hover:bg-subtle/40 font-medium border-transparent hover:border-current/50"
              ]}
            >
              <span class="truncate">{entry.data.title}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</aside>

<script>
  const initMobileNavigation = () => {
    const cleanupTasks: Array<() => void> = [];
    const openBtn = document.getElementById("m-sidebar-open");
    const closeBtn = document.getElementById("m-sidebar-close");
    const sidebar = document.getElementById("m-sidebar");
    const backdrop = document.getElementById("m-sidebar-backdrop");
    const tocDetails = document.getElementById("m-toc-details") as HTMLDetailsElement | null;
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>("[data-toc-mobile-slug]");
    const activeText = document.getElementById("m-toc-active-text");
    const progressRing = document.getElementById("m-toc-progress-ring") as SVGCircleElement | null;
    const tocListContainer = document.getElementById("m-toc-list-container");
    const tocMask = document.getElementById("m-toc-progress-mask");
    const tocBgPath = document.getElementById("m-toc-bg-path");
    const tocFgPath = document.getElementById("m-toc-fg-path");
    const tocFgSvg = document.getElementById("m-toc-fg-svg");

    if (openBtn && sidebar && backdrop) {
      const open = () => {
        if (tocDetails) tocDetails.removeAttribute("open");
        sidebar.classList.remove("-translate-x-full");
        backdrop.classList.remove("hidden");
        void sidebar.offsetWidth; 
        requestAnimationFrame(() => backdrop.classList.add("opacity-100"));
        document.body.style.overflow = "hidden";
      };

      const close = () => {
        sidebar.classList.add("-translate-x-full");
        backdrop.classList.remove("opacity-100");
        const handleTransitionEnd = () => {
          backdrop.classList.add("hidden");
          backdrop.removeEventListener("transitionend", handleTransitionEnd);
        };
        backdrop.addEventListener("transitionend", handleTransitionEnd);
        document.body.style.overflow = "";
      };

      openBtn.addEventListener("click", open);
      cleanupTasks.push(() => openBtn.removeEventListener("click", open));

      if (closeBtn) {
        closeBtn.addEventListener("click", close);
        cleanupTasks.push(() => closeBtn.removeEventListener("click", close));
      }

      backdrop.addEventListener("click", close);
      cleanupTasks.push(() => backdrop.removeEventListener("click", close));

      sidebar.querySelectorAll("nav a").forEach(l => {
        l.addEventListener("click", close);
        cleanupTasks.push(() => l.removeEventListener("click", close));
      });
    }

    if (tocLinks.length && tocDetails && activeText && tocListContainer && tocMask && tocBgPath && tocFgPath && tocFgSvg) {
      const linksArray = Array.from(tocLinks);
      const targets = linksArray.map(l => document.getElementById(l.dataset.tocMobileSlug!)).filter(Boolean) as HTMLElement[];
      let active = "";

      const circumference = 69.115;
      const updateRingProgress = () => {
        if (!progressRing) return;
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight <= 0 ? 0 : Math.min(scrollTop / docHeight, 1);
        progressRing.style.strokeDashoffset = String(circumference * (1 - progress));
      };
      
      updateRingProgress();
      window.addEventListener("scroll", updateRingProgress, { passive: true });
      cleanupTasks.push(() => window.removeEventListener("scroll", updateRingProgress));

      const OFFSET = 3; 

      const drawSvgPath = () => {
        if (tocListContainer.offsetHeight === 0) return;
        tocFgSvg.style.height = `${tocListContainer.offsetHeight}px`;

        const H2_X = 4;
        const H3_X = 18;
        
        let currentX = linksArray[0].dataset.isSub === "true" ? H3_X : H2_X;
        let currentY = OFFSET; 
        let d = `M ${currentX} ${currentY}`;

        linksArray.forEach((link) => {
          const li = link.parentElement;
          if (!li) return;

          const isSub = link.dataset.isSub === "true";
          const targetX = isSub ? H3_X : H2_X;
          const yTop = li.offsetTop;

          if (targetX !== currentX) {
            const turnStartY = Math.max(currentY, yTop - 8); 
            if (turnStartY > currentY) {
              d += ` L ${currentX} ${turnStartY}`;
            }
            const turnEndY = yTop + 10;
            d += ` L ${targetX} ${turnEndY}`;
            currentX = targetX;
            currentY = turnEndY;
          }
        });

        const lastLi = linksArray[linksArray.length - 1].parentElement;
        if (lastLi) {
          d += ` L ${currentX} ${lastLi.offsetTop + lastLi.offsetHeight - OFFSET}`;
        }

        tocBgPath.setAttribute("d", d);
        tocFgPath.setAttribute("d", d);
        updateLineProgress();
      };

      const updateLineProgress = () => {
        const activeIndex = linksArray.findIndex(l => l.dataset.tocMobileSlug === active);

        if (activeIndex !== -1) {
          const activeLink = linksArray[activeIndex];
          const li = activeLink.parentElement;
          if (li) {
            const height = li.offsetTop + li.offsetHeight - OFFSET;
            tocMask.style.height = `${height}px`;
          }
        } else {
          tocMask.style.height = "0px";
        }

        linksArray.forEach((l, i) => {
          const isSub = l.dataset.isSub === "true";
          if (i === activeIndex) {
            l.classList.add("text-strong");
            l.classList.remove("text-muted", "text-muted/80");
          } else {
            l.classList.add(isSub ? "text-muted/80" : "text-muted");
            l.classList.remove("text-strong");
          }
        });
      };

      const obs = new IntersectionObserver(entries => {
        const visible = entries
          .filter(e => e.isIntersecting)
          .map(e => targets.find(t => t.id === e.target.id))
          .filter(Boolean) as HTMLElement[];

        if (visible.length > 0) {
          const topMost = visible.reduce((a, b) => {
            const aTop = a.getBoundingClientRect().top;
            const bTop = b.getBoundingClientRect().top;
            return aTop <= bTop ? a : b;
          });
          active = topMost.id;
        } else if (window.scrollY < 50) {
          active = "";
          activeText.textContent = "Di Halaman Ini";
        }

        if (active) {
          const activeLink = linksArray.find(l => l.dataset.tocMobileSlug === active);
          if (activeLink) {
            activeText.textContent = activeLink.textContent?.trim() || "Di Halaman Ini";
          }
        }

        updateLineProgress();
      }, { rootMargin: "-10% 0% -70% 0%", threshold: 0 });

      targets.forEach(t => obs.observe(t));
      cleanupTasks.push(() => obs.disconnect());

      const handleScrollTop = () => {
        if (window.scrollY < 50) {
          active = "";
          activeText.textContent = "Di Halaman Ini";
          updateLineProgress();
        }
      };
      window.addEventListener("scroll", handleScrollTop, { passive: true });
      cleanupTasks.push(() => window.removeEventListener("scroll", handleScrollTop));

      const resizeObs = new ResizeObserver(() => drawSvgPath());
      resizeObs.observe(tocListContainer);
      cleanupTasks.push(() => resizeObs.disconnect());

      const closeToc = () => tocDetails.removeAttribute("open");
      linksArray.forEach(l => {
        l.addEventListener("click", closeToc);
        cleanupTasks.push(() => l.removeEventListener("click", closeToc));
      });
      
      if (openBtn) {
        openBtn.addEventListener("click", closeToc);
        cleanupTasks.push(() => openBtn.removeEventListener("click", closeToc));
      }

      const handleOutsideClick = (event: MouseEvent) => {
        if (tocDetails.hasAttribute("open") && !tocDetails.contains(event.target as Node)) {
          closeToc();
        }
      };
      document.addEventListener("click", handleOutsideClick);
      cleanupTasks.push(() => document.removeEventListener("click", handleOutsideClick));
    }

    return () => cleanupTasks.forEach(cleanupFn => cleanupFn());
  };

  let cleanupMobileNav: (() => void) | undefined;
  
  const runSetup = () => {
    cleanupMobileNav?.();
    cleanupMobileNav = initMobileNavigation();
  };

  runSetup();
  document.addEventListener("astro:page-load", runSetup);
</script>

<style>
  .toc-mobile-link {
    color: var(--fg-muted);
  }

  .toc-mobile-link.text-strong {
    color: var(--fg-strong) !important;
  }

  .toc-mobile-link.text-muted,
  .toc-mobile-link.text-muted\/80 {
    color: var(--fg-muted) !important;
  }
</style>