---
// src/components/guide/desktop/GuideTocDesktop.astro
import Section from "@/components/ui/Section.astro";
import Icon from "../ui/icons/Icon.astro";

interface Props { headings: { depth: number; text: string; slug: string }[]; }
const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <aside class="hidden lg:block w-60 shrink-0 sticky top-(--header-height) h-[calc(100svh-var(--header-height))] overflow-y-auto pl-4" style="scrollbar-width: none;">
    <Section size="sm">
      <div class="flex items-center gap-1.5 text-dim mb-2">
        <Icon name="toc" className="w-4 h-4" />
        <p class="text-label-13 font-semibold">Dihalaman ini</p>
      </div>
      <nav id="toc-desktop-nav" class="relative">
        <svg class="absolute inset-0 pointer-events-none text-(--border)" style="width: 100%; height: 100%; z-index: 0;">
          <path id="toc-bg-path" stroke="currentColor" stroke-width="1" fill="none" stroke-linejoin="round" stroke-linecap="round" />
        </svg>
        <div id="toc-progress-mask" class="absolute top-0 left-0 w-full overflow-hidden transition-[height] duration-300 ease-out" style="height: 0px; z-index: 1;">
          <svg id="toc-fg-svg" class="absolute top-0 left-0 pointer-events-none text-(--accent)" style="width: 100%;">
            <path id="toc-fg-path" stroke="currentColor" stroke-width="1" fill="none" stroke-linejoin="round" stroke-linecap="round" />
          </svg>
        </div>
        <ul id="toc-desktop-list" class="flex flex-col relative z-10">
          {filtered.map(h => {
            const isSubHeading = h.depth === 3;
            return (
              <li class="relative">
                <a 
                  href={`#${h.slug}`} 
                  class:list={[
                    "toc-desktop-link block py-1.5 transition-all duration-200 no-underline",
                    isSubHeading 
                      ? "pl-9 text-label-14 font-normal text-muted/80 hover:text-strong" 
                      : "pl-6 text-label-14 font-medium text-muted hover:text-strong"
                  ]} 
                  data-toc-desktop-slug={h.slug}
                  data-is-sub={isSubHeading.toString()}
                >
                  {h.text}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </Section>
  </aside>
)}

<script>
  const initDesktopToc = () => {
    const links = document.querySelectorAll<HTMLAnchorElement>("[data-toc-desktop-slug]");
    const nav = document.getElementById("toc-desktop-nav");
    const mask = document.getElementById("toc-progress-mask");
    const bgPath = document.getElementById("toc-bg-path");
    const fgPath = document.getElementById("toc-fg-path");
    const fgSvg = document.getElementById("toc-fg-svg");

    if (!links.length || !nav || !mask || !bgPath || !fgPath || !fgSvg) return;

    const linksArray = Array.from(links);
    const targets = linksArray.map(l => document.getElementById(l.dataset.tocDesktopSlug!)).filter(Boolean) as HTMLElement[];
    let active = "";

    const OFFSET = 3; 

    const drawSvgPath = () => {
      if (nav.offsetHeight === 0) return;
      fgSvg.style.height = `${nav.offsetHeight}px`;

      const H2_X = 4;
      const H3_X = 18;
      
      let currentX = linksArray[0].dataset.isSub === "true" ? H3_X : H2_X;
      
      let currentY = OFFSET; 
      let d = `M ${currentX} ${currentY}`;

      linksArray.forEach((link) => {
        const li = link.parentElement;
        if (!li) return;

        const isSub = link.dataset.isSub === "true";
        const targetX = isSub ? H3_X : H2_X;
        const yTop = li.offsetTop;

        if (targetX !== currentX) {
          const turnStartY = Math.max(currentY, yTop - 8); 
          if (turnStartY > currentY) {
            d += ` L ${currentX} ${turnStartY}`;
          }
          const turnEndY = yTop + 10;
          d += ` L ${targetX} ${turnEndY}`;
          currentX = targetX;
          currentY = turnEndY;
        }
      });

      const lastLi = linksArray[linksArray.length - 1].parentElement;
      if (lastLi) {
        d += ` L ${currentX} ${lastLi.offsetTop + lastLi.offsetHeight - OFFSET}`;
      }

      bgPath.setAttribute("d", d);
      fgPath.setAttribute("d", d);
      updateProgress();
    };

    const updateProgress = () => {
      const activeIndex = linksArray.findIndex(l => l.dataset.tocDesktopSlug === active);

      if (activeIndex !== -1) {
        const activeLink = linksArray[activeIndex];
        const li = activeLink.parentElement;
        if (li) {
          const height = li.offsetTop + li.offsetHeight - OFFSET;
          mask.style.height = `${height}px`;
        }
      } else {
        mask.style.height = "0px";
      }

      linksArray.forEach((l, i) => {
        const isSub = l.dataset.isSub === "true";
        if (i === activeIndex) {
          l.classList.add("text-strong");
          l.classList.remove("text-muted", "text-muted/80");
        } else {
          l.classList.add(isSub ? "text-muted/80" : "text-muted");
          l.classList.remove("text-strong");
        }
      });
    };

    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) active = e.target.id; });
      updateProgress();
    }, { rootMargin: "-15% 0% -75% 0%", threshold: 0 });

    targets.forEach(t => obs.observe(t));

    const handleScroll = () => {
      if (window.scrollY < 50 && active !== "") {
        active = "";
        updateProgress();
      }
    };
    window.addEventListener("scroll", handleScroll, { passive: true });

    const resizeObs = new ResizeObserver(() => drawSvgPath());
    resizeObs.observe(nav);

    drawSvgPath();

    return () => {
      obs.disconnect();
      resizeObs.disconnect();
      window.removeEventListener("scroll", handleScroll);
    };
  };

  let cleanup: (() => void) | undefined;
  
  const runSetup = () => { 
    cleanup?.(); 
    cleanup = initDesktopToc(); 
  };
  
  runSetup();
  document.addEventListener("astro:page-load", runSetup);
</script>