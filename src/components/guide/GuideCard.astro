---
// src/components/guide/GuideCard.astro
import type { CollectionEntry } from "astro:content";
import { formatDate, ROUTES } from "@/consts";

interface Props {
  entry: CollectionEntry<"guide">;
}

const { entry } = Astro.props;
const { title, description, pubDate, category, tags } = entry.data;

const badge = 'badge' in entry.data ? (entry.data as any).badge : undefined;

const BADGE_LABEL: Record<string, string> = {
  new:        "New",
  beta:       "Beta",
  deprecated: "Deprecated",
  updated:    "Updated",
};

const badgeColors: Record<string, string> = {
  new:        "bg-emerald-500/15 text-emerald-600 dark:text-emerald-400",
  beta:       "bg-indigo-500/15 text-indigo-600 dark:text-indigo-400",
  updated:    "bg-amber-500/15 text-amber-600 dark:text-amber-400",
  deprecated: "bg-red-500/15 text-red-600 dark:text-red-400",
};
---

<a href={`${ROUTES.guide}/${entry.id}`} class="group flex flex-col h-full p-5 lg:p-6 rounded-xl border border-(--border) bg-subtle hover:bg-base hover:border-strong hover:-translate-y-px transition-all duration-200 no-underline">
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2">
      {category && (
        <span class="text-[11px] font-bold tracking-widest uppercase text-subtle">{category}</span>
      )}
      {badge && BADGE_LABEL[badge] && (
        <span class={`text-[10px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded-[3px] ${badgeColors[badge]}`}>
          {BADGE_LABEL[badge]}
        </span>
      )}
    </div>
    <svg class="text-dim group-hover:text-strong transition-all duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" width="14" height="14" viewBox="0 0 14 14" fill="none">
      <path d="M3 11L11 3M11 3H5M11 3v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <h3 class="text-body-15 font-semibold tracking-tight text-strong leading-snug mb-1.5">{title}</h3>
  <p class="text-body-13 text-muted leading-relaxed mb-0 flex-1 line-clamp-2">{description}</p>
  <footer class="flex items-center justify-between gap-2 mt-5">
    <time class="text-label-12 text-dim" datetime={pubDate.toISOString()}>
      {formatDate(pubDate)}
    </time>
    {tags && tags.length > 0 && (
      <div class="flex gap-1.5">
        {tags.slice(0, 2).map((tag: string) => (
          <span class="text-[11px] text-subtle">#{tag}</span>
        ))}
      </div>
    )}
  </footer>
</a>