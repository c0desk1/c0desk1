---
// src/components/guide/GuideCard.astro
import type { CollectionEntry } from "astro:content";
import { formatDate, ROUTES, CATEGORIES } from "@/consts";

interface Props {
  entry: CollectionEntry<"guide">;
}

const { entry } = Astro.props;
const { title, description, pubDate, section } = entry.data;
const sectionLabel = CATEGORIES.find(c => c.slug === (section || 'general'))?.label || section || 'General';
---

<a
  href={`${ROUTES.guide}/${entry.id}`}
  class="group relative flex flex-col h-full p-4 lg:p-6 rounded-xl border border-(--border)/60 bg-base/70 backdrop-blur-sm hover:bg-base/90 hover:border-(--accent)/20 transition-all duration-300 no-underline overflow-hidden"
>
  <div class="absolute top-0 left-0 w-5 h-5 border-t border-l border-(--accent)/20 rounded-tl-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  <div class="absolute bottom-0 right-0 w-5 h-5 border-b border-r border-(--accent)/20 rounded-br-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  <div class="absolute inset-0 rounded-xl bg-linear-to-br from-(--accent)/5 via-transparent to-(--accent)/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
  <div class="flex items-center justify-between mb-4">
    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-label-13 text-muted bg-muted/40 border border-(--border)/40 group-hover:border-(--accent)/20 group-hover:text-strong transition-colors duration-300">
      <span class="w-1 h-1 rounded-full bg-(--accent)/60 group-hover:bg-(--accent) transition-colors duration-300"></span>
      {sectionLabel}
    </span>
    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full border border-(--border)/40 text-dim group-hover:text-strong group-hover:border-(--accent)/30 transition-all duration-300">
      <svg
        class="w-3 h-3 transition-transform duration-300 group-hover:translate-x-px group-hover:-translate-y-px"
        viewBox="0 0 14 14" fill="none">
        <path d="M3 11L11 3M11 3H5M11 3v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
  <h3 class="text-heading-16 lg:text-heading-18 font-semibold text-strong leading-snug line-clamp-2 mb-2">
    {title}
  </h3>
  <p class="text-body-14 text-muted leading-relaxed mb-0 flex-1 line-clamp-3 group-hover:text-strong transition-colors duration-300">
    {description}
  </p>
  <footer class="flex items-center justify-between gap-2 mt-5">
    <time class="text-label-13 text-muted tracking-tight" datetime={pubDate.toISOString()}>
      {formatDate(pubDate, true)}
    </time>
    <span class="text-label-13 text-muted opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      //baca
    </span>
  </footer>
</a>