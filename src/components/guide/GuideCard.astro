---
// src/components/guide/GuideCard.astro
import type { CollectionEntry } from "astro:content";
import { formatDate, ROUTES, CATEGORIES } from "@/consts";

interface Props {
  entry: CollectionEntry<"guide">;
}

const { entry } = Astro.props;
const { title, description, pubDate, section } = entry.data;
const sectionLabel = CATEGORIES.find(c => c.slug === (section || 'general'))?.label || section || 'General';
---

<a href={`${ROUTES.guide}/${entry.id}`} class="group flex flex-col h-full p-5 lg:p-6 rounded-xl border border-(--border) bg-subtle hover:bg-base hover:border-strong hover:-translate-y-px transition-all duration-200 no-underline">
  <div class="flex items-center justify-between mb-3">
    <span class="text-body-14 font-mediun text-subtle">
      {sectionLabel}
    </span>
    <svg
      class="text-dim group-hover:text-strong transition-all duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
      width="14" height="14" viewBox="0 0 14 14" fill="none">
      <path d="M3 11L11 3M11 3H5M11 3v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <h3 class="text-body-15 font-semibold text-strong leading-snug line-clamp-2 mb-1.5">
    {title}
  </h3>

  <p class="text-body-13 text-muted leading-relaxed mb-0 flex-1 line-clamp-3">
    {description}
  </p>

  <footer class="flex items-center justify-between gap-2 mt-5">
    <time class="text-label-12 text-dim" datetime={pubDate.toISOString()}>
      {formatDate(pubDate)}
    </time>
  </footer>
</a>