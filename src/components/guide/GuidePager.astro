---
// src/components/guide/GuidePager.astro
import type { CollectionEntry } from "astro:content";
import { ROUTES } from "@/consts";
import Section from "../ui/Section.astro";
import Icon from "../ui/icons/Icon.astro";

interface Props {
  prev?: CollectionEntry<"guide"> | null;
  next?: CollectionEntry<"guide"> | null;
}

const { prev, next } = Astro.props;
---
<Section size="sm">
  {(prev || next) && (
    <nav class="pt-8 border-t border-(--border)" aria-label="Guide pagination">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {prev ? (
          <div class="text-left">
            <a href={`${ROUTES.guide}/${prev.id}`} class="group flex flex-col gap-1.5 p-4 border border-(--border) rounded-lg hover:border-strong hover:bg-subtle transition-all duration-200 no-underline">
              <span class="flex items-center justify-start gap-1.5 text-label-13 text-muted uppercase mb-2">
                <Icon name="arrow-left" className="w-3.5 h-3.5" />
                {'Sebelumnya'}
              </span>
              <span class="text-body-14 md:text-body-16 font-medium text-fg group-hover:text-strong transition-colors duration-200 truncate">
                {prev.data.title}
              </span>
            </a>
          </div>
        ) : <div />}

        {next ? (
          <div class="text-right">
            <a href={`${ROUTES.guide}/${next.id}`} class="group flex flex-col gap-1.5 p-4 border border-(--border) rounded-lg hover:border-strong hover:bg-subtle transition-all duration-200 no-underline">
              <span class="flex items-center justify-end gap-1.5 text-label-13 text-muted uppercase mb-2">
                {'Selanjutnya'}
                <Icon name="arrow-right" className="w-3.5 h-3.5" />
              </span>
              <span class="text-body-14 md:text-body-16 font-medium text-fg group-hover:text-strong transition-colors duration-200 truncate">
                {next.data.title}
              </span>
            </a>
          </div>
        ) : <div />}
      </div>
    </nav>
  )}
</Section>