---
// src/components/guide/GuideSidebar.astro
import type { CollectionEntry } from "astro:content";

interface Props {
  entries:    CollectionEntry<"guide">[];
  currentId?: string;
}

const { entries, currentId } = Astro.props;

// Grouping berdasarkan properti 'section' dari skema Anda
const grouped = entries
  .filter(e => !e.data.draft)
  .reduce<Record<string, CollectionEntry<"guide">[]>>((acc, entry) => {
    // Gunakan 'section' jika ada, fallback ke "General"
    const sec = entry.data.section || "General";
    (acc[sec] ??= []).push(entry);
    return acc;
  }, {});

const BADGE_LABEL: Record<string, string> = {
  new:        "New",
  beta:       "Beta",
  deprecated: "Depr.",
  updated:    "Upd.",
};

const badgeColors: Record<string, string> = {
  new:        "bg-emerald-500/15 text-emerald-600 dark:text-emerald-400",
  beta:       "bg-indigo-500/15 text-indigo-600 dark:text-indigo-400",
  updated:    "bg-amber-500/15 text-amber-600 dark:text-amber-400",
  deprecated: "bg-red-500/15 text-red-600 dark:text-red-400",
};
---

<aside 
  class="order-1 w-full lg:w-60 shrink-0 sticky top-(--header-height) lg:top-[calc(var(--header-height)+2rem)] z-30 bg-base lg:bg-transparent border-b lg:border-b-0 border-(--border) lg:max-h-[calc(100svh-var(--header-height)-4rem)] overflow-y-auto lg:pr-4 py-2 lg:py-0"
  id="guide-sidebar"
  style="scrollbar-width: thin; scrollbar-color: var(--border) transparent;"
>
  <div class="lg:pb-12">
    <div class="flex lg:hidden items-center justify-between py-2 mb-2">
      <span class="text-label-12 font-bold tracking-widest uppercase text-muted">
        Navigasi Panduan
      </span>
      <button
        class="flex items-center justify-center w-8 h-8 rounded-md text-muted hover:text-strong hover:bg-subtle transition-colors focus:outline-none"
        id="sidebar-toggle"
        aria-expanded="false"
        aria-controls="sidebar-nav"
      >
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
          <path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <nav class="hidden lg:flex flex-col gap-6 mt-4 lg:mt-0" id="sidebar-nav">
      {Object.entries(grouped).map(([section, items]) => (
        <div class="flex flex-col gap-1.5">
          <p class="text-label-11 font-bold tracking-widest uppercase text-subtle px-2 mb-1">
            {section}
          </p>
          <ul class="flex flex-col gap-px" role="list">
            {items.map(entry => {
              const isActive = entry.id === currentId;
              const badge    = entry.data.badge;
              
              return (
                <li>
                  <a
                    href={`/guide/${entry.id}`}
                    class:list={[
                      "flex items-center justify-between gap-2 px-2 py-1.5 rounded-md text-body-13 transition-colors no-underline",
                      isActive 
                        ? "text-strong font-medium bg-muted" 
                        : "text-muted hover:text-strong hover:bg-subtle"
                    ]}
                    aria-current={isActive ? "page" : undefined}
                  >
                    <span class="flex-1 min-w-0 overflow-hidden text-ellipsis whitespace-nowrap">
                      {entry.data.title}
                    </span>
                    {badge && BADGE_LABEL[badge] && (
                      <span class={`shrink-0 text-[10px] font-bold tracking-wider uppercase px-1.5 py-px rounded-[3px] ${badgeColors[badge]}`}>
                        {BADGE_LABEL[badge]}
                      </span>
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </nav>
  </div>
</aside>

<script>
  const initSidebar = () => {
    const toggle = document.getElementById("sidebar-toggle");
    const nav    = document.getElementById("sidebar-nav");
    if (!toggle || !nav) return;

    toggle.removeEventListener("click", (window as any).__sidebarToggle);
    
    (window as any).__sidebarToggle = () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      
      if (!expanded) {
        nav.classList.remove("hidden");
        nav.classList.add("flex");
      } else {
        nav.classList.add("hidden");
        nav.classList.remove("flex");
      }
    };

    toggle.addEventListener("click", (window as any).__sidebarToggle);
  };

  initSidebar();
  document.addEventListener("astro:page-load", initSidebar);
</script>