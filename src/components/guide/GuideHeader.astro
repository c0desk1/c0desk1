---
// src/components/guide/GuideHeader.astro
import { formatDate } from "@/consts";
import Icon from "@/components/ui/icons/Icon.astro";

interface Props {
  title: string;
  pubDate: Date;
  description?: string;
  tags?: string[];
  authorName?: string;
  heroImage?: {
    src: string;
    alt: string;
  };
}

const {
  title,
  pubDate,
  description,
  tags = [],
  authorName,
  heroImage,
} = Astro.props;
---

<header class="mb-10">

  <h1 class="text-heading-24 md:text-heading-32 lg:text-heading-48 font-semibold text-strong mt-0! mb-4">
    {title}
  </h1>
  <div class="flex flex-wrap items-center gap-3 text-label-13 text-muted mb-4">
    {authorName && (
      <span class="flex items-center gap-1.5">
        <Icon name="user" className="w-3.5 h-3.5" />
        {authorName}
      </span>
    )}
    <time datetime={pubDate.toISOString()}>
      {formatDate(pubDate)}
    </time>
  </div>

  {description && (
    <p class="text-body-16 text-muted leading-relaxed max-w-3xl">
      {description}
    </p>
  )}

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-4">
      {tags.map(tag => (
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-medium bg-muted/50 text-subtle border border-(--border)">
          {tag}
        </span>
      ))}
    </div>
  )}

  {heroImage && (
    <figure class="mt-8 -mx-4 md:mx-0">
      <img
        src={heroImage.src}
        alt={heroImage.alt || title}
        class="w-full rounded-xl border border-(--border)"
        loading="eager"
      />
    </figure>
  )}
</header>