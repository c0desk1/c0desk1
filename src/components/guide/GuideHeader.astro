---
// src/components/guide/GuideHeader.astro
import PostAuthor from "@/components/blog/PostAuthor.astro";
import HeroImage from "@/components/blog/HeroImage.astro";
import Icon from "@/components/ui/icons/Icon.astro";
import { formatDate } from "@/consts";

interface Props {
  title: string;
  pubDate: Date;
  description?: string;
  authorName?: string;
  authorAvatar?: string;
  authorRole?: string;
  authorSlug?: string;
  heroImage?: {
    src: string;
    alt: string;
  };
  tags?: string[];
}

const {
  title,
  pubDate,
  description,
  authorName,
  authorAvatar,
  authorRole,
  authorSlug,
  heroImage,
  tags = [],
} = Astro.props;
---

<header class="w-full max-w-3xl mx-auto">
  <div class="flex flex-col items-center text-center gap-5 md:gap-6">
    <h1 class="text-heading-32 md:text-heading-40 lg:text-heading-48 font-bold text-balance tracking-tight">
      {title}
    </h1>
    {description && (
      <p class="lead text-(--prose-fg-dim) max-w-2xl">{description}</p>
    )}
    <div class="flex flex-col items-center gap-4 w-full">
      {authorName && (
        <PostAuthor
          name={authorName}
          avatar={authorAvatar}
          role={authorRole}
          slug={authorSlug || ""}
        />
      )}

      <div class="flex items-center justify-center gap-1.5 text-label-14 font-medium text-muted">
        <Icon name="clock" className="w-4 h-4" />
        <time datetime={pubDate.toISOString()}>
          {formatDate(pubDate)}
        </time>
      </div>
    </div>
    <hr class="w-16 border-t-4 border-(--border) rounded-full opacity-40" />
    {tags.length > 0 && (
      <div class="flex flex-wrap justify-center gap-2 mt-2">
        {tags.map(tag => (
          <span class="inline-flex items-center px-3 py-1 rounded-full text-[11px] font-medium bg-muted/40 text-subtle border border-(--border)">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
  {heroImage && (
    <HeroImage
      image={heroImage.src}
      alt={heroImage.alt || title}
    />
  )}
</header>