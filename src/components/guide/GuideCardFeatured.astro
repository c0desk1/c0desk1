---
// src/components/guide/GuideCardFeatured.astro
import { 
  getEntry, 
  type CollectionEntry 
} from 'astro:content'

import { Image } from 'astro:assets';

import { 
  AUTHOR,
  formatDate, 
  ROUTES, 
  SERIES,
  IMAGE
} from "@/consts";

import { 
  generateExcerpt, 
  cdnImage, 
  isCdnUrl, 
  slugify 
} from '@/lib/utils'

import Link from "../ui/Link.astro";

interface Props {
  entry: CollectionEntry<"guide">;
}

const { entry } = Astro.props;
const { data } = entry;

const { 
  title, 
  pubDate, 
  series, 
  heroImage, 
  seo 
} = entry.data;

const seriesLabel = SERIES.find(c => c.slug === series)?.label || series || 'General';
const excerpt = generateExcerpt(entry.body || '', 200);

const authorEntry = data.author ? await getEntry(data.author) : null;
const authorName = authorEntry?.data?.name || AUTHOR.name;
const rawAvatar = authorEntry?.data?.avatar;
const isAvatarPlaceholder = !rawAvatar || rawAvatar === '';
const optimizedAvatar = !isAvatarPlaceholder && isCdnUrl(rawAvatar)
  ? cdnImage(rawAvatar, { w: IMAGE.avatar.width, h: IMAGE.avatar.height, q: IMAGE.avatar.quality })
  : rawAvatar || IMAGE.avatar.placeholder;

const autoSlug = data.slug || slugify(title);
const guideUrl = `${ROUTES.guide}/${autoSlug}`;

const rawImage = heroImage?.src || seo?.ogImage;
const isPlaceholder = !rawImage || rawImage === '';

const optimizedImage = !isPlaceholder && isCdnUrl(rawImage)
  ? cdnImage(rawImage, { w: IMAGE.thumbnail.width, h: IMAGE.thumbnail.height, q: IMAGE.thumbnail.quality })
  : rawImage || IMAGE.thumbnail.placeholder;

const imageAlt = heroImage?.alt || title;
---

<article class="group relative flex flex-col rounded-lg border border-(--border) bg-base overflow-hidden hover:shadow-md transition-all duration-300 no-underline">
  <div class="relative aspect-video overflow-hidden bg-muted">
    {!isPlaceholder && (
      <div class="absolute inset-0 bg-base animate-pulse" aria-hidden="true"></div>
    )}
    <Image
      src={optimizedImage}
      alt={imageAlt}
      width={IMAGE.thumbnail.width}
      height={IMAGE.thumbnail.height}
      class:list={[
        "relative z-10 w-full h-full object-cover transition duration-500",
        isPlaceholder ? "opacity-100" : "opacity-0"
      ]}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      onload={!isPlaceholder ? "this.classList.remove('opacity-0')" : undefined}
    />
  </div>
  
  <div class="flex flex-col flex-1 p-4">
    <header>
      <div class="flex items-center justify-between mb-4">
        <time class="text-label-14 text-muted" datetime={pubDate.toISOString()}>
          {formatDate(pubDate, true)}
        </time>
        <div class="flex items-center gap-1.5">
          <span class="text-label-14 text-muted capitalize">
            {seriesLabel}
          </span>
          <div class="w-6 h-6 shrink-0 rounded-full overflow-hidden flex items-center justify-center bg-muted/50">
            <Image
              src={optimizedAvatar}
              alt={`Avatar ${authorName}`}
              width={IMAGE.avatar.width}
              height={IMAGE.avatar.height}
              loading="eager"
              decoding="async"
              fetchpriority="low"
              class:list={[
                "h-full w-full object-cover transition duration-300",
                isAvatarPlaceholder ? "opacity-100 grayscale" : "opacity-0"
              ]}
              onload={!isAvatarPlaceholder ? "this.classList.remove('opacity-0')" : undefined}
            />
          </div>
        </div>
      </div>
      <h3 class="text-heading-16 lg:text-heading-18 font-semibold text-strong leading-snug line-clamp-2 mb-4">
        {title}
      </h3>
    </header>
    <p class="text-body-14 text-muted mb-0 flex-1">
      {excerpt}
    </p>
    <footer class="flex items-center justify-between gap-2 mt-4">
      <Link href={`${ROUTES.guide}/${entry.id}`} size="md" variant="primary" class="flex flex-col rounded-md w-full text-label-14">
        <span>Baca selengkapnya</span>
      </Link>
    </footer>
  </div>
</article>