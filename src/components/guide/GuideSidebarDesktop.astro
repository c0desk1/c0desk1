---
// src/components/guide/desktop/GuideSidebarDesktop.astro
import Section from "@/components/ui/Section.astro";

import type { CollectionEntry } from "astro:content";
interface Props { entries: CollectionEntry<"guide">[]; currentId?: string; }
const { entries, currentId } = Astro.props;

const grouped = entries.reduce<Record<string, CollectionEntry<"guide">[]>>((acc, entry) => {
  const sec = entry.data.section || "General";
  (acc[sec] ??= []).push(entry);
  return acc;
}, {});
---
<aside class="hidden lg:flex flex-col w-64 shrink-0 sticky top-(--header-height) h-[calc(100svh-var(--header-height))] overflow-y-auto pr-6" style="scrollbar-width: thin;">
  <Section size="sm">
    <nav class="flex flex-col gap-6 w-full" role="list">
      {Object.entries(grouped).map(([section, items]) => (
        <div class="flex flex-col gap-1">
          <h3 class="text-[11px] font-bold tracking-wider uppercase text-muted/80 px-2 mb-1">{section}</h3>
          <ul class="flex flex-col gap-px">
            {items.map(entry => (
              <li>
                <a href={`/guide/${entry.id}`} class:list={["flex items-center justify-between gap-2 px-2.5 py-1.5 rounded-md text-[13px] transition-all no-underline border", entry.id === currentId ? "text-strong font-semibold bg-muted border-(--border)" : "text-muted hover:text-strong hover:bg-subtle/50 border-transparent"]}>
                  <span class="truncate">{entry.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </Section>
</aside>
