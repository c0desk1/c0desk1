---
// src/components/guide/desktop/GuideSidebarDesktop.astro
import type { CollectionEntry } from "astro:content";
import { ROUTES } from "@/consts";

import Section from "../ui/Section.astro";
import Breadcrumb from "../Breadcrumb.astro";

interface Props {
  entries: CollectionEntry<"guide">[];
  currentId?: string;
  series: string;
}

const { entries, currentId, series } = Astro.props;
---

<aside
  id="guide-sidebar-desktop"
  class="hidden lg:flex flex-col w-64 shrink-0 sticky top-(--header-height) h-[calc(100svh-var(--header-height))] overflow-y-auto border-r border-(--border)"
  style="scrollbar-width: thin; scrollbar-color: var(--border) transparent;"
>
  <Section size="sm">
    <div class="flex items-center px-3 text-muted mb-4">
      <Breadcrumb
        items={[
          { name: "Guide", url: ROUTES.guide },
          { name: series },
        ]}
       />
    </div>
    <nav class="flex flex-col gap-6 w-full"> 
      <ul class="flex flex-col gap-px">
        {entries.map(entry => {
          const isActive = entry.id === currentId;
          return (
            <li>
              <a
                href={`/guide/${entry.id}`}
                class:list={[
                  "sidebar-desktop-link group flex items-center justify-between gap-2 px-3 py-1.5 text-label-14 no-underline transition-all duration-200 border-l-2 -ml-px",
                  isActive
                    ? "text-strong font-medium bg-muted border-(--fg-strong)"
                    : "text-muted font-normal hover:text-strong hover:bg-subtle border-transparent"
                ]}
                aria-current={isActive ? "page" : undefined}
                data-active-sidebar={isActive ? "true" : "false"}
              >
                <span class="transition-transform duration-200 group-hover:translate-x-0.5 line-clamp-2">
                  {entry.data.title}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </Section>
</aside>

<script>
  const scrollSidebarToActiveItem = () => {
    const sidebar = document.getElementById("guide-sidebar-desktop");
    const activeLink = sidebar?.querySelector('[data-active-sidebar="true"]');
    
    if (sidebar && activeLink) {
      activeLink.scrollIntoView({ 
        behavior: 'instant', 
        block: 'center'
      });
    }
  };


  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', scrollSidebarToActiveItem);
  } else {
    scrollSidebarToActiveItem();
  }
  document.addEventListener("astro:page-load", scrollSidebarToActiveItem);
</script>