---
// src/components/guide/desktop/GuideSidebarDesktop.astro
import type { CollectionEntry } from "astro:content";
import Icon from "../ui/icons/Icon.astro";

interface Props {
  entries: CollectionEntry<"guide">[];
  currentId?: string;
  sectionLabel: string;
}

const { entries, currentId, sectionLabel } = Astro.props;
---

<aside
  id="guide-sidebar-desktop"
  class="hidden lg:flex flex-col w-64 shrink-0 sticky top-(--header-height) h-[calc(100svh-var(--header-height))] overflow-y-auto py-8 border-x border-(--border)"
  style="scrollbar-width: thin; scrollbar-color: var(--border) transparent;"
>
  <nav class="flex flex-col gap-6 w-full">
    <div class="flex flex-col gap-1">
      <div class="flex items-center border-y border-(--border) px-3 py-2 gap-1.5 text-muted">
        <span class="inline-flex shrink-0 items-center justify-center w-4 h-4">
          <Icon name="bot" className="w-full h-full text-subtle" />
        </span>
        <h3 class="text-heading-14 font-semibold select-none">
          {sectionLabel}
        </h3>
      </div>
      <ul class="flex flex-col gap-px">
        {entries.map(entry => {
          const isActive = entry.id === currentId;
          return (
            <li>
              <a
                href={`/guide/${entry.id}`}
                class:list={[
                  "sidebar-desktop-link group flex items-center justify-between gap-2 px-3 py-1.5 text-label-14 no-underline font-medium transition-colors border-l-2 -ml-px",
                  isActive
                    ? "text-strong bg-muted/80 border-(--accent)"
                    : "text-muted hover:text-strong hover:bg-subtle/40 border-transparent"
                ]}
                aria-current={isActive ? "page" : undefined}
                data-active-sidebar={isActive ? "true" : "false"}
              >
                <span class="truncate transition-transform duration-150 group-hover:translate-x-0.5">
                  {entry.data.title}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>
</aside>

<script>
  const scrollSidebarToActiveItem = () => {
    const sidebar = document.getElementById("guide-sidebar-desktop");
    const activeLink = sidebar?.querySelector('[data-active-sidebar="true"]');
    
    if (sidebar && activeLink) {
      activeLink.scrollIntoView({ 
        behavior: 'instant', 
        block: 'nearest' 
      });
    }
  };

  scrollSidebarToActiveItem();
  document.addEventListener("astro:page-load", scrollSidebarToActiveItem);
</script>