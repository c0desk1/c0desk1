---
// src/components/status/StatusPanel.astro
import StatusDot from "./statusDot.astro";
const { data } = Astro.props;
---

<div
  id="status-panel"
  class="fixed bottom-0 left-0 right-0 translate-y-full transition-transform duration-300 ease-out bg-white dark:bg-black border-t border-black/10 dark:border-white/10 shadow-2xl z-50"
>
  <div class="max-w-3xl mx-auto p-4 space-y-3">

    <div class="flex justify-between items-center">
      <p class="text-sm font-medium">System Status</p>
      <button id="status-close" class="text-xs opacity-60 hover:opacity-100">Close</button>
    </div>

    {data.services.map((s: any) => (
      <div class="flex justify-between items-center text-sm">
        <div class="flex items-center gap-2">
          <StatusDot status={s.status} />
          <span class="capitalize">{s.name}</span>
        </div>
        <span class="text-xs opacity-60">{s.status}</span>
      </div>
    ))}

    <p class="text-[11px] opacity-50 pt-2">
      Last updated: {new Date(data.updated).toLocaleTimeString()}
    </p>

  </div>
</div>