---
import Container from "@/components/ui/Container.astro";
import Link from "@/components/ui/Link.astro";
import { buildMeta, ROUTES, schemaWebPage, SITE } from "@/consts";
import Layout from "@/layouts/Layout.astro";

interface Props {
  code: string;
  title: string;
  description: string;
}

const { code, title, description } = Astro.props;

const meta = buildMeta({
  title: `${code} - ${title}`,
  description: description,
  noindex: true,
});

const schema = schemaWebPage({
  title: `${code} - ${title}`,
  description: description,
  url: `${SITE.url}/${code}`,
  type: "WebPage",
});
---

<Layout {meta} {schema} hideHeader={true} hideFooter={true}>
  <Container size="md">
    <div class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4">
      <h1 class="text-4xl md:text-7xl font-extrabold tracking-tighter text-strong mb-4">
        {code}
      </h1>
      <p class="text-body-16 text-muted mb-10 max-w-sm text-pretty">
        {description}
      </p>
      <Link href={ROUTES.home} variant="noir" size="lg">
        Kembali ke Beranda
      </Link>
    </div>
  </Container>
</Layout>
