---
// src/components/portfolio/PortfolioGallery.astro

interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

{images.length > 0 && (
  <div class="mt-10 pt-6 border-t border-zinc-100 dark:border-zinc-800">
    <div class="flex items-center gap-2 mb-4">
      <div class="h-px w-6 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
      <h3 class="text-sm font-semibold tracking-wider uppercasetext-zinc-500 dark:text-zinc-400">
        Gallery
      </h3>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {images.map((img, idx) => (
        <figure class="relative overflow-hidden bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
          <div class="relative overflow-hidden aspect-16/9">
            <img
              src={img}
              alt={`${title} screenshot ${idx + 1}`}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
              decoding="async"
              sizes="(min-width: 768px) 384px, 100vw"
            />
            <div class="absolute top-2 left-2 w-4 h-4 border-l border-t border-white/30"></div>
            <div class="absolute bottom-2 right-2 w-4 h-4 border-r border-b border-white/30"></div>
          </div>
        </figure>
      ))}
    </div>
  </div>
)}