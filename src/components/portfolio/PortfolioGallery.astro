---
// src/components/portfolio/PortfolioGallery.astro

interface ImageItem {
  src: string;
  alt?: string;
}

interface Props {
  images: (string | ImageItem)[];
  title: string;
}

const { images = [], title } = Astro.props;

const getSrc = (img: string | ImageItem) =>
  typeof img === "string" ? img : img.src;

const getAlt = (img: string | ImageItem, index: number) => {
  if (typeof img === "object" && img.alt) return img.alt;
  return `${title} ${index + 1}`;
};
---

{images.length > 0 && (
  <div class="mt-12 pt-8 border-t border-zinc-200/60 dark:border-zinc-800/60">
    <div class="flex items-center gap-2 mb-6">
      <span class="h-px w-6 bg-linear-to-r from-zinc-400 to-transparent dark:from-zinc-600"></span>
      <h2 class="text-xs font-mono tracking-[0.2em] uppercase text-zinc-500 dark:text-zinc-400">
        gallery.log
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {images.map((img, idx) => {
        const src = getSrc(img);
        const alt = getAlt(img, idx);
        const isPrimary = idx === 0;
        return (
          <figure
            class:list={[
              "group relative overflow-hidden border border-zinc-200/70 dark:border-zinc-800/70 bg-zinc-50 dark:bg-zinc-950",
              isPrimary && "md:col-span-2"
            ]}
          >
            <div class="relative aspect-video overflow-hidden">
              <div class="absolute inset-0 bg-zinc-100 dark:bg-zinc-900 animate-pulse" aria-hidden="true" />
              <img
                src={src}
                alt={alt}
                loading="lazy"
                decoding="async"
                class="relative z-10 h-full w-full object-cover transition duration-500 group-hover:scale-[1.02]"
              />
            </div>
            <div class="absolute top-2 left-2 text-[10px] font-mono text-zinc-400 dark:text-zinc-600">
              {String(idx + 1).padStart(2, "0")}
            </div>
          </figure>
        );
      })}
    </div>
  </div>
)}