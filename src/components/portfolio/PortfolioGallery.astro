---
// src/components/portfolio/PortfolioGallery.astro
import { Image } from "astro:assets";
import { cdnImage, isCdnUrl } from "@/lib/utils";

interface ImageItem {
  src: string;
  alt?: string;
}

interface Props {
  images?: (string | ImageItem)[];
  title: string;
}

const { images = [], title } = Astro.props;

const getSrc = (img: string | ImageItem) =>
  typeof img === "object" ? img.src : img;

const getAlt = (img: string | ImageItem, i: number) =>
  typeof img === "object" && img.alt
    ? img.alt
    : `${title} Showcase ${i + 1}`;
---

{images.length > 0 && (
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    {images.map((img, idx) => {
      const src = getSrc(img);
      if (!src) return null;

      const alt = getAlt(img, idx);
      const isPrimary = idx === 0;
      const optimizedSrc = isCdnUrl(src) ? cdnImage(src, { q: 85 }) : src;

      return (
        <figure class={[
          "relative group overflow-hidden",
          isPrimary && "md:col-span-2"
          ].join(' ')}>
            <span class="absolute top-3 left-3 z-10 px-2 py-0.5 rounded-sm bg-(--bg)/60 backdrop-blur-sm text-(--fg)/80 text-overline-10 pointer-events-none">
              {String(idx + 1).padStart(2, "0")}
            </span>
            <div class="absolute inset-0 bg-(--prose-image-bg) animate-pulse rounded-xl"></div>
            <Image
              src={optimizedSrc}
              alt={alt}
              width={1200}
              height={630}
              loading={idx === 0 ? "eager" : "lazy"}
              decoding="async"
              class="w-full h-full object-cover border border-(--prose-image-border)"
            />
        </figure>
      );
    })}
  </div>
)}