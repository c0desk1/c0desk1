---
// src/components/portfolio/PortfolioGallery.astro

interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

{images.length > 0 && (
  <div class="mt-10 pt-6 border-t border-zinc-100 dark:border-zinc-800">
    <div class="flex items-center gap-2 mb-4">
      <div class="h-px w-6 bg-linear-to-r from-zinc-300 to-transparent"></div>
      <h3 class="text-sm font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
        Gallery
      </h3>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {images.map((img, idx) => (
        <img 
          src={img}
          alt={`${title} screenshot ${idx + 1}`}
          class="border border-zinc-200 dark:border-zinc-800"
          loading="lazy"
        />
      ))}
    </div>
  </div>
)}