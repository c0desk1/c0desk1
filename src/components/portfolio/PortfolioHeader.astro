---
// src/components/portfolio/PortfolioHeader.astro
import { formatDate } from "@/lib/utils";

interface Props {
  title: string;
  date: Date;
  updatedDate?: Date;
  featured?: boolean;
  client?: string;
  role?: string;
  duration?: string;
  techStack?: string[];
  demoUrl?: string;
  repoUrl?: string;
}

const {
  title,
  date,
  updatedDate,
  featured,
  client,
  role,
  duration,
  techStack = [],
  demoUrl,
  repoUrl
} = Astro.props;

const formattedDate = date ? formatDate(date) : "";
const formattedUpdate = updatedDate ? formatDate(updatedDate) : null;
---

<header class="space-y-8">
  <div class="space-y-3 text-center">
    <h1 class="prose-custom
      text-3xl sm:text-4xl md:text-5xl
      font-semibold tracking-tight
      text-(--prose-black) dark:text-(--prose-white)
      leading-[1.15]
      text-balance
      mb-6 md:mb-8">
      {title}
    </h1>
    <div class="flex flex-wrap justify-center items-center gap-3 text-sm md:text-[13px] text-(--fg-muted)">
      <time datetime={date.toISOString()}>
        {formattedDate}
      </time>
      {formattedUpdate && (
        <>
          <span class="text-(--fg-subtle)" aria-hidden="true">/</span>
          <span>Diperbarui {formattedUpdate}</span>
        </>
      )}
      {featured && (
        <>
          <span class="text-(--fg-subtle)" aria-hidden="true">/</span>
          <span class="text-(--accent) font-medium">Unggulan</span>
        </>
      )}
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm md:text-[13px] border border-(--border) rounded-(--radius-md) p-4 bg-(--bg-subtle)">
    <div class="space-y-1">
      <div class="text-[12px] uppercase tracking-wider text-(--fg-subtle) font-mono">Client</div>
      <div class="text-(--fg-muted) font-medium">
        {client || "-"}
      </div>
    </div>
    <div class="space-y-1">
      <div class="text-[12px] uppercase tracking-wider text-(--fg-subtle) font-mono">Role</div>
      <div class="text-(--fg-muted) font-medium">
        {role || "-"}
      </div>
    </div>
    <div class="space-y-1">
      <div class="text-[12px] uppercase tracking-wider text-(--fg-subtle) font-mono">Duration</div>
      <div class="text-(--fg-muted) font-medium">
        {duration || "-"}
      </div>
    </div>
  </div>

  {(demoUrl || repoUrl) && (
    <div class="flex flex-wrap justify-center gap-4 text-sm md:text-[13px]">
      {demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-(--radius-md) border border-(--border) hover:border-(--border-strong) bg-(--bg) focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
        >
          Live Demo
        </a>
      )}
      {repoUrl && (
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-(--radius-md) border border-(--border) hover:border-(--border-strong) bg-(--bg-subtle) focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
        >
          Source Code
        </a>
      )}
    </div>
  )}

  {techStack.length > 0 && (
    <div class="space-y-3">
      <div class="text-xs md:text-sm uppercase tracking-wider text-(--fg) font-mono text-center">
        Tech Stack
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        {techStack.map((tech: string) => (
          <span class="text-xs px-2.5 py-1 rounded-(--radius-md) border border-(--border) text-(--fg-subtle) bg-(--bg-subtle)">
            {tech}
          </span>
        ))}
      </div>
    </div>
  )}
</header>