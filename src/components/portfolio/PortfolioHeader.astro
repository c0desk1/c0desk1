---
// src/components/portfolio/PortfolioHeader.astro
import { formatDate } from "@/lib/utils";

interface Props {
  title: string;
  date: Date;
  updatedDate?: Date;
  featured?: boolean;
  client?: string;
  role?: string;
  duration?: string;
  techStack?: string[];
  demoUrl?: string;
  repoUrl?: string;
}

const {
  title,
  date,
  updatedDate,
  featured,
  client,
  role,
  duration,
  techStack = [],
  demoUrl,
  repoUrl
} = Astro.props;

const formattedDate = date ? formatDate(date) : "";
const formattedUpdate = updatedDate ? formatDate(updatedDate) : null;
---

<header class="space-y-8">
  <div class="space-y-3 text-center">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-white leading-tight">
      {title}
    </h1>
    <div class="flex flex-wrap justify-center items-center gap-3 text-sm text-zinc-500 dark:text-zinc-400">
      <time datetime={date.toISOString()}>
        {formattedDate}
      </time>
      {formattedUpdate && (
        <>
          <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">/</span>
          <span>Diperbarui {formattedUpdate}</span>
        </>
      )}
      {featured && (
        <>
          <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">/</span>
          <span class="text-emerald-600 font-medium">Unggulan</span>
        </>
      )}
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm border border-zinc-200 dark:border-zinc-800 rounded-lg p-4 bg-zinc-50/50 dark:bg-zinc-900/20">
    <div class="space-y-1">
      <div class="text-[11px] uppercase tracking-wider text-zinc-400 font-mono">Client</div>
      <div class="text-zinc-700 dark:text-zinc-300 font-medium">
        {client || "-"}
      </div>
    </div>
    <div class="space-y-1">
      <div class="text-[11px] uppercase tracking-wider text-zinc-400 font-mono">Role</div>
      <div class="text-zinc-700 dark:text-zinc-300 font-medium">
        {role || "-"}
      </div>
    </div>
    <div class="space-y-1">
      <div class="text-[11px] uppercase tracking-wider text-zinc-400 font-mono">Duration</div>
      <div class="text-zinc-700 dark:text-zinc-300 font-medium">
        {duration || "-"}
      </div>
    </div>
  </div>

  {(demoUrl || repoUrl) && (
    <div class="flex flex-wrap justify-center gap-4 text-sm">
      {demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-md border border-zinc-200 dark:border-zinc-800 hover:border-emerald-500 dark:hover:border-emerald-500 transition-colors duration-200 bg-white dark:bg-black"
        >
          Live Demo
        </a>
      )}
      {repoUrl && (
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-md border border-zinc-200 dark:border-zinc-800 hover:border-zinc-900 dark:hover:border-white transition-colors duration-200 bg-white dark:bg-black"
        >
          Source Code
        </a>
      )}
    </div>
  )}

  {techStack.length > 0 && (
    <div class="space-y-3">
      <div class="text-[11px] uppercase tracking-wider text-zinc-400 font-mono text-center">
        Tech Stack
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        {techStack.map((tech: string) => (
          <span class="text-xs px-2.5 py-1 border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400 bg-zinc-50 dark:bg-zinc-900/50">
            {tech}
          </span>
        ))}
      </div>
    </div>
  )}
</header>