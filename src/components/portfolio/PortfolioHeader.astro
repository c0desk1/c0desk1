---
// src/components/portfolio/PortfolioHeader.astro
import { formatDate } from "@/lib/utils";
import { getCurrentLocale, getLabel } from '@/utils/i18n';

interface Props {
  title: string;
  date: Date;
  updatedDate?: Date;
  featured?: boolean;
  client?: string;
  role?: string;
  duration?: string;
  techStack?: string[];
  demoUrl?: string;
  repoUrl?: string;
}

const {
  title,
  date,
  updatedDate,
  featured,
  client,
  role,
  duration,
  techStack = [],
  demoUrl,
  repoUrl
} = Astro.props;

const locale = getCurrentLocale(Astro);

const updated_l = getLabel(locale, 'p_updated');
const featured_l = getLabel(locale, 'p_featured');
const client_l = getLabel(locale, 'p_client');
const role_l = getLabel(locale, 'p_role');
const duration_l = getLabel(locale, 'p_duration');
const liveDemo_l = getLabel(locale, 'p_liveDemo');
const sourceCode_l = getLabel(locale, 'p_sourceCode');
const techStack_l = getLabel(locale, 'p_techStack');

const dateLocale = locale === 'en'? 'en-US' : locale === 'ru'? 'ru-RU' : 'id-ID';

const formattedDate = date? formatDate(date, dateLocale) : "";
const formattedUpdate = updatedDate? formatDate(updatedDate, dateLocale) : null;
---

<header class="space-y-8 my-8 gap-4">
  <div class="space-y-3 text-center">
    <div class="prose-custom mb-6 md:mb-8">
      <h1>
        {title}
      </h1>
    </div>
    <div class="flex flex-wrap justify-center items-center gap-3 text-sm md:text-[13px] text-(--fg-muted) mb-6 md:mb-8">
      <time datetime={date.toISOString()}>
        {formattedDate}
      </time>
      {formattedUpdate && (
        <>
          <span class="text-(--fg-subtle)" aria-hidden="true">/</span>
          <span>{updated_l} {formattedUpdate}</span>
        </>
      )}
      {featured && (
        <>
          <span class="text-(--fg-subtle)" aria-hidden="true">/</span>
          <span class="text-(--accent) font-medium">{featured_l}</span>
        </>
      )}
    </div>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm md:text-[13px] border border-(--border) rounded-(--radius-md) p-4 bg-(--bg-subtle) mb-6 md:mb-8">
    <div class="space-y-1">
      <div class="text-[12px] uppercase tracking-wider text-(--fg-subtle) font-mono">{client_l}</div>
      <div class="text-(--fg-muted) font-medium">
        {client || "-"}
      </div>
    </div>
    <div class="space-y-1">
      <div class="text-[12px] uppercase tracking-wider text-(--fg-subtle) font-mono">{role_l}</div>
      <div class="text-(--fg-muted) font-medium">
        {role || "-"}
      </div>
    </div>
    <div class="space-y-1">
      <div class="text-[12px] uppercase tracking-wider text-(--fg-subtle) font-mono">{duration_l}</div>
      <div class="text-(--fg-muted) font-medium">
        {duration || "-"}
      </div>
    </div>
  </div>

  {(demoUrl || repoUrl) && (
    <div class="flex flex-wrap justify-center gap-4 text-sm md:text-[13px] mb-6 md:mb-8">
      {demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-(--radius-md) border border-(--border) hover:border-(--border-strong) bg-(--bg) focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
        >
          {liveDemo_l}
        </a>
      )}
      {repoUrl && (
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-(--radius-md) border border-(--border) hover:border-(--border-strong) bg-(--bg-subtle) focus:outline-none focus:ring-2 focus:ring-(--border-strong)"
        >
          {sourceCode_l}
        </a>
      )}
    </div>
  )}

  {techStack.length > 0 && (
    <div class="space-y-3">
      <div class="text-xs md:text-sm uppercase tracking-wider text-(--fg) font-mono text-center">
        {techStack_l}
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        {techStack.map((tech: string) => (
          <span class="text-xs px-2.5 py-1 rounded-(--radius-md) border border-(--border) text-(--fg-subtle) bg-(--bg-subtle)">
            {tech}
          </span>
        ))}
      </div>
    </div>
  )}
</header>