---
// src/components/portfolio/PortfolioHeader.astro

import { siteConfig } from "@/config/site";
import { formatDate } from "@/lib/utils";

interface Props {
  title       : string;
  date        : Date;
  updatedDate?: Date;
  featured?   : boolean;
  client?     : string;
  role?       : string;
  duration?   : string;
  techStack?  : string[];
  demoUrl?    : string;
  repoUrl?    : string;
}

const {
  title,
  date,
  updatedDate,
  featured,
  client,
  role,
  duration,
  techStack = [],
  demoUrl,
  repoUrl,
} = Astro.props;

const t = {
  updated:    siteConfig.p_updated,
  featured:   siteConfig.p_featured,
  client:     siteConfig.p_client,
  role:       siteConfig.p_role,
  duration:   siteConfig.p_duration,
  liveDemo:   siteConfig.p_liveDemo,
  sourceCode: siteConfig.p_sourceCode,
  techStack:  siteConfig.p_techStack,
};

const formattedDate   = date ? formatDate(date) : "";
const formattedUpdate = updatedDate ? formatDate(updatedDate) : null;

const infoItems = [
  { label: t.client, value: client },
  { label: t.role, value: role },
  { label: t.duration, value: duration },
].filter((item) => item.value);
---

<header class="relative w-full">

  <!-- Top -->
  <div class="mx-auto flex max-w-5xl flex-col items-center text-center">

    <!-- Eyebrow -->
    <div class="mb-5 flex flex-wrap items-center justify-center gap-2 text-label-12 text-(--fg-subtle)">

      <time datetime={date.toISOString()}>
        {formattedDate}
      </time>

      {formattedUpdate && (
        <>
          <span class="h-[3px] w-[3px] rounded-full bg-(--fg-subtle)" aria-hidden="true" />
          <span>{t.updated} {formattedUpdate}</span>
        </>
      )}

      {featured && (
        <>
          <span class="h-[3px] w-[3px] rounded-full bg-(--fg-subtle)" aria-hidden="true" />
          <span class="text-(--accent)">
            {t.featured}
          </span>
        </>
      )}
    </div>

    <!-- Title -->
    <h1 class="max-w-4xl text-heading-32 md:text-heading-48 lg:text-heading-64 text-balance text-(--fg)">
      {title}
    </h1>

    <!-- Meta Grid -->
    {infoItems.length > 0 && (
      <div class="mt-10 grid w-full max-w-3xl grid-cols-1 gap-px overflow-hidden rounded-2xl border border-(--border) bg-(--border) sm:grid-cols-3">

        {infoItems.map(({ label, value }) => (
          <div class="flex flex-col gap-2 bg-(--bg) px-6 py-5 text-left">

            <span class="text-label-12-mono uppercase text-(--fg-subtle)">
              {label}
            </span>

            <span class="text-label-16 text-(--fg)">
              {value}
            </span>

          </div>
        ))}

      </div>
    )}

    <!-- Actions -->
    {(demoUrl || repoUrl) && (
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">

        {demoUrl && (
          <a
            href={demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-(--border) bg-(--bg-muted) px-4 py-2 text-button-14 text-(--fg) transition-colors hover:border-(--border-strong) hover:bg-(--bg-subtle)"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <circle cx="8" cy="8" r="6"/>
              <path d="M8 2c-2 2-2 10 0 12M8 2c2 2 2 10 0 12M2 8h12"/>
            </svg>

            <span>{t.liveDemo}</span>
          </a>
        )}

        {repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-(--border) bg-(--bg-muted) px-4 py-2 text-button-14 text-(--fg) transition-colors hover:border-(--border-strong) hover:bg-(--bg-subtle)"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path d="M6 2h3l3 3v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1Z"/>
              <path d="M9 2v3h3"/>
              <line x1="8" y1="8" x2="8" y2="12"/>
              <line x1="6" y1="10" x2="10" y2="10"/>
            </svg>

            <span>{t.sourceCode}</span>
          </a>
        )}

      </div>
    )}

    <!-- Tech Stack -->
    {techStack.length > 0 && (
      <div class="mt-12 flex max-w-4xl flex-col items-center gap-4">

        <span class="text-label-12-mono uppercase text-(--fg-subtle)">
          {t.techStack}
        </span>

        <div class="flex flex-wrap items-center justify-center gap-2">

          {techStack.map((tech) => (
            <span class="inline-flex items-center rounded-full border border-(--border) bg-(--bg-muted) px-3 py-1.5 text-label-13-mono text-(--fg-muted)">
              {tech}
            </span>
          ))}

        </div>
      </div>
    )}

  </div>
</header>