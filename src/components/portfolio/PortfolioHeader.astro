---
// src/components/portfolio/PortfolioHeader.astro
import { formatDateCompact } from '@/lib/utils';

interface Props {
  title: string;
  date: Date;
  updatedDate?: Date;
  featured?: boolean;
  client?: string;
  role?: string;
  duration?: string;
  techStack?: string[];
  demoUrl?: string;
  repoUrl?: string;
}

const {
  title,
  date,
  updatedDate,
  featured,
  client,
  role,
  duration,
  techStack,
  demoUrl,
  repoUrl
} = Astro.props;

const formattedDate = formatDateCompact(date);
const formattedUpdateDate = updatedDate ? formatDateCompact(updatedDate) : undefined;
---

<header class="space-y-4">

  <!-- TITLE -->
  <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-white leading-tight">
    {title}
  </h1>

  <!-- META -->
  <div class="flex flex-wrap items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400">

    <span class="font-mono text-emerald-600 dark:text-emerald-500 font-semibold">
      $
    </span>

    <time class="font-mono" datetime={date.toISOString()}>
      {formattedDate}
    </time>

    {updatedDate && (
      <>
        <span class="text-zinc-300 dark:text-zinc-700">•</span>
        <span class="text-xs">diperbarui</span>
        <time class="font-mono">
          {formattedUpdateDate}
        </time>
      </>
    )}

    {featured && (
      <>
        <span class="text-zinc-300 dark:text-zinc-700">•</span>
        <span class="text-amber-600 dark:text-amber-500 text-xs">
          ▼
        </span>
      </>
    )}

  </div>

  <!-- CLIENT / ROLE -->
  {(client || role || duration) && (
    <div class="flex flex-wrap items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400">

      {client && (
        <span>{client}</span>
      )}

      {client && role && (
        <span class="text-zinc-300 dark:text-zinc-700">/</span>
      )}

      {role && (
        <span>{role}</span>
      )}

      {duration && (
        <>
          <span class="text-zinc-300 dark:text-zinc-700">/</span>
          <span>[{duration}]</span>
        </>
      )}

    </div>
  )}

  <!-- LINKS -->
  {(demoUrl || repoUrl) && (
    <div class="flex flex-wrap gap-4 pt-1 text-sm">

      {demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors"
        >
          Live →
        </a>
      )}

      {repoUrl && (
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors"
        >
          Code →
        </a>
      )}

    </div>
  )}

  <!-- TECH STACK -->
  {techStack && techStack.length > 0 && (
    <div class="flex flex-wrap gap-1.5 pt-1">

      {techStack.map(tech => (
        <span class="px-2 py-1 text-xs border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-400">
          {tech}
        </span>
      ))}

    </div>
  )}

  <!-- DIVIDER -->
  <div class="pt-2">
    <div class="h-px w-8 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
  </div>

</header>