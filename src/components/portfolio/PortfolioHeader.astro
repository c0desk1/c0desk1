---
// src/components/portfolio/PortfolioHeader.astro
import { formatDateCompact } from '@/lib/utils';

interface Props {
  title: string;
  date: Date;
  updatedDate?: Date;
  featured?: boolean;
  client?: string;
  role?: string;
  duration?: string;
  techStack?: string[];
  demoUrl?: string;
  repoUrl?: string;
  author?: {
    name: string;
    avatar?: string;
    title?: string;
  };
}

const { title, date, updatedDate, featured, client, role, duration, techStack, demoUrl, repoUrl, author } = Astro.props;

const formattedDate = formatDateCompact(date);
const formattedUpdateDate = updatedDate ? formatDateCompact(updatedDate) : undefined;
---

<header class="space-y-3">
  <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-zinc-900 dark:text-white leading-tight">
    {title}
  </h1>
  {(client || role) && (
    <div class="flex flex-wrap items-center gap-3 text-sm text-zinc-500 dark:text-zinc-400">
      {client && (
        <div class="flex items-center gap-1.5">
          <span class="text-zinc-400 dark:text-zinc-500">Client</span>
          <span class="text-zinc-900 dark:text-white">{client}</span>
        </div>
      )}
      {client && role && <span class="text-zinc-300 dark:text-zinc-700">/</span>}
      {role && (
        <div class="flex items-center gap-1.5">
          <span class="text-zinc-400 dark:text-zinc-500">Role</span>
          <span class="text-zinc-900 dark:text-white">{role}</span>
        </div>
      )}
      {duration && (
        <>
          <span class="text-zinc-300 dark:text-zinc-700">/</span>
          <span>[{duration}]</span>
        </>
      )}
    </div>
  )}

  <div class="flex flex-wrap items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400">
    <span class="text-emerald-600 dark:text-emerald-500 font-bold shrink-0">▲</span>
    <time class="font-mono" datetime={date.toISOString()}>{formattedDate}</time>
    {updatedDate && (
      <>
        <span class="text-zinc-300 dark:text-zinc-700">/</span>
        <span>Updated</span>
        <time class="font-mono" datetime={updatedDate.toISOString()}>{formattedUpdateDate}</time>
      </>
    )}
    {featured && (
      <>
        <span class="text-zinc-300 dark:text-zinc-700">/</span>
        <span class="text-amber-600 dark:text-amber-500">[Featured]</span>
      </>
    )}
  </div>

  <div class="flex flex-wrap items-center gap-2 pt-2">
    {demoUrl && (
      <a 
        href={demoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors"
      >
        <span>[Live</span>
        <span class="group-hover:translate-x-0.5 transition-transform duration-150">→</span>
        <span>]</span>
      </a>
    )}
    {repoUrl && (
      <a 
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors"
      >
        <span>[Code</span>
        <span class="group-hover:translate-x-0.5 transition-transform duration-150">→</span>
        <span>]</span>
      </a>
    )}
  </div>

  {techStack && techStack.length > 0 && (
    <div class="flex flex-wrap gap-1.5 pt-1">
      {techStack.map(tech => (
        <span 
          class="px-2 py-1 text-xs bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300 font-medium"
        >
          {tech}
        </span>
      ))}
    </div>
  )}
  
  <div class="pt-2">
    <div class="h-px w-8 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700"></div>
  </div>
</header>