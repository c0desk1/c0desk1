---
// src/components/portfolio/PortfolioHeader.astro
import { siteConfig } from "@/config/site";
import { formatDate } from "@/lib/utils";
import Icon from "../ui/Icon";

interface Props {
  title       : string;
  date        : Date;
  updatedDate?: Date;
  featured?   : boolean;
  client?     : string;
  role?       : string;
  duration?   : string;
  techStack?  : string[];
  demoUrl?    : string;
  repoUrl?    : string;
}

const {
  title,
  date,
  updatedDate,
  featured,
  client,
  role,
  duration,
  techStack = [],
  demoUrl,
  repoUrl,
} = Astro.props;

const t = {
  updated:    siteConfig.p_updated,
  featured:   siteConfig.p_featured,
  client:     siteConfig.p_client,
  role:       siteConfig.p_role,
  duration:   siteConfig.p_duration,
  liveDemo:   siteConfig.p_liveDemo,
  sourceCode: siteConfig.p_sourceCode,
  techStack:  siteConfig.p_techStack,
};

const formattedDate   = formatDate(date);
const formattedUpdate = updatedDate ? formatDate(updatedDate) : null;

const infoItems = [
  { label: t.client, value: client },
  { label: t.role, value: role },
  { label: t.duration, value: duration },
].filter((item) => item.value);
---

<header class="relative border-b border-(--border) bg-(--bg) py-12 md:py-16 lg:py-20">
  <div class="px-4 text-center">
    <div class="mb-6 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-copy-14 text-subtle">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {formattedUpdate && (
        <>
          <span class="h-1.5 w-1.5 rounded-full bg-muted" />
          <span>{t.updated} {formattedUpdate}</span>
        </>
      )}
      {featured && (
        <>
          <span class="h-1.5 w-1.5 rounded-full bg-muted" />
          <span class="text-accent">{t.featured}</span>
        </>
      )}
    </div>
    <h1 class="text-heading-24 md:text-heading32 lg:text-heading-48 font-semibold text-(--fg)">
      {title}
    </h1>
    {infoItems.length > 0 && (
      <div class="mt-6 flex flex-wrap justify-center gap-x-6 gap-y-2">
        {infoItems.map(({ label, value }) => (
          <div class="flex items-baseline gap-1 text-sm">
            <span class="text-label-mono-14 uppercase text-subtle">{label}:</span>
            <span class="text-label-14 font-medium text-(--fg)">{value}</span>
          </div>
        ))}
      </div>
    )}
    {(demoUrl || repoUrl) && (
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        {demoUrl && (
          <a
            href={demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-(--fg) px-5 py-2.5 text-sm font-medium text-(--bg) transition hover:bg-(--fg-muted) focus:outline-none focus:ring-2 focus:ring-accent"
          >
            <Icon name="globe" />
            {t.liveDemo}
          </a>
        )}
        {repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-(--border) bg-transparent px-5 py-2.5 text-sm font-medium text-muted transition hover:border-strong hover:bg-subtle hover:text-(--fg)"
          >
            <Icon name="code" />
            {t.sourceCode}
          </a>
        )}
      </div>
    )}
    {techStack.length > 0 && (
      <div class="mt-10 flex flex-wrap justify-center gap-2 border-t border-(--border) pt-8">
        {techStack.map((tech) => (
          <span class="rounded-full bg-muted px-3 py-1 text-code-14 text-muted">
            {tech}
          </span>
        ))}
      </div>
    )}
  </div>
</header>