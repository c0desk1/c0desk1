---
// src/components/portfolio/PortfolioHeader.astro
import { formatDate } from "@/lib/utils";
import { getCurrentLocale, getLabel } from "@/utils/i18n";

interface Props {
  title       : string;
  date        : Date;
  updatedDate?: Date;
  featured?   : boolean;
  client?     : string;
  role?       : string;
  duration?   : string;
  techStack?  : string[];
  demoUrl?    : string;
  repoUrl?    : string;
}

const {
  title,
  date,
  updatedDate,
  featured,
  client,
  role,
  duration,
  techStack = [],
  demoUrl,
  repoUrl,
} = Astro.props;

const locale = getCurrentLocale(Astro);

const t = {
  updated:    getLabel(locale, "p_updated"),
  featured:   getLabel(locale, "p_featured"),
  client:     getLabel(locale, "p_client"),
  role:       getLabel(locale, "p_role"),
  duration:   getLabel(locale, "p_duration"),
  liveDemo:   getLabel(locale, "p_liveDemo"),
  sourceCode: getLabel(locale, "p_sourceCode"),
  techStack:  getLabel(locale, "p_techStack"),
};

const dateLocale =
  locale === "en" ? "en-US" :
  locale === "ru" ? "ru-RU" :
  locale === "jp" ? "ja-JP" :
  "id-ID";

const formattedDate   = date        ? formatDate(date,        dateLocale) : "";
const formattedUpdate = updatedDate ? formatDate(updatedDate, dateLocale) : null;
---

<header class="ph-root">

  <!-- Title + date -->
  <div class="ph-top">
    <h1 class="ph-title">{title}</h1>

    <div class="ph-meta">
      <time datetime={date.toISOString()}>{formattedDate}</time>

      {formattedUpdate && (
        <>
          <span class="ph-dot" aria-hidden="true"></span>
          <span>{t.updated} {formattedUpdate}</span>
        </>
      )}

      {featured && (
        <>
          <span class="ph-dot" aria-hidden="true"></span>
          <span class="ph-featured">{t.featured}</span>
        </>
      )}
    </div>
  </div>

  <!-- Project meta: client / role / duration -->
  <div class="ph-info">
    {[
      { label: t.client,   value: client   },
      { label: t.role,     value: role     },
      { label: t.duration, value: duration },
    ].map(({ label, value }) => (
      <div class="ph-info-item">
        <span class="ph-info-label">{label}</span>
        <span class="ph-info-value">{value || "—"}</span>
      </div>
    ))}
  </div>

  <!-- Links -->
  {(demoUrl || repoUrl) && (
    <div class="ph-links">
      {demoUrl && (
        <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="ph-link">
          <!-- External / globe icon -->
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
            stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="8" cy="8" r="6"/>
            <path d="M8 2c-2 2-2 10 0 12M8 2c2 2 2 10 0 12M2 8h12"/>
          </svg>
          <span>{t.liveDemo}</span>
        </a>
      )}
      {repoUrl && (
        <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="ph-link">
          <!-- Code / repo icon -->
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"
            stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M6 2h3l3 3v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1Z"/>
            <path d="M9 2v3h3"/>
            <line x1="8" y1="8" x2="8" y2="12"/>
            <line x1="6" y1="10" x2="10" y2="10"/>
          </svg>
          <span>{t.sourceCode}</span>
        </a>
      )}
    </div>
  )}

  <!-- Tech stack -->
  {techStack.length > 0 && (
    <div class="ph-stack">
      <span class="ph-stack-label">{t.techStack}</span>
      <div class="ph-stack-tags">
        {techStack.map((tech: string) => (
          <span class="ph-tag">{tech}</span>
        ))}
      </div>
    </div>
  )}

</header>

<style>
  /* ─── ROOT ────────────────────────────────────────────────────── */
  .ph-root {
    width: 100%;
    max-width: 48rem;
    margin-inline: auto;
    padding-top: 5rem;
    padding-bottom: 4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  /* ─── TOP: title + meta ───────────────────────────────────────── */
  .ph-top {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .ph-title {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--fg);
    margin: 0;
    text-wrap: balance;
  }

  @media (min-width: 640px)  { .ph-title { font-size: 3rem; } }
  @media (min-width: 1024px) { .ph-title { font-size: 3.5rem; } }

  .ph-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--fg-muted);
    letter-spacing: -0.005em;
  }

  .ph-dot {
    width: 0.1875rem;
    height: 0.1875rem;
    border-radius: var(--radius-full);
    background-color: var(--fg-subtle);
    flex-shrink: 0;
  }

  .ph-featured {
    font-weight: 600;
    color: var(--accent);
  }

  /* ─── PROJECT INFO ────────────────────────────────────────────── */
  .ph-info {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem 3rem;
  }

  .ph-info-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }

  .ph-info-label {
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    font-family: var(--font-mono);
  }

  .ph-info-value {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  /* ─── LINKS ───────────────────────────────────────────────────── */
  .ph-links {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .ph-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--fg-muted);
    text-decoration: none;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
    letter-spacing: -0.005em;
  }

  .ph-link:hover {
    color: var(--fg);
    border-color: var(--border-strong);
    background-color: var(--bg-muted);
  }

  .ph-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ─── TECH STACK ──────────────────────────────────────────────── */
  .ph-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .ph-stack-label {
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    font-family: var(--font-mono);
  }

  .ph-stack-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.375rem;
  }

  .ph-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--fg-muted);
    letter-spacing: 0;
    font-family: var(--font-mono);
  }
</style>