---
// src/components/portfolio/ProjectCard.astro

import type { CollectionEntry } from 'astro:content';
import { formatDateCompact } from '@/lib/utils';

interface Props {
  project: CollectionEntry<'portfolio'>;
  variant?: 'default' | 'compact';
  showTechStack?: boolean;
}

const { project, variant = 'default', showTechStack = true } = Astro.props;
const { data, id } = project;
const { 
  title, 
  description, 
  techStack, 
  demoUrl, 
  repoUrl, 
  image, 
  imageAlt,
  date,
  featured,
  client,
  role
} = data;

const formattedDate = formatDateCompact(date);
const displayImage = typeof image === 'string' ? image : null;
const detailUrl = `/portfolio/${id}`;

const isCompact = variant === 'compact';
---

<article class="group relative h-full">
  <div class="block border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 transition-all duration-200 hover:border-zinc-300 dark:hover:border-zinc-700">
    <div class="flex gap-4 p-4 md:p-5">
      
      {/* Image - Left side */}
      {displayImage && (
        <a 
          href={detailUrl}
          class="shrink-0 w-20 h-20 md:w-24 md:h-24 overflow-hidden bg-zinc-100 dark:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-600"
          aria-label={`View project: ${title}`}
        >
          <img 
            src={displayImage}
            alt={imageAlt || title}
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
        </a>
      )}
      
      {/* Content - Right side */}
      <div class="flex-1 min-w-0">
        
        {/* Meta info */}
        <div class="flex items-center gap-1.5 font-mono text-[11px] md:text-xs tracking-wide text-zinc-500 dark:text-zinc-400 mb-1.5">
          <span class="text-emerald-500 dark:text-emerald-400 font-bold" aria-hidden="true">$</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">/</span>
          <div class="flex items-center gap-0.5">
            <span aria-hidden="true">[</span>
            <span>work</span>
            <span aria-hidden="true">]</span>
          </div>
          {featured && (
            <>
              <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">/</span>
              <span class="text-amber-500" aria-label="Featured project">[★]</span>
            </>
          )}
        </div>
        
        {/* Title */}
        <a href={detailUrl} class="block focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-600 rounded-sm">
          <h3 class="font-semibold text-zinc-900 dark:text-white group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors text-base md:text-lg leading-tight mb-1">
            {title}
          </h3>
        </a>
        
        {/* Client & Role */}
        {(client || role) && !isCompact && (
          <div class="flex items-center gap-1.5 mb-2 font-mono text-[10px] md:text-[11px] text-zinc-400 dark:text-zinc-500">
            {client && <span class="text-zinc-500 dark:text-zinc-400">{client}</span>}
            {client && role && <span aria-hidden="true">/</span>}
            {role && <span>{role}</span>}
          </div>
        )}
        
        {/* Description */}
        <a href={detailUrl} class="block">
          <p class="text-xs md:text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed line-clamp-2 mb-2">
            {description}
          </p>
        </a>
        
        {/* Tech Stack */}
        {showTechStack && techStack && techStack.length > 0 && !isCompact && (
          <div class="flex flex-wrap gap-1.5 mb-3">
            {techStack.slice(0, 3).map(tech => (
              <span 
                class="px-1.5 py-0.5 text-[10px] md:text-[11px] font-mono border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-400"
              >
                {tech}
              </span>
            ))}
            {techStack.length > 3 && (
              <span class="px-1.5 py-0.5 text-[10px] md:text-[11px] font-mono text-zinc-400 dark:text-zinc-500">
                +{techStack.length - 3}
              </span>
            )}
          </div>
        )}
        
        {/* Links - External */}
        <div class="flex items-center gap-4 pt-1">
          {demoUrl && (
            <a 
              href={demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group/link inline-flex items-center gap-1 text-[11px] md:text-xs font-mono text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-600"
              aria-label="Live demo"
            >
              <span aria-hidden="true">[</span>
              <span>live</span>
              <span class="group-hover/link:translate-x-0.5 transition-transform duration-150" aria-hidden="true">→</span>
              <span aria-hidden="true">]</span>
            </a>
          )}
          
          {repoUrl && (
            <a 
              href={repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group/link inline-flex items-center gap-1 text-[11px] md:text-xs font-mono text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-600"
              aria-label="Source code"
            >
              <span aria-hidden="true">[</span>
              <span>code</span>
              <span class="group-hover/link:translate-x-0.5 transition-transform duration-150" aria-hidden="true">→</span>
              <span aria-hidden="true">]</span>
            </a>
          )}
        </div>
        
        {/* Industrial hover line */}
        <div class="mt-3 h-px w-0 bg-linear-to-r from-zinc-300 to-transparent dark:from-zinc-700 group-hover:w-full transition-all duration-300"></div>
        
      </div>
      
      {/* Arrow indicator */}
      <a 
        href={detailUrl}
        class="hidden sm:flex shrink-0 items-center text-zinc-400 dark:text-zinc-600 group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-all duration-200 group-hover:translate-x-0.5 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-600"
        aria-label={`View project: ${title}`}
      >
        <span class="text-sm" aria-hidden="true">→</span>
      </a>
      
    </div>
  </div>
</article>