---
// src/components/portfolio/ProjectCard.astro

import type { CollectionEntry } from 'astro:content';
import { formatDateCompact } from '@/lib/utils';

interface Props {
  project: CollectionEntry<'portfolio'>;
}

const { project } = Astro.props;
const { data, id } = project;
const { title, description, date, featured } = data;

const formattedDate = formatDateCompact(date);
---

<a 
  href={`/portfolio/${id}`} 
  class="group block py-4 transition-colors duration-200 hover:border-zinc-300 dark:hover:border-zinc-700"
  aria-label={`View project: ${title}`}
>
  <div class="flex items-center gap-2 text-xs text-zinc-500 dark:text-zinc-400 mb-1.5">
    <span class="font-mono font-semibold text-emerald-600 dark:text-emerald-500" aria-hidden="true">$</span>
    <time class="font-mono" datetime={date.toISOString()}>{formattedDate}</time>
    {featured && (
      <>
        <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">/</span>
        <span class="text-amber-600 dark:text-amber-500" aria-label="Featured project">★</span>
      </>
    )}
  </div>
  <h3 class="font-semibold text-zinc-900 dark:text-white group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-colors text-base md:text-lg leading-tight mb-1.5">
    {title}
  </h3>
  <p class="text-sm md:text-base text-zinc-600 dark:text-zinc-400 leading-relaxed line-clamp-2">
    {description}
  </p>
</a>