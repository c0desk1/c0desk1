---
// src/components/portfolio/PortfolioMetrics.astro
import Container from '../ui/Container.astro';

interface Props {
  metrics?: {
    performance?: number;
    accessibility?: number;
    seo?: number;
  };
}

const { metrics } = Astro.props;
---

{metrics && (
  <div class="border-b border-zinc-100 dark:border-zinc-900">
    <Container size="md" class="py-6 md:py-8">
      <div class="flex flex-wrap justify-center gap-8 md:gap-12">
        
        {metrics.performance !== undefined && (
          <div class="text-center">
            <div class="flex items-baseline justify-center gap-0.5">
              <span class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white tabular-nums">
                {metrics.performance}
              </span>
              <span class="text-sm text-zinc-400 dark:text-zinc-500">%</span>
            </div>
            <div class="flex items-center gap-1.5 mt-1.5">
              <div class="w-1 h-1 rounded-full bg-emerald-500"></div>
              <span class="text-[10px] md:text-[11px] font-mono text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">
                Performance
              </span>
            </div>
          </div>
        )}
        
        {metrics.accessibility !== undefined && (
          <div class="text-center">
            <div class="flex items-baseline justify-center gap-0.5">
              <span class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white tabular-nums">
                {metrics.accessibility}
              </span>
              <span class="text-sm text-zinc-400 dark:text-zinc-500">%</span>
            </div>
            <div class="flex items-center gap-1.5 mt-1.5">
              <div class="w-1 h-1 rounded-full bg-emerald-500"></div>
              <span class="text-[10px] md:text-[11px] font-mono text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">
                Accessibility
              </span>
            </div>
          </div>
        )}
        
        {metrics.seo !== undefined && (
          <div class="text-center">
            <div class="flex items-baseline justify-center gap-0.5">
              <span class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white tabular-nums">
                {metrics.seo}
              </span>
              <span class="text-sm text-zinc-400 dark:text-zinc-500">%</span>
            </div>
            <div class="flex items-center gap-1.5 mt-1.5">
              <div class="w-1 h-1 rounded-full bg-emerald-500"></div>
              <span class="text-[10px] md:text-[11px] font-mono text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">
                SEO
              </span>
            </div>
          </div>
        )}
        
      </div>
    </Container>
  </div>
)}