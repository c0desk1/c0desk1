---
// src/components/portfolio/PortfolioMetrics.astro
import Container from "../ui/Container.astro";
import { getCurrentLocale, getLabel } from '@/utils/i18n';

interface Metric {
  label: string;
  value?: number;
}

interface Props {
  metrics?: {
    performance?: number;
    accessibility?: number;
    seo?: number;
  };
}

const { metrics } = Astro.props;
const locale = getCurrentLocale(Astro);

const performance_l = getLabel(locale, 'p_performance');
const accessibility_l = getLabel(locale, 'p_accessibility');
const seo_l = getLabel(locale, 'p_seo');

const items: Metric[] = [
  { label: performance_l, value: metrics?.performance },
  { label: accessibility_l, value: metrics?.accessibility },
  { label: seo_l, value: metrics?.seo },
].filter((m) => typeof m.value === "number");
---

{items.length > 0 && (
  <div class="border-b border-(--border)">
    <Container size="md" class="py-8">
      <div class="grid grid-cols-3 gap-6 md:gap-10 text-center">
        {items.map((item) => (
          <div class="group space-y-2">
            <div class="flex items-baseline justify-center font-mono tabular-nums transition-transform duration-300 group-hover:-translate-y-1">
              <span class="text-2xl md:text-3xl semifont-bold text-(--fg)">
                {item.value}
              </span>
              <span class="text-xs text-(--fg-muted) ml-1">%</span>
            </div>

            <div class="flex items-center justify-center gap-2">
              <span class="h-1 w-1 rounded-full bg-(--accent) animate-pulse"></span>
              <span class="text-sm md:text- text-(--fg-muted)">
                {item.label}
              </span>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </div>
)}