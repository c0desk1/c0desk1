---
// src/components/portfolio/PortfolioMetrics.astro
import Container from '@/components/ui/Container.astro';
interface Metrics {
  performance?: number;
  accessibility?: number;
  seo?: number;
}

interface Props {
  metrics?: Metrics;
}

const { metrics } = Astro.props;
---

{metrics && (
  <div class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-900/30">
    <Container size="md" class="py-8 md:py-10">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {metrics.performance !== undefined && (
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white">{metrics.performance}</div>
            <div class="text-xs font-mono text-zinc-500 dark:text-zinc-400 mt-1">Performance</div>
          </div>
        )}
        {metrics.accessibility !== undefined && (
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white">{metrics.accessibility}</div>
            <div class="text-xs font-mono text-zinc-500 dark:text-zinc-400 mt-1">Accessibility</div>
          </div>
        )}
        {metrics.seo !== undefined && (
          <div class="text-center">
            <div class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white">{metrics.seo}</div>
            <div class="text-xs font-mono text-zinc-500 dark:text-zinc-400 mt-1">SEO</div>
          </div>
        )}
      </div>
    </Container>
  </div>
)}
