---
// src/components/portfolio/PortfolioMetrics.astro
import Container from "../ui/Container.astro";

interface Metric {
  label: string;
  value?: number;
}

interface Props {
  metrics?: {
    performance?: number;
    accessibility?: number;
    seo?: number;
  };
}

const { metrics } = Astro.props;

const items: Metric[] = [
  { label: "PERFORMANCE", value: metrics?.performance },
  { label: "ACCESSIBILITY", value: metrics?.accessibility },
  { label: "SEO", value: metrics?.seo },
].filter((m) => typeof m.value === "number");
---

{items.length > 0 && (
  <div class="border-b border-zinc-200/60 dark:border-zinc-800/60 bg-white dark:bg-black">
    <Container size="md" class="py-8 md:py-10">
      <div class="grid grid-cols-3 gap-6 md:gap-10 text-center">
        {items.map((item) => (
          <div class="group space-y-2">
            <div class="flex items-baseline justify-center font-mono tabular-nums transition-transform duration-300 group-hover:-translate-y-1">
              <span class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white">
                {item.value}
              </span>
              <span class="text-xs text-zinc-400 dark:text-zinc-600 ml-1">%</span>
            </div>
            
            <div class="flex items-center justify-center gap-2">
              <span class="h-1 w-1 rounded-full bg-emerald-500 animate-pulse"></span>
              <span class="text-[10px] md:text-[11px] text-zinc-500 dark:text-zinc-400">
                {item.label}
              </span>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </div>
)}