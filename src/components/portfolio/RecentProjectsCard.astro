---
// src/components/portfolio/RecentProjectsCard.astro
import { formatDateCompact } from '@/lib/utils';

interface Props {
  projects: any[];
}

const { projects } = Astro.props;
---

{projects.length > 0 && (
  <div>
    <div class="flex items-center gap-2 mb-3">
      <div class="h-1.5 w-1.5 rounded-full bg-emerald-500"></div>
      <h3 class="text-sm font-bold tracking-wider text-zinc-500 dark:text-zinc-400">
        Recent work
      </h3>
    </div>
    <div class="space-y-2">
      {projects.map(project => {
        const formattedDate = formatDateCompact(project.data.date);
        
        return (
          <a 
            href={`/portfolio/${project.id}`}
            class="group block py-2 border-b border-zinc-100 dark:border-zinc-800 hover:pl-3 transition-all duration-200"
          >
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-mono text-emerald-600 dark:text-emerald-500 font-bold">$</span>
                  <h4 class="text-sm text-zinc-700 dark:text-zinc-300 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors line-clamp-1">
                    {project.data.title}
                  </h4>
                </div>
                <div class="flex items-center gap-2 text-xs font-mono text-zinc-400 dark:text-zinc-500">
                  <time datetime={project.data.date.toISOString()}>{formattedDate}</time>
                </div>
              </div>
              <div class="shrink-0 text-zinc-400 group-hover:text-emerald-500 transition-all group-hover:translate-x-0.5">
                <span class="text-xs">→</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
)}