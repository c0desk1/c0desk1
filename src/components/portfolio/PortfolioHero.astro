---
// src/components/blog/PortfolioHero.astro
import Container from '@/components/ui/Container.astro';
---

  <Container size="md" class="py-10 md:py-14">   
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-end gap-4">
      <div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-white leading-tight">
          Crafting
          <span class="text-zinc-400 dark:text-zinc-500">
            & experiences.
          </span>
        </h1>
        <p class="mt-3 max-w-xl text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
          Kumpulan projek pengembangan web dan beberapa eksperimen visual.
        </p>
      </div>
    </div>
  </Container>
