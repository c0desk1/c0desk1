---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  project: CollectionEntry<"portfolio">;
}

const { project } = Astro.props;
const { id, data } = project;

const {
  title,
  description,
  techStack = [],
  image,
} = data;
---

<article 
  class="group relative flex flex-col h-full bg-white dark:bg-black rounded-2xl border border-zinc-200/60 dark:border-zinc-800/60 overflow-hidden transition-all duration-300 hover:border-zinc-400 dark:hover:border-zinc-600 hover:shadow-xl hover:shadow-black/3 dark:hover:shadow-white/2"
>
  {image && (
    <a href={`/portfolio/${id}/`} class="relative block overflow-hidden aspect-16/9">
      <Image
        src={image.src}
        alt={image.alt ?? title}
        width={800}
        height={450}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
      <div class="absolute inset-0 bg-linear-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    </a>
  )}

  <div class="flex flex-col flex-1 p-5 md:p-6">
    {/* Tech Stack - Dipindah ke atas judul agar lebih modern */}
    <div class="flex flex-wrap gap-2 mb-4">
      {techStack.slice(0, 3).map((tech: string) => (
        <span class="text-[10px] font-mono tracking-wider uppercase px-2 py-0.5 rounded-full border border-zinc-100 dark:border-zinc-900 bg-zinc-50 dark:bg-zinc-950 text-zinc-500 dark:text-zinc-400">
          {tech}
        </span>
      ))}
    </div>

    {/* Content */}
    <div class="space-y-2 mb-6">
      <h2 class="text-lg font-semibold tracking-tight text-zinc-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-500 transition-colors">
        <a href={`/portfolio/${id}/`}>
          {title}
        </a>
      </h2>
      <p class="text-sm leading-relaxed text-zinc-500 dark:text-zinc-400 line-clamp-2">
        {description}
      </p>
    </div>

    {/* Bottom Link - Penanda interaksi */}
    <div class="mt-auto pt-4 flex items-center text-[12px] font-medium text-zinc-900 dark:text-white opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
      <span>Lihat Detail</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</article>