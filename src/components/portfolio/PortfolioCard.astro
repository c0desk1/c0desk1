---
// src/components/portfolio/PortfolioCard.astro
import type { CollectionEntry } from "astro:content";
import { formatDateCompact, generateExcerpt, slugify } from "@/lib/utils";
import { getCurrentLocale, localizePath, getLabel } from "@/utils/i18n";

interface Props {
  project: CollectionEntry<"portfolio">;
}

const { project } = Astro.props;
const locale = getCurrentLocale(Astro);

const { data } = project;

const {
  title,
  pubDate,
  metrics,
} = data;

const excerpt = generateExcerpt(project.body || '', 140);

const dateLocale = locale === 'en'? 'en-US' : locale === 'ru'? 'ru-RU' : 'id-ID';
const formattedDate = formatDateCompact(pubDate, dateLocale);

const autoSlug = slugify(title);
const postUrl = localizePath(`/portfolio/${autoSlug}/`, locale);

const perfLabel = getLabel(locale, 'perf');
const a11yLabel = getLabel(locale, 'a11y');
const seoLabel = getLabel(locale, 'seo');
---

<a 
  href={postUrl}
  class="group block relative"
>
  <div class="space-y-3">
    <div class="flex items-center justify-between text-[13px] text-(--fg-muted)">
      {metrics && (
      <div class="flex gap-3 pt-2">
        {metrics.performance && (
          <div class="flex items-center gap-1">
            <span class="text-[13px] text-(--fg-subtle)">{perfLabel}</span>
            <span class="text-[13px] font-semibold text-(--accent)">
              {metrics.performance}
            </span>
          </div>
        )}
        {metrics.accessibility && (
          <div class="flex items-center gap-1">
            <span class="text-[13px] text-(--fg-subtle)">{a11yLabel}</span>
            <span class="text-[13px] font-semibold text-(--accent)">
              {metrics.accessibility}
            </span>
          </div>
        )}
        {metrics.seo && (
          <div class="flex items-center gap-1">
            <span class="text-[13px] text-(--fg-subtle)">{seoLabel}</span>
            <span class="text-[13px] font-semibold text-(--accent)">
              {metrics.seo}
            </span>
          </div>
        )}
      </div>
    )}
      <time datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
    </div>
    <h3 class="text-lg md:text-xl font-semibold tracking-tight text-(--fg) leading-tight">
      {title}
    </h3>
    <p class="text-[13px] md:text-sm leading-relaxed line-clamp-3">
      {excerpt}
    </p>
  </div>
</a>