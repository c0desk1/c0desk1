---
// src/components/portfolio/PortfolioCard.astro
import type { CollectionEntry } from "astro:content";
import { Image } from 'astro:assets';
import { formatDateCompact } from "@/lib/utils";

interface Props {
  project: CollectionEntry<"portfolio">;
}

const { project } = Astro.props;
const { id, data } = project;

const {
  title,
  description,
  pubDate,
  image,
  techStack = [],
  client,
  role,
  duration,
  metrics,
} = data;
---

<a 
  href={`/portfolio/${id}/`}
  class="group block relative"
>
  <div class="relative overflow-hidden rounded-2xl bg-zinc-100 dark:bg-zinc-900 mb-4">
    <Image
      src={image.src}
      alt={image.alt ?? title}
      width={800}
      height={450}
      loading="lazy"
      class="aspect-video w-full object-cover"
    />
    
    {role && (
      <div class="absolute top-4 left-4">
        <span class="text-[13px] px-2 py-1 rounded-md bg-black/70 backdrop-blur-sm text-white">
          {role}
        </span>
      </div>
    )}

    {duration && (
      <div class="absolute top-4 right-4">
        <span class="text-[13px] px-2 py-1 rounded-md bg-black/70 backdrop-blur-sm text-white/80">
          {duration}
        </span>
      </div>
    )}
  </div>

  <div class="space-y-3">
    <div class="flex items-center justify-between text-[13px] text-zinc-500 dark:text-zinc-400">
      <span class="tracking-wide">
        {client || "Personal Project"}
      </span>
      <time datetime={pubDate.toISOString()}>
        {formatDateCompact(pubDate)}
      </time>
    </div>

    <h3 class="text-xl font-semibold tracking-tight text-zinc-900 dark:text-white leading-tight group-hover:text-emerald-600 dark:group-hover:text-emerald-500 transition-colors">
      {title}
    </h3>

    <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed line-clamp-2">
      {description}
    </p>

    {metrics && (
      <div class="flex gap-3 pt-2">
        {metrics.performance && (
          <div class="flex items-center gap-1">
            <span class="text-[13px] text-zinc-400">PERF</span>
            <span class="text-[13px] font-semibold text-emerald-600 dark:text-emerald-500">
              {metrics.performance}
            </span>
          </div>
        )}
        {metrics.accessibility && (
          <div class="flex items-center gap-1">
            <span class="text-[13px] text-zinc-400">A11Y</span>
            <span class="text-[13px] font-smibold text-emerald-600 dark:text-emerald-500">
              {metrics.accessibility}
            </span>
          </div>
        )}
        {metrics.seo && (
          <div class="flex items-center gap-1">
            <span class="text-[13px] text-zinc-400">SEO</span>
            <span class="text-[13px] font-semibold text-emerald-600 dark:text-emerald-500">
              {metrics.seo}
            </span>
          </div>
        )}
      </div>
    )}

    {techStack.length > 0 && (
      <div class="flex flex-wrap gap-1.5 pt-2">
        {techStack.slice(0, 4).map((tech: string) => (
          <span class="text-[13px] px-1.5 py-0.5 rounded border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-400">
            {tech}
          </span>
        ))}
        {techStack.length > 4 && (
          <span class="text-[13px] px-1.5 py-0.5 text-zinc-400">
            +{techStack.length - 4}
          </span>
        )}
      </div>
    )}
  </div>
</a>
