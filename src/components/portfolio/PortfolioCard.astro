---
// src/components/portfolio/PortfolioCard.astro
import type { CollectionEntry } from "astro:content";
import { formatDateCompact, generateExcerpt } from "@/lib/utils";

interface Props {
  project: CollectionEntry<"portfolio">;
}

const { project } = Astro.props;
const { id, data } = project;

const {
  title,
  pubDate,
  client,
  metrics,
} = data;

const excerpt = generateExcerpt(post.body, 140);
---

<a 
  href={`/portfolio/${id}/`}
  class="group block relative"
>
  <div class="space-y-3">
    <div class="flex items-center justify-between text-[13px] text-(--fg-subtle)">
      <span class="tracking-wide">
        {client}
      </span>
      <time datetime={pubDate.toISOString()}>
        {formatDateCompact(pubDate)}
      </time>
    </div>

    <h3 class="text-lg md:text-xl font-semibold tracking-tight text-(--fg) leading-tight">
      {title}
    </h3>

    <p class="text-sm md:text-[13px] leading-relaxed line-clamp-3">
      {excerpt}
    </p>

    {metrics && (
      <div class="flex gap-3 pt-2">
        {metrics.performance && (
          <div class="flex items-center gap-1">
            <span class="text-[13px] text-(--fg-subtle)">PERF</span>
            <span class="text-[13px] font-semibold text-(--accent)">
              {metrics.performance}
            </span>
          </div>
        )}
        {metrics.accessibility && (
          <div class="flex items-center gap-1">
            <span class="text-[13px] text-(--fg-subtle)">A11Y</span>
            <span class="text-[13px] font-semibold text-(--accent)">
              {metrics.accessibility}
            </span>
          </div>
        )}
        {metrics.seo && (
          <div class="flex items-center gap-1">
            <span class="text-[13px] text-(--fg-subtle)">SEO</span>
            <span class="text-[13px] font-semibold text-(--accent)">
              {metrics.seo}
            </span>
          </div>
        )}
      </div>
    )}
  </div>
</a>
