---
// src/components/portfolio/PortfolioCard.astro

import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"portfolio">;
}

const { project } = Astro.props;

const { id, data } = project;

const {
  title,
  description,
  techStack = [],
  image,
  imageAlt
} = data;
---

<article class="group rounded-xl border border-black/10 dark:border-white/10 overflow-hidden hover:border-black/30 dark:hover:border-white/30 transition">
  {image && (
    <a href={`/portfolio/${id}/`} class="block overflow-hidden">
      <img
        src={image}
        alt={imageAlt ?? title}
        loading="lazy"
        class="aspect-video w-full object-cover"
      />
    </a>
  )}
  <div class="p-5 space-y-3">
    <h3 class="font-semibold text-zinc-900 dark:text-white group-hover:underline">
      <a href={`/portfolio/${id}/`}>
        {title}
      </a>
    </h3>
    <p class="text-sm text-zinc-500 line-clamp-2">
      {description}
    </p>
    <div class="flex flex-wrap gap-1.5">
      {techStack.slice(0, 3).map((tech: string) => (
        <span class="text-[11px] px-2 py-0.5 rounded bg-zinc-100 dark:bg-zinc-900 text-zinc-600 dark:text-zinc-400">
          {tech}
        </span>
      ))}
    </div>
  </div>
</article>