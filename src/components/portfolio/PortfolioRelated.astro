---
// src/components/portfolio/PortfolioRelated.astro

import PortfolioCard from './PortfolioCard.astro';

interface Props {
  projects: any[];
}

const { projects } = Astro.props;
---

{projects.length > 0 && (
  <div class="mt-10 pt-6 border-t border-zinc-100 dark:border-zinc-900">
    <div class="flex items-center gap-2 mb-4">
      <h2 class="text-sm font-semibold text-zinc-500 dark:text-zinc-400">
        Proyek terkait
      </h2>
      <div class="h-px flex-1 bg-linear-to-r from-zinc-300/70 to-transparent dark:from-zinc-700/50"></div>
    </div>
    <div class="space-y-0 divide-y divide-zinc-100 dark:divide-zinc-900">
      {projects.map(project => (
        <PortfolioCard project={project} />
      ))}
    </div>
  </div>
)}