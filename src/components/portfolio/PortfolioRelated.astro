---
// src/components/portfolio/PortfolioRelated.astro

import ProjectCard from './ProjectCard.astro';

interface Props {
  projects: any[];
}

const { projects } = Astro.props;
---

{projects.length > 0 && (
  <div class="mt-10 pt-6 border-t border-zinc-100 dark:border-zinc-900">
    <div class="flex items-center gap-2 mb-4">
      <div class="h-px w-6 bg-linear-to-r from-zinc-300 to-transparent"></div>
      <h3 class="text-sm font-bold tracking-wider text-zinc-500 dark:text-zinc-400">
        Related projects
      </h3>
    </div>
    <div class="space-y-0">
      {projects.map(project => (
        <ProjectCard project={project} />
      ))}
    </div>
  </div>
)}