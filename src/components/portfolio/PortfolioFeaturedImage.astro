---
// src/components/portfolio/PortfolioHeroImage.astro
import { Image } from "astro:assets";
import Container from "../ui/Container.astro";

interface Props {
  src: any;
  alt?: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;

const finalSrc = typeof src === "object" && src !== null ? (src.src || src) : src;
const finalCaption = caption || alt;
---

<div class="border-y border-zinc-200/60 dark:border-zinc-800/60 bg-white dark:bg-black">
  <Container size="md" class="py-8 md:py-10">
    <figure class="group relative overflow-hidden border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950">
      <div class="relative aspect-video overflow-hidden">
        <div class="absolute aspect-video inset-0 bg-zinc-100 dark:bg-zinc-900 animate-pulse" aria-hidden="true"></div>
        
        <Image
          src={finalSrc}
          alt={alt || "Portfolio hero image"}
          width={1280}
          height={720}
          loading="eager"
          decoding="async"
          class="relative z-10 h-full w-full object-cover aspect-video transition duration-500 opacity-0"
          onload="this.classList.remove('opacity-0')"
        />
      </div>
      
      {finalCaption && (
        <figcaption class="flex items-center gap-2 border-t border-zinc-200/60 dark:border-zinc-800/60 px-3 py-2 text-xs text-zinc-500 dark:text-zinc-400">
          <span class="text-zinc-400 dark:text-zinc-600 font-mono">
            //
          </span>
          <span class="line-clamp-1">
            {finalCaption}
          </span>
        </figcaption>
      )}
    </figure>
  </Container>
</div>