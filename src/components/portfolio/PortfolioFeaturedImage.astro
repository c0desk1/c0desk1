---
import Container from '../ui/Container.astro';

// src/components/portfolio/PortfolioImage.astro
interface Props {
  src: string;
  alt?: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<div class="border-b border-zinc-100 dark:border-zinc-900">
  <Container size="md" class="py-6 md:py-8">
    <div class="relative overflow-hidden bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
      <img 
        src={src}
        alt={alt || 'Project image'}
        class="w-full h-auto max-h-80 md:max-h-96 object-cover"
        loading="eager"
      />
      <div class="absolute top-2 left-2 w-4 h-4 border-l border-t border-white/30"></div>
      <div class="absolute bottom-2 right-2 w-4 h-4 border-r border-b border-white/30"></div>
    </div>
    {caption && (
      <p class="text-xs text-center text-zinc-500 dark:text-zinc-400 mt-2 font-mono">
        {caption}
      </p>
    )}
  </Container>
</div>