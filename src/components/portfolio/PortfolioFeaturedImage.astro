---
// src/components/blog/BlogFeaturedImage.astro
import { Image } from 'astro:assets';
import { cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  image?: string;
  alt?: string;
}

const { image, alt = '' } = Astro.props;

const optimizedSrc  = image && isCdnUrl(image)
  ? cdnImage(image, { w: 1280, h: 720, q: 85 })
  : image ?? '';
---
<div class="absolute inset-0 z-0 overflow-hidden">
  <Image
    src={optimizedSrc}
    alt={alt}
    width={1200}
    height={630}
    loading="eager"
    decoding="async"
    fetchpriority="low"
    class="relative z-10 h-full w-full object-cover rounded-none opacity-40"
  />
</div>
