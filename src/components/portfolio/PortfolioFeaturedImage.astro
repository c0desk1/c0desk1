---
import Container from '../ui/Container.astro';

interface Props {
  src: string;
  alt?: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
const finalCaption = caption || alt;
---

<div class="border-b border-zinc-100 dark:border-zinc-900">
  <Container size="md" class="py-6 md:py-8">
    <figure class="relative overflow-hidden bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
      <div class="relative overflow-hidden aspect-16/9">
        <img 
          src={src}
          alt={alt || 'Project image'}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          decoding="async"
          sizes="(min-width: 768px) 768px, 100vw"
        />
        <div class="absolute top-2 left-2 w-4 h-4 border-l border-t border-white/30"></div>
        <div class="absolute bottom-2 right-2 w-4 h-4 border-r border-b border-white/30"></div>
      </div>
      {finalCaption && (
        <figcaption class="px-2 py-1.5 border-t border-zinc-200 dark:border-zinc-800 text-xs text-zinc-500 dark:text-zinc-400">
          <span class="text-zinc-400 dark:text-zinc-600 mr-1.5">
            //
          </span>
          {finalCaption}
        </figcaption>
      )}
    </figure>
  </Container>
</div>