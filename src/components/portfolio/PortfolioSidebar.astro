---
// src/components/portfolio/PortfolioSidebar.astro

interface Props {
  techStack?: string[];
  demoUrl?: string;
  repoUrl?: string;
}

const { techStack, demoUrl, repoUrl } = Astro.props;
---

<aside class="space-y-6">
  
  {/* Tech Stack Card */}
  {techStack && techStack.length > 0 && (
    <div class="p-5 border border-zinc-200 dark:border-zinc-800 rounded-lg bg-white dark:bg-zinc-950">
      <div class="flex items-center gap-2 mb-4">
        <div class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-500"></div>
        <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
          Tech stack
        </h3>
      </div>
      <div class="flex flex-wrap gap-2">
        {techStack.map(tech => (
          <span class="px-2 py-1 text-[11px] font-mono border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400 rounded">
            {tech}
          </span>
        ))}
      </div>
    </div>
  )}
  
  {/* Links Card */}
  {(demoUrl || repoUrl) && (
    <div class="p-5 border border-zinc-200 dark:border-zinc-800 rounded-lg bg-white dark:bg-zinc-950">
      <div class="flex items-center gap-2 mb-4">
        <div class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-500"></div>
        <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
          Links
        </h3>
      </div>
      <div class="space-y-2">
        {demoUrl && (
          <a 
            href={demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between py-2 text-sm font-mono text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors group/link"
          >
            <span>live demo</span>
            <span class="group-hover/link:translate-x-0.5 transition-transform">→</span>
          </a>
        )}
        {repoUrl && (
          <a 
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between py-2 text-sm font-mono text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors group/link"
          >
            <span>source code</span>
            <span class="group-hover/link:translate-x-0.5 transition-transform">→</span>
          </a>
        )}
      </div>
    </div>
  )}
  
  {/* Back to top */}
  <div class="pt-4">
    <a 
      href="#top" 
      class="inline-flex items-center gap-2 text-xs font-mono text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
    >
      <span>↑</span>
      <span>[back to top]</span>
    </a>
  </div>
  
</aside>