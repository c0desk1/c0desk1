---
// src/components/portfolio/PortfolioFeatured.astro (Industrial Corner)

import ProjectCard from './ProjectCard.astro';

interface Props {
  project: any;
}

const { project } = Astro.props;
---

{project && (
  <div class="relative mb-8 pb-6 border-b border-zinc-100 dark:border-zinc-900">
    <div class="absolute -top-2 -left-2 w-5 h-5 border-l-2 border-t-2 border-amber-500/50"></div>
    <div class="absolute -top-2 -right-2 w-5 h-5 border-r-2 border-t-2 border-amber-500/50"></div>
    <div class="flex items-center gap-2 mb-4 pl-2">
      <span class="text-sm font-bold text-amber-600 dark:text-amber-400">[ Featured ]</span>
      <div class="h-px flex-1 bg-linear-to-r from-amber-500/30 to-transparent"></div>
    </div>
    
    <div class="pt-2 px-2 pb-2">
      <ProjectCard 
        project={project}
      />
    </div>
    
  </div>
)}