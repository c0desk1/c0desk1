---
import Icon from "@/components/ui/Icon";
import { siteConfig } from "@/config/site";

interface Props {
  challenge?: string;
  solution?: string;
  result?: string;
  allowMultiple?: boolean;
}

const {
  challenge,
  solution,
  result,
  allowMultiple = true,
} = Astro.props;

interface Item { question: string; answer: string; }

const items: Item[] = [
  challenge && { question: siteConfig.p_challenge, answer: challenge },
  solution && { question: siteConfig.p_solution, answer: solution },
  result && { question: siteConfig.p_result, answer: result },
].filter(Boolean) as Item[];
---

{items.length > 0 && (
  <div 
    class="not-prose my-6 sm:my-8 border border-(--prose-details-border) rounded-xl bg-(--prose-details-bg) overflow-hidden shadow-sm relative"
    data-allow-multiple={allowMultiple}
  >
    <div class="absolute inset-0 opacity-5 pointer-events-none bg-noise"></div>
    
    <div class="relative z-10">
      {items.map((item, idx) => (
        <div class="border-b border-(--prose-details-border) last:border-b-0">
          <button
            class="csa-trigger w-full flex items-center justify-between gap-4 px-5 py-4 text-left transition-colors hover:bg-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
            aria-expanded="false"
            aria-controls={`csa-panel-${idx}`}
            id={`csa-btn-${idx}`}
          >
            <span class="text-heading-14 text-(--prose-details-summary) uppercase">
              {item.question}
            </span>
            <Icon name="chevron-right" className="csa-chevron w-5 h-5 text-(--prose-details-marker) transition-transform duration-200" />
          </button>
          <div
            class="csa-panel overflow-hidden transition-[max-height] duration-300 ease-out"
            id={`csa-panel-${idx}`}
            aria-labelledby={`csa-btn-${idx}`}
            hidden
          >
            <div class="px-5 pb-5 pt-2 text-copy-16 text-(--fg)">
              <p set:html={item.answer}></p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
)}

<script>
  // @ts-nocheck
  function initAccordion() {
    const roots = document.querySelectorAll('[data-allow-multiple]');
    roots.forEach((root) => {
      const allowMultiple = root.getAttribute('data-allow-multiple') === 'true';
      const triggers = root.querySelectorAll('.csa-trigger');

      function open(btn) {
        const panelId = btn.getAttribute('aria-controls');
        if (!panelId) return;
        const panel = document.getElementById(panelId);
        if (panel) {
          btn.setAttribute('aria-expanded', 'true');
          panel.hidden = false;
          panel.style.maxHeight = panel.scrollHeight + 'px';
        }
      }

      function close(btn) {
        const panelId = btn.getAttribute('aria-controls');
        if (!panelId) return;
        const panel = document.getElementById(panelId);
        if (panel) {
          btn.setAttribute('aria-expanded', 'false');
          panel.style.maxHeight = '';
          panel.hidden = true;
        }
      }

      triggers.forEach((btn) => {
        btn.addEventListener('click', () => {
          const isOpen = btn.getAttribute('aria-expanded') === 'true';
          if (!allowMultiple) {
            triggers.forEach((other) => {
              if (other !== btn && other.getAttribute('aria-expanded') === 'true') {
                close(other);
              }
            });
          }
          isOpen ? close(btn) : open(btn);
        });
      });
    });
  }
  initAccordion();
  document.addEventListener('astro:page-load', initAccordion);
</script>

<style is:global>
  .csa-panel[hidden] {
    display: none;
  }
  .csa-panel {
    max-height: 0;
    transition: max-height 0.3s ease-out;
  }
  .csa-panel:not([hidden]) {
    max-height: 500px;
  }
  .csa-trigger[aria-expanded="true"] .csa-chevron {
    transform: rotate(90deg);
  }
  .bg-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='1' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.4'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 80px;
  }
</style>