---
interface Props {
  challenge?: string;
  solution?: string;
  result?: string;
  allowMultiple?: boolean;
}
const { challenge, solution, result, allowMultiple = true } = Astro.props;

interface Item {
  question: string;
  answer: string;
}

const items: Item[] = [];
if (challenge) items.push({ question: "Tantangan", answer: challenge });
if (solution) items.push({ question: "Solusi", answer: solution });
if (result) items.push({ question: "Hasil", answer: result });
---

{items.length > 0 && (
  <div
    class="accordion not-prose mx-auto max-w-3xl my-8 md:my-10"
    data-allow-multiple={allowMultiple? "true" : "false"}
  >
    {items.map((item, i) => (
      <div class="accordion-item" data-index={i}>
        <button
          class="accordion-trigger"
          aria-expanded="false"
          aria-controls={`case-panel-${i}`}
          id={`case-btn-${i}`}
        >
          <span class="accordion-question text-[11px] font-mono uppercase tracking-[0.2em] text-(--fg)">{item.question}</span>
          <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </button>
        <div
          class="accordion-panel"
          id={`case-panel-${i}`}
          role="region"
          aria-labelledby={`case-btn-${i}`}
          hidden
        >
          <div class="accordion-body">
            <p class="text-(--fg-muted) leading-relaxed text-sm md:text-[13px]" set:html={item.answer} />
          </div>
        </div>
      </div>
    ))}
  </div>
)}

<style is:global>
 .accordion {
    border: 1px solid var(--border);
    border-radius: var(--radius-md, 8px);
    overflow: hidden;
  }
 .accordion-item { border-bottom: 1px solid var(--border); }
 .accordion-item:last-child { border-bottom: none; }
 .accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color 150ms ease;
  }
 .accordion-trigger:hover { background-color: var(--bg-subtle); }
 .accordion-trigger:focus-visible {
    outline: 2px solid var(--accent, #10b981);
    outline-offset: -2px;
  }
 .accordion-chevron {
    flex-shrink: 0;
    color: var(--fg-subtle);
    transition: transform 200ms ease;
  }
 .accordion-trigger[aria-expanded="true"].accordion-chevron { transform: rotate(180deg); }
 .accordion-panel { overflow: hidden; }
 .accordion-panel[hidden] { display: none; }
 .accordion-body { padding: 0 1.25rem 1rem; }
 .accordion-body p { margin: 0; }
</style>

<script>
  const initAccordion = () => {
    document.querySelectorAll<HTMLElement>('.accordion').forEach(root => {
      const allowMultiple = root.dataset.allowMultiple === 'true';
      const triggers = root.querySelectorAll<HTMLButtonElement>('.accordion-trigger');

      const open = (trigger: HTMLButtonElement) => {
        const panelId = trigger.getAttribute('aria-controls')!;
        const panel = document.getElementById(panelId);
        trigger.setAttribute('aria-expanded', 'true');
        panel?.removeAttribute('hidden');
      };

      const close = (trigger: HTMLButtonElement) => {
        const panelId = trigger.getAttribute('aria-controls')!;
        const panel = document.getElementById(panelId);
        trigger.setAttribute('aria-expanded', 'false');
        panel?.setAttribute('hidden', '');
      };

      triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
          const isOpen = trigger.getAttribute('aria-expanded') === 'true';
          if (!allowMultiple) {
            triggers.forEach(t => { if (t!== trigger) close(t); });
          }
          isOpen? close(trigger) : open(trigger);
        });
      });
    });
  };
  initAccordion();
  document.addEventListener('astro:after-swap', initAccordion);
</script>