---
// src/components/portfolio/PortfolioList.astro

import ProjectCard from './ProjectCard.astro';

interface Props {
  projects: any[];
  totalCount: number;
}

const { projects, totalCount } = Astro.props;
---

<div class="min-w-0">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-2">
      <span class="text-sm text-zinc-400 dark:text-zinc-500">$</span>
      <span class="text-sm text-zinc-500 dark:text-zinc-400 tracking-wider">
        All projects ({totalCount})
      </span>
    </div>
  </div>
  {projects.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {projects.map(project => (
        <ProjectCard 
          project={project}
        />
      ))}
    </div>
  ) : (
    <div class="py-12 text-center border border-zinc-200 dark:border-zinc-800">
      <p class="text-zinc-500 dark:text-zinc-400 text-sm">$ No projects found.</p>
    </div>
  )}
</div>