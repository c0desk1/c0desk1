---
// src/components/blog/CategoryTabs.astro
import type { CollectionEntry } from "astro:content";
import PostCard from "@/components/blog/PostCard.astro";
import { getCurrentLocale, getLabel, localizePath } from "@/utils/i18n";

interface Props {
  posts: CollectionEntry<"blog">[];
  categories: CollectionEntry<"categories">[];
}

const { posts, categories } = Astro.props;

const locale = getCurrentLocale(Astro);
const loc = locale as "id" | "en" | "ru";

const ALL_KEY = "__all__";
const POSTS_PER_PAGE = 6;
const POSTS_MAX = 12;

const categoryIdsInPosts = [...new Set(
  posts.map(p => p.data.category?.id).filter(Boolean)
)];

const categoriesWithPosts = categories.filter(cat =>
  categoryIdsInPosts.includes(cat.id)
);

const visibleCategories = categoriesWithPosts
  .sort((a, b) => {
    const countA = posts.filter(p => p.data.category?.id === a.id).length;
    const countB = posts.filter(p => p.data.category?.id === b.id).length;
    return countB - countA;
  })
  .slice(0, 8);

const postsByCategory: Record<string, CollectionEntry<"blog">[]> = {};
postsByCategory[ALL_KEY] = posts;

for (const cat of visibleCategories) {
  postsByCategory[cat.id] = posts.filter(p => p.data.category?.id === cat.id);
}

const allLabel = getLabel(locale, "allCategory");
const selectCategoryLabel = getLabel(locale, "selectCategory");
const noPostsInCategory = getLabel(locale, "noPostsInCategory");
const showMoreLabel = getLabel(locale, "showMore");
const seeAllPostsLabel = getLabel(locale, "seeAllPosts");
const browsePostsLabel = getLabel(locale, "browsePostsByCategory");
const filterCategoryLabel = getLabel(locale, "filterCategory");

const tabs = [
  { id: ALL_KEY, label: allLabel, slug: null, count: posts.length },
  ...visibleCategories.map((cat) => ({
    id: cat.id,
    label: cat.data.name[loc] || cat.data.name.id,
    slug: cat.id,
    count: postsByCategory[cat.id].length,
  })),
];
---

<section
  id="category-tabs"
  class="w-full"
  aria-label={browsePostsLabel}
  data-tabs={JSON.stringify(tabs)}
  data-posts-max={POSTS_MAX}
>

  <!-- ── Tab bar ──────────────────────────────────────────────────── -->
  <div class="mb-8 sticky top-15 z-40 bg-(--bg)">

    <!-- ┌─ Mobile ─────────────────── -->
    <div class="md:hidden" id="ct-mobile-dropdown">
      <button
        type="button"
        id="ct-trigger"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-controls="ct-listbox"
        class="ct-trigger group flex w-full items-center justify-between gap-4
               px-4 py-3 rounded-xl border border-(--border) bg-(--fg)
               text-label-13 font-medium text-(--bg) cursor-pointer
               transition-colors duration-200
               hover:border-(--border-strong) hover:bg-(--fg-muted)
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--accent)"
      >
        <span class="flex items-center gap-2.5">
          <span id="ct-trigger-label">{allLabel}</span>
        </span>
        <span class="flex items-center gap-2">
          <span id="ct-trigger-count"
            class="text-label-12 bg-(--bg-muted) text-(--fg-subtle)
                   border border-(--border) px-1.5 py-px rounded-full">
            {posts.length}
          </span>
          <svg id="ct-trigger-chevron" class="text-(--fg-subtle) transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
            width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <!-- Dropdown listbox -->
      <div
        id="ct-listbox"
        role="listbox"
        aria-label={selectCategoryLabel}
        class="ct-listbox mt-1.5 overflow-hidden rounded-xl border border-(--border)
               bg-(--bg) shadow-lg shadow-black/5
               origin-top scale-y-95 opacity-0 pointer-events-none
               transition-[opacity,transform] duration-200 ease-[cubic-bezier(0.16,1,0.3,1)]"
      >
        <ul class="p-1.5 flex flex-col gap-px">
          {tabs.map((tab, i) => (
            <li
              role="option"
              data-mob-opt={tab.id}
              aria-selected={i === 0? "true" : "false"}
              tabindex="-1"
              class:list={[
                "ct-option flex items-center justify-between gap-3 px-3 py-2.5 rounded-lg",
                "text-label-13 font-medium cursor-pointer select-none",
                "transition-colors duration-100",
                i === 0
                 ? "bg-(--fg) text-(--bg) ct-option--active"
                  : "text-(--fg-muted) hover:bg-(--bg-subtle) hover:text-(--fg)",
              ]}
            >
              <span class="flex items-center gap-2.5">
                <span>{tab.label}</span>
              </span>
              <span class:list={[
                "text-label-12 px-1.5 py-px rounded-full border",
                i === 0
                 ? "bg-(--bg)/20 text-(--bg) border-transparent"
                  : "bg-(--bg-muted) text-(--fg-subtle) border-(--border)",
              ]}>
                {tab.count}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- ┌─ Desktop ───────────── -->
    <div
      class="hidden md:flex gap-0 overflow-x-auto no-scrollbar py-4"
      role="tablist"
      aria-label={filterCategoryLabel}
    >
      {tabs.map((tab, i) => (
        <button
          type="button"
          role="tab"
          data-cat={tab.id}
          aria-selected={i === 0? "true" : "false"}
          aria-controls={`ct-panel-${tab.id}`}
          id={`ct-tab-${tab.id}`}
          class:list={[
            "ct-tab inline-flex items-center gap-1.5 px-3.5 py-2",
            "text-label-13 md:text-label-14 whitespace-nowrap cursor-pointer rounded-(--radius-xl) bg-transparent",
            "text-(--fg-muted) hover:text-(--fg)",
            "transition-colors duration-150",
            i === 0? "font-semibold!" : "bg-(--fg)",
          ]}
        >
          {tab.label}
          <span class="inline-flex items-center justify-center min-w-[1rem] p-0.05
                        text-label-12 rounded-full
                        bg-(--bg-muted) text-(--fg-muted) border border-(--border)
                        transition-colors duration-150">
            {tab.count}
          </span>
        </button>
      ))}
    </div>
  </div>

  <!-- ── Panels ───────────────────────────────────────────────────── -->
  {tabs.map((tab, i) => {
    const panelPosts = postsByCategory[tab.id]?? [];
    const initial = panelPosts.slice(0, POSTS_PER_PAGE);
    const middle = panelPosts.slice(POSTS_PER_PAGE, POSTS_MAX);
    const hasMore = panelPosts.length > POSTS_PER_PAGE;
    const needsSeeAll = panelPosts.length > POSTS_MAX;
    const categoryHref = tab.slug? localizePath(`/category/${tab.slug}`, locale) : null;
    const blogHref = localizePath('/blog', locale);

    return (
      <div
        role="tabpanel"
        id={`ct-panel-${tab.id}`}
        aria-labelledby={`ct-tab-${tab.id}`}
        data-panel={tab.id}
        {...(i!== 0? { hidden: true } : {})}
      >
        {panelPosts.length === 0? (
          <div class="flex items-center justify-center py-16 text-copy-14 text-(--fg-subtle)">
            {noPostsInCategory}
          </div>
        ) : (
          <>
            <!-- ── Initial grid ── -->
            <div data-grid class="ct-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
              {initial.map((post) => (
                <article class="ct-card transition-colors duration-150">
                  <PostCard post={post} />
                </article>
              ))}
            </div>

            <!-- ── Batch-2 ── -->
            {middle.length > 0 && (
              <div data-more hidden
                class="ct-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
                {middle.map((post) => (
                  <article class="ct-card transition-colors duration-150">
                    <PostCard post={post} />
                  </article>
                ))}
              </div>
            )}

            <!-- ── Footer actions ── -->
            {hasMore && (
              <div class="flex flex-col items-center gap-3 pt-8" data-loadmore-wrap>

                {middle.length > 0 && (
                  <button
                    data-loadmore
                    aria-label={`${showMoreLabel} ${tab.label}`}
                    class="group inline-flex items-center gap-2 px-4 py-2
                           text-button-14 font-medium text-(--fg-muted)
                           bg-(--bg-subtle) border border-(--border) rounded-full cursor-pointer
                           transition-all duration-150
                           hover:text-(--fg) hover:bg-(--bg-muted) hover:border-(--border-strong) hover:shadow-sm"
                  >
                    <span>{showMoreLabel}</span>
                  </button>
                )}

                {needsSeeAll && (
                  <a
                    data-seeall
                    href={categoryHref || blogHref}
                    hidden
                    class="group inline-flex items-center gap-1.5 px-4 py-2
                           text-button-14 font-medium text-(--fg)
                           bg-(--bg) border border-(--border-strong) rounded-full
                           transition-all duration-150
                           hover:bg-(--fg) hover:text-(--bg) hover:border-(--fg) hover:shadow-sm"
                  >
                    <span>{seeAllPostsLabel}</span>
                    <svg width="13" height="13" viewBox="0 0 13 13" fill="none"
                      class="transition-transform duration-150 group-hover:translate-x-0.5">
                      <path d="M2.5 6.5h8M7 3l3.5 3.5L7 10"
                        stroke="currentColor" stroke-width="1.4"
                        stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                )}
              </div>
            )}
          </>
        )}
      </div>
    );
  })}
</section>

<style>
 .no-scrollbar::-webkit-scrollbar { display: none; }
 .no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }

 .ct-tab[aria-selected="true"] {
    color: var(--bg)!important;
    font-weight: 600;
    border-radius: var(--radius-xl);
    background: var(--fg);
  }

 .ct-option--active {
    background: var(--fg);
    color: var(--bg);
  }

 .ct-listbox.ct-open {
    opacity: 1;
    transform: scaleY(1);
    pointer-events: auto;
  }

  [data-panel]:not([hidden]),
  [data-more]:not([hidden]) {
    animation: panel-in 0.22s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes panel-in {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #ct-mobile-dropdown { position: relative; }

 .ct-listbox {
    position: absolute;
    top: calc(100% + 0.375rem);
    left: 0;
    right: 0;
    z-index: 10;
    margin-top: 0!important;
  }

 .ct-listbox:not(.ct-open) {
    opacity: 0;
    transform: scaleY(0.95);
    pointer-events: none;
    visibility: hidden;
  }

 .ct-listbox.ct-open { visibility: visible; }

 .ct-grid { gap: 2rem; }

  [data-seeall]:not([hidden]) {
    animation: panel-in 0.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
</style>

<script>
  // (Script tetap sama seperti sebelumnya, tidak ada perubahan)
  const tabs: { id: string; label: string; slug: string | null; count: number }[] =
    JSON.parse(document.getElementById("category-tabs")?.dataset.tabs?? "[]");

  function switchCat(catId: string, label: string, count: number) {
    document.querySelectorAll<HTMLButtonElement>(".ct-tab").forEach((btn) => {
      btn.setAttribute("aria-selected", String(btn.dataset.cat === catId));
    });

    const triggerLabel = document.getElementById("ct-trigger-label");
    const triggerCount = document.getElementById("ct-trigger-count");
    if (triggerLabel) triggerLabel.textContent = label;
    if (triggerCount) triggerCount.textContent = String(count);

    document.querySelectorAll<HTMLElement>("[data-mob-opt]").forEach((opt) => {
      const active = opt.dataset.mobOpt === catId;
      opt.setAttribute("aria-selected", String(active));
      opt.classList.toggle("ct-option--active", active);
    });

    document.querySelectorAll<HTMLElement>("[data-panel]").forEach((panel) => {
      panel.dataset.panel === catId
       ? panel.removeAttribute("hidden")
        : panel.setAttribute("hidden", "");
    });
  }

  document.querySelectorAll<HTMLButtonElement>(".ct-tab").forEach((btn) => {
    btn.addEventListener("click", () => {
      const tab = tabs.find((t) => t.id === btn.dataset.cat);
      if (tab) switchCat(tab.id, tab.label, tab.count);
    });
  });

  // ── Mobile dropdown ──────────────────────────────────────────────────────
  const trigger = document.getElementById("ct-trigger")!;
  const listbox = document.getElementById("ct-listbox")!;
  const chevron = document.getElementById("ct-trigger-chevron")!;

  function openDropdown() {
    listbox.classList.add("ct-open");
    chevron.style.transform = "rotate(180deg)";
    trigger.setAttribute("aria-expanded", "true");
    listbox.querySelector<HTMLElement>("[aria-selected='true']")?.focus();
  }

  function closeDropdown() {
    listbox.classList.remove("ct-open");
    chevron.style.transform = "";
    trigger.setAttribute("aria-expanded", "false");
  }

  trigger.addEventListener("click", (e) => {
    e.stopPropagation();
    listbox.classList.contains("ct-open")? closeDropdown() : openDropdown();
  });

  listbox.querySelectorAll<HTMLElement>("[data-mob-opt]").forEach((opt) => {
    opt.addEventListener("click", () => {
      const id = opt.dataset.mobOpt!;
      const tab = tabs.find((t) => t.id === id)!;
      switchCat(tab.id, tab.label, tab.count);
      closeDropdown();
      trigger.focus();
    });
  });

  document.addEventListener("click", (e) => {
    if (!document.getElementById("ct-mobile-dropdown")?.contains(e.target as Node)) {
      closeDropdown();
    }
  });

  listbox.addEventListener("keydown", (e) => {
    const opts = Array.from(listbox.querySelectorAll<HTMLElement>("[data-mob-opt]"));
    const focused = document.activeElement as HTMLElement;
    const idx = opts.indexOf(focused);

    if (e.key === "ArrowDown") { e.preventDefault(); opts[(idx + 1) % opts.length]?.focus(); }
    else if (e.key === "ArrowUp") { e.preventDefault(); opts[(idx - 1 + opts.length) % opts.length]?.focus(); }
    else if (e.key === "Enter" || e.key === " ") { e.preventDefault(); focused.click(); }
    else if (e.key === "Escape") { closeDropdown(); trigger.focus(); }
  });

  // ── Load more + See all ───────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>("[data-loadmore]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const wrap = btn.closest("[data-loadmore-wrap]") as HTMLElement | null;
      const panel = btn.closest("[data-panel]");
      const moreGrid = panel?.querySelector<HTMLElement>("[data-more]");
      const seeAll = wrap?.querySelector<HTMLElement>("[data-seeall]");

      if (moreGrid) {
        moreGrid.removeAttribute("hidden");
      }

      btn.style.transition = "opacity 150ms ease";
      btn.style.opacity = "0";
      setTimeout(() => {
        btn.style.display = "none";

        if (seeAll) {
          seeAll.removeAttribute("hidden");
        } else {
          if (wrap &&!seeAll) {
            wrap.style.transition = "opacity 150ms ease";
            wrap.style.opacity = "0";
            setTimeout(() => wrap.remove(), 160);
          }
        }
      }, 160);
    });
  });
</script>