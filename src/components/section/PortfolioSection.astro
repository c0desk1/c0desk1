---
import Button from '../ui/Button.astro';
import ProjectCard from '@/components/portfolio/PortfolioCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'portfolio'>[];
}

const { projects } = Astro.props;
---

<div class="section-divider py-4 md:py-8">
  <div class="mb-4 md:mb-8">
    <h2 class="text-2xl md:text-3xl font-semibold text-(--fg)">
      Proyek Terbaru.
    </h2>
  </div>
  {projects.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 divide-y md:divide-y-0 divide-(--border)">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  ) : (
    <div class="py-12 text-center border border-dashed border-(--border) rounded-lg">
      <p class="text-(--fg-subtle) text-sm md:text-lg">
        ▼ Belum ada proyek.
      </p>
    </div>
  )}
    <div class="flex justify-center mt-8">
    <Button href="/portfolio/" variant="secondary" size="md">
      Lihat semua
    </Button>
  </div>
</div>
