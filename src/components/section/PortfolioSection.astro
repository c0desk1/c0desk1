---
import Button from '../ui/Button.astro';
import ProjectCard from '@/components/portfolio/PortfolioCard.astro';
import type { CollectionEntry } from 'astro:content';
import { getCurrentLocale, localizePath } from '@/utils/i18n';

interface Props {
  projects: CollectionEntry<'portfolio'>[];
}

const { projects } = Astro.props;
const locale = getCurrentLocale(Astro);

const labels = {
  id: {
    latestProjects: "Proyek Terbaru.",
    noProjects: "Belum ada proyek.",
    viewAll: "Lihat semua"
  },
  en: {
    latestProjects: "Latest Projects.",
    noProjects: "No projects yet.",
    viewAll: "View all"
  },
  ru: {
    latestProjects: "Последние проекты.",
    noProjects: "Пока нет проектов.",
    viewAll: "Смотреть все"
  }
}

const t = labels[locale] || labels.id;
---

<div class="py-4 md:py-8">
  <div class="mb-4 md:mb-8">
    <h2 class="text-(--fg) text-3xl md:text-4xl font-semibold tracking-tighter">
      {t.latestProjects}
    </h2>
  </div>
  {projects.length > 0? (
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 divide-y md:divide-y-0 divide-(--border)">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  ) : (
    <div class="py-12 text-center border border-dashed border-(--border) rounded-lg">
      <p class="text-(--fg-subtle) text-sm md:text-lg">
        {t.noProjects}
      </p>
    </div>
  )}
  <div class="flex justify-center my-16">
    <Button href={localizePath('/portfolio/', locale)} variant="secondary" size="md">
      {t.viewAll}
    </Button>
  </div>
</div>