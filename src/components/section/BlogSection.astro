---
// src/components/blog/BlogLatest.astro
import type { CollectionEntry } from 'astro:content';
import { getCurrentLocale, getLabel, localizePath } from "@/utils/i18n";

import C from "@/components/ui/C.astro";
import PostCard from '@/components/blog/PostCard.astro';
import Button from '@/components/ui/Button.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const locale = getCurrentLocale(Astro);
const blogPath = localizePath('/blog', locale);

const latestTitle = getLabel(locale, 'home_BlogSection');
const noPostsText = getLabel(locale, 'blog_noBlogPosts');
const viewAllText = getLabel(locale, 'blog_viewAll');
---

<div class="relative py-4 md:py-8">
  <div class="mb-4 md:mb-8">
    <h2 class="text-heading-32 md:text-heading-40 text-(--fg)">
      {latestTitle}
    </h2>
  </div>
  {posts.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-4 md:gap-x-8">
      {posts.map(post => (
        <div class="p-0">
          <PostCard post={post} />
        </div>
      ))}
    </div>
  ) : (
    <div class="py-12 text-center border border-dashed border-(--border) rounded-lg">
      <p class="text-copy-16 md:text-copy-18 text-(--fg-subtle)">
        {noPostsText}
      </p>
    </div>
  )}

  <div class="flex justify-center my-16">
    <Button href={blogPath} variant="secondary" size="md">
      {viewAllText}
    </Button>
  </div>
</div>