---
// src/components/mdx/Heading.astro
import Icon from "../ui/Icon.astro";
const { as: Tag = 'h2', id: propId, ...props } = Astro.props;

const raw = await Astro.slots.render('default');
const text = raw.replace(/<[^>]+>/g, '').trim();

const id = propId ?? text
  .toLowerCase()
  .replace(/\s+/g, '-')
  .replace(/[^\w-]+/g, '');
---

<Tag id={id} {...props} class:list={["group has-anchor", props.class]}>
  <span class="heading-text-content"><slot /></span>
  <a href={`#${id}`} class="anchor-link" aria-label="Link ke heading ini">
    <Icon name="link" />
  </a>
</Tag>