---
// src/components/mdx/HeadingAnchor.astro
import Icon from "../ui/Icon";
import { slugify } from "@/lib/utils";
import { getCurrentLocale } from "@/utils/i18n";

const locale = getCurrentLocale(Astro);
const { as: Tag = 'h2', id: _, ...props } = Astro.props;

const raw = await Astro.slots.render('default');
const text = raw.replace(/<[^>]+>/g, '').trim();
const id = slugify(text, 80);

const anchorLabels: Record<string, string> = {
  id: "Tautan ke judul ini",
  en: "Link to this heading",
  ru: "Ссылка на этот заголовок",
  jp: "この見出しへのリンク",
};
const anchorLabel = anchorLabels[locale] || anchorLabels.id;

const headingClasses: Record<string, string> = {
  h1: "text-heading-32 md:text-heading-40 lg:text-heading-56",
  h2: "text-heading-24 md:text-heading-32",
  h3: "text-heading-20 md:text-heading-24",
  h4: "text-heading-16 md:text-heading-20",
  h5: "text-label-14",
  h6: "text-label-12",
};
const classes = headingClasses[Tag] || "text-heading-20";
---

<Tag id={id} {...props} class:list={["heading-group has-anchor", classes, props.class]}>
  <span class="heading-text-content"><slot /></span>
  <a href={`#${id}`} class="anchor-link" aria-label={anchorLabel}>
    <Icon name="link" />
  </a>
</Tag>