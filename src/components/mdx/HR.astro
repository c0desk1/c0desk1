---
// src/components/mdx/Divider.astro
---
<div class="divider-full max-w-7xl" aria-hidden="true">
  <div class="flex items-center gap-2">
    <div class="h-px flex-1 bg-(--prose-border)/60"></div>
    <span class="text-(--prose-fg-subtle) text-base select-none tracking-widest">∅</span>
    <div class="h-px flex-1 bg-(--prose-border)/60"></div>
  </div>
</div>

<style is:inline>
  .divider-full {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    max-width: 80rem;
    box-sizing: border-box;
    padding: 0 1rem;
    margin: 2rem 0;
  }
  @media (min-width: 768px) {
    .divider-full {
      padding: 0 1.5rem;
    }
  }
  @media (min-width: 1024px) {
    .divider-full {
      padding: 0 2rem;
    }
  }
  @media (min-width: 1280px) {
    .divider-full {
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>