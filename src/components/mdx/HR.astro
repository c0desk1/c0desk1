---
// src/components/mdx/HR.astro
interface Props {
  variant?: 'grain' | 'fade' | 'void';
  class?: string;
}

const { variant = 'grain', class: className } = Astro.props;
---

<hr class:list={['hr-bn', `hr-bn-${variant}`, className]} />

<style>
  .hr-bn {
    margin: 2rem 0;
    border: none;
    overflow: visible;
  }

  .hr-bn-void {
    height: 0;
    margin: 3rem 0;
  }

  .hr-bn-fade {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--prose-hr) 20%,
      var(--prose-hr) 80%,
      transparent
    );
  }

  .hr-bn-grain {
    height: 2px;
    background: linear-gradient(
      to right,
      transparent,
      var(--prose-hr-strong) 10%,
      var(--prose-hr-strong) 90%,
      transparent
    );
    position: relative;
  }

  .hr-bn-grain::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
    opacity: 0.7;
    pointer-events: none;
  }

  @media (max-width: 767px) {
    .hr-bn {
      margin: 2rem 0;
    }
    .hr-bn-void {
      margin: 2rem 0;
    }
  }
</style>