---
// src/components/mdx/Blockquote.astro
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  author?: string;
}

const { author: authorSlug } = Astro.props;

let finalAuthor = '';
let finalRole = '';
let finalAvatar = '';
let optimizedAvatar = '';

if (authorSlug) {
  try {
    const authorEntry = await getEntry('authors', authorSlug);
    if (authorEntry) {
      finalAuthor = authorEntry.data.name;
      finalRole = authorEntry.data.role ?? '';
      finalAvatar = authorEntry.data.avatar ?? '';

      if (finalAvatar) {
        optimizedAvatar = isCdnUrl(finalAvatar)
          ? cdnImage(finalAvatar, { w: 48, h: 48, q: 80 })
          : finalAvatar;
      }
    }
  } catch {
    // fallback
  }
}
---

<blockquote class="quote flex flex-col items-stretch justify-start gap-6 lg:gap-8 flex-initial">
  <div class="quote-body text-heading-20 md:text-heading-24">
    <slot />
  </div>

  {(finalAuthor || finalRole) && (
    <div class="flex flex-col md:flex-row items-end md:items-center justify-end gap-2 md:gap-3 flex-initial">
      <div class="w-6 h-6 shrink-0 overflow-hidden flex items-center justify-center">
        {finalAvatar && (
          <Image
            src={optimizedAvatar}
            alt={finalAuthor}
            width={48}
            height={48}
            loading="lazy"
            decoding="async"
            class="block h-full w-full object-cover rounded-full border border-(--border)"
          />
        )}
      </div>

      {finalAuthor && (
        <span class="quote-name text-label-14 md:text-label-16">
          {finalAuthor}
        </span>
      )}

      {finalRole && (
        <span class="quote-role text-copy-14 md:text-copy-16">
          {finalRole}
        </span>
      )}
    </div>
  )}
</blockquote>