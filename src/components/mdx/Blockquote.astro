---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Icon from '@/components/ui/Icon';
import { cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  author?: string;
  cite?: string;
  citeLabel?: string;
}

const { author: authorSlug, cite, citeLabel } = Astro.props;

let finalAuthor = '';
let finalRole = '';
let finalAvatar = '';

if (authorSlug) {
  try {
    const authorEntry = await getEntry('authors', authorSlug);
    if (authorEntry) {
      finalAuthor = authorEntry.data.name;
      finalRole = authorEntry.data.role ?? '';
      finalAvatar = authorEntry.data.avatar ?? '';
      if (finalAvatar && isCdnUrl(finalAvatar)) {
        finalAvatar = cdnImage(finalAvatar, { w: 48, h: 48, q: 80 });
      }
    } else {
      finalAuthor = authorSlug;
    }
  } catch {
    finalAuthor = authorSlug;
  }
}

const showCredit = finalAuthor || cite;
---

<blockquote class="quote" cite={cite}>
  <div class="quote-body text-body-20 lg:text-heading-32 font-semibold">
    <slot />
  </div>
  {showCredit && (
    <div class="quote-footer">
      {finalAuthor && (
        <div class="quote-author">
          {finalAvatar && (
            <Image
              src={finalAvatar}
              alt={finalAuthor}
              width={24}
              height={24}
              class="quote-avatar"
              loading="lazy"
              decoding="async"
            />
          )}
          <span class="quote-name">{finalAuthor}</span>
          {finalRole && <span class="quote-role">{finalRole}</span>}
        </div>
      )}
      {cite && (
        <div class="quote-cite">
          <a href={cite} target="_blank" rel="noopener noreferrer">
            {citeLabel || 'Source'}
            <Icon name="external" className="w-3 h-3 ml-1" />
          </a>
        </div>
      )}
    </div>
  )}
</blockquote>