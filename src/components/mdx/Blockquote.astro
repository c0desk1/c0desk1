---
// src/components/mdx/Blockquote.astro
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Icon from '@/components/ui/Icon';
import { cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  author?: string;
  cite?: string;
  citeLabel?: string;
}

const { author: authorSlug, cite, citeLabel } = Astro.props;

let isAuthorMode = false;
let isPlainSource = false;
let isCiteMode = !!cite;

let finalAuthor = '';
let finalRole = '';
let finalAvatar = '';
let optimizedAvatar = '';

if (!isCiteMode && authorSlug) {
  if (authorSlug.includes(' ') || !/^[a-z0-9-]+$/.test(authorSlug)) {
    isPlainSource = true;
    finalAuthor = authorSlug;
  } else {
    try {
      const authorEntry = await getEntry('authors', authorSlug);
      if (authorEntry) {
        isAuthorMode = true;
        finalAuthor = authorEntry.data.name;
        finalRole = authorEntry.data.role ?? '';
        finalAvatar = authorEntry.data.avatar ?? '';

        if (finalAvatar) {
          optimizedAvatar = isCdnUrl(finalAvatar)
            ? cdnImage(finalAvatar, { w: 48, h: 48, q: 80 })
            : finalAvatar;
        }
      } else {
        isPlainSource = true;
        finalAuthor = authorSlug;
      }
    } catch {
      isPlainSource = true;
      finalAuthor = authorSlug;
    }
  }
}
---

<blockquote class="quote flex flex-col items-stretch justify-start gap-6 lg:gap-8 flex-initial" cite={cite}>
  <div class="quote-body text-heading-20 md:text-heading-24 font-semibold text-start">
    <slot />
  </div>
  {isAuthorMode && (finalAuthor || finalRole) && (
    <div class="author-info flex flex-col md:flex-row items-end md:items-center justify-end gap-2 md:gap-3 flex-initial">
      <div class="w-6 h-6 shrink-0 overflow-hidden flex items-center justify-center">
        {finalAvatar && (
          <Image
            src={optimizedAvatar}
            alt={finalAuthor}
            width={48}
            height={48}
            loading="lazy"
            decoding="async"
            class="block h-full w-full object-cover rounded-full border border-(--border)"
          />
        )}
      </div>
      <span class="quote-name text-label-14 md:text-label-16">{finalAuthor}</span>
      {finalRole && (<span class="quote-role text-copy-14 md:text-copy-16">{finalRole}</span>)}
    </div>
  )}
  {isPlainSource && finalAuthor && (<div class="quote-role text-copy-14 md:text-copy-16 self-end">{finalAuthor}</div>)}
  {isCiteMode && cite && (
    <div class="quote-role text-label-14 md:text-label-16 self-end">
      <a href={cite} target="_blank" rel="noopener noreferrer" class="flex items-center">
        {citeLabel || 'Source'}
        <Icon name="external" className="external-icon w-3 h-3"/>
      </a>
    </div>
  )}
</blockquote>
