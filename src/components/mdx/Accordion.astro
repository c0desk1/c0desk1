---
import Icon from '@/components/ui/icons/Icon.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="accordion not-prose border border-(--prose-border) rounded-lg overflow-hidden my-4">
  <button type="button" class="accordion-trigger flex items-center justify-between w-full px-5 py-4 text-left bg-muted/40 hover:bg-subtle active:bg-subtle transition-colors">
    <span class="text-heading-14 md:text-heading-16 font-semibold text-(--fg)">{title}</span>
    <span class="shrink-0 inline-flex justify-center items-center w-4 h-4 text-muted">
      <Icon name="chevron-down" className="accordion-icon w-full h-full transition-transform duration-300" />
    </span>
  </button>
  <div class="accordion-content-wrapper overflow-hidden transition-all duration-300" style="max-height: 0;">
    <div class="accordion-content-inner m-4 pt-1 text-body-14">
      <slot />
    </div>
  </div>
</div>

<script>
  function setupAccordions() {
    document.querySelectorAll('.accordion:not(.is-initialized)').forEach((el) => {
      const accordion = el as HTMLElement;
      accordion.classList.add('is-initialized');

      const trigger = accordion.querySelector('.accordion-trigger');
      const wrapper = accordion.querySelector<HTMLElement>('.accordion-content-wrapper');
      const icon = accordion.querySelector<HTMLElement>('.accordion-icon');

      if (!trigger || !wrapper || !icon) return;

      trigger.addEventListener('click', () => {
        const isOpen = accordion.classList.contains('open');
        if (isOpen) {
          wrapper.style.maxHeight = '0';
          icon.style.transform = 'rotate(0deg)';
          accordion.classList.remove('open');
        } else {
          const inner = wrapper.querySelector<HTMLElement>('.accordion-content-inner');
          if (!inner) return;
          wrapper.style.maxHeight = 'none';
          const contentHeight = inner.offsetHeight;
          wrapper.style.maxHeight = '0';
          wrapper.offsetHeight;
          wrapper.style.maxHeight = `${contentHeight + 32}px`;
          icon.style.transform = 'rotate(180deg)';
          accordion.classList.add('open');
        }
      });
    });
  }

  document.addEventListener('astro:page-load', setupAccordions);
  setupAccordions();
</script>