---
// src/components/mdx/Accordion.astro
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<details class="not-prose my-4 rounded-lg border border-zinc-200 dark:border-zinc-800">
  <summary class="cursor-pointer p-4 font-medium text-zinc-900 dark:text-white hover:bg-zinc-50 dark:hover:bg-zinc-900/50 transition-colors">
    {title}
  </summary>
  <div class="border-t border-zinc-200 dark:border-zinc-800 p-4">
    <slot />
  </div>
</details>