---
interface Props {
  titles?: string[]; // Made optional with '?' to prevent crashes
}

const { titles = ["Code"] } = Astro.props; // Default to ["Code"] if empty
---

<div class="not-prose my-6 overflow-hidden rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-950">
  <div class="flex overflow-x-auto border-b border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/50">
    {titles.map((title, index) => (
      <button
        data-code-tab={index}
        class="px-4 py-2 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors data-[active=true]:border-b-2 data-[active=true]:border-zinc-900 dark:data-[active=true]:border-white data-[active=true]:text-zinc-900 dark:data-[active=true]:text-white"
      >
        {title}
      </button>
    ))}
  </div>
  <div class="code-group-content [&_pre]:!my-0 [&_pre]:!rounded-none">
    <slot />
  </div>
</div>

<script>
  // Added a check to ensure code runs only when tabs exist
  const initTabs = () => {
    const tabs = document.querySelectorAll('[data-code-tab]');
    const contents = document.querySelector('.code-group-content')?.children;
    
    if (tabs.length && contents) {
      const activate = (index: number) => {
        tabs.forEach((tab, i) => {
          tab.setAttribute('data-active', (i === index).toString());
          if (contents[i]) {
            (contents[i] as HTMLElement).style.display = i === index ? 'block' : 'none';
          }
        });
      };
      tabs.forEach((tab, i) => tab.addEventListener('click', () => activate(i)));
      activate(0);
    }
  };

  // Run on initial load
  initTabs();
  // Run on view transitions if you use them
  document.addEventListener('astro:after-swap', initTabs);
</script>