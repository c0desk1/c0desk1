---
// src/components/mdx/CodeGroup.astro

import Icon from '@/components/ui/Icon.astro';

interface Props {
  titles?: string[];
}

const { titles = ["Code"] } = Astro.props;
---

<div class="code-group not-prose mx-auto max-w-3xl my-8 overflow-hidden border border-(--prose-border) bg-(--prose-surface)">
  <div class="flex items-center justify-between border-b border-(--prose-border) px-2">
    <div class="flex overflow-x-auto no-scrollbar">
      {titles.map((title, index) => (
        <button
          data-code-tab={index}
          class="
            relative px-4 py-2.5
            text-xs font-semibold tracking-wide
            text-(--prose-fg-subtle) hover:text-(--prose-fg)
            data-[active=true]:text-(--prose-fg)
            transition-colors duration-150
          "
        >
          {title}
          <span class="absolute bottom-0 left-0 h-0.5 w-full rounded-full scale-x-0 bg-(--prose-accent) transition-transform duration-200 [button[data-active=true]>&]:scale-x-100" />
        </button>
      ))}
    </div>
    <button
      class="copy-button p-2 text-(--prose-fg-subtle) hover:text-(--prose-accent) cursor-pointer transition-colors duration-150"
      aria-label="Copy code"
    >
      <Icon name="copy" class="copy-icon w-4 h-4" />
      <Icon name="check" class="check-icon w-4 h-4 hidden text-(--prose-accent)" />
    </button>
  </div>
  <div class="code-group-content">
    <slot />
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar { 
    display: none; 
  }
  
  .no-scrollbar { 
    -ms-overflow-style: none; 
    scrollbar-width: none; 
  }
  
  /* Hanya tambahkan ini - tidak override yang sudah ada di prose-custom */
  .code-group-content > :not(:first-child) { 
    display: none; 
  }
  
  /* Tambahan untuk mobile tap */
  .copy-button, [data-code-tab] {
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }
  
  /* Tooltip hanya untuk device dengan hover */
  @media (hover: hover) and (pointer: fine) {
    .copy-button {
      position: relative;
    }
    .copy-button:hover::after {
      content: "copy";
      position: absolute;
      bottom: -28px;
      left: 50%;
      transform: translateX(-50%);
      padding: 4px 8px;
      background: var(--prose-surface);
      border: 1px solid var(--prose-border);
      border-radius: var(--prose-radius-sm);
      font-size: 10px;
      font-family: var(--prose-font-mono);
      color: var(--prose-fg-subtle);
      white-space: nowrap;
      pointer-events: none;
      z-index: 20;
    }
  }
</style>

<script>
  const initCodeGroup = () => {
    document.querySelectorAll<HTMLElement>('.code-group').forEach(group => {
      const tabs = group.querySelectorAll<HTMLButtonElement>('[data-code-tab]');
      const contents = group.querySelector('.code-group-content')?.children;
      const copyBtn = group.querySelector<HTMLButtonElement>('.copy-button');

      if (!tabs.length || !contents) return;

      const activate = (index: number) => {
        tabs.forEach((tab, i) => {
          tab.setAttribute('data-active', String(i === index));
          if (contents[i]) {
            (contents[i] as HTMLElement).style.display = i === index ? 'block' : 'none';
          }
        });
      };

      tabs.forEach((tab, i) => tab.addEventListener('click', () => activate(i)));

      copyBtn?.addEventListener('click', async () => {
        const active = Array.from(contents).find(c => (c as HTMLElement).style.display !== 'none');
        const code = active?.querySelector('code')?.innerText;
        if (!code) return;

        await navigator.clipboard.writeText(code);

        const copyIcon  = copyBtn.querySelector('.copy-icon');
        const checkIcon = copyBtn.querySelector('.check-icon');
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');

        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
        }, 2000);
      });

      activate(0);
    });
  };

  initCodeGroup();
  document.addEventListener('astro:after-swap', initCodeGroup);
</script>