---
import Icon from '@/components/ui/Icon';

interface Props {
  titles?: string[];
}

const { titles = ["Code"] } = Astro.props;
---

<div class="code-group">
  <div class="code-group-wrapper">
    <div class="code-group-header" role="tablist">
      {titles.map((title, index) => (
        <button
          data-code-tab={index}
          role="tab"
          aria-selected={index === 0 ? "true" : "false"}
          class="code-group-title"
        >
          {title}
          <span class="underline-indicator" />
        </button>
      ))}
    </div>
    <button
      class="copy-button"
      aria-label="Copy code"
    >
      <Icon name="copy" className="copy-icon w-4 h-4" />
      <Icon name="check" className="check-icon w-4 h-4 hidden text-(--prose-accent)" />
    </button>
  </div>
  <div class="code-group-content" role="tabpanel">
    <slot />
  </div>
</div>

<script>
  const initCodeGroup = () => {
    document.querySelectorAll<HTMLElement>('.code-group').forEach(group => {
      const tabs = group.querySelectorAll<HTMLButtonElement>('[data-code-tab]');
      const contents = group.querySelector('.code-group-content')?.children;
      const copyBtn = group.querySelector<HTMLButtonElement>('.copy-button');

      if (!tabs.length || !contents) return;

      const activate = (index: number) => {
        tabs.forEach((tab, i) => {
          const isActive = i === index;
          tab.setAttribute('data-active', String(isActive));
          tab.setAttribute('aria-selected', String(isActive));
          if (contents[i]) {
            (contents[i] as HTMLElement).style.display = isActive ? 'block' : 'none';
          }
        });
      };

      tabs.forEach((tab, i) => tab.addEventListener('click', () => activate(i)));

      copyBtn?.addEventListener('click', async () => {
        const active = Array.from(contents).find(c => (c as HTMLElement).style.display !== 'none');
        const code = active?.querySelector('code')?.textContent;

        if (!code) {
          alert('Tidak ada kode untuk disalin');
          return;
        }

        try {
          await navigator.clipboard.writeText(code);

          const toast = (window as any).toast;
          if (toast && typeof toast.show === 'function') {
            toast.show('Berhasil disalin!', { type: 'success', duration: 2000 });
          } else {
            alert('Berhasil disalin!');
          }

          const copyIcon = copyBtn.querySelector('.copy-icon');
          const checkIcon = copyBtn.querySelector('.check-icon');
          copyIcon?.classList.add('hidden');
          checkIcon?.classList.remove('hidden');

          setTimeout(() => {
            copyIcon?.classList.remove('hidden');
            checkIcon?.classList.add('hidden');
          }, 2000);
        } catch (err) {
          console.error('Gagal copy:', err);
          const toast = (window as any).toast;
          if (toast && typeof toast.show === 'function') {
            toast.show('Gagal menyalin kode', { type: 'error', duration: 2500 });
          } else {
            alert('Gagal menyalin kode. Silakan coba manual.');
          }
        }
      });

      activate(0);
    });
  };

  initCodeGroup();
  document.addEventListener('astro:after-swap', initCodeGroup);
</script>
