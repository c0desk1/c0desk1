---
// src/components/mdx/CodeGroup.astro
interface Props {
  titles?: string[];
}

const { titles = ["Code"] } = Astro.props;
---

<div
  class="code-group not-prose mx-auto max-w-3xl my-8 overflow-hidden rounded-[var(--prose-radius-md)] border border-[var(--prose-border)] bg-[var(--prose-surface)]"
>
  <!-- Tab bar -->
  <div class="flex items-center justify-between border-b border-[var(--prose-border)] px-2">
    <div class="flex overflow-x-auto no-scrollbar">
      {titles.map((title, index) => (
        <button
          data-code-tab={index}
          class="
            relative px-4 py-2.5
            text-xs font-semibold tracking-wide
            text-[var(--prose-fg-subtle)] hover:text-[var(--prose-fg)]
            data-[active=true]:text-[var(--prose-fg)]
            transition-colors duration-150
          "
        >
          {title}
          <span class="absolute bottom-0 left-0 h-0.5 w-full rounded-full scale-x-0 bg-[var(--prose-emerald)] transition-transform duration-200 [button[data-active=true]>&]:scale-x-100" />
        </button>
      ))}
    </div>

    <!-- Copy button -->
    <button
      class="copy-button p-2 text-[var(--prose-fg-subtle)] hover:text-[var(--prose-emerald)] cursor-pointer transition-colors duration-150"
      aria-label="Copy code"
    >
      <!-- Copy icon -->
      <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      <!-- Check icon -->
      <svg class="check-icon hidden text-[var(--prose-emerald)]" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </button>
  </div>

  <!-- Code content -->
  <div class="code-group-content [&_pre]:m-0! [&_pre]:rounded-none! [&_pre]:border-none! [&_pre]:bg-transparent!">
    <slot />
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .code-group-content > :global(*:not(:first-child)) { display: none; }
</style>

<script>
  const initCodeGroup = () => {
    document.querySelectorAll<HTMLElement>('.code-group').forEach(group => {
      const tabs = group.querySelectorAll<HTMLButtonElement>('[data-code-tab]');
      const contents = group.querySelector('.code-group-content')?.children;
      const copyBtn = group.querySelector<HTMLButtonElement>('.copy-button');

      if (!tabs.length || !contents) return;

      const activate = (index: number) => {
        tabs.forEach((tab, i) => {
          tab.setAttribute('data-active', String(i === index));
          if (contents[i]) {
            (contents[i] as HTMLElement).style.display = i === index ? 'block' : 'none';
          }
        });
      };

      tabs.forEach((tab, i) => tab.addEventListener('click', () => activate(i)));

      copyBtn?.addEventListener('click', async () => {
        const active = Array.from(contents).find(c => (c as HTMLElement).style.display !== 'none');
        const code = active?.querySelector('code')?.innerText;
        if (!code) return;

        await navigator.clipboard.writeText(code);

        const copyIcon  = copyBtn.querySelector('.copy-icon');
        const checkIcon = copyBtn.querySelector('.check-icon');
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');

        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
        }, 2000);
      });

      activate(0);
    });
  };

  initCodeGroup();
  document.addEventListener('astro:after-swap', initCodeGroup);
</script>