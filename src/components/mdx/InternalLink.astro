---
// src/components/mdx/InternalLink.astro

interface Props {
  allPosts: any[];
}

const { allPosts } = Astro.props;
const html = await Astro.slots.render("default");

/* ================================
   BUILD KEYWORD MAP
================================ */

const keywordMap: Record<string, string> = {};

allPosts.forEach(post => {

  const words =
    post.data.title
      .toLowerCase()
      .replace(/[^\w\s]/g, "")
      .split(/\s+/)
      .filter((w: string) => w.length >= 5)
      .slice(0, 3); // 🔥 WAJIB dibatasi

  words.forEach((word: string) => {

    if (!keywordMap[word]) {

      keywordMap[word] =
        `/blog/${post.id}/`;

    }

  });

});

const sortedKeywords =
  Object.keys(keywordMap)
    .sort((a, b) => b.length - a.length);

/* ================================
   PROTECT FORBIDDEN BLOCKS
================================ */

const forbiddenBlocks: string[] = [];

let protectedHtml =
  html.replace(

    /<(h[1-6]|pre|code|button|a|svg|kbd|[A-Z][A-Za-z0-9]*)[^>]*>[\s\S]*?<\/\1>/g,

    (match) => {

      forbiddenBlocks.push(match);

      return `__BLOCK_${forbiddenBlocks.length - 1}__`;

    }

  );

/* ================================
   SPLIT TEXT / TAG
================================ */

const parts =
  protectedHtml.split(/(<[^>]+>)/g);

/* ================================
   LINK INJECTION
================================ */

let totalLinks = 0;

const MAX_LINKS = 8; // 🔥 SEO-safe

const processedParts =
  parts.map((part) => {

    if (part.startsWith("<"))
      return part;

    let text = part;

    for (const keyword of sortedKeywords) {

      const url =
        keywordMap[keyword];

      const regex =
        new RegExp(
          `\\b(${keyword})\\b`,
          "gi"
        );

      text =
        text.replace(
          regex,
          (match) => {

            if (
              totalLinks >= MAX_LINKS
            ) {
              return match;
            }

            totalLinks++;

            return `
<a href="${url}" class="internal-link">
〄 ${match}
</a>`;

          }
        );

    }

    return text;

  });

let finalHtml =
  processedParts.join("");

/* ================================
   RESTORE BLOCKS
================================ */

finalHtml =
  finalHtml.replace(
    /__BLOCK_(\d+)__/g,
    (_, i) =>
      forbiddenBlocks[
        Number(i)
      ]
  );

---

<Fragment set:html={finalHtml} />

<style is:global>

.internal-link {

  display: inline-flex;
  align-items: center;
  gap: 0.375rem;

  padding: 0.125rem 0.5rem;

  border-radius: 6px;

  font-size: 0.875rem;
  font-weight: 500;

  text-decoration: none !important;

  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);

  background-color:
    rgba(0, 0, 0, 0.05);

  color: #171717;

  border:
    1px solid rgba(0, 0, 0, 0.08);

}

:global(.dark) .internal-link {

  background-color:
    rgba(255, 255, 255, 0.06);

  color: #ededed;

  border:
    1px solid rgba(255, 255, 255, 0.1);

}

.internal-link:hover {

  background-color:
    rgba(0, 0, 0, 0.08);

  border-color:
    rgba(0, 0, 0, 0.2);

  transform:
    translateY(-1px);

}

:global(.dark)
.internal-link:hover {

  background-color:
    rgba(255, 255, 255, 0.12);

  border-color:
    rgba(255, 255, 255, 0.25);

}

</style>