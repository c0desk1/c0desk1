---
// src/components/mdx/InternalLink.astro
interface Props {
  allPosts: any[];
}

const { allPosts } = Astro.props;
const html = await Astro.slots.render('default');

const keywordMap: Record<string, string> = {};
allPosts.forEach(post => {
  const words = post.data.title
    .toLowerCase()
    .replace(/[^\w\s]/g, "")
    .split(/\s+/)
    .filter((w: string) => w.length >= 5);
  
  words.forEach((word: string) => {
    if (!keywordMap[word]) keywordMap[word] = `/blog/${post.id}/`;
  });
});

const sortedKeywords = Object.keys(keywordMap).sort((a, b) => b.length - a.length);

const parts = html.split(/(<[^>]+>)/g);
const processedParts = parts.map((part) => {
  if (part.startsWith('<')) return part;

  let text = part;
  for (const keyword of sortedKeywords) {
    const url = keywordMap[keyword];
    const regex = new RegExp(`\\b(${keyword})\\b`, "gi");
    
    text = text.replace(regex, `<a href="${url}" class="internal-link">〄 $1</a>`);
  }
  return text;
});

let processedHtml = processedHtml = processedParts.join('');

processedHtml = processedHtml.replace(/<(h[1-6]|pre|code|button)[^>]*>([\s\S]*?)<\/\1>/gi, (match) => {
  return match.replace(/<a href="\/blog\/[^"]*" class="internal-link">〄 (.*?)<\/a>/gi, '$1');
});
---

<Fragment set:html={processedHtml} />

<style is:global>
  .internal-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none !important;
    transition: all 0.2s ease;
    background-color: rgba(0, 0, 0, 0.05);
    color: #171717;
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  :global(.dark) .internal-link {
    background-color: rgba(255, 255, 255, 0.08);
    color: #ededed;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .internal-link:hover {
    background-color: rgba(0, 0, 0, 0.1);
    border-color: rgba(0, 0, 0, 0.3);
    transform: translateY(-1px);
  }

  :global(.dark) .internal-link:hover {
    background-color: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.4);
  }
</style>