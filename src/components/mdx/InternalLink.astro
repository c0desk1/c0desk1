---
// src/components/mdx/InternalLink.astro
interface Props {
  allPosts: any[];
}

const { allPosts } = Astro.props;
const html = await Astro.slots.render('default');

// 1. Siapkan Keyword Map
const keywordMap: Record<string, string> = {};
allPosts.forEach(post => {
  const words = post.data.title
    .toLowerCase()
    .replace(/[^\w\s]/g, "")
    .split(/\s+/)
    .filter((w: string) => w.length >= 5);
  
  words.forEach((word: string) => {
    if (!keywordMap[word]) keywordMap[word] = `/blog/${post.id}/`;
  });
});

const sortedKeywords = Object.keys(keywordMap).sort((a, b) => b.length - a.length);

// 2. LOGIKA ANTI-BOCOR: Split HTML berdasarkan Tag
// Regex ini memecah string menjadi array: [teks, <tag>, teks, <tag>, ...]
const parts = html.split(/(<[^>]+>)/g);

const processedParts = parts.map((part) => {
  // Jika ini adalah tag HTML, biarkan apa adanya (JANGAN DISENTUH)
  if (part.startsWith('<')) {
    return part;
  }

  // Jika ini adalah teks biasa, lakukan injeksi link
  let text = part;
  
  // Kita cek apakah teks ini berada di area terlarang secara manual
  // Namun dengan Split, kita sudah otomatis melindungi isi atribut tag (seperti src, href, class)
  
  for (const keyword of sortedKeywords) {
    const url = keywordMap[keyword];
    const regex = new RegExp(`\\b(${keyword})\\b`, "gi");
    
    // Vercel Style Injection
    text = text.replace(regex, `<a href="${url}" class="internal-link">〄 $1</a>`);
  }
  
  return text;
});

let processedHtml = processedParts.join('');

/**
 * PROTEKSI EXTRA: 
 * Karena kita menggunakan MDX, heading dan codeblock biasanya dibungkus tag <h1>...</h1> atau <pre>...
 * Kita gunakan Regex terakhir untuk membersihkan link yang "terlanjur" masuk ke tag terlarang tersebut.
 */
processedHtml = processedHtml.replace(/<(h[1-6]|pre|code|button)[^>]*>([\s\S]*?)<\/\1>/gi, (match) => {
  return match.replace(/<a href="\/blog\/[^"]*" class="internal-link">〄 (.*?)<\/a>/gi, '$1');
});
---

<Fragment set:html={processedHtml} />

<style is:global>
  .internal-link {
    @apply inline-flex items-center gap-1 no-underline transition-all duration-200;
    color: inherit;
    font-weight: 500;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    text-decoration: none !important;
  }

  :global(.dark) .internal-link {
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .internal-link:hover {
    @apply text-black dark:text-white;
    border-bottom-color: currentColor;
    background-color: rgba(0,0,0,0.04);
    border-radius: 2px;
  }
</style>
