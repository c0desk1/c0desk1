---
interface Props {
  allPosts: any[];
}

const { allPosts } = Astro.props;
const html = await Astro.slots.render("default");

const keywordMap: Record<string, string> = {};

allPosts.forEach(post => {
  const words = post.data.title
    .toLowerCase()
    .replace(/[^\w\s]/g, "")
    .split(/\s+/)
    .filter((w: string) => w.length >= 5)
    .slice(0, 2);

  words.forEach((word: string) => {
    if (!keywordMap[word]) {
      keywordMap[word] = `/blog/${post.id}/`;
    }
  });
});

const sortedKeywords = Object.keys(keywordMap).sort((a, b) => b.length - a.length);

const forbiddenBlocks: string[] = [];

let protectedHtml = html.replace(
  /<(h[1-6]|pre|code|button|a|svg|kbd|[A-Z][A-Za-z0-9]*)[^>]*>[\s\S]*?<\/\1>/g,
  (match) => {
    forbiddenBlocks.push(match);
    return `__BLOCK_${forbiddenBlocks.length - 1}__`;
  }
);

const parts = protectedHtml.split(/(<[^>]+>)/g);

let totalLinks = 0;
const MAX_LINKS = 8;
const MIN_DISTANCE = 120;
const usedKeywords = new Set<string>();

const processedParts = parts.map((part) => {
  if (part.startsWith("<")) return part;

  let text = part;
  let lastIndex = -999;

  for (const keyword of sortedKeywords) {
    if (totalLinks >= MAX_LINKS) break;
    if (usedKeywords.has(keyword)) continue;

    const url = keywordMap[keyword];
    if (url === Astro.url.pathname) continue;

    const regex = new RegExp(`\\b(${keyword})\\b(?![^<]*>)`, "gi");

    if (text.search(regex) !== -1) {
      text = text.replace(regex, (match, offset) => {
        if (offset - lastIndex < MIN_DISTANCE || totalLinks >= MAX_LINKS) {
          return match;
        }

        totalLinks++;
        lastIndex = offset;
        usedKeywords.add(keyword);

        forbiddenBlocks.push(`<a href="${url}" class="internal-link">〄 ${match}</a>`);
        return `__BLOCK_${forbiddenBlocks.length - 1}__`;
      });
    }
  }
  return text;
});

let finalHtml = processedParts.join("");
finalHtml = finalHtml.replace(/__BLOCK_(\d+)__/g, (_, i) => forbiddenBlocks[Number(i)]);
---

<Fragment set:html={finalHtml} />

<style is:global>
.internal-link {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.125rem 0.5rem;
  border-radius: 6px;
  font-size: 0.875rem;
  font-weight: 500;
  text-decoration: none !important;
  vertical-align: baseline;
  white-space: nowrap;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;

  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  background-color: rgba(0, 0, 0, 0.05);
  color: #171717;
  border: 1px solid rgba(0, 0, 0, 0.08);
}

.dark .internal-link {
  background-color: rgba(255, 255, 255, 0.06);
  color: #ededed;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.internal-link:hover {
  background-color: rgba(0, 0, 0, 0.08);
  border-color: rgba(0, 0, 0, 0.2);
  transform: translateY(-1px);
}

.dark .internal-link:hover {
  background-color: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.25);
}

.internal-link:active {
  background-color: #d4d4d4;
  border-color: #a3a3a3;
}

.dark .internal-link:active {
  background-color: #333;
  border-color: #525252;
}

.internal-link:focus-visible {
  outline: 2px solid #a3a3a3;
  outline-offset: 1px;
}

.dark .internal-link:focus-visible {
  outline-color: #525252;
}
</style>
