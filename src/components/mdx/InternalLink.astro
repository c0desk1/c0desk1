---
// src/components/mdx/InternalLink.astro
interface Props {
  allPosts: any[];
}

const { allPosts } = Astro.props;
const html = await Astro.slots.render('default');

let processedHtml = html;

const keywordMap: Record<string, string> = {};
allPosts.forEach(post => {
  const words = post.data.title
    .toLowerCase()
    .replace(/[^\w\s]/g, "")
    .split(/\s+/)
    .filter((w: string) => w.length >= 5);
  
  words.forEach((word: string) => {
    if (!keywordMap[word]) keywordMap[word] = `/blog/${post.id}/`;
  });
});

const sortedKeywords = Object.keys(keywordMap).sort((a, b) => b.length - a.length);

for (const keyword of sortedKeywords) {
  const url = keywordMap[keyword];
  const regex = new RegExp(`\\b(${keyword})\\b(?![^<]*>|[^<>]*<\/a>)`, "gi");

  processedHtml = processedHtml.replace(regex, (match, p1, offset) => {
    const textBefore = processedHtml.substring(0, offset);
    const isInsideCode = /<(code|pre)[^>]*>[^<]*$/i.test(textBefore);
    const isInsideHeading = /<(h1|h2|h3|h4|h5|h6)[^>]*>[^<]*$/i.test(textBefore);
    
    if (isInsideCode || isInsideHeading) {
      return match;
    }
    return `<a href="${url}" class="internal-link">〄 ${match}</a>`;
  });
}
---

<Fragment set:html={processedHtml} />

<style is:global>
  .internal-link {
    @apply inline-flex items-center gap-1 no-underline transition-all duration-200;
    color: inherit;
    font-weight: 500;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }

  :global(.dark) .internal-link {
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .internal-link:hover {
    @apply text-black dark:text-white;
    border-bottom-color: currentColor;
    background-color: rgba(0,0,0,0.03);
  }

  :global(.dark) .internal-link:hover {
    background-color: rgba(255,255,255,0.05);
  }
</style>
