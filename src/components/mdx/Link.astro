---
// src/components/mdx/InlineLink.astro

import Icon from '@/components/ui/icons/Icon.astro';

const { href, ...props } = Astro.props;
const site = Astro.site;

const isExternal = href?.startsWith('http') && !href?.startsWith(site?.href || '');
---

<a 
  href={href} 
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "nofollow noopener noreferrer" : undefined}
  class:list={["inline-link", props.class]}
  {...props}
>
  <slot />
  {isExternal && (
    <Icon name="external" className="external-icon w-3.5 h-3.5" />
  )}
</a>
