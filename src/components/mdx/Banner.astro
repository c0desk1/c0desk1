---
// src/components/mdx/Banner.astro
import { Image } from "astro:assets";
import Link from "../ui/Link.astro";
import Icon from "../ui/icons/Icon.astro";

interface Props {
  title?: string;
  icon?: string;
  description?: string;
  links?: string;
}

const {
  title,
  icon,
  description,
  links,
} = Astro.props;

const parsedLinks: { label: string; url: string }[] = links
  ? JSON.parse(links)
  : [];
---

<div class="rounded-xl border border-(--prose-border) bg-(--bg)/50 p-4 backdrop-blur-sm my-6 lg:my-8 transition-colors duration-300 hover:border-(--prose-border-strong)">
  <div class="flex items-start gap-3 sm:gap-4">
    {
      icon && (
        <div class="relative shrink-0 h-10 w-10 lg:h-12 lg:w-12">
          <div class="absolute inset-0 rounded-lg ring-1 ring-inset ring-(--prose-border-strong) opacity-20 z-10 pointer-events-none"></div>
          <Image
            src={icon}
            alt={title || "Ikon"}
            width={48}
            height={48}
            loading="lazy"
            fetchpriority="low"
            decoding="async"
            class="h-full w-full rounded-lg object-cover"
          />
        </div>
      )
    }
    
    <div class="min-w-0 flex-1">
      {
        title && (
          <h3 class="text-heading-16 lg:text-heading-20 font-semibold text-(--prose-fg-strong) mt-0! mb-1! wrap-break-word">
            {title}
          </h3>
        )
      }

      {
        description && (
          <p class="text-body-14 text-(--prose-fg-muted) mb-0! mt-0!">
            {description}
          </p>
        )
      }

      {
        parsedLinks.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2 justify-start sm:justify-end">
            {parsedLinks.map((link) => (
              <Link variant="noir" size="sm" title={link.label} href={link.url} class="text-(--prose-fg-strong) no-underline!">
                <Icon name="download" className="w-4 h-4" />
                {link.label}
              </Link>
            ))}
          </div>
        )
      }
    </div>
  </div>
</div>