---
import { Image } from "astro:assets";

interface Props {
  title?: string;
  icon?: string;
  description?: string;
  links?: string;
}

const {
  title,
  icon,
  description,
  links,
} = Astro.props;

const parsedLinks = links
  ? JSON.parse(links)
  : [];
---

<div class="rounded-2xl border border-(--border) bg-(--bg-muted)/60 p-4">
  <div class="flex items-start gap-3">
    {
      icon && (
        <div class="relative top-0.5 shrink-0">
          <Image
            src={icon}
            alt={title || ""}
            width={48}
            height={48}
            class="h-12 w-12 rounded-lg object-cover"
          />
        </div>
      )
    }
    <div class="min-w-0 flex-1">
      {
        title && (
          <h3 class="text-heading-20 font-semibold mt-0!">
            {title}
          </h3>
        )
      }

      {
        description && (
          <p class="mt-1.5 text-copy-14 text-muted">
            {description}
          </p>
        )
      }

      {
        parsedLinks.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {parsedLinks.map((link: any) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center rounded-md border border-(--border) px-2.5 py-1.5 text-button-14 transition hover:bg-muted gap-2"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="w-3.5 h-3.5" viewBox="0 0 16 16">
                    <path d="M14.222 9.374c1.037-.61 1.037-2.137 0-2.748L11.528 5.04 8.32 8l3.207 2.96zm-3.595 2.116L7.583 8.68 1.03 14.73c.201 1.029 1.36 1.61 2.303 1.055zM1 13.396V2.603L6.846 8zM1.03 1.27l6.553 6.05 3.044-2.81L3.333.215C2.39-.341 1.231.24 1.03 1.27"/>
                </svg>
                {link.label}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</div>
