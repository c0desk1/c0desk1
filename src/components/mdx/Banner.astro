---
import { Image } from "astro:assets";
import Button from "../ui/Button.astro";

interface Props {
  title?: string;
  icon?: string;
  description?: string;
  links?: string;
}

const {
  title,
  icon,
  description,
  links,
} = Astro.props;

const parsedLinks = links
  ? JSON.parse(links)
  : [];
---

<div class="rounded-2xl border border-(--border) bg-(--bg)/50 p-4 backdrop-blur-sm my-6 lg:my-8">
  <div class="flex items-start gap-3">
    {
      icon && (
        <div class="relative shrink-0">
          <Image
            src={icon}
            alt={title || ""}
            width={48}
            height={48}
            loading="lazy"
            fetchpriority="low"
            class="h-8 w-8 lg:h-12 lg:w-12 rounded-lg object-cover"
          />
        </div>
      )
    }
    <div class="min-w-0 flex-1">
      {
        title && (
          <h3 class="text-heading-20 font-semibold mt-0!">
            {title}
          </h3>
        )
      }

      {
        description && (
          <p class="mt-1.5 text-copy-14 text-muted mb-0!">
            {description}
          </p>
        )
      }

      {
        parsedLinks.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {parsedLinks.map((link: any) => (
              <Button variant="secondary" size="md" title={link.label}>
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center no-underline">
                {link.label}
              </a>
              </Button>
            ))}
          </div>
        )
      }
    </div>
  </div>
</div>
