---
// src/components/mdx/Kbd.astro
interface Props {
  keys: string; // e.g. "Ctrl+K" or "Ctrl+Shift+P"
}

const { keys } = Astro.props;
const keyList = keys.split('+').map(k => k.trim()).filter(Boolean);
---

<span class="kbd-group">
  {keyList.map((key, i) => (
    <>
      {i > 0 && <span class="kbd-separator text-copy-16 lg:text-copy-18">+</span>}
      <kbd class="kbd-key text-label-mono-13 sm:text-label-mono-14 text-(--prose-kbd-text)">{key}</kbd>
    </>
  ))}
</span>