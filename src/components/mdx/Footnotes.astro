---
// src/components/mdx/Footnotes.astro

interface Source {
  id: string;
  text: string;
  link?: string;
}

interface Props {
  sources: Source[];
}

const { sources } = Astro.props;
---
<div class="section-divider">
  {sources.length > 0 && (
    <div class="footnotes-section py-4 md:py-8">
      <h3>Referensi</h3>
      <ol>
        {sources.map((s) => (
          <li id={`fn-${s.id}`}>
            <span class="footnote-number">{s.id}. </span>
            <div class="footnote-content">
              {s.link ? (
                <a 
                  href={s.link} 
                  target="_blank" 
                  rel="noopener noreferrer"
                >
                  {s.text}
                </a>
              ) : (
                <span>{s.text}</span>
              )}
              <a 
                href={`#fnref-${s.id}`} 
                class="footnote-backlink"
                aria-label="Kembali ke referensi"
              >
                ↩
              </a>
            </div>
          </li>
        ))}
      </ol>
    </div>
  )}
</div>