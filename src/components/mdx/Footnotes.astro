---
// src/components/prose/FootnotesWrapper.astro
//
// Wraps the footnotes block. The outer div clips overflow at the
// layout level — catches anything the CSS alone misses on mobile
// when the prose parent has no explicit width constraint.
---

<div class="fn-wrap">
  <slot />
</div>

<style>
  .fn-wrap {
    /*
     * position:relative turns this into a containing block.
     * overflow-x:hidden clips any child that escapes horizontally.
     * min-width:0 is essential if this component sits inside a
     * flex or grid parent — without it the div won't shrink.
     */
    position: relative;
    width: 100%;
    min-width: 0;
    overflow-x: hidden;
    /* Contain layout — prevents this box from affecting ancestor width */
    contain: inline-size;
  }
</style>