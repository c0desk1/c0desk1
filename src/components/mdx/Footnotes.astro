---
// src/components/mdx/Footnotes.astro

interface Source {
  id: string;
  text: string;
  link?: string;
}

interface Props {
  sources: Source[];
}

const { sources } = Astro.props;
---

<section class="section-divider mt-16 pt-8 not-prose">
  <p class="text-[11px] font-bold tracking-[0.2em] text-zinc-400 mb-6">
    Referensi
  </p>
  <ol class="space-y-3">
    {sources.map((s) => (
      <li id={`fn-${s.id}`} class="group flex gap-3 text-[13px] text-zinc-500 dark:text-zinc-400 scroll-mt-32">
        <span class="shrink-0 font-mono text-[10px] text-zinc-400 mt-1">[{s.id}]</span>
        <div class="leading-relaxed">
          {s.link ? (
            <a href={s.link} target="_blank" rel="noopener" class="hover:text-emerald-500 transition-colors underline underline-offset-4 decoration-zinc-300 dark:decoration-zinc-700">
              {s.text}
            </a>
          ) : (
            <span>{s.text}</span>
          )}
          <a href={`#fnref-${s.id}`} class="ml-1.5 opacity-0 group-hover:opacity-100 transition-opacity text-emerald-500 no-underline">↩</a>
        </div>
      </li>
    ))}
  </ol>
</section>
