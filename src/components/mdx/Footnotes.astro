---
// src/components/prose/FootnotesWrapper.astro
// Wraps the footnotes section to prevent long URLs from causing
// horizontal scroll. Uses explicit width + overflow:hidden at
// every layer — the only reliable fix for flex-child overflow.
---

<div class="fn-outer">
  <div class="fn-inner">
    <slot />
  </div>
</div>

<style>
  /*
   * Two-layer containment:
   *
   * fn-outer — sets the boundary. position:relative + overflow:hidden
   *            clips anything that tries to escape.
   *
   * fn-inner — min-width:0 is critical inside any flex/grid parent.
   *            Without it, the child's minimum size is its content
   *            size, so it will never shrink to allow wrapping.
   */
  .fn-outer {
    width: 100%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
  }

  .fn-inner {
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }
</style>