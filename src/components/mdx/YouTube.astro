---
// src/components/mdx/YouTube.astro
interface Props {
  id: string;
  title?: string;
}

const { id, title = 'YouTube video player' } = Astro.props;
---

<div class="not-prose my-6 aspect-video overflow-hidden rounded-lg border border-zinc-200 dark:border-zinc-800">
  <iframe
    src={`https://www.youtube.com/embed/${id}`}
    title={title}
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    class="h-full w-full"
  ></iframe>
</div>