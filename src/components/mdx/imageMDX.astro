---
import { cdnImage, isCdnUrl } from '@/lib/utils';

import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt?: string;
  title?: string;
}

const { src, alt = '', title } = Astro.props;
const optimizedSrc = src && isCdnUrl(src)
	? cdnImage(src, { w: 1280, h: 720, q: 80 })
  : src ?? '';
const caption = title || alt;
---

<figure class="prose-custom">
  <div class="relative overflow-hidden">
    <div class="absolute aspect-video inset-0 bg-(--bg) animate-pulse" aria-hidden="true"></div>
    <Image
      src={optimizedSrc}
      alt={alt}
      loading="lazy"
      decoding="async"
      width={1280}
      height={720}
      class="relative z-10 h-full w-full object-cover aspect-video rounded-none transition duration-500 opacity-0"
      onload="this.classList.remove('opacity-0')"
    />
  </div>
  {caption && ( <figcaption>{caption}</figcaption> )}
</figure>
