---
// src/components/mdx/ImageMDX.astro
import { cdnImage, isCdnUrl } from '@/lib/utils';
import { Image } from 'astro:assets';
import Icon from '@/components/ui/Icon';

interface Props {
  src: string;
  alt?: string;
  title?: string;
}

const { src, alt = '', title } = Astro.props;

const optimizedSrc = src && isCdnUrl(src)
  ? cdnImage(src, { w: 1280, h: 720, q: 80 })
  : src ?? '';

const caption = title || alt;
---

<figure class="full-width-figure my-4">
  <div class="relative overflow-hidden rounded-(--prose-radius-lg) border border-(--prose-image-border) bg-(--prose-image-bg) p-2 shadow-sm">
    <Image
      src={optimizedSrc}
      alt={alt}
      loading="lazy"
      decoding="async"
      width={1200}
      height={630}
      class="zoomable-image relative h-full w-full object-cover transition duration-500 opacity-0 cursor-zoom-in"
      onload="this.classList.remove('opacity-0')"
    />
  </div>
  {caption && (
    <figcaption class="text-copy-14 text-(--prose-figure-caption) mt-4!">{caption}</figcaption>
  )}
</figure>

<div class="lightbox-overlay" id="lightbox-overlay">
  <button class="lightbox-close p-2 rounded-full bg-(--bg-muted)/10 hover:bg-(--bg-muted)/5 active:bg-(--bg-muted)/5 text-(--fg-inverted) dark:text-(--fg)" id="lightbox-close">
    <Icon name="close" className="w-6 h-6" />
  </button>
  <div class="lightbox-zoom-container">
    <img src="" alt="" class="lightbox-image" id="lightbox-image" />
  </div>
</div>

<style is:inline>
  .full-width-figure {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin: 2rem 0;
    max-width: 56rem;
    padding: 0 1rem;
  }
  @media (min-width: 768px) {
    .full-width-figure {
      padding: 0 1.5rem;
    }
  }
  @media (min-width: 1024px) {
    .full-width-figure {
      padding: 0 2rem;
    }
  }
  .full-width-figure .relative {
    width: 100%;
  }

  .lightbox-overlay {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: none;
    overscroll-behavior: contain;
  }

  .lightbox-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-zoom-container {
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .lightbox-image {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 0.5rem;
    cursor: zoom-out;
    touch-action: manipulation;
    transform: scale(0.8);
    transition: transform 0.3s ease;
  }

  .lightbox-overlay.active .lightbox-image {
    transform: scale(1);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    z-index: 1000;
  }

  @media (max-width: 767px) {
    .lightbox-close {
      top: auto;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(8px);
      border-radius: 50%;
      width: 3rem;
      height: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>

<script>
  function initLightbox() {
    const overlay = document.getElementById('lightbox-overlay');
    const lightboxImg = document.getElementById('lightbox-image') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close');

    if (!overlay || !lightboxImg || !closeBtn) return;

    const openLightbox = (src: string) => {
      lightboxImg.src = src;
      overlay.classList.add('active');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      overlay.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    // Buka lightbox dari artikel
    document.querySelectorAll('.zoomable-image').forEach(img => {
      img.addEventListener('click', () => {
        openLightbox((img as HTMLImageElement).src);
      });
    });

    // Tutup dengan klik gambar
    lightboxImg.addEventListener('click', closeLightbox);

    // Tutup dengan tombol close
    closeBtn.addEventListener('click', closeLightbox);

    // Tutup dengan klik di luar gambar
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeLightbox();
    });

    // Tutup dengan ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('active')) {
        closeLightbox();
      }
    });
  }

  document.addEventListener('astro:page-load', initLightbox);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLightbox);
  } else {
    initLightbox();
  }
</script>
