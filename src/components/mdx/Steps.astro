---
// src/components/mdx/Steps.astro
---

<div class="steps-container not-prose my-12 ml-4 border-l border-zinc-200 pl-9 dark:border-zinc-800">
  <slot />
</div>

<style is:global>
  .steps-container {
    counter-reset: step;
    position: relative;
  }

  .steps-container > * {
    counter-increment: step;
    position: relative;
    margin-bottom: 2.5rem !important;
  }

  .steps-container > *::before {
    content: counter(step);
    position: absolute;
    
    left: calc(-2.25rem - 1px); 
    top: 0;
    
    width: 1.75rem;
    height: 1.75rem;
    transform: translateX(-50%);
    
    background-color: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 9999px;
    
    display: flex;
    align-items: center;
    justify-content: center;
    
    font-size: 0.75rem;
    font-weight: 600;
    color: #71717a;
    z-index: 10;
  }

  .dark .steps-container > *::before {
    background-color: #09090b;
    border-color: #27272a;
    color: #a1a1aa;
  }
  .steps-container > * strong:first-child {
    display: block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #18181b;
    margin-bottom: 0.375rem;
    line-height: 1.75rem;
  }
  .dark .steps-container > * strong:first-child {
    color: #fafafa;
  }
  .steps-container > * {
    font-size: 0.9375rem;
    line-height: 1.625rem;
    color: #71717a;
  }

  .dark .steps-container > * {
    color: #a1a1aa;
  }
  .steps-container > *:last-child {
    margin-bottom: 0 !important;
  }
</style>