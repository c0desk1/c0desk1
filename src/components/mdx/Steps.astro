---
// src/components/mdx/Steps.astro
---

<div class="steps-container not-prose my-10 ml-4">
  <slot />
</div>

<style is:global>
  .steps-container {
    display: flex;
    flex-direction: column;
  }
  .steps-container > * {
    display: flex;
    gap: 1.5rem;
    position: relative;
    margin: 0 !important;
    padding-bottom: 2rem;
  }
  .steps-container > *:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 0.75rem;
    top: 2rem;
    bottom: 0;
    width: 1px;
    background-color: #e4e4e7;
  }

  .dark .steps-container > *:not(:last-child)::after {
    background-color: #27272a;
  }
  .steps-container > *::before {
    counter-increment: step;
    content: counter(step);
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    background-color: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: #71717a;
    z-index: 2;
  }

  .dark .steps-container > *::before {
    background-color: #09090b;
    border-color: #27272a;
    color: #a1a1aa;
  }
  .steps-container {
    counter-reset: step;
  }
  .steps-container > * {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #71717a;
    flex: 1;
  }
  .steps-container > * strong:first-child {
    display: block;
    color: #18181b;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }
  .dark .steps-container > * strong:first-child {
    color: #fafafa;
  }
</style>