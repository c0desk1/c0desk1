---
// src/components/mdx/Steps.astro
---

<div class="steps-container not-prose my-8 ml-4 border-l border-zinc-200 pl-8 dark:border-zinc-800">
  <slot />
</div>

<style is:global>
  .steps-container {
    counter-reset: step;
  }
  .steps-container > p,
  .steps-container > h3,
  .steps-container > div {
    counter-increment: step;
    position: relative;
    margin-bottom: 1.5rem !important; 
  }
  .steps-container > p::before,
  .steps-container > h3::before,
  .steps-container > div::before {
    content: counter(step);
    position: absolute;
    left: -2.85rem; 
    top: 0.1rem;
    width: 1.75rem;
    height: 1.75rem;
    background-color: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #18181b;
    z-index: 10;
  }

  .dark .steps-container > p::before,
  .dark .steps-container > h3::before,
  .dark .steps-container > div::before {
    background-color: #09090b; /* zinc-950 */
    border-color: #27272a;
    color: #fafafa;
  }

  .steps-container > *:last-child {
    margin-bottom: 0 !important;
  }
</style>
