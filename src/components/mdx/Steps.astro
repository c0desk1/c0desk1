---
// src/components/mdx/Steps.astro
---

<div class="steps-container not-prose my-8 ml-4 border-l border-zinc-200 pl-8 dark:border-zinc-800">
  <slot />
</div>

<style is:global>
  .steps-container h3 {
    counter-increment: step;
    position: relative;
    font-size: 1rem; /* text-base */
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--tw-prose-headings);
  }

  .steps-container {
    counter-reset: step;
  }
  .steps-container h3::before {
    content: counter(step);
    position: absolute;
    left: -2.85rem;
    top: -0.1rem;
    width: 1.75rem;
    height: 1.75rem;
    background-color: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #18181b;
  }
  .dark .steps-container h3::before {
    background-color: #09090b;
    border-color: #27272a;
    color: #fafafa;
  }
</style>