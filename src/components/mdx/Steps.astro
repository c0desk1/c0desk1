---
// src/components/mdx/Steps.astro
---

<div class="steps-container not-prose my-12 ml-4 border-l border-black/20 dark:border-zinc-800 pl-9">
  <slot />
</div>

<style is:global>
  .steps-container {
    position: relative;
  }
  
  .steps-container h3 {
    counter-increment: step;
    position: relative;

    font-size: 1.15rem !important;
    font-weight: 600 !important;

    margin-top: 2.25rem !important;
    margin-bottom: 0.75rem !important;

    line-height: 1.5rem !important;
    color: #18181b !important;
  }

  .dark .steps-container h3 {
    color: #fafafa !important;
  }

  .steps-container h3:first-of-type {
    margin-top: 0 !important;
  }

  .steps-container h3::before {
    content: counter(step);
    position: absolute;
    left: calc(-2.25rem - 0.875rem - 1px);
    top: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background: #fff;
    border: 1px solid #e4e4e7;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: #71717a;
  }

  .dark .steps-container h3::before {
    background: #09090b;
    border-color: #27272a;
    color: #a1a1aa;
  }

  .steps-container p,
  .steps-container li {
    font-size: 0.9em;
    line-height: 1.65rem !important;
    color: #3f3f46;
  }

  .dark .steps-container p,
  .dark .steps-container li {
	color: #d4d4d8d2;
  }

  .steps-container ul,
  .steps-container ol {
    margin: 0.25rem 0 1.5rem 0;
    padding-left: 0;
  }

  .steps-container ul > li,
  .steps-container ol > li {
    list-style: none;
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .steps-container ul > li::before {
    content: "";
    position: absolute;
    left: 0.6rem;
    top: 0.65rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 9999px;
    background: #71717a;
  }

  .dark .steps-container ul > li::before {
    background: #a1a1aa;
  }

  .steps-container ol {
    counter-reset: list-item;
  }

  .steps-container ol > li::before {
    counter-increment: list-item;
    content: counter(list-item);
    position: absolute;
    left: 0.6rem;
    top: 0.15rem;
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 9999px;
    border: 1px solid #e4e4e7;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: #71717a;
  }

  .dark .steps-container ol > li::before {
    border-color: #27272a;
    color: #a1a1aa;
  }

  .steps-container h3:not(:first-of-type) {
    margin-top: 2.5rem !important;
  }
</style>