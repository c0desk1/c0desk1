---
// src/components/mdx/Steps.astro
---

<div class="steps-container not-prose my-10 ml-4 border-l border-zinc-200 pl-8 dark:border-zinc-800">
  <slot />
</div>

<style is:global>
  .steps-container {
    counter-reset: step;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .steps-container > * {
    counter-increment: step;
    position: relative;
    margin: 0 !important;
  }

  .steps-container > *::before {
    content: counter(step);
    position: absolute;
    left: calc(-2rem - 1.35rem); 
    top: 0.25rem;
    width: 1.6rem;
    height: 1.6rem;
    background-color: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 600;
    color: #71717a;
    z-index: 10;
  }

  .dark .steps-container > *::before {
    background-color: #09090b;
    border-color: #27272a;
    color: #a1a1aa;
  }

  .steps-container > * strong:first-child {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #18181b;
    margin-bottom: 0.25rem;
  }

  .dark .steps-container > * strong:first-child {
    color: #fafafa;
  }

  .steps-container > * {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #71717a;
  }

  .dark .steps-container > * {
    color: #a1a1aa;
  }

  .steps-container {
    position: relative;
  }
</style>