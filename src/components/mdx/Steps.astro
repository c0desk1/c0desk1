---
// src/components/mdx/Steps.astro
---

<div class="steps-container not-prose my-8 ml-4 border-l-2 border-black/20 dark:border-zinc-800 pl-9">
  <slot />
</div>

<style is:global>
  .steps-container {
    position: relative;
    counter-reset: step;
  }
  
  .steps-container > :where(h1, h2, h3, h4, h5, h6) {
    counter-increment: step;
    position: relative;
    font-size: 1.15rem !important;
    font-weight: 600 !important;
    margin-top: 2rem !important;
    margin-bottom: 0.5rem !important;
    color: #000000 !important;
  }

  .dark .steps-container > :where(h1, h2, h3, h4, h5, h6) {
    color: #ffffff !important;
  }

  .steps-container > :where(h1, h2, h3, h4, h5, h6):first-of-type {
    margin-top: 0 !important;
  }

  .steps-container > :where(h1, h2, h3, h4, h5, h6)::before {
    content: counter(step);
    position: absolute;
    left: calc(-2.25rem - 0.875rem - 1px);
    top: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background: #ffffff;
    border: 2px solid rgba(0, 0, 0, 0.376);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: #71717a;
    box-sizing: border-box;
  }

  .dark .steps-container > :where(h1, h2, h3, h4, h5, h6)::before {
    background: #000000;
    border-color: #27272a;
    color: #a1a1aa;
  }

  .steps-container > :where(h1, h2, h3, h4, h5, h6):hover::before {
    content: "#";
    background: #ffffff;
    border-color: rgba(0, 0, 0, 0.376);
    color: #10b981;
  }

  .dark .steps-container > :where(h1, h2, h3, h4, h5, h6):hover::before {
    background: #000000;
    border-color: #27272a;
    color: #10b981;
  }

  .steps-container > :where(h1, h2, h3, h4, h5, h6)::before {
    transition: all 0.2s ease;
  }

  .steps-container p,
  .steps-container li {
    font-size: 0.9rem;
    color: #3f3f46;
  }

  .dark .steps-container p,
  .dark .steps-container li {
    color: #e7e7e7;
  }

  .steps-container ul,
  .steps-container ol {
    margin: 0.25rem 0 1.5rem 0;
    padding-left: 0;
  }

  .steps-container ul > li,
  .steps-container ol > li {
    list-style: none;
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.5rem;
    line-height: 1.65 !important;
  }

  .steps-container ul > li::before {
    content: "";
    position: absolute;
    left: 0.6rem;
    top: 0.65rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 9999px;
    background: #a1a1aa;
  }

  .dark .steps-container ul > li::before {
    background: #52525b;
  }

  .steps-container ol {
    counter-reset: list-item;
  }

  .steps-container ol > li::before {
    counter-increment: list-item;
    content: counter(list-item);
    position: absolute;
    left: 0.6rem;
    top: 0.15rem;
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 9999px;
    border: 1px solid #e4e4e7;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: #71717a;
    background: #ffffff;
  }

  .dark .steps-container ol > li::before {
    border-color: #27272a;
    color: #a1a1aa;
    background: #000000;
  }

  .steps-container > :where(h1, h2, h3, h4, h5, h6):not(:first-of-type) {
    margin-top: 2.5rem !important;
  }
</style>