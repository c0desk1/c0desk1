---
// src/components/mdx/Steps.astro
---

<div class="not-prose my-6 space-y-4">
  <slot />
</div>

<style is:global>
  .steps-container {
    counter-reset: step;
  }
  .step-item {
    counter-increment: step;
    position: relative;
    padding-left: 2.5rem;
  }
  .step-item::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    width: 1.75rem;
    height: 1.75rem;
    background-color: #f4f4f5;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 600;
    color: #18181b;
  }
  .dark .step-item::before {
    background-color: #27272a;
    color: #fafafa;
  }
  .step-item:not(:last-child) {
    padding-bottom: 1rem;
  }
</style>