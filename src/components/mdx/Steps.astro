---
// src/components/mdx/Steps.astro
---

<div class="steps-container not-prose my-12 ml-4">
  <slot />
</div>

<style is:global>
  .steps-container {
    counter-reset: step;
    display: flex;
    flex-direction: column;
  }

  .steps-container > h3,
  .steps-container > p:has(strong:first-child) {
    counter-increment: step;
    position: relative;
    padding-left: 2.25rem;
    margin-bottom: 0.5rem !important;
    margin-top: 2rem !important;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #18181b;
  }

  .dark .steps-container > h3,
  .dark .steps-container > p:has(strong:first-child) {
    color: #fafafa;
  }

  .steps-container > h3 + p,
  .steps-container > p:has(strong:first-child) + p {
    padding-left: 2.25rem;
    margin-top: -0.25rem !important;
    margin-bottom: 0 !important;
    font-size: 0.9375rem;
    color: #71717a;
    counter-increment: none; 
  }

  .steps-container > h3::before,
  .steps-container > p:has(strong:first-child)::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    width: 1.75rem;
    height: 1.75rem;
    background-color: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: #71717a;
    z-index: 10;
  }

  .dark .steps-container > h3::before,
  .dark .steps-container > p:has(strong:first-child)::before {
    background-color: #09090b;
    border-color: #27272a;
    color: #a1a1aa;
  }

  .steps-container > h3::after,
  .steps-container > p:has(strong:first-child)::after {
    content: "";
    position: absolute;
    left: 0.875rem;
    top: 1.75rem;
    bottom: -2.5rem;
    width: 1px;
    background-color: #e4e4e7;
    z-index: 1;
  }

  .dark .steps-container > h3::after,
  .dark .steps-container > p:has(strong:first-child)::after {
    background-color: #27272a;
  }

  .steps-container > h3:last-of-type::after,
  .steps-container > p:has(strong:first-child):last-of-type::after {
    display: none;
  }

  .steps-container > *:first-child {
    margin-top: 0 !important;
  }
</style>