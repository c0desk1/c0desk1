---
// src/components/mdx/CallQuote.astro
import Icon from '@/components/ui/Icon';
import { getCurrentLocale } from '@/utils/i18n';

const locale = getCurrentLocale(Astro);

const raw = await Astro.slots.render('default');
const cleanRaw = raw.replace(/^<p>/, '').replace(/<\/p>$/, '').trim();

const alertTypes = {
  '[!NOTE]': { type: 'note', icon: 'note' },
  '[!INFO]': { type: 'info', icon: 'info' },
  '[!TIP]': { type: 'tip', icon: 'tip' },
  '[!WARNING]': { type: 'warning', icon: 'warning' },
  '[!DANGER]': { type: 'danger', icon: 'danger' },
} as const;

const plainText = cleanRaw.replace(/<[^>]+>/g, '').trim();
const activeToken = Object.keys(alertTypes).find(token => plainText.startsWith(token));

let isAlert = false;
let alertConfig = null;
let calloutTitle = '';
let finalQuote = '';
let finalCite = '';

if (activeToken) {
  isAlert = true;
  alertConfig = alertTypes[activeToken as keyof typeof alertTypes];

  const tokenKey = activeToken.replace(/[\[\]!]/g, '').toLowerCase();
  const translations: Record<string, Record<string, string>> = {
    note:    { id: 'Catatan',      en: 'Note',         ru: 'Примечание',     jp: 'ノート' },
    info:    { id: 'Info',         en: 'Info',         ru: 'Информация',     jp: '情報' },
    tip:     { id: 'Tips',         en: 'Tip',          ru: 'Совет',          jp: 'ヒント' },
    warning: { id: 'Peringatan',   en: 'Warning',      ru: 'Предупреждение', jp: '警告' },
    danger:  { id: 'Bahaya',       en: 'Danger',       ru: 'Опасность',      jp: '危険' },
  };
  calloutTitle = translations[tokenKey]?.[locale] || translations[tokenKey]?.en || tokenKey.charAt(0).toUpperCase() + tokenKey.slice(1);

  finalQuote = cleanRaw.replace(activeToken, '').trim();
} else {
  const slashRegex = /\/(?![^<]*>)/; 
  const hasSlash = slashRegex.test(cleanRaw);

  if (hasSlash) {
    const parts = cleanRaw.split(slashRegex);
    finalQuote = parts[0].trim();
    finalCite = parts.slice(1).join('/').replace(/<\/?[^>]+(>|$)/g, "").trim();
  } else {
    finalQuote = cleanRaw;
  }
}
---

{isAlert ? (
  <aside class="callout" data-callout={alertConfig?.type}>
    <div class="callout-body">
      <div class="callout-header">
        <div class="callout-icon">
          <Icon name={alertConfig?.icon as any} />
        </div>
        {calloutTitle && <p class="callout-title text-label-14 md:text-label-16 font-semibold">{calloutTitle}</p>}
      </div>
      <div class="callout-content">
        <div set:html={finalQuote} />
      </div>
    </div>
  </aside>
) : (
  <blockquote class="quote flex flex-col items-stretch justify-start gap-6 lg:gap-8 flex-initial">
    <div class="quote-body">
      <div set:html={finalQuote} />
    </div>
    <div class="flex flex-col md:flex-row items-end md:items-center justify-end gap-2 md:gap-3 flex-initial">
      {finalCite && (
        <span class="quote-cite text-label-14">{finalCite}</span>
      )}
    </div>
  </blockquote>
)}