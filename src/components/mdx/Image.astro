---
// src/components/mdx/Image.astro
import { cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  src: string;
  alt?: string;
  title?: string;
  loading?: boolean;
}

const { src, alt = '', title, loading = true } = Astro.props;
const optimizedSrc = !loading && src && isCdnUrl(src)
	? cdnImage(src, { w: 1280, h: 720, q: 85 })
  : src ?? '';
const caption = title || alt;
---

{loading ? (
  <figure class="prose-custom mx-auto max-w-3xl my-4 md:my-8 overflow-hidden" aria-hidden="true">
    <div class="flex items-center border-2 border-(--border) rounded-(--radius-md) overflow-hidden">
      <div class="sk-img w-full" style="aspect-ratio:16/9;"></div>
    </div>
  </figure>
) : (
<figure class="prose-custom mx-auto max-w-3xl overflow-hidden">
  <img
    src={optimizedSrc}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="block w-full h-auto object-cover"
  />
  {caption && ( <figcaption>{caption}</figcaption> )}
</figure>
)}