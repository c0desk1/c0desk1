---
import { cdnImage, isCdnUrl } from '@/lib/utils';

interface Props {
  src: string;
  alt?: string;
  title?: string;
}

const { src, alt = "", title } = Astro.props;
const caption = title || alt;
const optimizedSrc = isCdnUrl(src) ? cdnImage(src, { q: 85 }) : src;
---

<figure class="mx-auto max-w-2xl my-4 md:my-8 overflow-hidden">
  <img
    src={optimizedSrc}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="block w-full h-auto object-cover"
  />
  {caption && (
    <figcaption class="text-xs md:text-[13px] text-center leading-snug">
      {caption}
    </figcaption>
  )}
</figure>