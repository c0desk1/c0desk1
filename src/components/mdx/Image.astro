---
interface Props {
  src: string;
  alt?: string;
  title?: string;
}

const { src, alt = "", title } = Astro.props;

const caption = title || alt;
---

<figure class="my-8 overflow-hidden rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900">

  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="w-full h-auto object-cover"
  />

  {caption && (
    <figcaption class="px-2 py-1.5 border-t border-zinc-200 dark:border-zinc-800 text-xs md:text-sm text-center text-zinc-500 dark:text-zinc-400">
      {caption}
    </figcaption>
  )}

</figure>