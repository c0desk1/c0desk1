---
interface Props {
  src: string;
  alt?: string;
  title?: string;
}

const { src, alt = "", title } = Astro.props;
const caption = title || alt;
---

<figure class="mx-auto my-4 md:my-8 overflow-hidden">
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="block w-full h-auto object-cover"
  />
  {caption && (
    <figcaption class="mt-4 px-3 py-2 text-[13px] md:text-sm text-center text-zinc-500 dark:text-zinc-400 leading-snug">
      {caption}
    </figcaption>
  )}
</figure>