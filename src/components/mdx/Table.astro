---
// src/components/mdx/Table.astro
import Icon from "@/components/ui/Icon";

const { title = "Tabel" } = Astro.props;
---

<div class="table-wrapper relative my-4 overflow-hidden rounded-lg border border-(--prose-table-border) bg-(--prose-table-bg)">
  <div class="table-header flex items-center justify-between border-b border-(--prose-code-border) bg-(--prose-code-bg) px-4 py-2">
    <div class="flex items-center gap-2 min-w-0">
      <span class="table-block-title text-label-14">{title}</span>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <button
        type="button"
        aria-label="Copy table as CSV"
        title="Copy as CSV"
        class="copy-table-button rounded-full p-2 hover:bg-muted active:bg-muted"
      >
        <Icon name="copy" className="copy-icon size-5 transition-colors" />
        <Icon name="check" className="check-icon hidden size-5 text-accent transition-colors" />
      </button>
    </div>
  </div>
  <div class="table-content overflow-x-auto">
    <table class="min-w-full border-collapse">
      <slot />
    </table>
  </div>
</div>

<script>
  (() => {
    function tableToCSV(table: HTMLTableElement) {
      const rows = Array.from(table.querySelectorAll('tr'));
      const csvRows = rows.map(row => {
        const cells = Array.from(row.querySelectorAll('th, td'));
        const csvCells = cells.map(cell => {
          let text = cell.textContent?.trim() || '';
          
          text = text.replace(/"/g, '""');
          
          if (text.search(/("|,|\n)/g) >= 0) {
            text = `"${text}"`;
          }
          return text;
        });
        return csvCells.join(',');
      });
      return csvRows.join('\n');
    }

    document.querySelectorAll('.table-wrapper').forEach((wrapper) => {
      const copyBtn = wrapper.querySelector('.copy-table-button');
      const table = wrapper.querySelector('table');
      
      if (!table || !copyBtn) return;

      copyBtn.addEventListener('click', async () => {
        const csvData = tableToCSV(table);
        try {
          await navigator.clipboard.writeText(csvData);
          
          const copyIcon = copyBtn.querySelector('.copy-icon');
          const checkIcon = copyBtn.querySelector('.check-icon');
          
          copyIcon?.classList.add('hidden');
          checkIcon?.classList.remove('hidden');
          copyBtn.setAttribute('aria-label', 'Copied!');
          
          setTimeout(() => {
            copyIcon?.classList.remove('hidden');
            checkIcon?.classList.add('hidden');
            copyBtn.setAttribute('aria-label', 'Copy table as CSV');
          }, 2000);
          
        } catch (err) {
          console.error("Gagal menyalin CSV:", err);
        }
      });
    });
  })();
</script>

<style>
  .table-wrapper th,
  .table-wrapper td {
    padding: 0.75rem 1rem;
    white-space: nowrap;
  }
</style>
