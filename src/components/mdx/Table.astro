---
// src/components/mdx/Table.astro
import Icon from "@/components/ui/Icon";

const { title = "Table" } = Astro.props;
---

<div class="table-wrapper relative my-4 overflow-hidden rounded-lg border border-(--prose-table-border) bg-(--prose-table-bg)">
  <div class="table-header flex items-center justify-between border-b border-(--prose-code-border) bg-(--prose-code-bg) px-4 py-2">
    <div class="flex items-center gap-2 min-w-0">
      <span class="table-block-title text-label-14">{title}</span>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <button
        type="button"
        aria-label="Copy table as Markdown"
        class="copy-table-button rounded-full p-2 hover:bg-muted active:bg-muted"
      >
        <Icon name="copy" className="copy-icon size-5 transition-colors" />
        <Icon name="check" className="check-icon hidden size-5 text-accent transition-colors" />
      </button>
      <button
        type="button"
        aria-label="Zoom table"
        class="zoom-table-button rounded-full p-2 hover:bg-muted active:bg-muted"
      >
        <Icon name="zoom" className="copy-icon size-5 transition-colors" />
      </button>
    </div>
  </div>
  <div class="table-content overflow-x-auto">
    <table class="min-w-full border-collapse">
      <slot />
    </div>
  </div>
</div>

<script>
  // @ts-nocheck
  (() => {
    function tableToMarkdown(table) {
      const rows = Array.from(table.querySelectorAll('tr'));
      const mdRows = [];
      rows.forEach((row, idx) => {
        const cells = Array.from(row.querySelectorAll('th, td'));
        const contents = cells.map(cell => {
          let t = cell.textContent?.trim() || '';
          t = t.replace(/\|/g, '\\|').replace(/\n/g, ' ');
          return t;
        });
        mdRows.push('| ' + contents.join(' | ') + ' |');
        if (idx === 0) {
          mdRows.push('|' + cells.map(() => ' --- |').join(''));
        }
      });
      return mdRows.join('\n');
    }

    // Perbaiki selector: gunakan .table-wrapper, bukan .table-block-wrapper
    document.querySelectorAll('.table-wrapper').forEach(wrapper => {
      const copyBtn = wrapper.querySelector('.copy-table-button');
      const zoomBtn = wrapper.querySelector('.zoom-table-button');
      const table = wrapper.querySelector('table');
      if (!table || !copyBtn) return;

      copyBtn.addEventListener('click', async () => {
        const markdown = tableToMarkdown(table);
        try {
          await navigator.clipboard.writeText(markdown);
          const copyIcon = copyBtn.querySelector('.copy-icon');
          const checkIcon = copyBtn.querySelector('.check-icon');
          copyIcon?.classList.add('hidden');
          checkIcon?.classList.remove('hidden');
          setTimeout(() => {
            copyIcon?.classList.remove('hidden');
            checkIcon?.classList.add('hidden');
          }, 2000);
        } catch (err) {
          console.error(err);
        }
      });

      if (zoomBtn) {
        zoomBtn.addEventListener('click', () => {
          wrapper.classList.toggle('table-zoomed');
        });
      }
    });
  })();
</script>

<style>
  .table-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .table-wrapper.table-zoomed .table-content {
    overflow-x: auto;
  }
  .table-wrapper.table-zoomed table {
    min-width: 800px;
    font-size: 1rem;
  }
  .table-wrapper.table-zoomed th,
  .table-wrapper.table-zoomed td {
    padding: 0.75rem 1rem;
  }
</style>
