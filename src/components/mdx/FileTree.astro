---
// src/components/mdx/FileTree.astro
import { fileIcons } from '@/components/ui/icons/file';

const svg = fileIcons;
const extIcons = fileIcons;
---

<style is:global>
  .file-tree-container {
    margin: 2.5rem 0;
    background-color: var(--prose-code-bg);
    border: 1px solid var(--prose-code-border);
    border-radius: var(--prose-radius-md);
    padding: 1.25rem;
    overflow-x: auto;
    font-family: var(--prose-font-mono);
  }

  .file-tree,
  .file-tree ul,
  .file-tree ol,
  .file-tree li,
  .file-tree-list {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .file-tree {
    min-width: max-content;
  }

  .file-tree li::marker,
  .file-tree ul::marker,
  .file-tree ol::marker,
  .file-tree li::before,
  .file-tree ul::before,
  .file-tree ol::before,
  .file-tree li::after,
  .file-tree ul::after,
  .file-tree ol::after {
    content: none !important;
    display: none !important;
  }

  .file-tree li + li {
    margin-top: 0.35rem !important;
  }

  .file-tree-children {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
    margin-left: 0.45rem !important;
    padding-left: 0.85rem !important;
    border-left: 1px solid var(--prose-border-strong);
  }

  .file-tree-folder.open > .file-tree-children {
    grid-template-rows: 1fr;
  }

  .file-tree-children > ul,
  .file-tree-children > ol {
    overflow: hidden;
  }

  .file-tree-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--prose-fg-muted);
    font-size: 0.875rem;
    transition: color var(--prose-duration) var(--prose-ease-out);
    white-space: nowrap;
  }

  .file-tree-folder > .file-tree-label {
    color: var(--prose-fg-muted);
    font-weight: 500;
    cursor: pointer;
  }

  .file-tree-folder.open > .file-tree-label {
    color: var(--prose-fg-strong);
    font-weight: 600;
  }

  .file-tree-label:hover {
    color: var(--prose-fg-dim);
  }

  .icon {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    transition: color var(--prose-duration) var(--prose-ease-out);
  }

  .file-tree-folder > .file-tree-label > .folder-icon {
    color: var(--prose-fg-dim);
  }

  .file-tree-folder.open > .file-tree-label > .folder-icon {
    color: var(--prose-fg);
  }

  .file-tree-folder > .file-tree-label:hover > .folder-icon {
    color: var(--prose-fg-dim);
  }

  .file-tree-label.is-highlighted {
    color: var(--prose-fg-strong);
    background-color: var(--prose-bg-muted);
    border: 1px solid transparent;
    padding: 0.125rem 0.5rem 0.125rem 0.35rem;
    margin-left: -0.35rem;
    margin-top: 0.15rem;
    margin-bottom: 0.15rem;
    border-radius: var(--prose-radius-sm);
    font-weight: 600;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  }

  .file-tree-label.is-highlighted .icon {
    color: var(--prose-fg-strong) !important;
  }

  .file-tree-label.is-highlighted:hover {
    background-color: var(--prose-bg-subtle);
  }

  .file-tree-label.is-removed {
    color: var(--error);
    background-color: var(--error-soft);
    border: 1px dashed var(--error);
    opacity: 0.8;
    padding: 0.125rem 0.5rem 0.125rem 0.35rem;
    margin-left: -0.35rem;
    margin-top: 0.15rem;
    margin-bottom: 0.15rem;
    border-radius: var(--prose-radius-sm);
  }

  .file-tree-label.is-removed .icon {
    color: var(--error) !important;
    opacity: 0.8;
  }

  .file-tree-label.is-removed .file-name {
    text-decoration: line-through;
    text-decoration-color: var(--error);
    opacity: 0.7;
  }

  .file-tree-label.is-removed:hover {
    opacity: 1;
    background-color: color-mix(in srgb, var(--error-soft) 100%, transparent);
  }
</style>

<div class="file-tree-container">
  <div class="file-tree">
    <slot />
  </div>
</div>

<script define:vars={{ svg, extIcons }}>
  (function () {
    function getIcon(filename) {
      const ext = filename.split(".").pop()?.toLowerCase() || "";
      return extIcons[ext] ?? svg.file;
    }
    
    function refreshFolderIcon(folderItem) {
      const label = folderItem.querySelector(':scope > .file-tree-label');
      const iconEl = label?.querySelector('.folder-icon');
      if (!iconEl) return;

      const isOpen = folderItem.classList.contains('open');
      iconEl.innerHTML = isOpen
        ? (svg['folder-open'] || svg.folder)
        : svg.folder;
    }

    const init = () => {
      const trees = document.querySelectorAll(".file-tree:not(.is-processed)");

      trees.forEach((root) => {
        root.classList.add("is-processed");

        function processList(list) {
          list.classList.add("file-tree-list");

          for (const item of list.children) {
            if (!(item instanceof HTMLLIElement)) continue;

            let rawText = "";
            let isHighlighted = false;
            let isRemoved = false;
            const childNodesToRemove = [];

            for (const node of item.childNodes) {
              if (node.nodeName === 'UL' || node.nodeName === 'OL') break;

              if (node.nodeName === 'STRONG' || node.nodeName === 'B' || node.nodeName === 'MARK') {
                isHighlighted = true;
              }

              if (node.nodeName === 'DEL' || node.nodeName === 'S' || node.nodeName === 'STRIKE') {
                isRemoved = true;
              }

              rawText += node.textContent;
              childNodesToRemove.push(node);
            }

            rawText = rawText.trim();
            if (!rawText) continue;

            const isFolder = rawText.endsWith("/");
            const label = document.createElement("div");
            label.className = "file-tree-label";

            if (isRemoved) {
              label.classList.add("is-removed");
            } else if (isHighlighted) {
              label.classList.add("is-highlighted");
            }

            childNodesToRemove.forEach(n => n.remove());

            if (isFolder) {
              const name = rawText.slice(0, -1);
              item.classList.add("file-tree-folder");
              item.classList.add("open");

              label.innerHTML = `
                <span class="icon folder-icon">${svg['folder-open'] || svg.folder}</span>
                <span class="file-name">${name}</span>
              `;

              label.addEventListener('click', () => {
                item.classList.toggle('open');
                refreshFolderIcon(item);
              });

              const childrenContainer = document.createElement('div');
              childrenContainer.className = 'file-tree-children';

              while (item.firstChild && (item.firstChild.nodeName === 'UL' || item.firstChild.nodeName === 'OL')) {
                childrenContainer.appendChild(item.firstChild);
              }

              item.appendChild(childrenContainer);
            } else {
              item.classList.add("file-tree-file");
              label.innerHTML = `
                <span class="icon file-icon">${getIcon(rawText)}</span>
                <span class="file-name">${rawText}</span>
              `;
            }

            item.prepend(label);
          }
        }

        root.querySelectorAll("ul, ol").forEach(processList);
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }

    document.addEventListener("astro:page-load", init);
  })();
</script>