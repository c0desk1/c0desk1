---
// src/components/mdx/Code.astro
import Icon from "@/components/ui/icons/Icon.astro";

interface Props {
  ins?:   string;
  del?:   string;
  mark?:  string;
  title?: string;
}

const { ins = "", del = "", mark = "", title = "" } = Astro.props;

const $ = {
  wrapper: "code-block-wrapper not-prose relative shadow-2xl shadow-black/20 rounded-xl overflow-hidden",
  header: "code-block-header flex items-center justify-between px-4 py-2 border-b border-(--prose-code-border) bg-(--prose-code-header-bg)",
  leftSlot: "flex-1 flex items-center justify-start",
  centerSlot: "shrink-0 flex justify-center",
  rightSlot: "flex-1 flex items-center justify-end gap-2",  
  dots: "mac-controls flex items-center gap-1.5",
  dot: "mac-dot size-3 rounded-full border border-black/10 dark:border-white/10",
  titleText: "code-block-title font-mono truncate text-label-13 text-(--prose-fg-muted) tracking-wide",
  langBadge: "font-mono text-label-11 font-bold text-(--prose-fg-muted) bg-black/5 dark:bg-white/5 uppercase px-2 py-0.5 rounded-full",
  content: "code-content relative",
  copyBtn: "copy-button absolute top-3 right-3 z-10 flex items-center gap-1.5 px-2.5 py-1.5 rounded-md font-mono text-label-12 text-(--prose-fg-muted) border border-(--prose-code-border) bg-(--prose-code-bg)/60 backdrop-blur-md transition-all duration-200 opacity-0 group-hover/content:opacity-100 hover:text-(--prose-fg-strong) hover:bg-(--prose-code-header-bg)",
} as const;
---

<div
  class={$.wrapper}
  data-ins={ins}
  data-del={del}
  data-mark={mark}
>
  <div class={$.header}>
    <div class={$.leftSlot}>
      <div class={$.dots} aria-hidden="true">
        <div class:list={[$.dot, "bg-[#ff5f56]"]}></div>
        <div class:list={[$.dot, "bg-[#ffbd2e]"]}></div>
        <div class:list={[$.dot, "bg-[#27c93f]"]}></div>
      </div>
    </div>

    <div class={$.centerSlot}>
      {title && (
        <span class={$.titleText}>{title}</span>
      )}
    </div>

    <div class={$.rightSlot}>
      {(ins || del) && (
        <div class="code-diff-legend" aria-hidden="true">
          {ins && <span class="diff-tag add">+</span>}
          {del && <span class="diff-tag remove">−</span>}
        </div>
      )}
      <span class:list={[$.langBadge, "lang-badge"]}></span>
    </div>
  </div>

  <div class:list={[$.content, "group/content"]}>
    <button
      type="button"
      aria-label="Salin kode"
      class={$.copyBtn}
    >
      <Icon name="copy"  className="copy-icon  w-3.5 h-3.5" />
      <Icon name="check" className="check-icon w-3.5 h-3.5 hidden" />
      <span class="copy-label">Salin</span>
    </button>

    <slot />
  </div>
</div>

<style is:global>
  .code-block-wrapper.is-collapsed .code-content pre {
    max-height: 8rem;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  }
  
  .btn-expand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem;
    color: var(--prose-fg-muted);
    background-color: var(--prose-code-header-bg);
    border-top: 1px solid var(--prose-code-border);
    cursor: pointer;
    transition: color 150ms ease, background-color 150ms ease;
  }
  .btn-expand:hover {
    color: var(--prose-fg-strong);
    background-color: color-mix(in srgb, var(--prose-code-header-bg) 95%, #000);
  }
  .btn-expand svg { transition: transform 200ms ease; }
  .code-block-wrapper.is-collapsed .btn-expand svg { transform: rotate(180deg); }
</style>

<script>
  (() => {
    const NAMES: Record<string, string> = {
      js: "JS", ts: "TS", jsx: "JSX", tsx: "TSX",
      py: "PY", html: "HTML", css: "CSS", scss: "SCSS",
      json: "JSON", jsonc: "JSON", yaml: "YAML", toml: "TOML",
      bash: "BASH", sh: "SH", zsh: "ZSH", sql: "SQL",
      md: "MD", mdx: "MDX", astro: "ASTRO", vue: "VUE",
      svelte: "SVELTE", go: "GO", rust: "RS", cpp: "C++",
      c: "C", cs: "C#", java: "JAVA", php: "PHP",
      rb: "RB", swift: "SWIFT", kt: "KT",
      dockerfile: "DOCKER", prisma: "PRISMA", graphql: "GQL",
    };

    const ALIASES: Record<string, string> = {
      javascript: "js", typescript: "ts", python: "py",
      shell: "sh", ruby: "rb", csharp: "cs",
    };

    // UBAH ANGKA INI UNTUK TESTING (misalnya ubah jadi 5 untuk tes instan)
    const COLLAPSE_THRESHOLD = 25;

    const normalize = (l = "") => ALIASES[l.toLowerCase().trim()] ?? l.toLowerCase().trim();

    const getLang = (pre: Element | null): string => {
      if (!pre) return "";
      const dl = pre.getAttribute("data-language");
      if (dl) return normalize(dl);
      const m = pre.className.match(/language-([a-zA-Z0-9+#-]+)/);
      return normalize(m?.[1] ?? "");
    };

    const parseRanges = (str = ""): Set<number> => {
      const set = new Set<number>();
      for (const part of str.split(",")) {
        const t = part.trim();
        if (!t) continue;
        if (t.includes("-")) {
          const [a, b] = t.split("-").map(Number);
          if (!isNaN(a) && !isNaN(b)) for (let i = a; i <= b; i++) set.add(i);
        } else {
          const n = Number(t);
          if (!isNaN(n) && n > 0) set.add(n);
        }
      }
      return set;
    };

    const updateLangBadge = (wrapper: HTMLElement, lang: string) => {
      const badge = wrapper.querySelector<HTMLElement>(".lang-badge");
      if (!badge || !lang) return;
      badge.textContent = NAMES[lang] ?? lang.toUpperCase();
      badge.style.display = 'inline-flex';
    };

    const applyLineNumbers = (wrapper: HTMLElement): number => {
      const pre   = wrapper.querySelector(".code-content pre");
      const lines = pre?.querySelectorAll("code .line");
      if (!pre || !lines?.length || lines.length <= 1) return lines?.length ?? 0;
      pre.classList.add("line-numbers");
      return lines.length;
    };

    const applyLineClasses = (wrapper: HTMLElement) => {
      const ins  = parseRanges(wrapper.dataset.ins);
      const del  = parseRanges(wrapper.dataset.del);
      const mark = parseRanges(wrapper.dataset.mark);
      if (!ins.size && !del.size && !mark.size) return;

      wrapper.querySelectorAll(".code-content pre code .line")
        .forEach((line, i) => {
          const n = i + 1;
          if (ins.has(n))  line.classList.add("diff-add");
          if (del.has(n))  line.classList.add("diff-remove");
          if (mark.has(n)) line.classList.add("highlighted");
        });

      if (mark.size) wrapper.setAttribute("data-focus", "");
    };

    const setupCopy = (wrapper: HTMLElement) => {
      const btn  = wrapper.querySelector<HTMLButtonElement>(".copy-button");
      const code = wrapper.querySelector(".code-content pre code");
      if (!btn || !code) return;

      btn.addEventListener("click", async () => {
        const text = code.textContent?.trimEnd() ?? "";
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.cssText = "position:absolute;left:-9999px;top:-9999px";
          document.body.append(ta);
          ta.select();
          document.execCommand("copy");
          ta.remove();
        }

        const label     = btn.querySelector<HTMLElement>(".copy-label");
        const copyIcon  = btn.querySelector(".copy-icon");
        const checkIcon = btn.querySelector(".check-icon");

        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
        btn.classList.add("copied");
        btn.setAttribute("aria-label", "Tersalin!");
        if (label) label.textContent = "Tersalin!";

        setTimeout(() => {
          copyIcon?.classList.remove("hidden");
          checkIcon?.classList.add("hidden");
          btn.classList.remove("copied");
          btn.setAttribute("aria-label", "Salin kode");
          if (label) label.textContent = "Salin";
        }, 2000);
      });
    };

    const setupCollapse = (wrapper: HTMLElement, lineCount: number) => {
      if (lineCount < COLLAPSE_THRESHOLD) return;
      wrapper.classList.add("is-collapsed");

      const btn = document.createElement("button");
      btn.className = "btn-expand text-label-13 font-mono"; 
      btn.setAttribute("aria-label", "Tampilkan seluruh kode");
      btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
        <span class="expand-label">Tampilkan ${lineCount} baris</span>
      `;

      wrapper.appendChild(btn);

      btn.addEventListener("click", () => {
        const collapsed = wrapper.classList.toggle("is-collapsed");
        const label = btn.querySelector<HTMLElement>(".expand-label");
        btn.setAttribute("aria-label", collapsed ? "Tampilkan seluruh kode" : "Sembunyikan kode");
        if (label) label.textContent = collapsed ? `Tampilkan ${lineCount} baris` : "Sembunyikan";
      });
    };

    const init = (wrapper: HTMLElement) => {
      wrapper.classList.add("is-processed");
      const pre       = wrapper.querySelector(".code-content pre");
      const lang      = getLang(pre);
      updateLangBadge(wrapper, lang);
      const lineCount = applyLineNumbers(wrapper);
      applyLineClasses(wrapper);
      setupCopy(wrapper);
      setupCollapse(wrapper, lineCount);
    };

    const initAll = () =>
      document.querySelectorAll<HTMLElement>(".code-block-wrapper:not(.is-processed)").forEach(init);

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initAll);
    } else {
      initAll();
    }
  })();
</script>