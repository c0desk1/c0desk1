---
// src/components/mdx/Code.astro
import Icon from "@/components/ui/icons/Icon.astro";

interface Props {
  ins?:   string;
  del?:   string;
  mark?:  string;
  title?: string;
}

const { ins = "", del = "", mark = "", title = "" } = Astro.props;

const $ = {
  wrapper: "code-block-wrapper not-prose relative my-8 rounded-xl overflow-hidden border border-(--prose-code-border) bg-(--prose-header-bg) p-0.5",
  header: "code-block-header grid grid-cols-[1fr_auto_1fr] items-center px-4 py-2 border-b border-(--prose-code-border) bg-(--prose-code-header-bg)",
  leftSlot: "header-left flex items-center justify-start gap-1.5",
  centerSlot: "header-center flex items-center justify-center min-w-0 gap-1 text-label-13",
  rightSlot: "header-right flex items-center justify-end gap-3", 
  dot: "mac-dot size-2.5 rounded-full border border-(--prose-border)/10",
  titleText: "code-block-title font-mono truncate text-(--prose-fg-muted) tracking-wide",
  diffTag: "diff-tag flex items-center justify-center size-5 rounded text-[10px] font-mono font-bold border",
  langBadge: "lang-badge text-label-11 font-mono font-semibold text-(--prose-fg-muted) bg-(--bg) uppercase px-2 py-0.5 rounded-full",  
  content: "code-content relative overflow-x-auto group/conten rounded-xl border border-(--prose-code-border) bg-(--prose-code-bg)",
  copyBtn: "copy-button absolute top-3 right-3 z-10 flex items-center justify-center p-2 rounded-md text-(--prose-fg-muted) border border-(--prose-code-border) bg-(--prose-code-bg)/60 backdrop-blur-md opacity-0 group-hover/content:opacity-100 transition-all duration-200 hover:text-(--prose-fg-strong) hover:bg-(--prose-code-header-bg)",
} as const;
---

<div
  class={$.wrapper}
  data-ins={ins}
  data-del={del}
  data-mark={mark}
>
  <div class={$.header}>
    <div class={$.leftSlot} aria-hidden="true">
      <div class:list={[$.dot, "bg-error"]}></div>
      <div class:list={[$.dot, "bg-warning"]}></div>
      <div class:list={[$.dot, "bg-success"]}></div>
    </div>

    <div class={$.centerSlot}>
      <span class={$.langBadge} style="display: none;"></span>
      {title && <span class={$.titleText}>{title}</span>}
    </div>

    <div class={$.rightSlot}>
      {(ins || del) && (
        <div class="diff-legend flex items-center gap-1" aria-hidden="true">
          {ins && (
            <span class:list={[$.diffTag, "bg-(--prose-code-diff-add-bg) text-(--prose-code-diff-add-text) border-(--prose-code-diff-add-text)/20"]}>+</span>
          )}
          {del && (
            <span class:list={[$.diffTag, "bg-(--prose-code-diff-remove-bg) text-(--prose-code-diff-remove-text) border-(--prose-code-diff-remove-text)/20"]}>−</span>
          )}
        </div>
      )}
    </div>
  </div>

  <div class={$.content}>
    <button type="button" aria-label="Salin kode" title="Salin" class={$.copyBtn}>
      <Icon name="copy" className="copy-icon w-4 h-4" />
      <Icon name="check" className="check-icon w-4 h-4 hidden" />
    </button>
    <slot />
  </div>
</div>

<style is:global>
  @reference '@/styles/utils.css';
  .code-block-wrapper[data-focus] .line:not(.highlighted) { opacity: 0.8 !important; }
  .code-block-wrapper.is-collapsed .code-content pre {
    max-height: 8rem;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  }

  .code-content pre {
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }

  .code-content,
  .code-content pre {
    overflow-y: hidden !important;
    scrollbar-width: none !important;
    -ms-overflow-style: none !important;
  }

  .code-content::-webkit-scrollbar,
  .code-content pre::-webkit-scrollbar {
    display: none !important;
    width: 0 !important;
    height: 0 !important;
  }
  
  .btn-expand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem;
    color: var(--prose-fg-muted);
    background-color: var(--prose-code-bg);
    border-top: 1px solid var(--prose-code-border);
    cursor: pointer;
    transition: color 150ms ease, background-color 150ms ease;
    @apply text-button-13;
  }
  .btn-expand:hover {
    color: var(--prose-fg-strong);
  }
  .btn-expand svg { transition: transform 200ms ease; }
  .code-block-wrapper.is-collapsed .btn-expand svg { transform: rotate(180deg); }

  .copy-button.copied {
    color: var(--success) !important;
    border-color: var(--success) !important;
    background-color: var(--success-soft) !important;
  }
</style>

<script>
  (() => {
    const NAMES: Record<string, string> = {
      js: "JS", ts: "TS", jsx: "JSX", tsx: "TSX", py: "PY", html: "HTML", css: "CSS", 
      json: "JSON", jsonc: "JSON", yaml: "YAML", toml: "TOML", bash: "BASH", sh: "SH",
      md: "MD", mdx: "MDX", astro: "ASTRO", vue: "VUE", svelte: "SVELTE", rust: "RS"
    };

    const ALIASES: Record<string, string> = { javascript: "js", typescript: "ts", python: "py", shell: "sh" };
    
    const COLLAPSE_THRESHOLD = 25;

    const normalize = (l = "") => ALIASES[l.toLowerCase().trim()] ?? l.toLowerCase().trim();

    const getLang = (pre: Element | null): string => {
      if (!pre) return "";
      const dl = pre.getAttribute("data-language");
      if (dl) return normalize(dl);
      const m = pre.className.match(/language-([a-zA-Z0-9+#-]+)/);
      return normalize(m?.[1] ?? "");
    };

    const parseRanges = (str = ""): Set<number> => {
      const set = new Set<number>();
      for (const part of str.split(",")) {
        const t = part.trim();
        if (!t) continue;
        if (t.includes("-")) {
          const [a, b] = t.split("-").map(Number);
          if (!isNaN(a) && !isNaN(b)) for (let i = a; i <= b; i++) set.add(i);
        } else { const n = Number(t); if (!isNaN(n) && n > 0) set.add(n); }
      }
      return set;
    };

    const updateLangBadge = (wrapper: HTMLElement, lang: string) => {
      const badge = wrapper.querySelector<HTMLElement>(".lang-badge");
      if (!badge || !lang) return;
      badge.textContent = NAMES[lang] ?? lang.toUpperCase();
      badge.style.display = 'inline-flex';
    };

    const applyLineNumbers = (wrapper: HTMLElement): number => {
      const pre = wrapper.querySelector(".code-content pre");
      const lines = pre?.querySelectorAll("code .line");
      if (!pre || !lines?.length || lines.length <= 1) return lines?.length ?? 0;
      
      pre.classList.add("line-numbers");
      return lines.length;
    };

    const applyLineClasses = (wrapper: HTMLElement) => {
      const ins  = parseRanges(wrapper.dataset.ins);
      const del  = parseRanges(wrapper.dataset.del);
      const mark = parseRanges(wrapper.dataset.mark);
      if (!ins.size && !del.size && !mark.size) return;

      wrapper.querySelectorAll(".code-content pre code .line")
        .forEach((line, i) => {
          const n = i + 1;
          if (ins.has(n))  line.classList.add("diff-add");
          if (del.has(n))  line.classList.add("diff-remove");
          if (mark.has(n)) line.classList.add("highlighted");
        });

      if (mark.size) wrapper.setAttribute("data-focus", "");
    };

    const setupCopy = (wrapper: HTMLElement) => {
      const btn  = wrapper.querySelector<HTMLButtonElement>(".copy-button");
      const code = wrapper.querySelector(".code-content pre code");
      if (!btn || !code) return;

      btn.addEventListener("click", async () => {
        const text = code.textContent?.trimEnd() ?? "";
        
        try { 
          await navigator.clipboard.writeText(text); 
          
          const copyIcon = btn.querySelector(".copy-icon");
          const checkIcon = btn.querySelector(".check-icon");

          copyIcon?.classList.add("hidden"); 
          checkIcon?.classList.remove("hidden");
          btn.classList.add("copied"); 
          btn.setAttribute("aria-label", "Tersalin!");

          setTimeout(() => {
            copyIcon?.classList.remove("hidden"); 
            checkIcon?.classList.add("hidden");
            btn.classList.remove("copied"); 
            btn.setAttribute("aria-label", "Salin kode");
          }, 2000);
          
        } catch (err) {
          console.error("Gagal menyalin kode:", err);
        }
      });
    };

    const setupCollapse = (wrapper: HTMLElement, lineCount: number) => {
      if (lineCount < COLLAPSE_THRESHOLD) return;
      wrapper.classList.add("is-collapsed");

      const btn = document.createElement("button");
      btn.className = "btn-expand"; 
      btn.setAttribute("aria-label", "Tampilkan seluruh kode");
      btn.innerHTML = `
        <div class='flex items-center gap-2 rounded-lg hover:bg-muted active:bg-muted p-2'>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
          <span class="expand-label">Tampilkan ${lineCount} baris</span>
        </div>
      `;

      wrapper.appendChild(btn);
      const pre = wrapper.querySelector(".code-content pre") as HTMLElement;

      btn.addEventListener("click", () => {
        const collapsed = wrapper.classList.toggle("is-collapsed");
        const label = btn.querySelector<HTMLElement>(".expand-label");
        
        if (collapsed) {
          if (label) label.textContent = `Tampilkan ${lineCount} baris`;
          
          if (pre) pre.style.maxHeight = ""; 

          const rect = wrapper.getBoundingClientRect();

          if (rect.top < 0) {
            wrapper.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        } else {
          if (label) label.textContent = "Sembunyikan";
          if (pre) pre.style.maxHeight = `${pre.scrollHeight + 16}px`;
        }
      });
    };

    const init = (wrapper: HTMLElement) => {
      wrapper.classList.add("is-processed");
      const pre       = wrapper.querySelector(".code-content pre");
      const lang      = getLang(pre);
      
      updateLangBadge(wrapper, lang);
      const lineCount = applyLineNumbers(wrapper);
      applyLineClasses(wrapper);
      setupCopy(wrapper);
      setupCollapse(wrapper, lineCount);
    };

    const initAll = () => document.querySelectorAll<HTMLElement>(".code-block-wrapper:not(.is-processed)").forEach(init);
    
    if (document.readyState === "loading") { 
      document.addEventListener("DOMContentLoaded", initAll); 
    } else { 
      initAll(); 
    }
  })();
</script>