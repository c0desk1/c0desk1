---
import Icon from '@/components/ui/Icon';

interface Props {
  titles?: string[];
}

const { titles = ["Code"] } = Astro.props;
---

<div class="code-group not-prose mx-auto max-w-3xl my-8 overflow-hidden rounded-(--radius-md) border border-(--border) bg-(--bg-subtle)">
  <div class="flex items-center justify-between border-b border-(--border) px-2 md:px-3">
    <div class="flex overflow-x-auto no-scrollbar">
      {titles.map((title, index) => (
        <button
          data-code-tab={index}
          class="
            relative px-2 py-2 md:px-4 md:py-2.5
            text-xs md:text-sm font-semibold tracking-wide
            text-(--fg-subtle) hover:text-(--fg)
            data-[active=true]:text-(--fg)
            transition-colors duration-150
            whitespace-nowrap
          "
        >
          {title}
          <span class="absolute bottom-0 left-0 h-0.5 w-full rounded-full scale-x-0 bg-(--accent) transition-transform duration-200 [button[data-active=true]>&]:scale-x-100" />
        </button>
      ))}
    </div>
    <button
      class="copy-button p-1.5 md:p-2 text-(--fg-subtle) hover:text-(--accent) cursor-pointer transition-colors duration-150"
      aria-label="Copy code"
    >
      <Icon name="copy" className="copy-icon w-4 h-4" />
      <Icon name="check" className="check-icon w-4 h-4 hidden text-(--accent)" />
    </button>
  </div>
  <div class="code-group-content [&_pre]:m-0! [&_pre]:rounded-none! [&_pre]:border-none! [&_pre]:bg-transparent!">
    <slot />
  </div>
</div>

<style is:global>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  
  .code-group-content > :global(*:not(:first-child)) { display: none; }
  
  /* Hanya override yang diperlukan – biarkan font-size/padding dari global code.css */
  .code-group-content pre {
    margin: 0 !important;
    border-radius: 0 !important;
    border: none !important;
    background: transparent !important;
  }
</style>

<script>
  const initCodeGroup = () => {
    document.querySelectorAll<HTMLElement>('.code-group').forEach(group => {
      const tabs = group.querySelectorAll<HTMLButtonElement>('[data-code-tab]');
      const contents = group.querySelector('.code-group-content')?.children;
      const copyBtn = group.querySelector<HTMLButtonElement>('.copy-button');

      if (!tabs.length || !contents) return;

      const activate = (index: number) => {
        tabs.forEach((tab, i) => {
          tab.setAttribute('data-active', String(i === index));
          if (contents[i]) {
            (contents[i] as HTMLElement).style.display = i === index ? 'block' : 'none';
          }
        });
      };

      tabs.forEach((tab, i) => tab.addEventListener('click', () => activate(i)));

      copyBtn?.addEventListener('click', async () => {
        const active = Array.from(contents).find(c => (c as HTMLElement).style.display !== 'none');
        const code = active?.querySelector('code')?.innerText;
        if (!code) return;

        await navigator.clipboard.writeText(code);

        const copyIcon  = copyBtn.querySelector('.copy-icon');
        const checkIcon = copyBtn.querySelector('.check-icon');
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');

        setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
        }, 2000);
      });

      activate(0);
    });
  };

  initCodeGroup();
  document.addEventListener('astro:after-swap', initCodeGroup);
</script>