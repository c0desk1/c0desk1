---
// src/components/mdx/Code.astro
import Icon from "@/components/ui/icons/Icon.astro";

interface Props {
  ins?:   string;
  del?:   string;
  mark?:  string;
  title?: string;
}

const { ins = "", del = "", mark = "", title = "" } = Astro.props;

const $ = {
  wrapper:   "code-block-wrapper not-prose relative my-8 rounded-xl overflow-hidden border border-(--prose-code-border) bg-(--prose-code-bg)",
  header:    "grid grid-cols-[1fr_auto_1fr] items-center px-4 py-2 border-b border-(--prose-code-border) bg-(--prose-code-header-bg)",
  leftSlot:  "flex items-center justify-start gap-1.5",
  centerSlot:"flex items-center justify-center min-w-0",
  rightSlot: "flex items-center justify-end gap-3", 
  dot:       "size-2.5 rounded-full border border-(--prose-border)/10",
  titleText: "code-block-title truncate text-(--prose-fg-muted) tracking-wide",
  diffTag:   "diff-tag flex items-center justify-center size-5 rounded border",
  langBadge: "lang-badge text-(--prose-fg-muted) bg-muted/5 uppercase px-2 py-0.5 rounded-full",  
  content:   "code-content relative group/content",
  copyBtn:   "copy-button absolute top-3 right-3 z-10 flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-(--prose-fg-muted) border border-(--prose-code-border) bg-(--prose-code-bg)/60 backdrop-blur-md opacity-0 group-hover/content:opacity-100 transition-all duration-200 hover:text-(--prose-fg-strong) hover:bg-(--prose-code-header-bg)",
} as const;
---

<div
  class={$.wrapper}
  data-ins={ins}
  data-del={del}
  data-mark={mark}
>
  <div class={$.header}>
    <div class={$.leftSlot} aria-hidden="true">
      <div class:list={[$.dot, "bg-error"]}></div>
      <div class:list={[$.dot, "bg-warning"]}></div>
      <div class:list={[$.dot, "bg-success"]}></div>
    </div>

    <div class={$.centerSlot}>
      <span class={$.langBadge} style="display: none;"></span>
      {title && <span class={$.titleText}>{title}</span>}
    </div>

    <div class={$.rightSlot}>
      {(ins || del) && (
        <div class="flex items-center gap-1" aria-hidden="true">
          {ins && (
            <span class:list={[$.diffTag, "bg-(--prose-code-diff-add-bg) text-(--prose-code-diff-add-text) border-(--prose-code-diff-add-text)/20"]}>+</span>
          )}
          {del && (
            <span class:list={[$.diffTag, "bg-(--prose-code-diff-remove-bg) text-(--prose-code-diff-remove-text) border-(--prose-code-diff-remove-text)/20"]}>−</span>
          )}
        </div>
      )}
    </div>
  </div>

  <div class={$.content}>
    <button type="button" aria-label="Copy code" class={$.copyBtn}>
      <Icon name="copy"  className="copy-icon  w-3.5 h-3.5" />
      <Icon name="check" className="check-icon w-3.5 h-3.5 hidden" />
      <span class="copy-label">Copy</span>
    </button>
    <slot />
  </div>
</div>

<style is:global>
  .code-block-title { @apply text-label-13 font-mono; }
  .diff-tag { @apply text-[10px] font-mono font-bold; }
  .lang-badge { @apply text-label-11 font-mono font-bold; }
  .copy-button { @apply text-label-12 font-mono; }
  .btn-expand { @apply text-label-13 font-mono; }

  .code-block-wrapper .code-content pre {
    @apply text-code-14;
    margin: 0 !important;
    padding: 1rem 0 !important;
    background: transparent !important;
    border: none !important;
    overflow-x: auto !important; /* Fix Horizontal Scroll */
    white-space: pre !important; /* Force code to not wrap */
    word-break: normal !important;
    word-wrap: normal !important;
    scrollbar-width: thin;
    scrollbar-color: var(--prose-border-strong) transparent;
  }
  .code-block-wrapper .code-content pre::-webkit-scrollbar { height: 4px; }
  .code-block-wrapper .code-content pre::-webkit-scrollbar-track { background: transparent; }
  .code-block-wrapper .code-content pre::-webkit-scrollbar-thumb { background: var(--prose-border-strong); border-radius: 2px; }

  .code-block-wrapper .code-content pre code {
    display: block !important;
    width: fit-content !important;
    min-width: 100% !important;
    white-space: pre !important;
  }

  .code-block-wrapper .code-content .line {
    display: block !important;
    padding-inline: 1.5rem !important;
    min-height: 1.5em !important;
    position: relative !important;
    transition: background-color 100ms ease, opacity 200ms ease;
  }

  .code-block-wrapper .code-content pre.line-numbers { counter-reset: cb-line; }
  .code-block-wrapper .code-content pre.line-numbers .line {
    padding-inline-start: calc(3.5rem + 1.5rem) !important;
    counter-increment: cb-line;
  }
  .code-block-wrapper .code-content pre.line-numbers .line::before {
    @apply text-code-14;
    content: counter(cb-line);
    position: absolute;
    left: 0;
    bottom: 0;
    top: 0;
    height: 100%;
    width: 3.5rem;
    text-align: right;
    color: var(--prose-code-number);
    font-variant-numeric: tabular-nums;
    user-select: none;
    pointer-events: none;
    padding-right: 0.75rem;
    border-right: 1px solid var(--prose-code-border);
  }

  .code-block-wrapper .code-content .line.diff-add { background-color: var(--prose-code-line-add-bg) !important; }
  .code-block-wrapper .code-content .line.diff-remove { background-color: var(--prose-code-line-remove-bg) !important; opacity: 0.6; }
  .code-block-wrapper .code-content .line.highlighted { background-color: var(--prose-code-line-highlighted-bg) !important; }
  
  .code-block-wrapper .code-content .line.highlighted::before {
    content: "";
    position: absolute;
    left: 0; top: 0; bottom: 0; width: 3px;
    background-color: var(--prose-code-line-highlighted-border);
    pointer-events: none;
    z-index: 2;
  }

  .code-block-wrapper .code-content .line.diff-add::after,
  .code-block-wrapper .code-content .line.diff-remove::after {
    position: absolute;
    left: 0.35rem;
    top: 0;
    font-weight: 800;
    pointer-events: none;
    user-select: none;
    z-index: 2;
    @apply text-label-14;
  }
  .code-block-wrapper .code-content .line.diff-add::after { content: "+"; color: var(--prose-code-diff-add-text); }
  .code-block-wrapper .code-content .line.diff-remove::after { content: "−"; color: var(--prose-code-diff-remove-text); }
  
  .code-block-wrapper .code-content pre.line-numbers .line.diff-add::after,
  .code-block-wrapper .code-content pre.line-numbers .line.diff-remove::after {
    left: calc(3.5rem + 0.35rem) !important;
  }

  /* Focus Mode Dimming */
  .code-block-wrapper[data-focus] .line:not(.highlighted) { opacity: 0.35 !important; }
  .code-block-wrapper[data-focus] .line:not(.highlighted):hover { opacity: 0.8 !important; }

  /* Fix Expanded (Collapse Masking) */
  .code-block-wrapper.is-collapsed .code-content pre {
    max-height: 8rem !important;
    overflow-y: hidden !important;
    mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  }
  
  .btn-expand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem;
    color: var(--prose-fg-muted);
    background-color: var(--prose-code-header-bg);
    border-top: 1px solid var(--prose-code-border);
    cursor: pointer;
    transition: color 150ms ease, background-color 150ms ease;
  }
  .btn-expand:hover {
    color: var(--prose-fg-strong);
    background-color: color-mix(in srgb, var(--prose-code-header-bg) 95%, #000);
  }
  .btn-expand svg { transition: transform 200ms ease; }
  .code-block-wrapper.is-collapsed .btn-expand svg { transform: rotate(180deg); }

  .copy-button.copied {
    color: var(--success) !important;
    border-color: var(--success) !important;
    background-color: var(--success-soft) !important;
  }
</style>

<script>
  (() => {
    const NAMES: Record<string, string> = {
      js: "JS", ts: "TS", jsx: "JSX", tsx: "TSX", py: "PY", html: "HTML", css: "CSS", 
      json: "JSON", jsonc: "JSON", yaml: "YAML", toml: "TOML", bash: "BASH", sh: "SH",
      md: "MD", mdx: "MDX", astro: "ASTRO", vue: "VUE", svelte: "SVELTE", rust: "RS"
    };

    const ALIASES: Record<string, string> = { javascript: "js", typescript: "ts", python: "py", shell: "sh" };
    
    const COLLAPSE_THRESHOLD = 25;

    const normalize = (l = "") => ALIASES[l.toLowerCase().trim()] ?? l.toLowerCase().trim();

    const getLang = (pre: Element | null): string => {
      if (!pre) return "";
      const dl = pre.getAttribute("data-language");
      if (dl) return normalize(dl);
      const m = pre.className.match(/language-([a-zA-Z0-9+#-]+)/);
      return normalize(m?.[1] ?? "");
    };

    const parseRanges = (str = ""): Set<number> => {
      const set = new Set<number>();
      for (const part of str.split(",")) {
        const t = part.trim();
        if (!t) continue;
        if (t.includes("-")) {
          const [a, b] = t.split("-").map(Number);
          if (!isNaN(a) && !isNaN(b)) for (let i = a; i <= b; i++) set.add(i);
        } else { const n = Number(t); if (!isNaN(n) && n > 0) set.add(n); }
      }
      return set;
    };

    const updateLangBadge = (wrapper: HTMLElement, lang: string) => {
      const badge = wrapper.querySelector<HTMLElement>(".lang-badge");
      if (!badge || !lang) return;
      badge.textContent = NAMES[lang] ?? lang.toUpperCase();
      badge.style.display = 'inline-flex';
    };

    const applyLineNumbers = (wrapper: HTMLElement): number => {
      const pre   = wrapper.querySelector(".code-content pre");
      const lines = pre?.querySelectorAll("code .line");
      if (!pre || !lines?.length || lines.length <= 1) return lines?.length ?? 0;
      pre.classList.add("line-numbers");
      return lines.length;
    };

    const applyLineClasses = (wrapper: HTMLElement) => {
      const ins  = parseRanges(wrapper.dataset.ins);
      const del  = parseRanges(wrapper.dataset.del);
      const mark = parseRanges(wrapper.dataset.mark);
      if (!ins.size && !del.size && !mark.size) return;

      wrapper.querySelectorAll(".code-content pre code .line")
        .forEach((line, i) => {
          const n = i + 1;
          if (ins.has(n))  line.classList.add("diff-add");
          if (del.has(n))  line.classList.add("diff-remove");
          if (mark.has(n)) line.classList.add("highlighted");
        });

      if (mark.size) wrapper.setAttribute("data-focus", "");
    };

    const setupCopy = (wrapper: HTMLElement) => {
      const btn  = wrapper.querySelector<HTMLButtonElement>(".copy-button");
      const code = wrapper.querySelector(".code-content pre code");
      if (!btn || !code) return;

      btn.addEventListener("click", async () => {
        const text = code.textContent?.trimEnd() ?? "";
        try { await navigator.clipboard.writeText(text); } catch {
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.cssText = "position:absolute;left:-9999px;top:-9999px";
          document.body.append(ta); ta.select(); document.execCommand("copy"); ta.remove();
        }

        const label = btn.querySelector<HTMLElement>(".copy-label");
        const copyIcon = btn.querySelector(".copy-icon");
        const checkIcon = btn.querySelector(".check-icon");

        copyIcon?.classList.add("hidden"); checkIcon?.classList.remove("hidden");
        btn.classList.add("copied"); if (label) label.textContent = "Copied!";

        setTimeout(() => {
          copyIcon?.classList.remove("hidden"); checkIcon?.classList.add("hidden");
          btn.classList.remove("copied"); if (label) label.textContent = "Copy";
        }, 2000);
      });
    };

    const setupCollapse = (wrapper: HTMLElement, lineCount: number) => {
      if (lineCount < COLLAPSE_THRESHOLD) return;
      wrapper.classList.add("is-collapsed");

      const btn = document.createElement("button");
      btn.className = "btn-expand"; 
      btn.setAttribute("aria-label", "Show full code");
      btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
        <span class="expand-label">Show ${lineCount} lines</span>
      `;

      wrapper.appendChild(btn);
      btn.addEventListener("click", () => {
        const collapsed = wrapper.classList.toggle("is-collapsed");
        const label = btn.querySelector<HTMLElement>(".expand-label");
        if (label) label.textContent = collapsed ? `Show ${lineCount} lines` : "Hide";
      });
    };

    const init = (wrapper: HTMLElement) => {
      wrapper.classList.add("is-processed");
      const pre       = wrapper.querySelector(".code-content pre");
      const lang      = getLang(pre);
      updateLangBadge(wrapper, lang);
      const lineCount = applyLineNumbers(wrapper);
      applyLineClasses(wrapper);
      setupCopy(wrapper);
      setupCollapse(wrapper, lineCount);
    };

    const initAll = () => document.querySelectorAll<HTMLElement>(".code-block-wrapper:not(.is-processed)").forEach(init);
    if (document.readyState === "loading") { document.addEventListener("DOMContentLoaded", initAll); } else { initAll(); }
  })();
</script>