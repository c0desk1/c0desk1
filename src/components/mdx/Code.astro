---
// src/components/mdx/Code.astro
import Icon from "@/components/ui/icons/Icon.astro";

interface Props {
  ins?:   string;
  del?:   string;
  mark?:  string;
  title?: string;
}

const { ins = "", del = "", mark = "", title = "" } = Astro.props;

// ── Tailwind class consts ────────────────────────────────────────────────────
const $ = {
  wrapper:   "code-block not-prose relative my-8 rounded-xl overflow-hidden",
  header:    "code-block__header flex items-center gap-3 px-4 py-2.5",
  dots:      "flex items-center gap-1.5 shrink-0",
  dot:       "size-2.5 rounded-full",
  titleText: "code-block__title font-mono truncate text-[11px] tracking-wide",
  langBadge: "code-block__lang font-mono text-[9px] font-bold tracking-[0.12em] uppercase px-2 py-0.5 rounded-full ml-auto shrink-0",
  divider:   "code-block__divider h-px",
  content:   "code-block__content relative overflow-x-auto",
  copyBtn:   "code-block__copy absolute top-2.5 right-2.5 z-10 flex items-center gap-1.5 px-2 py-1 rounded-md text-[10px] font-mono font-medium transition-all duration-200 opacity-0 group-hover/content:opacity-100",
} as const;
---

<div
  class={$.wrapper}
  data-ins={ins}
  data-del={del}
  data-mark={mark}
>
  <!-- Header: dots + title + lang badge -->
  <div class={$.header}>
    <div class={$.dots} aria-hidden="true">
      <div class:list={[$.dot, "dot-close"]}></div>
      <div class:list={[$.dot, "dot-min"]}></div>
      <div class:list={[$.dot, "dot-max"]}></div>
    </div>

    {title && (
      <span class={$.titleText}>{title}</span>
    )}

    <!-- Diff legend pills -->
    {(ins || del) && (
      <div class="flex items-center gap-1 ml-auto" aria-hidden="true">
        {ins && <span class="diff-pill ins">+</span>}
        {del && <span class="diff-pill del">−</span>}
      </div>
    )}

    <span class={$.langBadge}></span>
  </div>

  <!-- Divider -->
  <div class={$.divider} aria-hidden="true"></div>

  <!-- Code content + floating copy button -->
  <div class:list={[$.content, "group/content"]}>
    <button
      type="button"
      aria-label="Salin kode"
      class={$.copyBtn}
    >
      <Icon name="copy"  className="copy-icon  w-3.5 h-3.5" />
      <Icon name="check" className="check-icon w-3.5 h-3.5 hidden" />
      <span class="copy-label">Salin</span>
    </button>

    <slot />
  </div>
</div>

<!-- ─── Styles ─────────────────────────────────────────────────────────────── -->
<style>
  /* ── Design tokens ─────────────────────────────────────────────────────── */
  .code-block {
    --cb-bg:          color-mix(in srgb, var(--prose-bg, #0d0d0d) 96%, #000);
    --cb-border:      color-mix(in srgb, var(--prose-fg, #fff) 9%, transparent);
    --cb-header-bg:   color-mix(in srgb, var(--prose-bg, #0d0d0d) 85%, #000);
    --cb-header-fg:   color-mix(in srgb, var(--prose-fg, #fff) 35%, transparent);
    --cb-title-fg:    color-mix(in srgb, var(--prose-fg, #fff) 55%, transparent);
    --cb-accent:      #10b981;
    --cb-accent-dim:  color-mix(in srgb, #10b981 14%, transparent);
    --cb-accent-ring: color-mix(in srgb, #10b981 22%, transparent);

    /* diff */
    --cb-ins-bg:   color-mix(in srgb, #10b981 7%, transparent);
    --cb-ins-fg:   #10b981;
    --cb-del-bg:   color-mix(in srgb, #ef4444 7%, transparent);
    --cb-del-fg:   #ef4444;
    --cb-mark-bg:  color-mix(in srgb, #f59e0b 9%, transparent);
    --cb-mark-fg:  #f59e0b;

    /* line numbers */
    --cb-ln-fg: color-mix(in srgb, var(--prose-fg, #fff) 16%, transparent);
    --cb-ln-w:  2.5rem;

    background:  var(--cb-bg) !important;
    border:      1px solid var(--cb-border) !important;
    box-shadow:
      0 0 0 1px color-mix(in srgb, #10b981 3%, transparent),
      0 2px 4px  color-mix(in srgb, #000 15%, transparent),
      0 12px 40px color-mix(in srgb, #000 25%, transparent) !important;
  }

  /* ── Header ───────────────────────────────────────────────────────────── */
  .code-block__header {
    background:  var(--cb-header-bg) !important;
    min-height:  2.375rem !important;
    border-bottom: none !important;
  }

  /* ── Mac dots ─────────────────────────────────────────────────────────── */
  .dot-close { background: #ff5f57 !important; }
  .dot-min   { background: #febc2e !important; }
  .dot-max   { background: #28c840 !important; }

  /* ── Title ────────────────────────────────────────────────────────────── */
  .code-block__title {
    font-family: var(--font-GeistMono, ui-monospace, monospace) !important;
    color:       var(--cb-title-fg) !important;
    font-size:   0.6875rem !important;
  }

  /* ── Lang badge ───────────────────────────────────────────────────────── */
  .code-block__lang {
    font-family: var(--font-GeistMono, ui-monospace, monospace) !important;
    background:  var(--cb-accent-dim) !important;
    color:       var(--cb-accent) !important;
    border:      1px solid var(--cb-accent-ring) !important;
    display:     none !important;
  }
  .code-block__lang:not(:empty) {
    display: inline-flex !important;
    align-items: center !important;
  }

  /* ── Diff pills ───────────────────────────────────────────────────────── */
  .diff-pill {
    display:         inline-flex !important;
    align-items:     center !important;
    justify-content: center !important;
    width:           1.25rem !important;
    height:          1.25rem !important;
    border-radius:   4px !important;
    font-size:       0.7rem !important;
    font-weight:     700 !important;
    font-family:     var(--font-GeistMono, ui-monospace, monospace) !important;
  }
  .diff-pill.ins {
    background: var(--cb-ins-bg) !important;
    color:      var(--cb-ins-fg) !important;
    border:     1px solid color-mix(in srgb, #10b981 18%, transparent) !important;
  }
  .diff-pill.del {
    background: var(--cb-del-bg) !important;
    color:      var(--cb-del-fg) !important;
    border:     1px solid color-mix(in srgb, #ef4444 18%, transparent) !important;
  }

  /* ── Divider ──────────────────────────────────────────────────────────── */
  .code-block__divider {
    background: var(--cb-border) !important;
  }

  /* ── Content scrollbar ────────────────────────────────────────────────── */
  .code-block__content {
    scrollbar-width: thin !important;
    scrollbar-color: var(--cb-border) transparent !important;
  }
  .code-block__content::-webkit-scrollbar       { height: 3px !important; }
  .code-block__content::-webkit-scrollbar-track  { background: transparent !important; }
  .code-block__content::-webkit-scrollbar-thumb  {
    background:    var(--cb-border) !important;
    border-radius: 999px !important;
  }

  /* ── Copy button ──────────────────────────────────────────────────────── */
  .code-block__copy {
    background:      color-mix(in srgb, var(--prose-fg, #fff) 5%, transparent) !important;
    color:           color-mix(in srgb, var(--prose-fg, #fff) 40%, transparent) !important;
    border:          1px solid var(--cb-border) !important;
    backdrop-filter: blur(8px) !important;
    font-family:     var(--font-GeistMono, ui-monospace, monospace) !important;
  }
  .code-block__copy:hover {
    background:   color-mix(in srgb, var(--prose-fg, #fff) 9%, transparent) !important;
    color:        var(--cb-accent) !important;
    border-color: var(--cb-accent-ring) !important;
  }
  .code-block__copy.copied {
    color:        var(--cb-accent) !important;
    border-color: var(--cb-accent-ring) !important;
    background:   var(--cb-accent-dim) !important;
  }
  /* touch devices: always visible */
  @media (hover: none) {
    .code-block__copy { opacity: 1 !important; }
  }

  /* ── Pre / Code reset ─────────────────────────────────────────────────── */
  .code-block__content pre {
    margin:        0 !important;
    padding:       1rem 0 !important;
    background:    transparent !important;
    border-radius: 0 !important;
    border:        none !important;
    box-shadow:    none !important;
    font-family:   var(--font-GeistMono, ui-monospace, monospace) !important;
    font-size:     0.8125rem !important;
    line-height:   1.75 !important;
  }
  .code-block__content code {
    display:    block !important;
    width:      fit-content !important;
    min-width:  100% !important;
    background: transparent !important;
    padding:    0 !important;
    border:     none !important;
    box-shadow: none !important;
  }

  /* ── Lines ────────────────────────────────────────────────────────────── */
  .code-block__content .line {
    display:        block !important;
    padding-inline: 1.25rem !important;
    min-height:     1.75em !important;
    position:       relative !important;
    transition:     background 80ms ease !important;
  }

  /* ── Line numbers ─────────────────────────────────────────────────────── */
  .code-block__content pre.line-numbers { counter-reset: cb-line !important; }
  .code-block__content pre.line-numbers .line {
    padding-inline-start: calc(var(--cb-ln-w) + 1.25rem) !important;
    counter-increment:    cb-line !important;
  }
  .code-block__content pre.line-numbers .line::before {
    content:              counter(cb-line) !important;
    position:             absolute !important;
    left:                 0 !important;
    width:                var(--cb-ln-w) !important;
    text-align:           right !important;
    padding-right:        0.875rem !important;
    color:                var(--cb-ln-fg) !important;
    font-variant-numeric: tabular-nums !important;
    user-select:          none !important;
    pointer-events:       none !important;
    font-size:            0.6875rem !important;
  }

  /* ── INS lines ────────────────────────────────────────────────────────── */
  .code-block__content .line.diff-add { background: var(--cb-ins-bg) !important; }
  .code-block__content .line.diff-add::after {
    content:        "+" !important;
    position:       absolute !important;
    left:           0.3rem !important;
    top:            0 !important;
    line-height:    1.75 !important;
    color:          var(--cb-ins-fg) !important;
    font-size:      0.6rem !important;
    font-weight:    800 !important;
    pointer-events: none !important;
    user-select:    none !important;
  }

  /* ── DEL lines ────────────────────────────────────────────────────────── */
  .code-block__content .line.diff-remove {
    background: var(--cb-del-bg) !important;
    opacity:    0.6 !important;
  }
  .code-block__content .line.diff-remove::after {
    content:        "−" !important;
    position:       absolute !important;
    left:           0.3rem !important;
    top:            0 !important;
    line-height:    1.75 !important;
    color:          var(--cb-del-fg) !important;
    font-size:      0.6rem !important;
    font-weight:    800 !important;
    pointer-events: none !important;
    user-select:    none !important;
  }

  /* ── MARK lines ───────────────────────────────────────────────────────── */
  .code-block__content .line.highlighted { background: var(--cb-mark-bg) !important; }
  .code-block__content .line.highlighted::before {
    content:       "" !important;
    position:      absolute !important;
    left:          0 !important;
    top:           0 !important;
    bottom:        0 !important;
    width:         2px !important;
    background:    var(--cb-mark-fg) !important;
    border-radius: 0 2px 2px 0 !important;
    pointer-events: none !important;
  }

  /* line-numbers + diff: shift gutter marker ───────────────────────────── */
  .code-block__content pre.line-numbers .line.diff-add::after,
  .code-block__content pre.line-numbers .line.diff-remove::after {
    left: calc(var(--cb-ln-w) + 0.2rem) !important;
  }

  /* ── Focus mode: dim non-marked lines ────────────────────────────────── */
  .code-block[data-focus] .line:not(.highlighted) {
    opacity:    0.3 !important;
    transition: opacity 200ms ease !important;
  }
  .code-block[data-focus] .line:not(.highlighted):hover {
    opacity: 0.7 !important;
  }

  /* ── Collapse ─────────────────────────────────────────────────────────── */
  .code-block.is-collapsed .code-block__content pre {
    max-height:           5rem !important;
    overflow:             hidden !important;
    mask-image:           linear-gradient(to bottom, black 20%, transparent 100%) !important;
    -webkit-mask-image:   linear-gradient(to bottom, black 20%, transparent 100%) !important;
  }
  .code-block__expand {
    display:         flex !important;
    align-items:     center !important;
    justify-content: center !important;
    gap:             0.375rem !important;
    width:           100% !important;
    padding:         0.5rem !important;
    font-family:     var(--font-GeistMono, ui-monospace, monospace) !important;
    font-size:       0.6875rem !important;
    color:           var(--cb-header-fg) !important;
    background:      var(--cb-header-bg) !important;
    border-top:      1px solid var(--cb-border) !important;
    border-left:     none !important;
    border-right:    none !important;
    border-bottom:   none !important;
    cursor:          pointer !important;
    transition:      color 150ms ease, background 150ms ease !important;
    letter-spacing:  0.04em !important;
  }
  .code-block__expand:hover {
    color:      var(--cb-accent) !important;
    background: var(--cb-accent-dim) !important;
  }
  .code-block__expand svg {
    transition: transform 200ms ease !important;
  }
  .code-block.is-collapsed .code-block__expand svg {
    transform: rotate(180deg) !important;
  }
</style>

<!-- ─── Script ─────────────────────────────────────────────────────────────── -->
<script>
  (() => {
    const NAMES: Record<string, string> = {
      js: "JS", ts: "TS", jsx: "JSX", tsx: "TSX",
      py: "PY", html: "HTML", css: "CSS", scss: "SCSS",
      json: "JSON", jsonc: "JSON", yaml: "YAML", toml: "TOML",
      bash: "BASH", sh: "SH", zsh: "ZSH", sql: "SQL",
      md: "MD", mdx: "MDX", astro: "ASTRO", vue: "VUE",
      svelte: "SVELTE", go: "GO", rust: "RS", cpp: "C++",
      c: "C", cs: "C#", java: "JAVA", php: "PHP",
      rb: "RB", swift: "SWIFT", kt: "KT",
      dockerfile: "DOCKER", prisma: "PRISMA", graphql: "GQL",
    };

    const ALIASES: Record<string, string> = {
      javascript: "js", typescript: "ts", python: "py",
      shell: "sh", ruby: "rb", csharp: "cs",
    };

    const COLLAPSE_THRESHOLD = 25;

    const normalize = (l = "") => ALIASES[l.toLowerCase().trim()] ?? l.toLowerCase().trim();

    const getLang = (pre: Element | null): string => {
      if (!pre) return "";
      const dl = pre.getAttribute("data-language");
      if (dl) return normalize(dl);
      const m = pre.className.match(/language-([a-zA-Z0-9+#-]+)/);
      return normalize(m?.[1] ?? "");
    };

    const parseRanges = (str = ""): Set<number> => {
      const set = new Set<number>();
      for (const part of str.split(",")) {
        const t = part.trim();
        if (!t) continue;
        if (t.includes("-")) {
          const [a, b] = t.split("-").map(Number);
          if (!isNaN(a) && !isNaN(b)) for (let i = a; i <= b; i++) set.add(i);
        } else {
          const n = Number(t);
          if (!isNaN(n) && n > 0) set.add(n);
        }
      }
      return set;
    };

    const updateLangBadge = (wrapper: HTMLElement, lang: string) => {
      const badge = wrapper.querySelector<HTMLElement>(".code-block__lang");
      if (!badge || !lang) return;
      badge.textContent = NAMES[lang] ?? lang.toUpperCase();
    };

    const applyLineNumbers = (wrapper: HTMLElement): number => {
      const pre   = wrapper.querySelector(".code-block__content pre");
      const lines = pre?.querySelectorAll("code .line");
      if (!pre || !lines?.length || lines.length <= 1) return lines?.length ?? 0;
      pre.classList.add("line-numbers");
      return lines.length;
    };

    const applyLineClasses = (wrapper: HTMLElement) => {
      const ins  = parseRanges(wrapper.dataset.ins);
      const del  = parseRanges(wrapper.dataset.del);
      const mark = parseRanges(wrapper.dataset.mark);
      if (!ins.size && !del.size && !mark.size) return;

      wrapper.querySelectorAll(".code-block__content pre code .line")
        .forEach((line, i) => {
          const n = i + 1;
          if (ins.has(n))  line.classList.add("diff-add");
          if (del.has(n))  line.classList.add("diff-remove");
          if (mark.has(n)) line.classList.add("highlighted");
        });

      // Focus mode aktif jika ada mark lines
      if (mark.size) wrapper.setAttribute("data-focus", "");
    };

    const setupCopy = (wrapper: HTMLElement) => {
      const btn  = wrapper.querySelector<HTMLButtonElement>(".code-block__copy");
      const code = wrapper.querySelector(".code-block__content pre code");
      if (!btn || !code) return;

      btn.addEventListener("click", async () => {
        const text = code.textContent?.trimEnd() ?? "";
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.cssText = "position:absolute;left:-9999px;top:-9999px";
          document.body.append(ta);
          ta.select();
          document.execCommand("copy");
          ta.remove();
        }

        const label     = btn.querySelector<HTMLElement>(".copy-label");
        const copyIcon  = btn.querySelector(".copy-icon");
        const checkIcon = btn.querySelector(".check-icon");

        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
        btn.classList.add("copied");
        btn.setAttribute("aria-label", "Tersalin!");
        if (label) label.textContent = "Tersalin!";

        setTimeout(() => {
          copyIcon?.classList.remove("hidden");
          checkIcon?.classList.add("hidden");
          btn.classList.remove("copied");
          btn.setAttribute("aria-label", "Salin kode");
          if (label) label.textContent = "Salin";
        }, 2000);
      });
    };

    const setupCollapse = (wrapper: HTMLElement, lineCount: number) => {
      if (lineCount < COLLAPSE_THRESHOLD) return;
      wrapper.classList.add("is-collapsed");

      const btn = document.createElement("button");
      btn.className = "code-block__expand";
      btn.setAttribute("aria-label", "Tampilkan seluruh kode");
      btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
        <span class="expand-label">Tampilkan ${lineCount} baris</span>
      `;

      wrapper.appendChild(btn);

      btn.addEventListener("click", () => {
        const collapsed = wrapper.classList.toggle("is-collapsed");
        const label = btn.querySelector<HTMLElement>(".expand-label");
        btn.setAttribute("aria-label", collapsed ? "Tampilkan seluruh kode" : "Sembunyikan kode");
        if (label) label.textContent = collapsed ? `Tampilkan ${lineCount} baris` : "Sembunyikan";
      });
    };

    const init = (wrapper: HTMLElement) => {
      wrapper.classList.add("is-processed");
      const pre       = wrapper.querySelector(".code-block__content pre");
      const lang      = getLang(pre);
      updateLangBadge(wrapper, lang);
      const lineCount = applyLineNumbers(wrapper);
      applyLineClasses(wrapper);
      setupCopy(wrapper);
      setupCollapse(wrapper, lineCount);
    };

    const initAll = () =>
      document.querySelectorAll<HTMLElement>(".code-block:not(.is-processed)").forEach(init);

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initAll);
    } else {
      initAll();
    }
  })();
</script>