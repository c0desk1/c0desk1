---
// src/components/mdx/Code.astro
import Icon from "@/components/ui/icons/Icon.astro";

interface Props {
  ins?:   string;
  del?:   string;
  mark?:  string;
  title?: string;
}

const { ins = "", del = "", mark = "", title = "" } = Astro.props;

const $ = {
  wrapper:    "code-block not-prose my-8 rounded-xl overflow-hidden isolate",
  header:     "code-block__header flex items-center justify-between gap-4 px-4 py-2.5",
  left:       "flex items-center gap-3 min-w-0",
  dots:       "flex items-center gap-1.5 shrink-0",
  dot:        "size-3 rounded-full",
  titleWrap:  "flex items-center gap-2 min-w-0",
  titleIcon:  "shrink-0 opacity-40",
  titleText:  "code-block__title truncate text-xs font-medium tracking-wide",
  langBadge:  "code-block__lang shrink-0 font-mono text-[10px] font-semibold tracking-widest uppercase px-2 py-0.5 rounded-full",
  right:      "flex items-center gap-1 shrink-0",
  diffLegend: "flex items-center gap-1 mr-1",
  diffAdd:    "flex items-center gap-1 text-[11px] font-mono font-medium px-1.5 py-0.5 rounded",
  diffRem:    "flex items-center gap-1 text-[11px] font-mono font-medium px-1.5 py-0.5 rounded",
  copyBtn:    "code-block__copy group/btn relative flex items-center justify-center size-7 rounded-md transition-all duration-150",
  divider:    "code-block__divider h-px",
  content:    "code-block__content overflow-x-auto",
} as const;
---

<div
  class={$.wrapper}
  data-ins={ins}
  data-del={del}
  data-mark={mark}
>
  <div class={$.header}>

    <div class={$.left}>
      <div class={$.dots} aria-hidden="true">
        <div class:list={[$.dot, "dot-close"]}></div>
        <div class:list={[$.dot, "dot-min"]}></div>
        <div class:list={[$.dot, "dot-max"]}></div>
      </div>

      {title && (
        <div class={$.titleWrap}>
          <svg class={$.titleIcon} xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          <span class={$.titleText}>{title}</span>
        </div>
      )}
    </div>

    <div class={$.right}>

      {(ins || del) && (
        <div class={$.diffLegend} aria-hidden="true">
          {ins && (
            <span class:list={[$.diffAdd, "diff-legend-add"]}>
              <Icon name="plus" className="w-3 h-3" />
            </span>
          )}
          {del && (
            <span class:list={[$.diffRem, "diff-legend-rem"]}>
              <Icon name="minus" className="w-3 h-3" />
            </span>
          )}
        </div>
      )}

      <span class={$.langBadge} aria-hidden="true"></span>

      <button
        type="button"
        aria-label="Salin kode"
        class={$.copyBtn}
      >
        <Icon name="copy"  className="copy-icon  w-4 h-4 transition-all duration-150" />
        <Icon name="check" className="check-icon w-4 h-4 transition-all duration-150 hidden" />
      </button>
    </div>
  </div>

  <div class={$.divider} aria-hidden="true"></div>

  <div class={$.content}>
    <slot />
  </div>
</div>

<style>
  .code-block {
    --cb-bg:            color-mix(in srgb, var(--prose-bg, #0a0a0a) 97%, transparent);
    --cb-border:        color-mix(in srgb, var(--prose-fg, #fff) 8%, transparent);
    --cb-header-bg:     color-mix(in srgb, var(--prose-bg, #0a0a0a) 80%, transparent);
    --cb-accent:        #10b981;
    --cb-accent-muted:  color-mix(in srgb, #10b981 15%, transparent);
    --cb-header-fg:     color-mix(in srgb, var(--prose-fg, #fff) 45%, transparent);
    --cb-title-fg:      color-mix(in srgb, var(--prose-fg, #fff) 70%, transparent);
    --cb-lang-bg:       color-mix(in srgb, #10b981 12%, transparent);
    --cb-lang-fg:       #10b981;
    --cb-lang-border:   color-mix(in srgb, #10b981 25%, transparent);

    --cb-ins-bg:        color-mix(in srgb, #10b981 8%, transparent);
    --cb-ins-stripe:    #10b981;
    --cb-del-bg:        color-mix(in srgb, #ef4444 8%, transparent);
    --cb-del-stripe:    #ef4444;
    --cb-mark-bg:       color-mix(in srgb, #f59e0b 10%, transparent);
    --cb-mark-stripe:   #f59e0b;

    --cb-ln-fg:         color-mix(in srgb, var(--prose-fg, #fff) 18%, transparent);
    --cb-ln-width:      2.75rem;

    background-color: var(--cb-bg) !important;
    border: 1px solid var(--cb-border) !important;
    box-shadow:
      0 0 0 1px color-mix(in srgb, #10b981 4%, transparent),
      0 1px 2px color-mix(in srgb, #000 20%, transparent),
      0 8px 32px color-mix(in srgb, #000 30%, transparent) !important;
  }

  .code-block__header {
    background: var(--cb-header-bg) !important;
    backdrop-filter: blur(8px) !important;
    color: var(--cb-header-fg) !important;
  }

  .dot-close  { background: #ff5f57 !important; }
  .dot-min    { background: #febc2e !important; }
  .dot-max    { background: #28c840 !important; }

  .code-block__title {
    font-family: var(--font-GeistMono, ui-monospace, monospace) !important;
    color: var(--cb-title-fg) !important;
    font-size: 0.7rem !important;
    letter-spacing: 0.02em !important;
  }

  .code-block__lang {
    font-family: var(--font-GeistMono, ui-monospace, monospace) !important;
    background: var(--cb-lang-bg) !important;
    color: var(--cb-lang-fg) !important;
    border: 1px solid var(--cb-lang-border) !important;
    /* hidden until JS populates it */
    display: none !important;
  }
  .code-block__lang:not(:empty) {
    display: inline-flex !important;
  }

  .diff-legend-add {
    background: var(--cb-ins-bg) !important;
    color: var(--cb-ins-stripe) !important;
    border: 1px solid color-mix(in srgb, #10b981 20%, transparent) !important;
  }
  .diff-legend-rem {
    background: var(--cb-del-bg) !important;
    color: var(--cb-del-stripe) !important;
    border: 1px solid color-mix(in srgb, #ef4444 20%, transparent) !important;
  }

  .code-block__copy {
    color: var(--cb-header-fg) !important;
  }
  .code-block__copy:hover {
    background: color-mix(in srgb, var(--prose-fg, #fff) 6%, transparent) !important;
    color: var(--cb-accent) !important;
  }
  .code-block__copy.copied {
    color: var(--cb-accent) !important;
  }

  .code-block__divider {
    background: var(--cb-border) !important;
  }

  .code-block__content pre {
    margin: 0 !important;
    padding: 1.125rem 0 !important;
    background: transparent !important;
    border-radius: 0 !important;
    border: none !important;
    box-shadow: none !important;
    font-family: var(--font-GeistMono, ui-monospace, monospace) !important;
    font-size: 0.8125rem !important;
    line-height: 1.7 !important;

    scrollbar-width: thin !important;
    scrollbar-color: var(--cb-border) transparent !important;
  }
  .code-block__content pre::-webkit-scrollbar       { height: 3px !important; }
  .code-block__content pre::-webkit-scrollbar-track  { background: transparent !important; }
  .code-block__content pre::-webkit-scrollbar-thumb  {
    background: var(--cb-border) !important;
    border-radius: 999px !important;
  }

  .code-block__content code {
    display: block !important;
    width: fit-content !important;
    min-width: 100% !important;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
  }

  .code-block__content .line {
    display: block !important;
    padding-inline: 1.25rem !important;
    min-height: 1.7em !important;
    transition: background 80ms ease !important;
    position: relative !important;
  }

  .code-block__content pre.line-numbers {
    counter-reset: cb-line !important;
  }
  .code-block__content pre.line-numbers .line {
    padding-inline-start: calc(var(--cb-ln-width) + 1.25rem) !important;
    counter-increment: cb-line !important;
  }
  .code-block__content pre.line-numbers .line::before {
    content: counter(cb-line) !important;
    position: absolute !important;
    left: 0 !important;
    width: var(--cb-ln-width) !important;
    text-align: right !important;
    padding-right: 1rem !important;
    color: var(--cb-ln-fg) !important;
    font-variant-numeric: tabular-nums !important;
    user-select: none !important;
    pointer-events: none !important;
    font-size: 0.7rem !important;
  }

  .code-block__content .line.diff-add {
    background: var(--cb-ins-bg) !important;
  }
  .code-block__content .line.diff-add::after {
    content: "+" !important;
    position: absolute !important;
    left: 0.375rem !important;
    top: 0 !important;
    line-height: inherit !important;
    color: var(--cb-ins-stripe) !important;
    font-size: 0.65rem !important;
    font-weight: 700 !important;
    pointer-events: none !important;
  }

  .code-block__content .line.diff-remove {
    background: var(--cb-del-bg) !important;
    opacity: 0.65 !important;
  }
  .code-block__content .line.diff-remove::after {
    content: "−" !important;
    position: absolute !important;
    left: 0.375rem !important;
    top: 0 !important;
    line-height: inherit !important;
    color: var(--cb-del-stripe) !important;
    font-size: 0.65rem !important;
    font-weight: 700 !important;
    pointer-events: none !important;
  }

  .code-block__content .line.highlighted {
    background: var(--cb-mark-bg) !important;
  }
  .code-block__content .line.highlighted::before {
    content: "" !important;
    position: absolute !important;
    left: 0 !important;
    top: 0 !important;
    bottom: 0 !important;
    width: 2px !important;
    background: var(--cb-mark-stripe) !important;
    border-radius: 0 1px 1px 0 !important;
  }

  .code-block__content pre.line-numbers .line.diff-add::after,
  .code-block__content pre.line-numbers .line.diff-remove::after {
    left: calc(var(--cb-ln-width) + 0.25rem) !important;
  }
</style>

<script>
  (() => {
    const NAMES: Record<string, string> = {
      js: "JavaScript", 
      ts: "TypeScript", 
      jsx: "JSX", 
      tsx: "TSX",
      py: "Python",     
      html: "HTML",     
      css: "CSS", 
      scss: "SCSS",
      json: "JSON",     
      jsonc: "JSONC",   
      yaml: "YAML", 
      toml: "TOML",
      bash: "Bash",     
      sh: "Shell",      
      zsh: "Zsh",  
      sql: "SQL",
      md: "Markdown",   
      mdx: "MDX",       
      astro: "Astro", 
      vue: "Vue",
      svelte: "Svelte", 
      go: "Go",         
      rust: "Rust", 
      cpp: "C++",
      c: "C",           
      cs: "C#",         
      java: "Java", 
      php: "PHP",
      rb: "Ruby",       
      swift: "Swift",   
      kt: "Kotlin",
      dockerfile: "Dockerfile",           
      prisma: "Prisma",
      graphql: "GraphQL",                 
      plain: "Plain",
    };

    const ALIASES: Record<string, string> = {
      javascript: "js", typescript: "ts", python: "py",
      shell: "sh",      ruby: "rb",       csharp: "cs",
    };

    const normalize = (l = "") => {
      const n = l.toLowerCase().trim();
      return ALIASES[n] ?? n;
    };

    const getLang = (pre: Element | null): string => {
      if (!pre) return "plain";
      const dl = pre.getAttribute("data-language");
      if (dl) return normalize(dl);
      const m = pre.className.match(/language-([a-zA-Z0-9+#-]+)/);
      return normalize(m?.[1] ?? "plain");
    };

    const parseRanges = (str = ""): Set<number> => {
      const set = new Set<number>();
      if (!str) return set;
      for (const part of str.split(",")) {
        const trimmed = part.trim();
        if (trimmed.includes("-")) {
          const [a, b] = trimmed.split("-").map(Number);
          if (!isNaN(a) && !isNaN(b)) for (let i = a; i <= b; i++) set.add(i);
        } else {
          const n = Number(trimmed);
          if (!isNaN(n) && n > 0) set.add(n);
        }
      }
      return set;
    };

    const applyLineClasses = (wrapper: HTMLElement) => {
      const ins  = parseRanges(wrapper.dataset.ins);
      const del  = parseRanges(wrapper.dataset.del);
      const mark = parseRanges(wrapper.dataset.mark);
      if (!ins.size && !del.size && !mark.size) return;

      wrapper.querySelectorAll(".code-block__content pre code .line")
        .forEach((line, i) => {
          const n = i + 1;
          if (ins.has(n))  line.classList.add("diff-add");
          if (del.has(n))  line.classList.add("diff-remove");
          if (mark.has(n)) line.classList.add("highlighted");
        });
    };

    const applyLineNumbers = (wrapper: HTMLElement) => {
      const pre = wrapper.querySelector(".code-block__content pre");
      if (!pre || pre.classList.contains("line-numbers")) return;
      const lines = pre.querySelectorAll("code .line");
      if (lines.length <= 1) return;
      pre.classList.add("line-numbers");
    };

    const setupCopy = (wrapper: HTMLElement) => {
      const btn  = wrapper.querySelector<HTMLButtonElement>(".code-block__copy");
      const code = wrapper.querySelector(".code-block__content pre code");
      if (!btn || !code) return;

      btn.addEventListener("click", async () => {
        const text = code.textContent ?? "";
        try {
          await navigator.clipboard.writeText(text.trimEnd());
        } catch {
          const ta = Object.assign(document.createElement("textarea"), {
            value: text.trimEnd(), style: "position:absolute;left:-9999px",
          });
          document.body.append(ta);
          ta.select();
          document.execCommand("copy");
          ta.remove();
        }

        const copyIcon  = btn.querySelector(".copy-icon");
        const checkIcon = btn.querySelector(".check-icon");
        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
        btn.classList.add("copied");
        btn.setAttribute("aria-label", "Tersalin!");

        setTimeout(() => {
          copyIcon?.classList.remove("hidden");
          checkIcon?.classList.add("hidden");
          btn.classList.remove("copied");
          btn.setAttribute("aria-label", "Salin kode");
        }, 2000);
      });
    };

    const updateLangBadge = (wrapper: HTMLElement, lang: string) => {
      const badge = wrapper.querySelector<HTMLElement>(".code-block__lang");
      if (!badge) return;
      const label = NAMES[lang] ?? lang.toUpperCase();
      badge.textContent = label;
    };

    const updateTitle = (wrapper: HTMLElement, lang: string) => {
      const titleEl = wrapper.querySelector<HTMLElement>(".code-block__title");
      if (titleEl) return;
    };

    const init = (wrapper: HTMLElement) => {
      wrapper.classList.add("is-processed");
      const pre  = wrapper.querySelector(".code-block__content pre");
      const lang = getLang(pre);

      updateLangBadge(wrapper, lang);
      updateTitle(wrapper, lang);
      applyLineNumbers(wrapper);
      applyLineClasses(wrapper);
      setupCopy(wrapper);
    };

    const initAll = () =>
      document.querySelectorAll<HTMLElement>(".code-block:not(.is-processed)")
        .forEach(init);

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initAll);
    } else {
      initAll();
    }
  })();
</script>