---
// src/components/mdx/Code.astro
import Icon from "@/components/ui/Icon";
import { codeIcons } from "@/assets/icons/code";

interface Props {
  ins?:   string;  // "1,3-5"  → diff-add lines
  del?:   string;  // "2,4"    → diff-remove lines
  mark?:  string;  // "6-8"    → highlighted lines
  title?: string;  // filename atau label header
}

const { ins = "", del = "", mark = "", title = "" } = Astro.props;
---

<div
  class="code-block-wrapper"
  data-ins={ins}
  data-del={del}
  data-mark={mark}
>
  <div class="code-block-header">
    <div class="flex items-center gap-2 min-w-0">
      <span data-icon-placeholder class="code-icon" aria-hidden="true">
        <Fragment set:html={codeIcons.default} />
      </span>
      <span class="code-block-title">
        {title || <span class="code-language">plain</span>}
      </span>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      {(ins || del) && (
        <span class="code-diff-legend" aria-hidden="true">
          {ins && <span class="diff-tag add">+</span>}
          {del && <span class="diff-tag remove">−</span>}
        </span>
      )}
      <button
        type="button"
        aria-label="Salin kode"
        class="copy-button"
      >
        <Icon name="copy"  className="copy-icon  size-4" />
        <Icon name="check" className="check-icon size-4" />
      </button>
    </div>
  </div>

  <div class="code-content">
    <slot />
  </div>
</div>

<script define:vars={{ codeIcons }}>
  (() => {
    /* ── Language map ── */
    const NAMES = {
      js:         "JavaScript",
      ts:         "TypeScript",
      jsx:        "JSX",
      tsx:        "TSX",
      py:         "Python",
      html:       "HTML",
      css:        "CSS",
      scss:       "SCSS",
      json:       "JSON",
      jsonc:      "JSONC",
      yaml:       "YAML",
      toml:       "TOML",
      bash:       "Bash",
      sh:         "Shell",
      zsh:        "Zsh",
      sql:        "SQL",
      md:         "Markdown",
      mdx:        "MDX",
      astro:      "Astro",
      vue:        "Vue",
      svelte:     "Svelte",
      go:         "Go",
      rust:       "Rust",
      cpp:        "C++",
      c:          "C",
      cs:         "C#",
      java:       "Java",
      php:        "PHP",
      rb:         "Ruby",
      swift:      "Swift",
      kt:         "Kotlin",
      dockerfile: "Dockerfile",
      prisma:     "Prisma",
      graphql:    "GraphQL",
    };
    const ALIASES = {
      javascript: "js", typescript: "ts",
      python:     "py", shell:      "sh",
      ruby:       "rb", csharp:     "cs",
    };

    const normalize = (l = "") => {
      const n = l.toLowerCase();
      return ALIASES[n] || n;
    };

    const getLang = (pre) => {
      if (!pre) return "plain";
      const dl = pre.getAttribute("data-language");
      if (dl) return normalize(dl);
      const m = pre.className.match(/language-([a-zA-Z0-9+#-]+)/);
      return normalize(m?.[1] || "plain");
    };

    const parseRanges = (str = "") => {
      const set = new Set();
      if (!str) return set;
      str.split(",").forEach((part) => {
        const [a, b] = part.trim().split("-").map(Number);
        if (!isNaN(a) && !isNaN(b)) {
          for (let i = a; i <= b; i++) set.add(i);
        } else if (!isNaN(a)) {
          set.add(a);
        }
      });
      return set;
    };

    const applyLineClasses = (wrapper) => {
      const ins  = parseRanges(wrapper.dataset.ins);
      const del  = parseRanges(wrapper.dataset.del);
      const mark = parseRanges(wrapper.dataset.mark);
      if (!ins.size && !del.size && !mark.size) return;

      const lines = wrapper.querySelectorAll(".code-content pre code .line");
      lines.forEach((line, i) => {
        const n = i + 1;
        if (ins.has(n))  line.classList.add("diff-add");
        if (del.has(n))  line.classList.add("diff-remove");
        if (mark.has(n)) line.classList.add("highlighted");
      });
    };

    const applyLineNumbers = (wrapper) => {
      const pre = wrapper.querySelector(".code-content pre");
      if (!pre || pre.classList.contains("line-numbers")) return;
      const lines = pre.querySelectorAll("code .line");
      if (lines.length <= 1) return;
      pre.classList.add("line-numbers");
    };

    const setupCopy = (wrapper) => {
      const btn  = wrapper.querySelector(".copy-button");
      const code = wrapper.querySelector(".code-content pre code");
      if (!btn || !code) return;

      btn.addEventListener("click", async () => {
        const text = code.textContent ?? "";
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.cssText = "position:fixed;opacity:0";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          ta.remove();
        }
        const copy  = btn.querySelector(".copy-icon");
        const check = btn.querySelector(".check-icon");
        copy?.classList.add("hidden");
        check?.classList.remove("hidden");
        btn.setAttribute("aria-label", "Tersalin!");
        setTimeout(() => {
          copy?.classList.remove("hidden");
          check?.classList.add("hidden");
          btn.setAttribute("aria-label", "Salin kode");
        }, 2000);
      });
    };

    const updateHeader = (wrapper, lang) => {
      const iconEl = wrapper.querySelector("[data-icon-placeholder]");
      if (iconEl) iconEl.innerHTML = codeIcons[lang] || codeIcons.default;

      const langEl = wrapper.querySelector(".code-language");
      if (langEl) langEl.textContent = NAMES[lang] || lang.toUpperCase();
    };

    document.querySelectorAll(".code-block-wrapper").forEach((wrapper) => {
      const pre  = wrapper.querySelector(".code-content pre");
      const lang = getLang(pre);

      updateHeader(wrapper, lang);
      applyLineNumbers(wrapper);
      applyLineClasses(wrapper);
      setupCopy(wrapper);
    });
  })();
</script>