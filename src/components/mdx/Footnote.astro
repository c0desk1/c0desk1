---
// src/components/mdx/Footnote.astro
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<sup id={`fnref-${id}`} class="scroll-margin-top-24">
  <a 
    href={`#fn-${id}`} 
    class="text-[10px] font-medium text-zinc-400 hover:text-emerald-500 dark:hover:text-emerald-400 no-underline transition-colors duration-200"
  >
    [{id}]
  </a>
</sup>