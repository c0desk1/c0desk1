---
// src/components/mdx/ImageGrid.astro
interface Props {
  images: { src: string; alt: string; caption?: string }[];
  columns?: 2 | 3;
}

const { images, columns = 2 } = Astro.props;
const isSingle = images.length === 1;

const gridCols = {
  2: "md:grid-cols-2",
  3: "md:grid-cols-3",
};
---

<div class={`not-prose my-12 grid grid-cols-1 gap-6 ${!isSingle ? gridCols[columns as keyof typeof gridCols] : ''}`}>
  {images.map((img) => (
    <div class="mx-auto w-full">
      <figure class="overflow-hidden rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900 m-0">
        <div class="relative aspect-video overflow-hidden">
          <div class="absolute inset-0 animate-pulse bg-zinc-200 dark:bg-zinc-800" aria-hidden="true"></div>     
          <img
            src={img.src}
            alt={img.alt || ''}
            class="relative z-10 w-full h-full object-cover opacity-0 transition-opacity duration-500"
            loading="lazy"
            decoding="async"
            onload="this.style.opacity='1'"
          />
        </div>

        {img.caption && (
          <figcaption class="px-2 py-1.5 border-t border-zinc-200 dark:border-zinc-800 text-xs md:text-sm text-center text-zinc-500 dark:text-zinc-400 flex items-center justify-center gap-2">
            <span>{img.caption}</span>
          </figcaption>
        )}
      </figure>
    </div>
  ))}
</div>