---
interface Props {
  images: {
    src: string;
    alt?: string;
  }[];
}

const { images } = Astro.props;

const cols =
  images.length === 1
    ? "grid-cols-1"
    : images.length === 2
    ? "grid-cols-1 sm:grid-cols-2"
    : "grid-cols-1 sm:grid-cols-2 md:grid-cols-3";
---

<div class={`grid ${cols} gap-4 my-10`}>
  {images.map((img) => (
    <figure class="overflow-hidden rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900">
      <img
        src={img.src}
        alt={img.alt || ""}
        loading="lazy"
        decoding="async"
        class="w-full h-auto object-cover"
      />
      {img.alt && (
        <figcaption class="px-2 py-1.5 text-xs text-center text-zinc-500 dark:text-zinc-400 border-t border-zinc-200 dark:border-zinc-800">
          {img.alt}
        </figcaption>
      )}
    </figure>
  ))}
</div>