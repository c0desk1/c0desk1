---
// src/components/mdx/Callout.astro
import Icon from '@/components/ui/Icon.astro';

interface Props {
  type?: 'note' | 'info' | 'tip' | 'warning' | 'danger';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const icons = {
  note: 'note',
  info: 'info',
  tip: 'tip',
  warning: 'warning',
  danger: 'danger'
};

const iconName = icons[type];
---

<aside class="callout" data-callout={type}>
  <div class="callout-icon">
    <Icon name={iconName as any} size={18} />
  </div>
  <div class="callout-body">
    {title && <p class="callout-title">{title}</p>}
    <div class="callout-content">
      <slot />
    </div>
  </div>
</aside>