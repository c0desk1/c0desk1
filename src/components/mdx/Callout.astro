---
// src/components/mdx/Callout.astro

import Icon from '@/components/ui/Icon';

interface Props {
  type?: 'note' | 'info' | 'tip' | 'warning' | 'danger';
}

const { type = 'note' } = Astro.props;

const types = {
  note: { icon: 'note' },
  info: { icon: 'info' },
  tip: { icon: 'tip' },
  warning: { icon: 'warning' },
  danger: { icon: 'danger' },
} as const;

const current = types[type];
---

<aside class="callout" data-callout={type}>
  <div class="callout-body">
    <div class="callout-icon">
      <Icon name={current.icon as any} />
    </div>

    <div class="callout-content">
      <slot />
    </div>
  </div>
</aside>