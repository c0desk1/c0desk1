---
import Icon from '@/components/ui/icons/Icon.astro';

interface Props {
  type?: "note" | "info" | "tip" | "warning" | "danger" | "important" | "caution";
}

const { type = "note" } = Astro.props;

const icons = {
  note:      "note",
  info:      "info",
  tip:       "tip",
  warning:   "warning",
  danger:    "danger",
  important: "important",
  caution:   "caution",
} as const;

const label = type.charAt(0).toUpperCase() + type.slice(1);
---

<aside class="callout rounded-lg" data-callout={type} role="note" aria-label={label}>
  <div class="callout-aside px-2! py-2.5">
    <span class="callout-icon" aria-hidden="true">
      <Icon name={icons[type] as any} className="w-4 h-4" />
    </span>
    <span class="callout-label hidden" aria-hidden="true">{label}</span>
  </div>
  <div class="callout-body py-1.5! px-2">
    <div class="callout-content">
      <slot />
    </div>
  </div>
</aside>