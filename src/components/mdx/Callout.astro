---
// src/components/mdx/Callout.astro
interface Props {
  type?: 'note' | 'warning' | 'danger' | 'tip' | 'info';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const config = {
  note: {
    defaultTitle: 'Note',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`
  },
  info: {
    defaultTitle: 'Info',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`
  },
  warning: {
    defaultTitle: 'Warning',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>`
  },
  danger: {
    defaultTitle: 'Danger',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>`
  },
  tip: {
    defaultTitle: 'Tip',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>`
  }
};

const { defaultTitle, icon } = config[type];
---

<div
  class="callout not-prose mx-auto max-w-3xl my-8"
  data-callout={type}
>
  <span class="callout-icon" set:html={icon} aria-hidden="true" />
  <div class="callout-body">
    <p class="callout-title">{title || defaultTitle}</p>
    <div class="callout-content">
      <slot />
    </div>
  </div>
</div>

<style is:global>
  /* ── Base layout ── */
  .callout {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md, 8px);
    border: 1px solid;
    font-size: 0.9rem;
  }

  .callout-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    line-height: 1;
  }

  .callout-body { flex: 1; min-width: 0; }

  .callout-title {
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: -0.01em;
    margin: 0 0 0.25rem !important;
    color: inherit !important;
    max-width: none !important;
    line-height: 1.4;
  }

  .callout-content > *:first-child { margin-top: 0 !important; }
  .callout-content > *:last-child  { margin-bottom: 0 !important; }

  .callout-content p,
  .callout-content li {
    color: inherit !important;
    font-size: 0.875rem !important;
    line-height: 1.6;
    max-width: none !important;
    margin-bottom: 0.5rem !important;
  }
  .callout-content p:last-child { margin-bottom: 0 !important; }

  .callout-content strong { color: inherit; font-weight: 600; }

  .callout-content a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    opacity: 0.85;
  }
  .callout-content a:hover { opacity: 1; }

  .callout-content code:not(pre code) {
    background-color: rgb(0 0 0 / 0.07);
    border: none;
    border-radius: 3px;
    font-size: 0.8125rem;
    padding: 0.125rem 0.375rem;
    color: inherit;
  }
  .dark .callout-content code:not(pre code) {
    background-color: rgb(255 255 255 / 0.1);
  }

  /* ── Variants via data-callout attribute ── */

  [data-callout="note"] {
    background-color: #eff6ff;
    border-color: #bfdbfe;
    color: #1e40af;
  }
  .dark [data-callout="note"] {
    background-color: #172554;
    border-color: #1d4ed8;
    color: #93c5fd;
  }

  [data-callout="info"] {
    background-color: #f0f9ff;
    border-color: #bae6fd;
    color: #075985;
  }
  .dark [data-callout="info"] {
    background-color: #082f49;
    border-color: #0284c7;
    color: #7dd3fc;
  }

  [data-callout="tip"] {
    background-color: #f0fdf4;
    border-color: #bbf7d0;
    color: #14532d;
  }
  .dark [data-callout="tip"] {
    background-color: #022c22;
    border-color: #10b981;
    color: #6ee7b7;
  }

  [data-callout="warning"] {
    background-color: #fffbeb;
    border-color: #fed7aa;
    color: #92400e;
  }
  .dark [data-callout="warning"] {
    background-color: #431407;
    border-color: #c2410c;
    color: #fdba74;
  }

  [data-callout="danger"] {
    background-color: #fff1f2;
    border-color: #fecdd3;
    color: #9f1239;
  }
  .dark [data-callout="danger"] {
    background-color: #4c0519;
    border-color: #be123c;
    color: #fda4af;
  }
</style>