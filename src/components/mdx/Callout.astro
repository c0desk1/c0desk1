---
// src/components/mdx/Callout.astro

import Icon from '@/components/ui/Icon';

interface Props {
  type?: 'note' | 'info' | 'tip' | 'warning' | 'danger' | 'important' | 'caution';
}

const { type = 'note' } = Astro.props;

const types = {
  note: { icon: 'note' },
  info: { icon: 'info' },
  tip: { icon: 'tip' },
  warning: { icon: 'warning' },
  danger: { icon: 'danger' },
  important: {icon: 'important'},
  caution: {icon: 'caution'}
} as const;

const current = types[type];
---

<aside class="callout" data-callout={type}>
  <div class="callout-body">
    <div class="callout-icon justify-center">
      <Icon name={current.icon as any} className='w-4 h-4 lg:w-5 lg:h-5' />
    </div>
    <div class="text-copy-14 md:text-copy-16 callout-content mt-0!">
      <slot />
    </div>
  </div>
</aside>
