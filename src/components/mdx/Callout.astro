---
// src/components/mdx/Callout.astro

import Icon from '@/components/ui/Icon';

interface Props {
  type?: 'note' | 'info' | 'tip' | 'warning' | 'danger' | 'important' | 'caution';
}

const { type = 'note' } = Astro.props;

const types = {
  note: { icon: 'note' },
  info: { icon: 'info' },
  tip: { icon: 'tip' },
  warning: { icon: 'warning' },
  danger: { icon: 'danger' },
  important: {icon: 'important'},
  caution: {icon: 'caution'}
} as const;

const current = types[type];
---

<aside class="callout" data-callout={type}>
  <div class="callout-body gap-4">
    <div class="flex flex-col items-center h-full order-1">
      <div class="callout-icon items-center justify-center top-1">
        <Icon name={current.icon as any} className="size-4 lg:size-5" />
      </div>
    </div>
    <div class="text-body-14 md:text-body-16 callout-content order-2">
      <slot />
    </div>
  </div>
</aside>
