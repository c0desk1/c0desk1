---
// src/components/mdx/Callout.astro
interface Props {
  type?: 'note' | 'warning' | 'danger' | 'tip' | 'info';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const config = {
  note: {
    defaultTitle: 'Note',
    // Vercel style: border lebih tipis, background lebih subtle
    classes: 'border-blue-200/50 bg-blue-50/50 text-blue-800 dark:border-blue-800/30 dark:bg-blue-950/20 dark:text-blue-200',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`
  },
  info: {
    defaultTitle: 'Info',
    classes: 'border-blue-200/50 bg-blue-50/50 text-blue-800 dark:border-blue-800/30 dark:bg-blue-950/20 dark:text-blue-200',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`
  },
  warning: {
    defaultTitle: 'Warning',
    classes: 'border-amber-200/50 bg-amber-50/50 text-amber-800 dark:border-amber-800/30 dark:bg-amber-950/20 dark:text-amber-200',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>`
  },
  danger: {
    defaultTitle: 'Danger',
    classes: 'border-red-200/50 bg-red-50/50 text-red-800 dark:border-red-800/30 dark:bg-red-950/20 dark:text-red-200',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>`
  },
  tip: {
    defaultTitle: 'Tip',
    classes: 'border-emerald-200/50 bg-emerald-50/50 text-emerald-800 dark:border-emerald-800/30 dark:bg-emerald-950/20 dark:text-emerald-200',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/><path d="M12 6v4"/><path d="M12 14h.01"/></svg>`
  }
};

const { defaultTitle, classes, icon } = config[type];
---

<div class="not-prose my-6 rounded-lg border p-4 text-sm shadow-sm" class:list={[classes]}>
  <div class="mb-2 flex items-center gap-2 font-medium">
    <span class="h-4 w-4 flex-shrink-0" set:html={icon} />
    <span>{title || defaultTitle}</span>
  </div>
  <div class="callout-content [&_p:first-child]:mt-0 [&_p:last-child]:mb-0 [&_ul:first-child]:mt-0 [&_ul:last-child]:mb-0">
    <slot />
  </div>
</div>

<style is:global>
  .callout-content code:not(pre code) {
    background-color: rgb(0 0 0 / 0.05);
    border-radius: 0.25rem;
    font-size: 0.8125rem;
    padding: 0.125rem 0.375rem;
  }
  
  .dark .callout-content code:not(pre code) {
    background-color: rgb(255 255 255 / 0.1);
  }
  
  .callout-content a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  
  .callout-content strong {
    color: inherit;
    font-weight: 600;
  }
</style>