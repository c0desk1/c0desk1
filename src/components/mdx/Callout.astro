---
import Icon from '@/components/ui/Icon';

interface Props {
  type?: 'note' | 'info' | 'tip' | 'warning' | 'danger' | 'important' | 'caution';
}

const { type = 'note' } = Astro.props;

const types = {
  note: { icon: 'note' },
  info: { icon: 'info' },
  tip: { icon: 'tip' },
  warning: { icon: 'warning' },
  danger: { icon: 'danger' },
  important: { icon: 'important' },
  caution: { icon: 'caution' },
} as const;

const current = types[type];
const label = type.toUpperCase();
---

<aside class="callout" data-callout={type}>
  <div class="callout-body">
    <div class="callout-header">
      <div class="callout-icon" aria-hidden="true">
        <Icon name={current.icon as any} className="size-5 md:size-6" />
      </div>
      <span class="callout-mobile-label">{label}</span>
    </div>
    <div class="callout-content text-body-14 md:text-body-16">
      <slot />
    </div>
  </div>
</aside>