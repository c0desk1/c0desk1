---
// src/components/mdx/Timeline.astro

const html = await Astro.slots.render('default');

const eventRegex = /<p[^>]*>\s*\[([^\]]+)\]\s*<\/p>\s*(<h[234][^>]*>[\s\S]*?<\/h[234]>)\s*([\s\S]*?)(?=<p[^>]*>\s*\[|$)/gi;
const events: { date: string; heading: string; content: string }[] = [];
let match;
while ((match = eventRegex.exec(html)) !== null) {
  events.push({
    date: match[1].trim(),
    heading: match[2].trim(),
    content: match[3].trim(),
  });
}

if (events.length === 0) {
  const headingRegex = /(<h[234][^>]*>[\s\S]*?<\/h[234]>)\s*([\s\S]*?)(?=<h[234]|$)/gi;
  while ((match = headingRegex.exec(html)) !== null) {
    events.push({
      date: '',
      heading: match[1].trim(),
      content: match[2].trim(),
    });
  }
}
---

<div class="relative my-8 md:my-12 pl-10 sm:pl-12" id="timeline-wrapper">
  <div id="timeline-line" class="absolute left-3 w-px bg-(--prose-border-strong)" style="top:0; bottom:0;"></div>

  <div class="space-y-10">
    {events.map((event) => (
      <div class="relative timeline-item">
        {event.date && (
          <div class="relative flex items-center mb-4">
            <div class="timeline-dot absolute -left-8 sm:-left-10 w-2.5 h-2.5 rotate-45 bg-(--prose-fg-strong) ring-4 ring-(--prose-bg) z-10"></div>
            
            <div class="inline-flex items-center px-2.5 py-0.5 rounded-sm bg-(--prose-bg-subtle) border border-(--prose-border-strong) text-mono-label-13 uppercase tracking-wider text-(--prose-fg-strong)">
              {event.date}
            </div>
          </div>
        )}
        
        <div class="timeline-content-wrapper">
          {event.heading && (
            <div class="timeline-content text-heading-16 font-semibold text-(--prose-fg-strong) mb-2 mt-0!" set:html={event.heading} />
          )}
          {event.content && (
            <div class="timeline-content text-body-14 lg:text-body-16 text-(--prose-fg-muted) space-y-2" set:html={event.content} />
          )}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .timeline-item :global(h2),
  .timeline-item :global(h3),
  .timeline-item :global(h4) {
    margin-top: 0 !important;
    margin-bottom: 0.5rem !important;
  }
  .timeline-item :global(p) {
    margin-top: 0 !important;
    margin-bottom: 0.5rem !important;
  }
</style>

<script>
  function adjustLine() {
    const wrapper = document.getElementById('timeline-wrapper');
    const line = document.getElementById('timeline-line');
    if (!wrapper || !line) return;

    const dots = wrapper.querySelectorAll('.timeline-dot');
    if (dots.length === 0) return;

    const firstDot = dots[0] as HTMLElement;
    const lastDot = dots[dots.length - 1] as HTMLElement;

    const wrapperRect = wrapper.getBoundingClientRect();
    const firstRect = firstDot.getBoundingClientRect();
    const lastRect = lastDot.getBoundingClientRect();

    const top = firstRect.top - wrapperRect.top + firstDot.offsetHeight / 2;
    const bottom = wrapperRect.bottom - (lastRect.top + lastDot.offsetHeight / 2);

    line.style.top = `${top}px`;
    line.style.bottom = `${bottom}px`;
  }

  document.addEventListener('astro:page-load', adjustLine);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', adjustLine);
  } else {
    adjustLine();
  }
  window.addEventListener('resize', adjustLine);
</script>