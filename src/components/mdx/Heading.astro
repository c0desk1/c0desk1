---
import Icon from '@/components/ui/icons/Icon.astro';

interface Props {
  id?: string;
  class?: string;
  level: number;
}

const { id, class: className, level } = Astro.props as Props;
const Tag = `h${level}` as any;

const anchorLabel = 'Link to this heading';

const headingClasses: Record<string, string> = {
  h1: "text-heading-32 md:text-heading-40 lg:text-heading-56",
  h2: "text-heading-24 md:text-heading-32",
  h3: "text-heading-20 md:text-heading-24",
  h4: "text-heading-16 md:text-heading-20",
  h5: "text-label-14",
  h6: "text-label-12",
};
const classes = headingClasses[`h${level}`] || "text-heading-20";
---

<Tag
  id={id}
  class:list={[
    "heading-group has-anchor",
    "relative inline-flex items-baseline flex-wrap gap-x-1 text-balance font-bold tracking-tight",
    classes,
    className,
  ]}
>
  <span class:list={["heading-text-content"]}><slot /></span>
  {id && (
    <a
      href={`#${id}`}
      class="anchor-link inline-flex items-center justify-center w-6 h-6 md:w-8 md:h-8 opacity-0 group-hover:opacity-100 transition-all duration-200 ml-2"
      aria-label={anchorLabel}
    >
      <Icon name="link" className="w-3 h-3 md:w-4 md:h-4 hover:text-strong" />
    </a>
  )}
</Tag>