---
// src/components/ui/Figure.astro

import { 
  cdnImage, 
  isCdnUrl 
} from '@/lib/utils';

import { Image } from 'astro:assets';
import { 
  SITE, 
  IMAGE 
} from '@/consts';

import Icon from '@/components/ui/icons/Icon.astro';

interface Props {
  src?: string;
  alt?: string;
  title?: string;
  caption?: string;
  href?: string;
}

const { 
  src, 
  alt = '', 
  title, 
  caption, 
  href 
} = Astro.props;

const isPlaceholder = !src || src === '';

const optimizedSrc = !isPlaceholder && isCdnUrl(src) 
  ? cdnImage(src, { 
    w: IMAGE.thumbnail.width, 
    h: IMAGE.thumbnail.height, 
    q: IMAGE.thumbnail.qulity 
  }) 
  : src || IMAGE.thumbnail.placeholder;
  
const hasLink = !!href;
const tooltip = title;

let displayUrl = SITE.url;

if (href && href.startsWith('http')) {
  try { 
    displayUrl = new URL(href).hostname; 
  } catch(e) {}
} else if (title) {
  displayUrl = title.toLowerCase().replace(/\s+/g, '-');
}

const imageClass = hasLink
  ? `relative h-full w-full object-cover transition duration-500 ${isPlaceholder ? 'opacity-100' : 'opacity-0'}`
  : `zoomable-image relative h-full w-full object-cover transition duration-500 cursor-zoom-in ${isPlaceholder ? 'opacity-100' : 'opacity-0'}`;

const figureClass    = "full-width-figure my-8 lg:my-12";
const browserWindow  = "relative overflow-hidden rounded-xl border border-(--border) bg-base shadow-lg dark:shadow-xl";
const browserHeader  = "flex items-center px-4 py-3 border-b border-(--border)";
const trafficLights  = "flex items-center justify-start gap-1.5";
const urlBarWrapper  = "absolute inset-x-0 flex justify-center pointer-events-none";
const urlBar         = "flex items-center justify-center bg-dim border border-(--border) rounded-md h-6 px-2 max-w-30 gap-1.5 md:max-w-xs w-full text-body-13 text-muted truncate";
const imageContainer = "relative w-full bg-base";
const captionClass = "text-caption-14! text-muted mt-4 text-center max-w-2xl mx-auto px-4 text-pretty";
---

<figure class={figureClass}>
  <div class={browserWindow}>
    <div class={browserHeader}>
      <div class={trafficLights}>
        <div class="size-2.5 rounded-full border border-(--prose-border)/10 bg-error"></div>
        <div class="size-2.5 rounded-full border border-(--prose-border)/10 bg-warning"></div>
        <div class="size-2.5 rounded-full border border-(--prose-border)/10 bg-success"></div>
      </div>
      <div class={urlBarWrapper}>
        <div class={urlBar}>
          <span class="inline-flex shrink-0 w-3.5 h-3.5 items-center">
            <Icon name="lock" className="w-full h-full text-muted" />
          </span>
          <span class="truncate">
            {displayUrl}
          </span>
        </div>
      </div>
    </div>
    <div class={imageContainer}>
      {hasLink ? (
        <a href={href} target="_blank" rel="nofollow noopener noreferrer" title={tooltip} class="block w-full h-full">
          <Image
            src={optimizedSrc}
            alt={isPlaceholder ? "No image available" : alt}
            title={tooltip}
            loading="lazy"
            decoding="async"
            width={1200}
            height={630}
            class={imageClass}
            onload={!isPlaceholder ? "this.classList.remove('opacity-0')" : undefined}
          />
        </a>
      ) : (
        <Image
          src={optimizedSrc}
          alt={isPlaceholder ? "No image available" : alt}
          title={tooltip}
          loading="lazy"
          decoding="async"
          width={1200}
          height={630}
          class={imageClass}
          onload={!isPlaceholder ? "this.classList.remove('opacity-0')" : undefined}
        />
      )}
    </div>
  </div>
  {caption && (
    <figcaption class={captionClass}>{caption}</figcaption>
  )}
</figure>

<div id="lightbox-overlay" aria-hidden="true" class="lightbox-overlay">
  <button id="lightbox-close" aria-label="Close lightbox" class="lightbox-close p-2 rounded-full bg-subtle/50 hover:bg-muted active:bg-muted">
    <Icon name="close" className="w-6 h-6" />
  </button>
  <div class="lightbox-zoom-container">
    <img id="lightbox-image" src="" alt="" class="lightbox-image" />
  </div>
</div>

<style is:inline>
  .full-width-figure {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin: 2rem 0;
    max-width: 56rem;
    padding: 0 1rem;
  }
  
  .full-width-figure .relative { 
    width: 100%; 
  }

  .lightbox-overlay {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    overscroll-behavior: contain;
  }

  .lightbox-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-zoom-container {
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .lightbox-image {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 0.5rem;
    cursor: zoom-out;
    touch-action: manipulation;
    transform: scale(0.8);
    transition: transform 0.3s ease;
  }

  .lightbox-overlay.active .lightbox-image {
    transform: scale(1);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    z-index: 1000;
    color: var(--fg-inverted);
  }

  @media (max-width: 767px) {
    .lightbox-close {
      top: auto;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(8px);
      border-radius: 50%;
      width: 3rem;
      height: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--fg-inverted);
    }
  }
  
  @media (min-width: 768px) {
    .full-width-figure { 
      padding: 0 1.5rem; 
    }
  }
  
  @media (min-width: 1024px) {
    .full-width-figure { 
      padding: 0 2rem; 
    }
  }
</style>

<script>
  let overlay: HTMLElement | null = null;
  let lightboxImg: HTMLImageElement | null = null;

  const openLightbox = (src: string, alt: string) => {
    if (!overlay || !lightboxImg) return;
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    overlay.classList.add('active');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = () => {
    if (!overlay) return;
    overlay.classList.remove('active');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  const handleImageClick = (e: Event) => {
    const target = e.currentTarget as HTMLImageElement;
    openLightbox(target.src, target.alt);
  };

  const handleKeyDown = (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay?.classList.contains('active')) {
      closeLightbox();
    }
  };

  const handleOverlayClick = (e: MouseEvent) => {
    if (e.target === overlay) closeLightbox();
  };

  function initLightbox() {
    document.body.style.overflow = '';

    const overlays = document.querySelectorAll('.lightbox-overlay');
    if (overlays.length === 0) return;


    overlay = overlays[0] as HTMLElement;
    for (let i = 1; i < overlays.length; i++) {
      overlays[i].remove();
    }

    lightboxImg = overlay.querySelector('.lightbox-image') as HTMLImageElement;
    const closeBtn = overlay.querySelector('.lightbox-close') as HTMLButtonElement;

    if (!overlay || !lightboxImg || !closeBtn) return;

    closeBtn.removeEventListener('click', closeLightbox);
    closeBtn.addEventListener('click', closeLightbox);

    overlay.removeEventListener('click', handleOverlayClick);
    overlay.addEventListener('click', handleOverlayClick);

    document.querySelectorAll('.zoomable-image').forEach(img => {
      img.removeEventListener('click', handleImageClick);
      img.addEventListener('click', handleImageClick);
    });

    document.removeEventListener('keydown', handleKeyDown);
    document.addEventListener('keydown', handleKeyDown);
  }

  document.addEventListener('astro:page-load', initLightbox);
</script>