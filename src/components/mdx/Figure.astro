---
import { 
  cdnImage, 
  isCdnUrl 
} from '@/lib/utils';

import { Image } from 'astro:assets';

import Icon from '@/components/ui/icons/Icon.astro';
import Container from '../ui/Container.astro';

interface Props {
  src: string;
  alt: string;
  title?: string;
  caption?: string;
  href?: string;
}

const { src, alt, title, caption, href } = Astro.props;

const fallbackSrc = '/images/placeholder.svg';

const optimizedSrc = src 
  ? (isCdnUrl(src) ? cdnImage(src, { w: 1280, h: 720, q: 80 }) : src) 
  : fallbackSrc;
  
const hasLink = !!href;
const imageClass = hasLink
  ? "relative h-full w-full object-cover transition duration-500 opacity-0"
  : "zoomable-image relative h-full w-full object-cover transition duration-500 opacity-0 cursor-zoom-in";

const tooltip = title;

let displayUrl = 'c0desk1.my.id';
if (href && href.startsWith('http')) {
  try { displayUrl = new URL(href).hostname; } catch(e) {}
} else if (title) {
  displayUrl = title.toLowerCase().replace(/\s+/g, '-');
}
---

<figure class="full-width-figure my-8 lg:my-12">
  <div class="relative overflow-hidden rounded-xl border border-strong bg-ase shadow-lg dark:shadow-xl">
    <div class="flex items-center px-4 py-3 border-b border-strong bg-subtle">
      <div class="flex items-center gap-1.5 shrink-0 z-10">
        <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56] border border-(--border)/10"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e] border border-(--border)/10"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f] border border-(--border)/10"></div>
      </div>
      <div class="absolute inset-x-0 flex justify-center pointer-events-none">
        <div class="flex items-center justify-center bg-dim border border-strong rounded-md h-6 px-8 max-w-30 md:max-w-xs w-full text-body-13 text-muted truncate">
          <Icon name="lock" className="w-3.5 h-3.5 mr-1.5 text-subtle" />
          {displayUrl}
        </div>
      </div>
    </div>
    <div class="relative w-full bg-base">
      {hasLink ? (
        <a href={href} target="_blank" rel="nofollow noopener noreferrer" title={tooltip} class="block w-full h-full">
          <Image
            src={optimizedSrc}
            alt={alt}
            title={tooltip}
            loading="lazy"
            decoding="async"
            width={1200}
            height={630}
            class={imageClass}
            onload="this.classList.remove('opacity-0')"
          />
        </a>
      ) : (
        <Image
          src={optimizedSrc}
          alt={alt}
          title={tooltip}
          loading="lazy"
          decoding="async"
          width={1200}
          height={630}
          class={imageClass}
          onload="this.classList.remove('opacity-0')"
        />
      )}
    </div>
  </div>

  {caption && (
    <Container size="md">
      <figcaption class="text-caption-14 text-subtle mt-4 text-center">{caption}</figcaption>
    </Container>
  )}
</figure>

<div class="lightbox-overlay" id="lightbox-overlay" aria-hidden="true">
  <button class="lightbox-close p-2 rounded-full bg-muted/50 hover:bg-muted active:bg-muted text-inverted" id="lightbox-close" aria-label="Close lightbox">
    <Icon name="close" className="w-6 h-6" />
  </button>
  <div class="lightbox-zoom-container">
    <img src="" alt="" class="lightbox-image" id="lightbox-image" />
  </div>
</div>

<style is:inline>
  .full-width-figure {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin: 2rem 0;
    max-width: 56rem;
    padding: 0 1rem;
  }
  @media (min-width: 768px) {
    .full-width-figure { padding: 0 1.5rem; }
  }
  @media (min-width: 1024px) {
    .full-width-figure { padding: 0 2rem; }
  }
  .full-width-figure .relative { width: 100%; }

  .lightbox-overlay {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    overscroll-behavior: contain;
  }

  .lightbox-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-zoom-container {
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .lightbox-image {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 0.5rem;
    cursor: zoom-out;
    touch-action: manipulation;
    transform: scale(0.8);
    transition: transform 0.3s ease;
  }

  .lightbox-overlay.active .lightbox-image {
    transform: scale(1);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    z-index: 1000;
  }

  @media (max-width: 767px) {
    .lightbox-close {
      top: auto;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(8px);
      border-radius: 50%;
      width: 3rem;
      height: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>

<script>
  function initLightbox() {
    const overlays = document.querySelectorAll('.lightbox-overlay');
    if (overlays.length === 0) return;

    if (overlays.length > 1) {
      for (let i = 1; i < overlays.length; i++) {
        overlays[i].remove();
      }
    }

    const overlay = document.getElementById('lightbox-overlay') as HTMLElement;
    const lightboxImg = document.getElementById('lightbox-image') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close');

    if (!overlay || !lightboxImg || !closeBtn) return;

    const openLightbox = (src: string, alt: string) => {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      overlay.classList.add('active');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      overlay.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    document.querySelectorAll('.zoomable-image').forEach(img => {
      img.removeEventListener('click', handleImageClick);
      img.addEventListener('click', handleImageClick);
    });

    function handleImageClick(e: Event) {
      const target = e.target as HTMLImageElement;
      openLightbox(target.src, target.alt);
    }

    lightboxImg.onclick = closeLightbox;
    closeBtn.onclick = closeLightbox;
    overlay.onclick = (e) => {
      if (e.target === overlay) closeLightbox();
    };

    document?.removeEventListener('keydown', handleKeyDown);
    document.addEventListener('keydown', handleKeyDown);

    function handleKeyDown(e: KeyboardEvent) {
      if (e.key === 'Escape' && overlay.classList.contains('active')) {
        closeLightbox();
      }
    }
  }

  document.addEventListener('astro:page-load', initLightbox);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLightbox);
  } else {
    initLightbox();
  }
</script>