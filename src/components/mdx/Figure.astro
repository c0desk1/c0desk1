---
// src/components/ui/Figure.astro
import { 
  cdnImage, 
  isCdnUrl 
} from '@/lib/utils';
import { Image } from 'astro:assets';
import { IMAGE } from '@/consts';
import Icon from '@/components/ui/icons/Icon.astro';

interface Props {
  src?: string;
  alt?: string;
  title?: string;
  caption?: string;
  href?: string;
}

const { src, alt = '', title, caption, href } = Astro.props;

const isPlaceholder = !src || src === '';

const optimizedSrc = !isPlaceholder && isCdnUrl(src) 
  ? cdnImage(src, { 
    w: IMAGE.thumbnail.width, 
    h: IMAGE.thumbnail.height, 
    q: IMAGE.thumbnail.qulity 
  }) 
  : src || IMAGE.thumbnail.placeholder;
  
const hasLink = !!href;
const tooltip = title;

let displayUrl = 'c0desk1.my.id';

if (href && href.startsWith('http')) {
  try { 
    displayUrl = new URL(href).hostname; 
  } catch(e) {}
} else if (title) {
  displayUrl = title.toLowerCase().replace(/\s+/g, '-');
}

const figureClass    = "full-width-figure my-8 lg:my-12";
const browserWindow  = "relative overflow-hidden rounded-xl border border-(--border) bg-base shadow-lg dark:shadow-xl";
const browserHeader  = "flex items-center px-4 py-3 border-b border-(--border)";
const trafficLights  = "flex items-center justify-start gap-1.5";
const urlBarWrapper  = "absolute inset-x-0 flex justify-center pointer-events-none";
const urlBar         = "flex items-center justify-center bg-dim border border-(--border) rounded-md h-6 px-8 max-w-30 md:max-w-xs w-full text-body-13 text-muted truncate";
const imageContainer = "relative w-full bg-base";

const imageClass = hasLink
  ? `relative h-full w-full object-cover transition duration-500 ${isPlaceholder ? 'opacity-100' : 'opacity-0'}`
  : `zoomable-image relative h-full w-full object-cover transition duration-500 cursor-zoom-in ${isPlaceholder ? 'opacity-100' : 'opacity-0'}`;

const captionClass = "text-caption-14! text-muted mt-4 text-center max-w-2xl mx-auto px-4 text-pretty";
---

<figure class={figureClass}>
  <div class={browserWindow}>
    <div class={browserHeader}>
      <div class={trafficLights}>
        <div class="size-2.5 rounded-full border border-(--prose-border)/10 bg-error"></div>
        <div class="size-2.5 rounded-full border border-(--prose-border)/10 bg-warning"></div>
        <div class="size-2.5 rounded-full border border-(--prose-border)/10 bg-success"></div>
      </div>
      <div class={urlBarWrapper}>
        <div class={urlBar}>
          <Icon name="lock" className="w-3.5 h-3.5 mr-1.5 text-muted" />
          {displayUrl}
        </div>
      </div>
    </div>

    <div class={imageContainer}>
      {hasLink ? (
        <a href={href} target="_blank" rel="nofollow noopener noreferrer" title={tooltip} class="block w-full h-full">
          <Image
            src={optimizedSrc}
            alt={isPlaceholder ? "No image available" : alt}
            title={tooltip}
            loading="lazy"
            decoding="async"
            width={1200}
            height={630}
            class={imageClass}
            onload={!isPlaceholder ? "this.classList.remove('opacity-0')" : undefined}
          />
        </a>
      ) : (
        <Image
          src={optimizedSrc}
          alt={isPlaceholder ? "No image available" : alt}
          title={tooltip}
          loading="lazy"
          decoding="async"
          width={1200}
          height={630}
          class={imageClass}
          onload={!isPlaceholder ? "this.classList.remove('opacity-0')" : undefined}
        />
      )}
    </div>
  </div>

  {caption && (
    <figcaption class={captionClass}>{caption}</figcaption>
  )}
</figure>

<style is:inline>
  .full-width-figure {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin: 2rem 0;
    max-width: 56rem;
    padding: 0 1rem;
  }
  @media (min-width: 768px) {
    .full-width-figure { padding: 0 1.5rem; }
  }
  @media (min-width: 1024px) {
    .full-width-figure { padding: 0 2rem; }
  }
  .full-width-figure .relative { width: 100%; }

  .lightbox-overlay {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    overscroll-behavior: contain;
  }

  .lightbox-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-zoom-container {
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .lightbox-image {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 0.5rem;
    cursor: zoom-out;
    touch-action: manipulation;
    transform: scale(0.8);
    transition: transform 0.3s ease;
  }

  .lightbox-overlay.active .lightbox-image {
    transform: scale(1);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    z-index: 1000;
  }

  @media (max-width: 767px) {
    .lightbox-close {
      top: auto;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(8px);
      border-radius: 50%;
      width: 3rem;
      height: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>

<script>
  function initLightbox() {
    const overlays = document.querySelectorAll('.lightbox-overlay');
    if (overlays.length === 0) return;

    if (overlays.length > 1) {
      for (let i = 1; i < overlays.length; i++) {
        overlays[i].remove();
      }
    }

    const overlay = document.getElementById('lightbox-overlay') as HTMLElement;
    const lightboxImg = document.getElementById('lightbox-image') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;

    if (!overlay || !lightboxImg || !closeBtn) return;

    const openLightbox = (src: string, alt: string) => {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      overlay.classList.add('active');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      overlay.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    document.querySelectorAll('.zoomable-image').forEach(img => {
      img.removeEventListener('click', handleImageClick as EventListener);
      img.addEventListener('click', handleImageClick as EventListener);
    });

    function handleImageClick(e: Event) {
      const target = e.target as HTMLImageElement;
      openLightbox(target.src, target.alt);
    }

    lightboxImg.onclick = closeLightbox;
    closeBtn.onclick = closeLightbox;
    
    overlay.onclick = (e: MouseEvent) => {
      if (e.target === overlay) closeLightbox();
    };

    document?.removeEventListener('keydown', handleKeyDown);
    document.addEventListener('keydown', handleKeyDown);

    function handleKeyDown(e: KeyboardEvent) {
      if (e.key === 'Escape' && overlay?.classList.contains('active')) {
        closeLightbox();
      }
    }
  }

  document.addEventListener('astro:page-load', initLightbox);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLightbox);
  } else {
    initLightbox();
  }
</script>