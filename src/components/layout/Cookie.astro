---
// src/components/ui/Cookie.astro
import { siteConfig } from "@/config/site";
import Button from "@/components/ui/Button.astro";

const siteData = siteConfig
const policyUrl = "/cookie-policy";
const policyLabel = "Cookie Policy"
---

<div id="cookie-consent" class="fixed bottom-4 left-4 right-4 z-50 max-w-sm mx-auto opacity-0 translate-y-4 transition-all duration-300 ease-out pointer-events-none" aria-hidden="true" role="dialog" aria-label={siteData.cookiePreference}>
  <div class="flex flex-col gap-3 p-4 bg-(--bg)/90 backdrop-blur-lg border border-(--border) rounded-2xl shadow-lg">
    <p class="text-copy-14 text-(--fg-muted) m-0 leading-relaxed">
      {siteData.cookieMessage}
      <a
        href={policyUrl}
        class="text-label-14 text-(--fg) hover:text-(--accent) ml-1 whitespace-nowrap transition-colors">
        {policyLabel}
      </a>
    </p>
    <div class="flex items-center gap-2 justify-end">
      <Button id="ck-reject" variant="secondary" size="sm">
        {siteData.cookieRejectAll}
      </Button>
      <Button id="ck-accept" variant="primary" size="sm">
        {siteData.cookieAcceptAll}
      </Button>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = "cookie-consent-v2";
  const bar = document.getElementById("cookie-consent");

  const hideBar = () => {
    if (bar) {
      bar.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
      bar.setAttribute("aria-hidden", "true");
    }
  };

  const showBar = () => {
    if (bar) {
      bar.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
      bar.setAttribute("aria-hidden", "false");
    }
  };

  try {
    const stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || "null");
    if (stored?.done) {
      hideBar();
    } else {
      requestAnimationFrame(showBar);
    }
  } catch {
    requestAnimationFrame(showBar);
  }

  const saveConsent = (accepted: boolean) => {
    localStorage.setItem(
      STORAGE_KEY,
      JSON.stringify({ done: true, accepted, ts: Date.now() })
    );
    hideBar();
  };

  document.getElementById("ck-accept")?.addEventListener("click", () => saveConsent(true));
  document.getElementById("ck-reject")?.addEventListener("click", () => saveConsent(false));
</script>