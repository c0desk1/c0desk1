---
// src/components/blog/RssFeed.astro

import { siteConfig } from "@/config/site";
import Icon from "../ui/Icon";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const siteURL = (Astro.site?.toString() ?? siteConfig.siteUrl).replace(/\/$/, "");
const rssURL = `${siteURL}/rss.xml`;
---

<div class:list={["border border-(--border) rounded-lg bg-(--bg) overflow-hidden", className]}>
  <div class="flex items-center gap-3 p-4 flex-wrap">
    <div class="flex items-center justify-center w-8 h-8 rounded-full border border-(--border) text-(--fg-muted) shrink-0">
      <Icon name="rss" className="w-5 h-5" />
    </div>
    <div class="flex-1 min-w-0">
      <h4 class="text-heading-16 font-semibold text-(--fg)">
        Subscribe via RSS
      </h4>
      <p class="text-copy-14 text-(--fg-muted) mt-0.5 hidden sm:inline">
        Get new posts delivered to your reader automatically.
      </p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <a href={rssURL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-button-14 font-medium px-3 py-1.5 rounded-md border border-(--border) bg-(--bg) text-(--fg) hover:bg-(--bg-subtle) transition-colors whitespace-nowrap" aria-label="Open RSS feed">
        Open feed
      </a>
    </div>
  </div>
</div>