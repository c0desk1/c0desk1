---
import NavLink from "../ui/NavLink.astro";
import { siteConfig } from "@/config/site";
import { getCollection } from 'astro:content';

const allSettings = await getCollection('settings');
const activeSetting = allSettings[0];
const siteData = activeSetting?.data || siteConfig;
const currentPath = Astro.url.pathname;
const navItems = siteData.navItems || siteConfig.navItems;
---

<nav class="hidden md:flex items-center justify-center gap-2 ml-2" aria-label="Main navigation">
  {navItems.map((item: { href: string; label: string }) => {
    const normalize = (path: string) => path.replace(/\/$/, "") || "/";
    const activePath = normalize(currentPath);
    const targetPath = normalize(item.href);

    const isActive =
      activePath === targetPath ||
      (targetPath !== "/" && activePath.startsWith(targetPath));
      
    return (
      <NavLink
        href={item.href}
        current={isActive}
      >
        {item.label}
      </NavLink>
    );
  })}
</nav>
