---
// src/components/search/SearchModal.astro
import { getCollection, getEntry } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);

const searchData = await Promise.all(
  posts.map(async (post) => {
    const category = post.data.category ? await getEntry(post.data.category) : null;
    return {
      id:           post.id,
      title:        post.data.title,
      desc:         post.data.description ?? '',
      category:     category?.data?.name  ?? 'Uncategorized',
      categorySlug: category?.data?.slug  ?? 'uncategorized',
      url:          `/blog/${post.id}/`,
    };
  })
);
---

<div
  id="search-modal"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Cari artikel"
  inert
>
  <!-- Backdrop -->
  <div
    id="search-backdrop"
    class="absolute inset-0 bg-(--bg)/50 backdrop-blur-sm opacity-0 transition-opacity duration-200"
  ></div>

  <div class="relative flex min-h-full items-start justify-center p-3 sm:pt-20">
    <div
      id="search-panel"
      class="w-full max-w-xl scale-95 opacity-0 transition-all duration-200
             bg-(--bg) border border-(--border) rounded-(--radius-xl) shadow-2xl overflow-hidden"
    >
      <!-- Input row -->
      <div class="flex items-center gap-2 px-3.5 border-b border-(--border)">
        <!-- Search icon -->
        <svg class="w-4 h-4 shrink-0 text-(--fg-muted)" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>

        <input
          id="search-input"
          type="text"
          placeholder="Cari artikel…"
          aria-label="Cari artikel"
          class="flex-1 py-3.5 text-sm bg-transparent text-(--fg)
                 placeholder:text-(--fg-muted) outline-none min-w-0"
          autocomplete="off"
          spellcheck="false"
        />

        <!-- Clear input -->
        <button
          id="search-clear"
          class="hidden p-1 rounded text-(--fg-muted) hover:text-(--fg)
                 hover:bg-(--bg-muted) transition shrink-0"
          aria-label="Hapus teks pencarian"
          tabindex="-1"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>

        <!-- 
          Tombol CLOSE MODAL — mobile only.
        -->
        <button
          id="search-close-mobile"
          class="sm:hidden flex items-center justify-center p-1.5 -mr-1
                 rounded-md text-(--fg-muted) hover:text-(--fg) hover:bg-(--bg-muted)
                 transition shrink-0"
          aria-label="Tutup pencarian"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>

        <!-- ESC badge — desktop only -->
        <kbd class="hidden sm:inline-flex shrink-0 items-center px-1.5 py-0.5 text-[12px]
                    text-(--fg-muted) bg-(--bg-muted) border border-(--border) rounded-md
                    pointer-events-none">
          ESC
        </kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="search-scroll max-h-[55vh] overflow-y-auto">
        <!-- diisi JS -->
      </div>

      <!-- Footer — desktop only -->
      <div class="hidden sm:flex items-center justify-between px-3.5 py-2
                  border-t border-(--border) bg-(--bg-muted)">
        <div class="flex items-center gap-3 text-[12px] text-(--fg-muted)">
          <span class="inline-flex items-center gap-1.5">
            <kbd class="px-1.5 py-0.5 bg-(--bg) border border-(--border) rounded text-[11px]">↑↓</kbd>
            Navigasi
          </span>
          <span class="inline-flex items-center gap-1.5">
            <kbd class="px-1.5 py-0.5 bg-(--bg) border border-(--border) rounded text-[11px]">↵</kbd>
            Buka
          </span>
        </div>
        <span id="search-count" class="text-[11px] text-(--fg-muted)"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .search-scroll::-webkit-scrollbar { width: 3px; }
  .search-scroll::-webkit-scrollbar-track { background: transparent; }
  .search-scroll::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }
  .search-hl {
    background: color-mix(in srgb, var(--fg) 12%, transparent);
    border-radius: 2px;
    padding: 0 1px;
  }
</style>

<script define:vars={{ searchData }}>
  (() => {
    const modal       = document.getElementById('search-modal');
    const backdrop    = document.getElementById('search-backdrop');
    const panel       = document.getElementById('search-panel');
    const input       = document.getElementById('search-input');
    const results     = document.getElementById('search-results');
    const clearBtn    = document.getElementById('search-clear');
    const closeMobile = document.getElementById('search-close-mobile');
    const countEl     = document.getElementById('search-count');

    if (!modal || !backdrop || !panel || !input || !results) return;

    let activeIdx = -1;
    let filtered  = [];
    let prevFocus = null;

    // ── Helpers
    const escHtml = (s) =>
      String(s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    const hlText = (str, q) => {
      if (!q) return escHtml(str);
      const safeQ = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      return escHtml(str).replace(
        new RegExp(`(${safeQ})`, 'gi'),
        '<mark class="search-hl">$1</mark>'
      );
    };
    
    // ——— fuzzy
    const scoreMatch = (post, q) => {
      const tl = post.title.toLowerCase();
      const dl = post.desc.toLowerCase();
      const cl = post.category.toLowerCase();
      if (tl === q)          return 100;
      if (tl.startsWith(q)) return 80;
      if (tl.includes(q))   return 60;
      if (dl.includes(q))   return 40;
      if (cl.includes(q))   return 30;

      let qi = 0;
      for (let i = 0; i < tl.length && qi < q.length; i++) {
        if (tl[i] === q[qi]) qi++;
      }
      return qi === q.length ? 10 : 0;
    };

    // ── Render
    const renderEmpty = (msg, sub) => {
      results.innerHTML = `
        <div class="py-12 flex flex-col items-center gap-2 text-center">
          <svg class="w-7 h-7 text-(--fg-muted)" fill="none" stroke="currentColor"
            stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <p class="text-sm text-(--fg)">${msg}</p>
          <p class="text-[12px] text-(--fg-muted)">${sub}</p>
        </div>`;
      if (countEl) countEl.textContent = '';
    };

    const setActiveStyle = (items) => {
      items.forEach((el, i) => {
        el.classList.toggle('bg-(--bg-muted)', i === activeIdx);
      });
    };

    const renderResults = (items, q) => {
      if (!items.length) {
        renderEmpty('Tidak ditemukan', 'Coba kata kunci lain');
        return;
      }
      if (countEl) countEl.textContent = `${items.length} hasil`;

      results.innerHTML = items.map((p, i) => `
        <a
          href="${escHtml(p.url)}"
          data-idx="${i}"
          class="sritem flex items-start gap-3 px-3.5 py-3
                 hover:bg-(--bg-muted) transition-colors
                 ${i === activeIdx ? 'bg-(--bg-muted)' : ''}"
        >
          <svg class="mt-0.5 w-4 h-4 shrink-0 text-(--fg-muted)" fill="none"
            stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
            stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-medium text-(--fg) truncate">
              ${hlText(p.title, q)}
            </div>
            <div class="mt-0.5 text-[12px] text-(--fg-muted) line-clamp-1">
              ${hlText(p.desc, q)}
            </div>
            <div class="mt-1 text-[11px] text-(--fg-subtle)">
              ${escHtml(p.category)}
            </div>
          </div>
        </a>
      `).join('');
    };

    const resetView = () => {
      activeIdx = -1;
      filtered  = [];
      renderEmpty('Cari artikel', 'Ketik untuk mulai mencari');
    };

    // ── Open / Close
    const openModal = () => {
      prevFocus = document.activeElement;
      modal.classList.remove('hidden');
      modal.removeAttribute('inert');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        backdrop.classList.remove('opacity-0');
        panel.classList.remove('scale-95', 'opacity-0');
        input.focus();
      });
      resetView();
    };

    const closeModal = () => {
      backdrop.classList.add('opacity-0');
      panel.classList.add('scale-95', 'opacity-0');
      document.body.style.overflow = '';
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.setAttribute('inert', '');
        input.value = '';
        
		// Reset clear
        if (clearBtn) clearBtn.classList.add('hidden');
        resetView();
        prevFocus?.focus();
      }, 200);
    };

    // ── Event listeners
    document.addEventListener('open-search', openModal);
    backdrop.addEventListener('click', closeModal);

    closeMobile?.addEventListener('click', closeModal);

    clearBtn?.addEventListener('click', () => {
      input.value = '';
      clearBtn.classList.add('hidden');
      input.focus();
      resetView();
    });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        modal.classList.contains('hidden') ? openModal() : closeModal();
        return;
      }
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        e.preventDefault();
        closeModal();
      }
    });

    // Input — debounce 80ms
    let debounceTimer;
    input.addEventListener('input', () => {
      const q = input.value.trim();
      
      if (q) {
		clearBtn?.classList.remove('hidden');
    	closeMobile?.classList.add('hidden');
  	} else {
    	clearBtn?.classList.add('hidden');
    	closeMobile?.classList.remove('hidden');
  	}

      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        if (!q) { resetView(); return; }
        const ql = q.toLowerCase();
        filtered = searchData
          .map(p => ({ ...p, _score: scoreMatch(p, ql) }))
          .filter(p => p._score > 0)
          .sort((a, b) => b._score - a._score)
          .slice(0, 8);
        activeIdx = -1;
        renderResults(filtered, ql);
      }, 80);
    });

    // Keyboard navigation
    input.addEventListener('keydown', (e) => {
      const items = results.querySelectorAll('.sritem');
      if (!items.length) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIdx = (activeIdx + 1) % items.length;
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIdx = (activeIdx - 1 + items.length) % items.length;
      } else if (e.key === 'Enter' && activeIdx >= 0) {
        e.preventDefault();
        items[activeIdx]?.click();
        return;
      } else {
        return;
      }

      setActiveStyle(items);
      items[activeIdx]?.scrollIntoView({ block: 'nearest' });
    });

    // URL param ?q=
    document.addEventListener('DOMContentLoaded', () => {
      const q = new URLSearchParams(window.location.search).get('q');
      if (q) {
        setTimeout(() => {
          openModal();
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
          history.replaceState({}, '', window.location.pathname);
        }, 100);
      }
    });
  })();
</script>