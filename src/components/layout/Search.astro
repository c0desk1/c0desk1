---
// src/components/layout/Search.astro
import { getCollection, getEntry } from "astro:content";
import { siteConfig } from "@/config/site";
import { slugify } from "@/lib/utils";
import Icon from "@/components/ui/Icon";


const siteData = siteConfig

const searchModalLabel = siteData.searchModalLabel;
const searchPlaceholder = siteData.searchPlaceholder;
const clearSearchLabel = siteData.clearSearch;
const closeSearchLabel = siteData.closeSearch;
const navigateLabel =siteData.navigate;
const openLabel = siteData.open;
const resultsLabel = siteData.results;
const notFoundTitle = siteData.notFound;
const tryOtherKeywords = siteData.tryOtherKeywords;
const searchArticlesTitle = siteData.searchArticles;
const typeToSearch = siteData.typeToSearch;
const dataNotReady = siteData.dataNotReady;
const refreshPage = siteData.refreshPage;

const posts = await getCollection("blog", ({ data }) => {
  return !data.draft;
});

const searchData = await Promise.all(
  posts.map(async (post) => {
    const categoryEntry = post.data.category ? await getEntry(post.data.category) : null;
    const nameObj = categoryEntry?.data?.name as Record<string, string> | undefined;
    const categoryName = nameObj;

    const autoSlug = post.data.slug || slugify(post.data.title);
    const url = `/blog/${autoSlug}`;

    return {
      id: post.id,
      title: post.data.title,
      desc: post.data.description ?? "",
      category: categoryName,
      categorySlug: categoryEntry?.id ?? "uncategorized",
      url,
    };
  })
);

const scriptLabels = {
  notFoundTitle,
  tryOtherKeywords,
  searchArticlesTitle,
  typeToSearch,
  dataNotReady,
  refreshPage,
  resultsLabel
};
---

<div id="search-modal" role="dialog" aria-modal="true" aria-label={searchModalLabel} inert class="fixed inset-0 z-50 hidden">
  <div id="search-backdrop" class="absolute inset-0 bg-[color-mix(in_srgb,var(--bg)_50%,transparent)] backdrop-blur-sm opacity-0 transition-opacity duration-200"></div>
  <div class="relative flex min-h-full items-start justify-center p-4 sm:pt-20">
    <div id="search-panel" class="w-full max-w-3xl overflow-hidden rounded-xl border border-(--border) bg-(--bg) opacity-0 shadow-(--shadow-lg) scale-96 transition-all duration-200">
      <div class="flex items-center gap-2 border-b border-(--border) px-3.5">
        <Icon name="search" className="h-5 w-5 shrink-0 text-dim"/>
        <input
          id="search-input"
          type="text"
          placeholder={searchPlaceholder}
          aria-label={searchModalLabel}
          autocomplete="off"
          spellcheck="false"
          class="flex-1 min-w-0 border-none bg-transparent py-3.5 text-copy-14 lg:text-copy-16 text-muted outline-none placeholder:text-dim"
        />
        <button 
          id="search-clear"
         class="flex h-7 w-7 shrink-0 items-center justify-center 
                rounded-full
                text-muted hover:bg-muted hover:text-(--fg)
                transition-colors duration-150 
                focus-visible:outline-2 
                focus-visible:outline-(--accent) 
                focus-visible:outline-offset-2" 
          aria-label={clearSearchLabel} 
          tabindex="-1">
          <Icon name="trash" className="h-5 w-5 block" />
        </button>
        <button 
          id="search-close-mobile" 
          class="flex h-7 w-7 shrink-0 items-center justify-center 
                rounded-full 
                text-muted
                hover:bg-muted hover:text-(--fg) 
                transition-colors duration-150 
                focus-visible:outline-2 
                focus-visible:outline-(--accent) 
                focus-visible:outline-offset-2 
                sm:hidden" 
          aria-label={closeSearchLabel}>
          <Icon name="close" className="h-5 w-5 block" />
        </button>
        <kbd class="
            mx-0.5 md:inline-flex items-center justify-center align-middle
            rounded-md
            border border-(--prose-kbd-border)
            bg-(--prose-kbd-bg)
            px-1.5 py-0.5'
            text-label-mono-13
            md:text-label-mono-14
            text-(--prose-kbd-text)
            shadows-(--prose-kbd-shadow)
            hidden">
          ESC
        </kbd>
      </div>
      <div id="search-results" class="max-h-[55dvh] overflow-y-auto scrollbar-thin scrollbar-track-transparent scrollbar-thumb-(--border)"></div>
      <div class="hidden items-center justify-between border-t border-(--border) bg-subtle px-3.5 py-2 sm:flex">
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center gap-1.5 text-label-14">
            <kbd class="
              mx-0.5 md:inline-flex items-center justify-center align-middle
              rounded-md
              border border-(--prose-kbd-border)
              bg-(--prose-kbd-bg)
              px-1.5 py-0.5'
              text-label-mono-13
              md:text-label-mono-14
              text-(--prose-kbd-text)
              shadows-(--prose-kbd-shadow)
              hidden">
              ↑↓
            </kbd>
            {navigateLabel}
          </span>
          <span class="inline-flex items-center gap-1.5 text-label-14">
            <kbd class="
              mx-0.5 md:inline-flex items-center justify-center align-middle
              rounded-md
              border border-(--prose-kbd-border)
              bg-(--prose-kbd-bg)
              px-1.5 py-0.5'
              text-label-mono-13
              md:text-label-mono-14
              text-(--prose-kbd-text)
              shadows-(--prose-kbd-shadow)
              hidden">
              ↵
            </kbd>
            {openLabel}
          </span>
        </div>
        <span id="search-count" class="text-overline-11 text-subtle"></span>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .sm-hl {
    background: var(--prose-highlight-bg);
    border-radius: var(--radius-xs);
    padding: 0.5px 1px;
    color: var(--prose-highlight-text);
  }
  .sritem {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0.875rem;
    text-decoration: none;
  }

  .sritem:hover,
  .sritem.is-active {
    background-color: var(--bg-muted);
  }

  .sritem-icon {
    margin-top: 0.125rem;
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    color: var(--fg-dim);
  }

  .sritem-title {
    font-size: 16px;
    line-height: 24px;
    letter-spacing: -0.01em;
    font-weight: 600;
    color: var(--fg);

    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sritem-desc {
    font-size: 14px;
    line-height: 22px;
    letter-spacing: 0;
    font-weight: 400;
    color: var(--fg-muted);
    margin-top: 0.125rem;

    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  .sritem-cat {
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0;
    font-weight: 500;
    margin-bottom: 0.25rem;
    color: var(--fg-subtle);
  }

  .sm-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 3rem 1rem;
    text-align: center;
  }

  .sm-empty-icon {
    width: 48px;
    height: 48px;
    color: var(--fg-dim);
  }

  .sm-empty-title {
    margin: 0;
    font-size: 20px;
    line-height: 28px;
    letter-spacing: -0.01em;
    font-weight: 600;
    color: var(--fg);
  }

  .sm-empty-sub {
    margin: 0;
    font-size: 16px;
    line-height: 26px;
    letter-spacing: 0;
    font-weight: 400;
    color: var(--fg-subtle);
  }

  @media (max-width: 767px){
    .sritem-icon {
      display: hidden;
    }
  }
</style>

<script define:vars={{ searchData, labels: scriptLabels }}>
  (() => {
    if (!Array.isArray(searchData) ||!searchData.length) {
      console.warn("[Search] No data available.");
      const results = document.getElementById("search-results");
      if (results) results.innerHTML = emptyHTML(labels.dataNotReady, labels.refreshPage, true);
      return;
    }

    const modal = document.getElementById("search-modal");
    const backdrop = document.getElementById("search-backdrop");
    const panel = document.getElementById("search-panel");
    const input = document.getElementById("search-input");
    const results = document.getElementById("search-results");
    const clearBtn = document.getElementById("search-clear");
    const closeMobile = document.getElementById("search-close-mobile");
    const countEl = document.getElementById("search-count");

    if (!modal ||!backdrop ||!panel ||!input ||!results) return;

    let activeIdx = -1;
    let filtered = [];
    let prevFocus = null;
    let debounce;

    /* ── Helpers */
    const esc = (s) =>
      String(s)
      .replace(/&/g, "&amp;").replace(/</g, "&lt;")
      .replace(/>/g, "&gt;").replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");

    const highlight = (str, q) => {
      if (!q) return esc(str);
      const safe = q.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      return esc(str).replace(
        new RegExp(`(${safe})`, "gi"),
        '<mark class="sm-hl">$1</mark>'
      );
    };

    const score = (post, q) => {
      const tl = post.title.toLowerCase();
      const dl = post.desc.toLowerCase();
      const cl = post.category.toLowerCase();
      if (tl === q) return 100;
      if (tl.startsWith(q)) return 80;
      if (tl.includes(q)) return 60;
      if (dl.includes(q)) return 40;
      if (cl.includes(q)) return 30;
      let qi = 0;
      for (let i = 0; i < tl.length && qi < q.length; i++)
        if (tl[i] === q[qi]) qi++;
      return qi === q.length? 10 : 0;
    };

    function emptyHTML(title, sub, isError = false) {
      const icon = isError
      ? `<svg class="sm-empty-icon" style="color:#ef4444" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" x2="12" y1="2" y2="6" />
            <line x1="12" x2="12" y1="18" y2="22" />
            <line x1="4.93" x2="7.76" y1="4.93" y2="7.76" />
            <line x1="16.24" x2="19.07" y1="16.24" y2="19.07" />
            <line x1="2" x2="6" y1="12" y2="12" />
            <line x1="18" x2="22" y1="12" y2="12" />
            <line x1="4.93" x2="7.76" y1="19.07" y2="16.24" />
            <line x1="16.24" x2="19.07" y1="7.76" y2="4.93" />
           </svg>`
        : `<svg class="sm-empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="24" height="24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
           </svg>`;
      return `<div class="sm-empty">${icon}
        <p class="sm-empty-title">${title}</p>
        <p class="sm-empty-sub">${sub}</p>
      </div>`;
    }

    const setActive = (items) =>
      items.forEach((el, i) =>
        el.classList.toggle("is-active", i === activeIdx)
      );

    const renderResults = (items, q) => {
      if (!items.length) {
        results.innerHTML = emptyHTML(labels.notFoundTitle, labels.tryOtherKeywords);
        if (countEl) countEl.textContent = "";
        return;
      }

      if (countEl) countEl.textContent = `${items.length} ${labels.resultsLabel}`;

      results.innerHTML = items.map((p, i) => `
        <a href="${esc(p.url)}" data-idx="${i}" class="sritem${i === activeIdx? " is-active" : ""}">
          <svg class="sritem-icon" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" width="24" height="24">
            <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
            <path d="M14 2v4a2 2 0 0 0 2 2h4" />
            <path d="M10 9H8" />
            <path d="M16 13H8" />
            <path d="M16 17H8" />
          </svg>
          <div style="min-width:0;flex:1">
            <div class="sritem-cat">${esc(p.category)}</div>
            <div class="sritem-title">${highlight(p.title, q)}</div>
            <div class="sritem-desc">${highlight(p.desc, q)}</div>
          </div>
        </a>
      `).join("");
    };

    const resetView = () => {
      activeIdx = -1;
      filtered = [];
      results.innerHTML = emptyHTML(labels.searchArticlesTitle, labels.typeToSearch);
      if (countEl) countEl.textContent = "";
    };

    const openModal = () => {
      prevFocus = document.activeElement;
      modal.style.display = "block";
      modal.removeAttribute("inert");
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => {
        backdrop.style.opacity = "1";
        panel.style.opacity = "1";
        panel.style.transform = "scale(1)";
        input.focus();
      });
      resetView();
    };

    const closeModal = () => {
      backdrop.style.opacity = "0";
      panel.style.opacity = "0";
      panel.style.transform = "scale(0.96)";
      document.body.style.overflow = "";
      setTimeout(() => {
        modal.style.display = "none";
        modal.setAttribute("inert", "");
        input.value = "";
        clearBtn?.classList.add("hidden");
        resetView();
        prevFocus?.focus();
      }, 200);
    };

    document.addEventListener("open-search", openModal);
    backdrop.addEventListener("click", closeModal);
    closeMobile?.addEventListener("click", closeModal);

    clearBtn?.addEventListener("click", () => {
      input.value = "";
      clearBtn.classList.add("hidden");
      input.focus();
      resetView();
    });

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        modal.style.display === "none"? openModal() : closeModal();
        return;
      }
      if (e.key === "Escape" && modal.style.display!== "none") {
        e.preventDefault();
        closeModal();
      }
    });

    input.addEventListener("input", () => {
      const q = input.value.trim();
      clearBtn?.classList.toggle("hidden",!q);
      clearTimeout(debounce);
      debounce = setTimeout(() => {
        if (!q) { resetView(); return; }
        const ql = q.toLowerCase();
        filtered = searchData
        .map((p) => ({...p, _score: score(p, ql) }))
        .filter((p) => p._score > 0)
        .sort((a, b) => b._score - a._score)
        .slice(0, 8);
        activeIdx = -1;
        renderResults(filtered, ql);
      }, 80);
    });

    input.addEventListener("keydown", (e) => {
      const items = results.querySelectorAll(".sritem");
      if (!items.length) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeIdx = (activeIdx + 1) % items.length;
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIdx = (activeIdx - 1 + items.length) % items.length;
      } else if (e.key === "Enter" && activeIdx >= 0) {
        e.preventDefault();
        items[activeIdx]?.click();
        return;
      } else {
        return;
      }

      setActive(items);
      items[activeIdx]?.scrollIntoView({ block: "nearest" });
    });

    document.addEventListener("DOMContentLoaded", () => {
      const q = new URLSearchParams(window.location.search).get("q");
      if (!q) return;
      setTimeout(() => {
        openModal();
        input.value = q;
        input.dispatchEvent(new Event("input", { bubbles: true }));
        history.replaceState({}, "", window.location.pathname);
      }, 100);
    });
  })();
</script>