---
// src/components/search/SearchModal.astro
import { getCollection, getEntry } from "astro:content";
import Container from "../ui/Container.astro";

let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {
  console.warn('Settings not found, using siteConfig fallback');
}

const posts = await getCollection("blog", ({ data }) => !data.draft);

const postsWithCategory = await Promise.all(
  posts.map(async (post) => {
    const category = post.data.category ? await getEntry(post.data.category) : null;
    return {
      id: post.id,
      title: post.data.title,
      desc: post.data.description,
      category: category?.data?.name || "Uncategorized",
      categorySlug: category?.data?.slug || "uncategorized",
      url: `/blog/${post.id}/`
    };
  })
);

const searchData = postsWithCategory;
---

<Container size="md">
  <div
    id="search-modal"
    class="fixed inset-0 z-50 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="search-label"
  >
    <div
      id="search-backdrop"
      class="absolute inset-0 bg-black/40 backdrop-blur-sm opacity-0 transition-opacity duration-200"
    ></div>

    <div class="relative flex min-h-full items-start justify-center p-4 sm:pt-24">
      <div
        id="search-panel"
        class="w-full max-w-2xl scale-95 opacity-0 transition-all duration-200 bg-white dark:bg-black border-2 border-zinc-200/80 dark:border-zinc-800 rounded-xl shadow-2xl overflow-hidden"
      >
        <div class="flex items-center gap-3 px-4 border-b border-zinc-200/80 dark:border-zinc-800">
          <svg class="w-5 h-5 text-zinc-500 dark:text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="Cari artikel..."
            aria-label="Cari artikel"
            class="w-full py-4 bg-transparent text-sm text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 outline-none"
            autocomplete="off"
            spellcheck="false"
          />
          <button
            id="close-search"
            type="button"
            class="sm:hidden p-1.5 -mr-1.5 text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 rounded-md hover:bg-zinc-100 dark:hover:bg-zinc-800 transition"
            aria-label="Close search"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <kbd class="hidden sm:inline-flex items-center gap-1 px-1.5 py-0.5 text-[13px] text-zinc-400 bg-zinc-100 dark:bg-black border border-black/20 dark:border-zinc-800 rounded-sm">
            ESC
          </kbd>
        </div>

        <div id="search-results" class="max-h-[60vh] overflow-y-auto">
          <div class="py-14 items-center text-center">
            <svg class="mx-auto w-8 h-8 text-zinc-300 dark:text-zinc-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <p id="search-label" class="mt-3 text-sm text-zinc-500">Cari artikel</p>
            <p class="mt-1 text-xs text-zinc-400">Ketik untuk mencari</p>
          </div>
        </div>

        <div class="hidden sm:flex items-center justify-between px-4 py-2.5 border-t border-black/20 dark:border-zinc-800 bg-zinc-50/50 dark:bg-zinc-900/50">
          <div class="flex items-center gap-2 text-[13px]">
            <kbd class="px-1.5 py-0.5 text-zinc-500 dark:text-zinc-400 bg-white dark:bg-black border border-black/20 dark:border-zinc-800 rounded-sm">↑↓</kbd>
            <span>Navigasi</span>
            <kbd class="ml-2 px-1.5 py-0.5 text-zinc-500 dark:text-zinc-400 bg-white dark:bg-black border border-black/20 dark:border-zinc-800 rounded-sm">↵</kbd>
            <span>Pilih</span>
          </div>
          <div class="flex items-center gap-1 text-xs text-zinc-400">
            <span>Search by</span>
            <span class="font-semibold text-zinc-600 dark:text-zinc-300">c0desk1</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Container>

<script define:vars={{ searchData }}>
  const modal = document.getElementById("search-modal");
  const backdrop = document.getElementById("search-backdrop");
  const panel = document.getElementById("search-panel");
  const input = document.getElementById("search-input");
  const results = document.getElementById("search-results");
  const closeBtn = document.getElementById("close-search");
  let activeIndex = -1;
  let lastActiveElement = null;

  const open = () => {
    lastActiveElement = document.activeElement;
    modal.classList.remove("hidden");
    modal.removeAttribute("inert");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      backdrop.classList.remove("opacity-0");
      panel.classList.remove("scale-95", "opacity-0");
      input.focus();
    });
  };

  const close = () => {
    if (document.activeElement instanceof HTMLElement) {
      document.activeElement.blur();
    }

    backdrop.classList.add("opacity-0");
    panel.classList.add("scale-95", "opacity-0");
    document.body.style.overflow = "";

    setTimeout(() => {
      modal.classList.add("hidden");
      modal.setAttribute("inert", "");
      input.value = "";
      resetResults();
      activeIndex = -1;
      lastActiveElement?.focus();
    }, 200);
  };

  const resetResults = () => {
    results.innerHTML = `
      <div class="py-14 text-center">
        <svg class="mx-auto w-8 h-8 text-zinc-300 dark:text-zinc-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <p class="mt-3 text-sm text-zinc-500">Cari artikel</p>
        <p class="mt-1 text-xs text-zinc-400">Ketik untuk mulai mencari</p>
      </div>
    `;
  };

  const renderResults = (items) => {
    if (!items.length) {
      results.innerHTML = `
        <div class="py-14 text-center">
          <p class="text-sm text-zinc-500">Tidak ada hasil yang ditemukan</p>
          <p class="mt-1 text-xs text-zinc-400">Coba kata kunci yang berbeda</p>
        </div>
      `;
      return;
    }

    results.innerHTML = items.map((p, i) => `
      <a
        href="${p.url}"
        data-index="${i}"
        class="group flex items-start gap-3 px-4 py-3 hover:bg-zinc-100 dark:hover:bg-zinc-800/50 transition-colors ${i === activeIndex? 'bg-zinc-100 dark:bg-zinc-800/50' : ''}"
      >
        <div class="mt-0.5 w-5 h-5 shrink-0 text-zinc-400 group-hover:text-zinc-600 dark:group-hover:text-zinc-300">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="min-w-0 flex-1">
          <div class="text-sm md:text-lg font-medium text-black dark:text-white truncate">
            ${p.title}
          </div>
          <div class="mt-0.5 text-xs md:text-[13px] text-zinc-500 line-clamp-1">
            ${p.desc}
          </div>
        </div>
      </a>
    `).join("");
  };

  // Events
  document.addEventListener("open-search", open);
  closeBtn?.addEventListener("click", close);
  backdrop.addEventListener("click", close);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" &&!modal.classList.contains("hidden")) {
      e.preventDefault();
      close();
    }
  });

  input.addEventListener("input", (e) => {
    const q = e.target.value.toLowerCase().trim();
    activeIndex = -1;

    if (!q) return resetResults();

    const filtered = searchData.filter(p =>
      p.title.toLowerCase().includes(q) ||
      p.desc.toLowerCase().includes(q) ||
      p.category.toLowerCase().includes(q)
    ).slice(0, 8);

    renderResults(filtered);
  });

  input.addEventListener("keydown", (e) => {
    const items = results.querySelectorAll("a");
    if (!items.length) return;

    if (e.key === "ArrowDown") {
      e.preventDefault();
      activeIndex = (activeIndex + 1) % items.length;
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      activeIndex = (activeIndex - 1 + items.length) % items.length;
    } else if (e.key === "Enter" && activeIndex >= 0) {
      e.preventDefault();
      items[activeIndex].click();
    }

    items.forEach((el, i) => {
      el.classList.toggle("bg-zinc-100", i === activeIndex);
      el.classList.toggle("dark:bg-zinc-800/50", i === activeIndex);
    });
    items[activeIndex]?.scrollIntoView({ block: "nearest" });
  });

  modal.setAttribute("inert", "");
  
  document.addEventListener("DOMContentLoaded", () => {
    const urlParams = new URLSearchParams(window.location.search);
    const q = urlParams.get("q");
    
    if (q) {
      setTimeout(() => {
        open();
        input.value = q;
        input.dispatchEvent(new Event('input', { bubbles: true }));
        window.history.replaceState({}, document.title, window.location.pathname);
      }, 100);
    }
  });
</script>

<style>
  #search-results::-webkit-scrollbar { width: 4px; }
  #search-results::-webkit-scrollbar-track { background: transparent; }
  #search-results::-webkit-scrollbar-thumb {
    background: rgb(212 212 216);
    border-radius: 3px;
  }
.dark #search-results::-webkit-scrollbar-thumb {
    background: rgb(63 63 70);
  }
</style>
