---
// src/components/search/SearchModal.astro
import { getCollection, getEntry } from "astro:content";
import Container from "../ui/Container.astro";
import Icon from "../ui/Icon.astro";

let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {
  console.warn('Settings not found, using siteConfig fallback');
}

const posts = await getCollection("blog", ({ data }) => !data.draft);

const postsWithCategory = await Promise.all(
  posts.map(async (post) => {
    const category = post.data.category ? await getEntry(post.data.category) : null;
    return {
      id: post.id,
      title: post.data.title,
      desc: post.data.description,
      category: category?.data?.name || "Uncategorized",
      categorySlug: category?.data?.slug || "uncategorized",
      url: `/blog/${post.id}/`
    };
  })
);

const searchData = postsWithCategory;
---

<Container size="md">
  <div
    id="search-modal"
    class="fixed inset-0 z-50 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="search-label"
  >
    <div
      id="search-backdrop"
      class="absolute inset-0 bg-(--bg)/40 backdrop-blur-sm opacity-0 transition-opacity duration-200"
    ></div>

    <div class="relative flex min-h-full items-start justify-center p-4 sm:pt-24">
      <div
        id="search-panel"
        class="w-full max-w-2xl scale-95 opacity-0 transition-all duration-200 bg-(--bg) border-2 border-(--border) rounded-(--radius-xl) shadow-2xl overflow-hidden"
      >
        <div class="flex items-center gap-3 px-4 border-b border-(--border) text-(--fg-muted)">
          <Icon name="search" class="w-5 h-5" />
          <input
            id="search-input"
            type="text"
            placeholder="Cari artikel..."
            aria-label="Cari artikel"
            class="w-full py-4 bg-transparent text-sm md:text-base text-(--fg) placeholder:text-(--fg-muted) outline-none"
            autocomplete="off"
            spellcheck="false"
          />
          <button
            id="close-search"
            type="button"
            class="sm:hidden p-1.5 -mr-1.5 text-(--fg-muted) hover:text-(--fg) rounded-md hover:bg-(--bg-muted) transition"
            aria-label="Close search"
          >
            <Icon name="close" class="w-5 h-5" />
          </button>
          <kbd class="hidden sm:inline-flex items-center gap-1 px-1.5 py-0.5 text-[13px] text-(--fg) bg-(--bg-subtle) border border-(--border-strong) rounded-(--radius)">
            ESC
          </kbd>
        </div>

        <div id="search-results" class="max-h-[60vh] overflow-y-auto">
          <div class="flex flex-col py-14 items-center text-center text-(--fg-subtle)">
            <Icon name="search" class="items-center w-8 h-8" />
            <p id="search-label" class="mt-3 text-sm md:text-base text-(--fg)">Cari artikel</p>
            <p class="mt-1 text-xs md:text-[13px] text-(--fg-muted)">Ketik untuk mencari</p>
          </div>
        </div>

        <div class="hidden sm:flex items-center justify-between px-4 py-2.5 border-t border-(--border) bg-(--bg-muted)">
          <div class="flex items-center gap-2 text-[13px]">
            <kbd class="px-1.5 py-0.5 text-(--fg) bg-(--bg-subtle) border border-(--border-strong) rounded-(--radius)">↑ ↓</kbd>
            <span>Navigasi</span>
            <kbd class="ml-2 px-1.5 py-0.5 text-(--fg) bg-(--bg-subtle) border border-(--border-strong) rounded-(--radius)">↵</kbd>
            <span>Pilih</span>
          </div>
          <div class="flex items-center gap-1 text-xs text-zinc-400(--fg-subtle)">
            <span>Search by</span>
            <span class="font-semibold text-(--fg-muted)">c0desk1</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Container>

<script define:vars={{ searchData }}>
  const modal = document.getElementById("search-modal");
  const backdrop = document.getElementById("search-backdrop");
  const panel = document.getElementById("search-panel");
  const input = document.getElementById("search-input");
  const results = document.getElementById("search-results");
  const closeBtn = document.getElementById("close-search");
  let activeIndex = -1;
  let lastActiveElement = null;

  const open = () => {
    lastActiveElement = document.activeElement;
    modal.classList.remove("hidden");
    modal.removeAttribute("inert");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      backdrop.classList.remove("opacity-0");
      panel.classList.remove("scale-95", "opacity-0");
      input.focus();
    });
  };

  const close = () => {
    if (document.activeElement instanceof HTMLElement) {
      document.activeElement.blur();
    }

    backdrop.classList.add("opacity-0");
    panel.classList.add("scale-95", "opacity-0");
    document.body.style.overflow = "";

    setTimeout(() => {
      modal.classList.add("hidden");
      modal.setAttribute("inert", "");
      input.value = "";
      resetResults();
      activeIndex = -1;
      lastActiveElement?.focus();
    }, 200);
  };

  const resetResults = () => {
    results.innerHTML = `
      <div class="py-14 text-center">
        <svg class="mx-auto w-8 h-8 text-(--fg-muted)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            d="M21 21L16.65 16.65M19 11C19 15.4183 15.4183 19 11 19C6.58172 19 3 15.4183 3 11C3 6.58172 6.58172 3 11 3C15.4183 3 19 6.58172 19 11Z"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
          />
        </svg>
        <p class="mt-3 text-sm md:text-base text-(--fg)">Cari artikel</p>
        <p class="mt-1 text-xs md:text-[13px] text-(--fg-muted)">Ketik untuk mulai mencari</p>
      </div>
    `;
  };

  const renderResults = (items) => {
    if (!items.length) {
      results.innerHTML = `
        <div class="py-14 text-center">
          <p class="text-sm md:text-base text-(--fg)">Tidak ada hasil yang ditemukan</p>
          <p class="mt-1 text-xs md:text-[13px] text-(--fg-subtle)">Coba kata kunci yang berbeda</p>
        </div>
      `;
      return;
    }

    results.innerHTML = items.map((p, i) => `
      <a
        href="${p.url}"
        data-index="${i}"
        class="group flex items-center gap-3 px-4 py-3 hover:bg-(--bg-muted) transition-colors ${i === activeIndex? 'bg-(--bg-subtle)' : ''}"
      >
        <div class="items-center w-5 h-5 shrink-0 text-zinc-(--fg-subtle) group-hover:text-(--fg)">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              d="M14 11H8M10 15H8M16 7H8M20 6.8V17.2C20 18.8802 20 19.7202 19.673 20.362C19.3854 20.9265 18.9265 21.3854 18.362 21.673C17.7202 22 16.8802 22 15.2 22H8.8C7.11984 22 6.27976 22 5.63803 21.673C5.07354 21.3854 4.6146 20.9265 4.32698 20.362C4 19.7202 4 18.8802 4 17.2V6.8C4 5.11984 4 4.27976 4.32698 3.63803C4.6146 3.07354 5.07354 2.6146 5.63803 2.32698C6.27976 2 7.11984 2 8.8 2H15.2C16.8802 2 17.7202 2 18.362 2.32698C18.9265 2.6146 19.3854 3.07354 19.673 3.63803C20 4.27976 20 5.11984 20 6.8Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
        <div class="min-w-0 flex-1">
          <div class="text-sm md:text-base font-medium text-(--fg) truncate">
            ${p.title}
          </div>
          <div class="mt-0.5 text-xs md:text-[13px] text-(--fg-muted) line-clamp-1">
            ${p.desc}
          </div>
        </div>
      </a>
    `).join("");
  };

  document.addEventListener("open-search", open);
  closeBtn?.addEventListener("click", close);
  backdrop.addEventListener("click", close);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" &&!modal.classList.contains("hidden")) {
      e.preventDefault();
      close();
    }
  });

  input.addEventListener("input", (e) => {
    const q = e.target.value.toLowerCase().trim();
    activeIndex = -1;

    if (!q) return resetResults();

    const filtered = searchData.filter(p =>
      p.title.toLowerCase().includes(q) ||
      p.desc.toLowerCase().includes(q) ||
      p.category.toLowerCase().includes(q)
    ).slice(0, 8);

    renderResults(filtered);
  });

  input.addEventListener("keydown", (e) => {
    const items = results.querySelectorAll("a");
    if (!items.length) return;

    if (e.key === "ArrowDown") {
      e.preventDefault();
      activeIndex = (activeIndex + 1) % items.length;
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      activeIndex = (activeIndex - 1 + items.length) % items.length;
    } else if (e.key === "Enter" && activeIndex >= 0) {
      e.preventDefault();
      items[activeIndex].click();
    }

    items.forEach((el, i) => {
      el.classList.toggle("bg-zinc-100", i === activeIndex);
      el.classList.toggle("dark:bg-zinc-800/50", i === activeIndex);
    });
    items[activeIndex]?.scrollIntoView({ block: "nearest" });
  });

  modal.setAttribute("inert", "");
  
  document.addEventListener("DOMContentLoaded", () => {
    const urlParams = new URLSearchParams(window.location.search);
    const q = urlParams.get("q");
    
    if (q) {
      setTimeout(() => {
        open();
        input.value = q;
        input.dispatchEvent(new Event('input', { bubbles: true }));
        window.history.replaceState({}, document.title, window.location.pathname);
      }, 100);
    }
  });
</script>

<style>
  #search-results::-webkit-scrollbar { width: 4px; }
  #search-results::-webkit-scrollbar-track { background: transparent; }
  #search-results::-webkit-scrollbar-thumb {
    background: rgb(212 212 216);
    border-radius: 3px;
  }
.dark #search-results::-webkit-scrollbar-thumb {
    background: rgb(63 63 70);
  }
</style>
