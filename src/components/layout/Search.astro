---
// src/components/layout/Search.astro
import { getCollection, getEntry } from "astro:content";
import { slugify } from "@/lib/utils";
import { siteConfig } from "@/config/site";
import Icon from "@/components/ui/Icon";


const siteData = siteConfig

const searchModalLabel = siteData.searchModalLabel;
const searchPlaceholder = siteData.searchPlaceholder;
const clearSearchLabel = siteData.clearSearch;
const closeSearchLabel = siteData.closeSearch;
const navigateLabel =siteData.navigate;
const openLabel = siteData.open;
const resultsLabel = siteData.results;
const notFoundTitle = siteData.notFound;
const tryOtherKeywords = siteData.tryOtherKeywords;
const searchArticlesTitle = siteData.searchArticles;
const typeToSearch = siteData.typeToSearch;
const dataNotReady = siteData.dataNotReady;
const refreshPage = siteData.refreshPage;

const posts = await getCollection("blog", ({ data }) => {
  return !data.draft;
});

const searchData = await Promise.all(
  posts.map(async (post) => {
    const categoryEntry = post.data.category ? await getEntry(post.data.category) : null;
    const nameObj = categoryEntry?.data?.name as Record<string, string> | undefined;
    const categoryName = nameObj;

    const autoSlug = slugify(post.data.title);
    const url = `/blog/${autoSlug}/`;

    return {
      id: post.id,
      title: post.data.title,
      desc: post.data.description ?? "",
      category: categoryName,
      categorySlug: categoryEntry?.id ?? "uncategorized",
      url,
    };
  })
);

const scriptLabels = {
  notFoundTitle,
  tryOtherKeywords,
  searchArticlesTitle,
  typeToSearch,
  dataNotReady,
  refreshPage,
  resultsLabel
};
---

<div id="search-modal" role="dialog" aria-modal="true" aria-label={searchModalLabel} inert
  class="fixed inset-0 z-50 hidden">
  <!-- Backdrop -->
  <div id="search-backdrop"
    class="absolute inset-0 bg-[color-mix(in_srgb,var(--bg)_50%,transparent)] backdrop-blur-sm opacity-0 transition-opacity duration-200"></div>

  <!-- Positioner -->
  <div class="relative flex min-h-full items-start justify-center p-3 sm:pt-20">
    <div id="search-panel"
      class="w-full max-w-3xl overflow-hidden rounded-(--radius-xl) border border-(--border) bg-(--bg) opacity-0 shadow-(--shadow-lg) scale-96 transition-all duration-200">
      <!-- Input row -->
      <div class="flex items-center gap-2 border-b border-(--border) px-3.5">
        <Icon name="search"
          className="h-4 w-4 shrink-0 text-(--fg-subtle)"/>

        <input
          id="search-input"
          type="text"
          placeholder={searchPlaceholder}
          aria-label={searchModalLabel}
          autocomplete="off"
          spellcheck="false"
          class="flex-1 min-w-0 border-none bg-transparent py-3.5 text-sm tracking-[-0.005em] text-(--fg) outline-none placeholder:text-(--fg-subtle)"
        />

        <button id="search-clear" class="hidden h-7 w-7 shrink-0 items-center justify-center rounded-full border border-(--border) text-(--fg-subtle) transition-colors duration-150 hover:bg-(--bg-muted) hover:text-(--fg) focus-visible:outline-2 focus-visible:outline-(--accent) focus-visible:outline-offset-2" aria-label={clearSearchLabel} tabindex="-1">
          <Icon name="trash" className="h-3.5 w-3.5 block" />
        </button>

        <button id="search-close-mobile" class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-(--border) text-(--fg-subtle) transition-colors duration-150 hover:bg-(--bg-muted) hover:text-(--fg) focus-visible:outline-2 focus-visible:outline-(--accent) focus-visible:outline-offset-2 sm:hidden" aria-label={closeSearchLabel}>
          <Icon name="close" className="h-3.5 w-3.5 block" />
        </button>

        <kbd class="hidden shrink-0 pointer-events-none items-center rounded-(--radius-sm) border border-(--border) bg-(--bg-muted) px-1.5 py-0.5 font-mono text-[11px] font-medium text-(--fg-subtle) sm:inline-flex">
          ESC
        </kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[55dvh] overflow-y-auto scrollbar-thin scrollbar-track-transparent scrollbar-thumb-(--border)"></div>

      <!-- Footer -->
      <div class="hidden items-center justify-between border-t border-(--border) bg-(--bg-subtle) px-3.5 py-2 sm:flex">
        <div class="flex items-center gap-3 text-[11px] text-(--fg-subtle)">
          <span class="inline-flex items-center gap-1.5">
            <kbd class="rounded-(--radius-sm) border border-(--border) bg-(--bg) px-1.5 py-0.5 font-mono text-[10px] text-(--fg-subtle)">
              ↑↓
            </kbd>
            {navigateLabel}
          </span>
          <span class="inline-flex items-center gap-1.5">
            <kbd class="rounded-(--radius-sm) border border-(--border) bg-(--bg) px-1.5 py-0.5 font-mono text-[10px] text-(--fg-subtle)">
              ↵
            </kbd>
            {openLabel}
          </span>
        </div>
        <span id="search-count" class="text-[11px] tracking-normal text-(--fg-subtle)"></span>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .sm-hl {
    background: color-mix(in srgb, var(--fg) 12%, transparent);
    border-radius: 2px;
    padding: 0 1px;
    color: var(--fg);
  }

  .sritem {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0.875rem;
    text-decoration: none;
    transition: background-color 0.1s ease;
  }

  .sritem:hover,
  .sritem.is-active {
    background-color: var(--bg-muted);
  }

  .sritem-icon {
    margin-top: 0.125rem;
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--fg-subtle);
  }

  .sritem-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .sritem-desc {
    margin-top: 0.125rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    font-size: 0.75rem;
    color: var(--fg-muted);
  }

  .sritem-cat {
    margin-top: 0.25rem;
    font-size: 0.6875rem;
    letter-spacing: 0;
    color: var(--fg-subtle);
  }

  .sm-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 3rem 1rem;
    text-align: center;
  }

  .sm-empty-icon {
    width: 1.75rem;
    height: 1.75rem;
    color: var(--fg-subtle);
  }

  .sm-empty-title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .sm-empty-sub {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--fg-subtle);
  }
</style>

<script define:vars={{ searchData, labels: scriptLabels }}>
  (() => {
    /* ── Guard */
    if (!Array.isArray(searchData) ||!searchData.length) {
      console.warn("[Search] No data available.");
      const results = document.getElementById("search-results");
      if (results) results.innerHTML = emptyHTML(labels.dataNotReady, labels.refreshPage, true);
      return;
    }

    const modal = document.getElementById("search-modal");
    const backdrop = document.getElementById("search-backdrop");
    const panel = document.getElementById("search-panel");
    const input = document.getElementById("search-input");
    const results = document.getElementById("search-results");
    const clearBtn = document.getElementById("search-clear");
    const closeMobile = document.getElementById("search-close-mobile");
    const countEl = document.getElementById("search-count");

    if (!modal ||!backdrop ||!panel ||!input ||!results) return;

    let activeIdx = -1;
    let filtered = [];
    let prevFocus = null;
    let debounce;

    /* ── Helpers */
    const esc = (s) =>
      String(s)
      .replace(/&/g, "&amp;").replace(/</g, "&lt;")
      .replace(/>/g, "&gt;").replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");

    const highlight = (str, q) => {
      if (!q) return esc(str);
      const safe = q.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      return esc(str).replace(
        new RegExp(`(${safe})`, "gi"),
        '<mark class="sm-hl">$1</mark>'
      );
    };

    const score = (post, q) => {
      const tl = post.title.toLowerCase();
      const dl = post.desc.toLowerCase();
      const cl = post.category.toLowerCase();
      if (tl === q) return 100;
      if (tl.startsWith(q)) return 80;
      if (tl.includes(q)) return 60;
      if (dl.includes(q)) return 40;
      if (cl.includes(q)) return 30;
      let qi = 0;
      for (let i = 0; i < tl.length && qi < q.length; i++)
        if (tl[i] === q[qi]) qi++;
      return qi === q.length? 10 : 0;
    };

    function emptyHTML(title, sub, isError = false) {
      const icon = isError
      ? `<svg class="sm-empty-icon" style="color:#ef4444" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11 2C15.968 2 20 6.032 20 11C20 15.968 15.968 20 11 20C6.032 20 2 15.968 2 11C2 6.032 6.032 2 11 2ZM11 18C14.8675 18 18 14.8675 18 11C18 7.1325 14.8675 4 11 4C7.1325 4 4 7.1325 4 11C4 14.8675 7.1325 18 11 18ZM19.4853 18.0711L22.3137 20.8995L20.8995 22.3137L18.0711 19.4853L19.4853 18.0711Z" />
           </svg>`
        : `<svg class="sm-empty-icon" fill="currentColor" viewBox="0 0 24 24">
             <path d="M11 2C15.968 2 20 6.032 20 11C20 15.968 15.968 20 11 20C6.032 20 2 15.968 2 11C2 6.032 6.032 2 11 2ZM11 18C14.8675 18 18 14.8675 18 11C18 7.1325 14.8675 4 11 4C7.1325 4 4 7.1325 4 11C4 14.8675 7.1325 18 11 18ZM19.4853 18.0711L22.3137 20.8995L20.8995 22.3137L18.0711 19.4853L19.4853 18.0711Z" />
           </svg>`;
      return `<div class="sm-empty">${icon}
        <p class="sm-empty-title">${title}</p>
        <p class="sm-empty-sub">${sub}</p>
      </div>`;
    }

    /* ── Render */
    const setActive = (items) =>
      items.forEach((el, i) =>
        el.classList.toggle("is-active", i === activeIdx)
      );

    const renderResults = (items, q) => {
      if (!items.length) {
        results.innerHTML = emptyHTML(labels.notFoundTitle, labels.tryOtherKeywords);
        if (countEl) countEl.textContent = "";
        return;
      }

      if (countEl) countEl.textContent = `${items.length} ${labels.resultsLabel}`;

      results.innerHTML = items.map((p, i) => `
        <a
          href="${esc(p.url)}"
          data-idx="${i}"
          class="sritem${i === activeIdx? " is-active" : ""}"
        >
          <svg class="sritem-icon" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          <div style="min-width:0;flex:1">
            <div class="sritem-title">${highlight(p.title, q)}</div>
            <div class="sritem-desc">${highlight(p.desc, q)}</div>
            <div class="sritem-cat">${esc(p.category)}</div>
          </div>
        </a>
      `).join("");
    };

    const resetView = () => {
      activeIdx = -1;
      filtered = [];
      results.innerHTML = emptyHTML(labels.searchArticlesTitle, labels.typeToSearch);
      if (countEl) countEl.textContent = "";
    };

    /* ── Open / close */
    const openModal = () => {
      prevFocus = document.activeElement;
      modal.style.display = "block";
      modal.removeAttribute("inert");
      document.body.style.overflow = "hidden";
      requestAnimationFrame(() => {
        backdrop.style.opacity = "1";
        panel.style.opacity = "1";
        panel.style.transform = "scale(1)";
        input.focus();
      });
      resetView();
    };

    const closeModal = () => {
      backdrop.style.opacity = "0";
      panel.style.opacity = "0";
      panel.style.transform = "scale(0.96)";
      document.body.style.overflow = "";
      setTimeout(() => {
        modal.style.display = "none";
        modal.setAttribute("inert", "");
        input.value = "";
        clearBtn?.classList.add("hidden");
        resetView();
        prevFocus?.focus();
      }, 200);
    };

    /* ── Events */
    document.addEventListener("open-search", openModal);
    backdrop.addEventListener("click", closeModal);
    closeMobile?.addEventListener("click", closeModal);

    clearBtn?.addEventListener("click", () => {
      input.value = "";
      clearBtn.classList.add("hidden");
      input.focus();
      resetView();
    });

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        modal.style.display === "none"? openModal() : closeModal();
        return;
      }
      if (e.key === "Escape" && modal.style.display!== "none") {
        e.preventDefault();
        closeModal();
      }
    });

    input.addEventListener("input", () => {
      const q = input.value.trim();
      clearBtn?.classList.toggle("hidden",!q);
      clearTimeout(debounce);
      debounce = setTimeout(() => {
        if (!q) { resetView(); return; }
        const ql = q.toLowerCase();
        filtered = searchData
        .map((p) => ({...p, _score: score(p, ql) }))
        .filter((p) => p._score > 0)
        .sort((a, b) => b._score - a._score)
        .slice(0, 8);
        activeIdx = -1;
        renderResults(filtered, ql);
      }, 80);
    });

    input.addEventListener("keydown", (e) => {
      const items = results.querySelectorAll(".sritem");
      if (!items.length) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeIdx = (activeIdx + 1) % items.length;
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIdx = (activeIdx - 1 + items.length) % items.length;
      } else if (e.key === "Enter" && activeIdx >= 0) {
        e.preventDefault();
        items[activeIdx]?.click();
        return;
      } else {
        return;
      }

      setActive(items);
      items[activeIdx]?.scrollIntoView({ block: "nearest" });
    });

    /* ── URL param */
    document.addEventListener("DOMContentLoaded", () => {
      const q = new URLSearchParams(window.location.search).get("q");
      if (!q) return;
      setTimeout(() => {
        openModal();
        input.value = q;
        input.dispatchEvent(new Event("input", { bubbles: true }));
        history.replaceState({}, "", window.location.pathname);
      }, 100);
    });
  })();
</script>