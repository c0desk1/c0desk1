---
// src/components/layout/MobileMenu.astro

import { siteConfig } from "@/config/site";
import { getCurrentLocale, localizePath, getLabel } from "@/utils/i18n";

import Icon from "@/components/ui/Icon";
import LanguageButton from "@/components/ui/LanguageButton.astro";
import ThemeToggle from "@/components/ui/ThemeToggle.astro";

interface Props {
  alternateSlugs?: Record<string, string>;
  basePath?: 'blog' | 'portfolio' | 'legal' | '';
}

const { alternateSlugs, basePath = '' } = Astro.props;

const nav = siteConfig.mobileNavItems;
const locale = getCurrentLocale(Astro);

const mobileAria = locale === 'en'
? 'Navigation menu'
  : locale === 'ru'
? 'Меню навигации'
  : locale === 'ja'
? 'ナビゲーションメニュー'
  : 'Menu navigasi';
---

<div
  id="mnav-backdrop"
  class="fixed inset-0 z-100 bg-(--bg)/60 backdrop-blur-sm"
  style="display: none; opacity: 0; transition: opacity 0.25s ease;"
  aria-hidden="true"
/>

<div
  id="mnav-sheet"
  role="dialog"
  aria-modal="true"
  aria-label={mobileAria}
  class="fixed bottom-0 left-0 right-0 z-200
         bg-(--bg) border-t border-(--border)
         rounded-t-(--radius-xl)
         shadow-[0_-8px_40px_rgba(0,0,0,0.12)]
         max-h-[75dvh]
         pb-[env(safe-area-inset-bottom)]"
  style="display: none; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);"
  inert
>
  <div id="mnav-handle" class="flex h-2 justify-center pt-4 pb-1">
    <div class="w-9 h-1 rounded-full bg-(--border)"></div>
  </div>

  <nav class="flex flex-col px-3 pt-2 pb-4 gap-3 overflow-y-auto max-h-[calc(75dvh-120px)]">
    {nav.map((section) => (
      <div class="flex flex-col gap-0.5">
        <div class="px-3 py-2 text-label-14 text-(--fg) uppercase">
          {getLabel(locale, section.titleKey)}
        </div>

        {section.items.map((item) => {
          const href = item.isExternal
          ? item.href
            : localizePath(item.href, locale);

          return (
            <a
              href={href}
              target={item.isExternal? "_blank" : undefined}
              rel={item.isExternal? "noopener noreferrer" : undefined}
              class="mnav-link flex items-center gap-2 px-3 py-1.5 text-copy-16 text-(--fg-muted) transition-colors"
            >
              {getLabel(locale, item.labelKey)}
              {item.isExternal && (
                <Icon name="external" className="w-3 h-3 shrink-0 opacity-80 transition-opacity group-hover:opacity-100" />
              )}
            </a>
          )
        })}
      </div>
    ))}
  </nav>

  <div class="flex items-center p-6 justify-between border-t border-dashed border-(--border) gap-4">
    <ThemeToggle />
    <LanguageButton alternateSlugs={alternateSlugs} basePath={basePath} />
  </div>
</div>

<script>
  (() => {
    const sheet = document.getElementById('mnav-sheet') as HTMLElement;
    const backdrop = document.getElementById('mnav-backdrop') as HTMLElement;
    const handle = document.getElementById('mnav-handle') as HTMLElement;

    if (!sheet ||!backdrop ||!handle) return;

    let open = false;
    let startY = 0, currentY = 0, dragging = false;
    let focusableElements: HTMLElement[] = [];
    let firstFocusable: HTMLElement | null = null;
    let lastFocusable: HTMLElement | null = null;

    const getFocusable = () => {
      return Array.from(
        sheet.querySelectorAll<HTMLElement>(
          'a[href], button, [tabindex]:not([tabindex="-1"])'
        )
      ).filter(el =>!el.hasAttribute('disabled') &&!el.hasAttribute('inert'));
    };

    const trapFocus = (e: KeyboardEvent) => {
      if (e.key!== 'Tab' ||!open) return;
      if (!firstFocusable) return;

      if (e.shiftKey && document.activeElement === firstFocusable) {
        e.preventDefault();
        lastFocusable?.focus();
      } else if (!e.shiftKey && document.activeElement === lastFocusable) {
        e.preventDefault();
        firstFocusable.focus();
      }
    };

    const openSheet = () => {
      if (open) return;
      open = true;

      sheet.style.display = 'block';
      backdrop.style.display = 'block';
      sheet.offsetHeight;
      sheet.style.transform = 'translateY(0)';
      backdrop.style.opacity = '1';
      sheet.removeAttribute('inert');
      document.body.style.overflow = 'hidden';

      focusableElements = getFocusable();
      firstFocusable = focusableElements[0]?? null;
      lastFocusable = focusableElements[focusableElements.length - 1]?? null;
      firstFocusable?.focus();

      const btn = document.getElementById('mnav-btn');
      if (btn) btn.setAttribute('aria-expanded', 'true');
    };

    const closeSheet = () => {
      if (!open) return;
      open = false;

      sheet.style.transform = 'translateY(100%)';
      backdrop.style.opacity = '0';
      document.body.style.overflow = '';

      setTimeout(() => {
        if (!open) {
          sheet.style.display = 'none';
          backdrop.style.display = 'none';
          sheet.setAttribute('inert', '');
        }
      }, 300);

      const btn = document.getElementById('mnav-btn');
      if (btn) btn.setAttribute('aria-expanded', 'false');

      document.getElementById('mnav-btn')?.focus();
    };

    window.addEventListener('mnav:open', openSheet);
    backdrop.addEventListener('click', closeSheet);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && open) closeSheet();
      trapFocus(e);
    });

    document.querySelectorAll('.mnav-link').forEach(link => {
      link.addEventListener('click', closeSheet);
    });

    handle.addEventListener('touchstart', e => {
      startY = e.touches[0].clientY;
      dragging = true;
      sheet.style.transition = 'none';
      e.preventDefault();
    }, { passive: false });

    handle.addEventListener('touchmove', e => {
      if (!dragging ||!open) return;
      currentY = e.touches[0].clientY;
      const delta = Math.max(0, currentY - startY);
      sheet.style.transform = `translateY(${delta}px)`;
    }, { passive: true });

    handle.addEventListener('touchend', () => {
      dragging = false;
      const delta = currentY - startY;
      sheet.style.transition = 'transform 0.3s cubic-bezier(0.32, 0.72, 0, 1)';

      if (delta > 80) {
        closeSheet();
      } else {
        sheet.style.transform = 'translateY(0)';
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768 && open) {
        closeSheet();
      }
    });
  })();
</script>