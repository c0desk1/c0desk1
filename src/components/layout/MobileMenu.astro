---
// src/components/layout/MobileMenu.astro

import { siteConfig } from "@/config/site";
import { getEntry } from 'astro:content';
import Icon from "@/components/ui/Icon";

let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {}

const siteData = settings?.data || siteConfig;
const nav = siteData.mobileNavItems || siteConfig.mobileNavItems;
const social = siteData.social || siteConfig.social;
---

<div
  id="mnav-backdrop"
  class="fixed inset-0 z-100 bg-(--bg)/60 backdrop-blur-sm"
  style="display: none; opacity: 0; transition: opacity 0.25s ease;"
  aria-hidden="true"
></div>

<div
  id="mnav-sheet"
  role="dialog"
  aria-modal="true"
  aria-label="Menu navigasi"
  class="fixed bottom-0 left-0 right-0 z-200
         bg-(--bg) border-t border-(--border)
         rounded-t-(--radius-xl)
         shadow-[0_-8px_40px_rgba(0,0,0,0.12)]
         max-h-[85vh] overflow-y-auto
         pb-[env(safe-area-inset-bottom)]"
  style="display: none; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);"
  inert>
  <div id="mnav-handle" class="flex h-2 justify-center pt-3 pb-1">
    <div class="w-9 h-1 rounded-full bg-(--border)"></div>
  </div>

  <nav class="flex flex-col px-3 pt-2 pb-4 gap-0.5">
    <nav class="flex flex-col px-3 pt-2 pb-4 gap-3">
      {nav.map((section) => (
        <div class="flex flex-col gap-0.5">
          <div class="px-3 py-2 text-base font-semibold uppercase tracking-wide text-(--fg)">
            {section.title}
          </div>

          {section.items.map((item) => (
            <a href={item.href} target={item.isExternal ? "_blank" : undefined} rel={item.isExternal ? "noopener noreferrer" : undefined}
              class="mnav-link flex items-center gap-2 px-3 py-1.5
                    text-[13px] text-(--fg-muted) transition-colors"
            >
              {item.label}
              {item.isExternal && (
                <Icon name="external" className="w-3 h-3 shrink-0 opacity-80 transition-opacity group-hover:opacity-100" />
              )}
            </a>
          ))}
        </div>
      ))}
      <!--{nav.length > 0 && social.length > 0 && (
        <div class="h-px bg-(--border) my-1.5 mx-1"></div>
      )}

      {social.map((item) => (
        <a
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={item.label}
          class="mnav-link flex items-center gap-3 px-3 py-1.5 rounded-(--radius-lg)
                text-sm font-medium text-(--fg-muted)
                hover:text-(--fg) hover:bg-(--bg-muted) transition-colors"
        >
          <Icon name={item.label as any} className="w-4 h-4 shrink-0" />
          <span class="capitalize">{item.label}</span>
        </a>
      ))}-->
  </nav>
</div>

<script>
  (() => {
    const sheet    = document.getElementById('mnav-sheet');
    const backdrop = document.getElementById('mnav-backdrop');
    const handle = document.getElementById('mnav-handle');
    
    if (!sheet ||!backdrop ||!handle) return;

    let open = false;
    let startY = 0, currentY = 0, dragging = false;

    const openSheet = () => {
      if (open) return;
      open = true;
      
      sheet.style.display = 'block';
      backdrop.style.display = 'block';
      sheet.offsetHeight;
      sheet.style.transform = 'translateY(0)';
      backdrop.style.opacity = '1';
      sheet.removeAttribute('inert');
      document.body.style.overflow = 'hidden';
      
      const btn = document.getElementById('mnav-btn');
      if (btn) btn.setAttribute('aria-expanded', 'true');
    };

    const closeSheet = () => {
      if (!open) return;
      open = false;
      
      sheet.style.transform = 'translateY(100%)';
      backdrop.style.opacity = '0';
      document.body.style.overflow = '';
      
      setTimeout(() => {
        if (!open) {
          sheet.style.display = 'none';
          backdrop.style.display = 'none';
          sheet.setAttribute('inert', '');
        }
      }, 300);
      
      const btn = document.getElementById('mnav-btn');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    };

    window.addEventListener('mnav:open', openSheet);
    backdrop.addEventListener('click', closeSheet);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && open) closeSheet();
    });

    document.querySelectorAll('.mnav-link').forEach(link => {
      link.addEventListener('click', closeSheet);
    });

    handle.addEventListener('touchstart', e => {     
      startY = e.touches[0].clientY;
      dragging = true;
      sheet.style.transition = 'none';
    }, { passive: true });

    handle.addEventListener('touchmove', e => {
      if (!dragging || !open) return;
      currentY = e.touches[0].clientY;
      const delta = Math.max(0, currentY - startY);  
      sheet.style.transform = `translateY(${delta}px)`;
    }, { passive: true });

    handle.addEventListener('touchend', () => {
      dragging = false;
      sheet.style.transition = '';
      const delta = currentY - startY;
      sheet.style.transform = '';
      if (delta > 80) closeSheet();
    });
  })();
</script>