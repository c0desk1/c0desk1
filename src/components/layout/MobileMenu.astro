---
// src/components/layout/MobileMenu.astro
import { siteConfig } from "@/config/site";
import Icon from "@/components/ui/Icon";
import ThemeToggle from "@/components/ui/ThemeToggle.astro";

const navItems = siteConfig.MobileNavItems;
---

<div
  id="mnav-backdrop"
  class="fixed inset-0 z-100 bg-(--bg)/60 backdrop-blur-sm"
  style="display: none; opacity: 0; transition: opacity 0.25s ease;"
  aria-hidden="true"
></div>

<div
  id="mnav-sheet"
  role="dialog"
  aria-modal="true"
  aria-label={siteConfig.mobileAria}
  class="fixed bottom-0 left-0 right-0 z-200
         bg-(--bg) border-t border-(--border)
         rounded-t-xl
         shadow-[0_-8px_40px_rgba(0,0,0,0.12)]
         max-h-[75dvh]
         pb-[env(safe-area-inset-bottom)]"
  style="display: none; transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);"
  inert>
  
  <div id="mnav-handle" class="flex h-6 justify-center pt-4 pb-1">
    <div class="w-9 h-1 rounded-full bg-(--border)"></div>
  </div>

  <nav class="flex flex-col px-3 pt-2 pb-4 gap-3 overflow-y-auto max-h-[calc(75dvh-120px)]">
    {navItems.map((item) => {
      const hasChildren = item.children && item.children.length > 0;
      if (hasChildren) {
        return (
          <div class="accordion-item" data-accordion>
            <button aria-expanded="false" class="accordion-trigger flex items-center justify-between w-full px-3 py-2 text-copy-14 font-medium text-(--fg) rounded-lg active:bg-subtle hover:bg-subtle transition-colors">
              <span>{item.label}</span>
              <Icon name="chevron-right" className="chevron-icon w-4 h-4 transition-transform duration-200" />
            </button>
            <div class="accordion-content">
              <div class="overflow-hidden">
                <div class="pl-4 flex flex-col gap-0.5">
                  {item.children?.map((child) => {
                    const isExternal = child.isExternal === true;
                    return (
                      <a
                        href={child.href}
                        target={isExternal ? "_blank" : undefined}
                        rel={isExternal ? "noopener noreferrer" : undefined}
                        class="mnav-link flex items-center gap-2 px-3 py-1.5 text-copy-14 text-(--fg) rounded-lg active:bg-subtle hover:bg-subtle transition-colors">
                        {child.label}
                        {isExternal && (
                          <Icon name="external" className="w-3 h-3 shrink-0 opacity-80" />
                        )}
                      </a>
                    );
                  })}
                </div>
              </div>
            </div>
          </div>
        );
      } else {
        return (
          <a href={item.href}
            class="mnav-link flex items-center gap-2 px-3 py-2 text-copy-14 text-(--fg) active:bg-muted hover:bg-subtle rounded-lg transition-colors">
            {item.label}
            {item.isExternal && (
              <Icon name="external" className="w-3 h-3 shrink-0 opacity-80" />
            )}
          </a>
        );
      }
    })}
  </nav>
  
  <div class="flex items-center p-6 justify-end border-t border-dashed border-(--border) gap-4">
    <ThemeToggle />
  </div>
</div>

<style is:global>
  .accordion-trigger .chevron-icon {
    transition: transform 0.2s ease;
  }
  .accordion-trigger[aria-expanded="true"] .chevron-icon {
    transform: rotate(90deg);
  }
  
  .accordion-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease-out;
  }
  
  .accordion-content > div {
    overflow: hidden;
  }
  
  .accordion-content.open {
    grid-template-rows: 1fr;
  }
</style>

<script>
  (() => {
    const sheet    = document.getElementById('mnav-sheet');
    const backdrop = document.getElementById('mnav-backdrop');
    const handle = document.getElementById('mnav-handle');
    
    if (!sheet || !backdrop || !handle) return;

    let open = false;
    let startY = 0, currentY = 0, dragging = false;

    const openSheet = () => {
      if (open) return;
      open = true;
      
      sheet.style.display = 'block';
      backdrop.style.display = 'block';
      sheet.offsetHeight;
      sheet.style.transform = 'translateY(0)';
      backdrop.style.opacity = '1';
      sheet.removeAttribute('inert');
      document.body.style.overflow = 'hidden';
      
      const btn = document.getElementById('mnav-btn');
      if (btn) btn.setAttribute('aria-expanded', 'true');
    };

    const closeSheet = () => {
      if (!open) return;
      open = false;
      
      sheet.style.transform = 'translateY(100%)';
      backdrop.style.opacity = '0';
      document.body.style.overflow = '';
      
      setTimeout(() => {
        if (!open) {
          sheet.style.display = 'none';
          backdrop.style.display = 'none';
          sheet.setAttribute('inert', '');
        }
      }, 300);
      
      const btn = document.getElementById('mnav-btn');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    };

    window.addEventListener('mnav:open', openSheet);
    backdrop.addEventListener('click', closeSheet);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && open) closeSheet();
    });

    document.querySelectorAll('.mnav-link').forEach(link => {
      link.addEventListener('click', closeSheet);
    });

    handle.addEventListener('touchstart', e => {     
      startY = e.touches[0].clientY;
      dragging = true;
      sheet.style.transition = 'none';
    }, { passive: true });

    handle.addEventListener('touchmove', e => {
      if (!dragging || !open) return;
      currentY = e.touches[0].clientY;
      const delta = Math.max(0, currentY - startY);  
      sheet.style.transform = `translateY(${delta}px)`;
    }, { passive: true });

    handle.addEventListener('touchend', () => {
      dragging = false;
      sheet.style.transition = '';
      const delta = currentY - startY;
      sheet.style.transform = '';
      if (delta > 80) closeSheet();
    });

    const accordionTriggers = document.querySelectorAll('.accordion-trigger');
    accordionTriggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const accordionItem = trigger.closest('.accordion-item');
        if (!accordionItem) return;

        const content = accordionItem.querySelector('.accordion-content');
        if (!(content instanceof HTMLElement)) return;

        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        
        if (isExpanded) {
          content.classList.remove('open');
          trigger.setAttribute('aria-expanded', 'false');
        } else {
          content.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();
</script>
