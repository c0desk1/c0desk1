---
// src/components/layout/BaseHead.astro
import "@/styles/global.css";
import { siteConfig } from "@/config/site";
import { Font } from "astro:assets";

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  lang?: string;
  category?: {
    name: string;
    description?: string;
    slug: string;
  };
  author?: {
    name: string;
    role: string;
    avatar: string;
    bio: string;
    slug: string;
  };
  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };
  breadcrumbItems?: { name: string; item: string }[];
}

const {
  title: propsTitle,
  description: propsDescription,
  image: propsImage,
  seo,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  lang = "id",
  category,
  author,
  breadcrumbItems = [],
} = Astro.props;

// ─── Helpers
const siteURL = siteConfig.siteUrl.startsWith("http://")
  ? siteConfig.siteUrl.replace("https://", "https://")
  : siteConfig.siteUrl;

const seoResolved = {
  title:
    seo?.title ??
    propsTitle ??
    siteConfig.defaultSeo.title ??
    siteConfig.siteName,
  description:
    seo?.description ??
    propsDescription ??
    siteConfig.defaultSeo.description ??
    "",
  canonical: seo?.canonical
    ? new URL(seo.canonical, siteURL)
    : Astro.props.canonicalURL
    ? new URL(Astro.props.canonicalURL, siteURL)
    : new URL(Astro.url.pathname, siteURL),
  noIndex: seo?.noIndex ?? Astro.props.noIndex ?? false,
};

const formattedTitle =
  seoResolved.title === siteConfig.siteName
    ? siteConfig.siteName
    : `${seoResolved.title} — ${siteConfig.siteName}`;

const rawImage = seo?.ogImage ?? propsImage?.src ?? siteConfig.ogImage;
const ogImageURL: string = !rawImage
  ? new URL(siteConfig.siteLogo, siteURL).toString()
  : rawImage.startsWith("http")
  ? rawImage
  : new URL(rawImage, siteURL).toString();

const authorConfig = siteConfig.author;
const activeAuthor = {
  name: author?.name ?? authorConfig.name,
  role: author?.role ?? authorConfig.role,
  avatar: author?.avatar ?? authorConfig.avatar,
  bio: author?.bio ?? authorConfig.bio,
  slug: author?.slug ?? authorConfig.slug,
};

const isHomepage = Astro.url.pathname === "/";
const isTimedContent = type === "article";
const datePublished = isTimedContent ? publishedTime?.toISOString() : undefined;
const dateModified = isTimedContent
  ? (modifiedTime?.toISOString() ?? datePublished)
  : undefined;

const twitterHandle = "@c0desk1";

const schemaGraph: any[] = [];

// 1. Organization
schemaGraph.push({
  "@type": "Organization",
  "@id": `${siteURL}/#organization`,
  name: siteConfig.siteName,
  url: siteURL,
  logo: {
    "@type": "ImageObject",
    "@id": `${siteURL}/#logo`,
    url: new URL(siteConfig.siteLogo, siteURL).toString(),
    width: 512,
    height: 512,
  },
});

// 2. WebSite
schemaGraph.push({
  "@type": "WebSite",
  "@id": `${siteURL}/#website`,
  url: siteURL,
  name: siteConfig.siteName,
  publisher: { "@id": `${siteURL}/#organization` },
  potentialAction: [
    {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${siteURL}/search?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  ],
});

// 3. Person
schemaGraph.push({
  "@type": "Person",
  "@id": `${siteURL}/#person`,
  name: activeAuthor.name,
  jobTitle: activeAuthor.role,
  description: activeAuthor.bio,
  image: {
    "@type": "ImageObject",
    url: activeAuthor.avatar.startsWith("http")
      ? activeAuthor.avatar
      : new URL(activeAuthor.avatar, siteURL).toString(),
    width: 400,
    height: 400,
  },
  url: new URL(`author/${activeAuthor.slug}`, siteURL).toString(),
  worksFor: { "@id": `${siteURL}/#organization` },
});

// 4. WebPage
schemaGraph.push({
  "@type": "WebPage",
  "@id": `${seoResolved.canonical}#webpage`,
  url: seoResolved.canonical.toString(),
  name: formattedTitle,
  description: seoResolved.description,
  isPartOf: { "@id": `${siteURL}/#website` },
  ...(type === "article" && {
    primaryImageOfPage: { "@id": `${seoResolved.canonical}#primaryimage` },
  }),
  inLanguage: lang,
  ...(datePublished && { datePublished }),
  ...(dateModified && { dateModified }),
  potentialAction: [
    { "@type": "ReadAction", target: [seoResolved.canonical.toString()] },
  ],
});

// 5. BreadcrumbList
if (!isHomepage && breadcrumbItems.length > 0) {
  schemaGraph.push({
    "@type": "BreadcrumbList",
    "@id": `${seoResolved.canonical}#breadcrumb`,
    itemListElement: breadcrumbItems.map((item, index) => {
      
      let absoluteItemUrl = item.item.startsWith("http")
        ? item.item
        : new URL(item.item, siteURL).toString();

      if (absoluteItemUrl.startsWith("http://") && !absoluteItemUrl.includes("localhost")) {
        absoluteItemUrl = absoluteItemUrl.replace("http://", "https://");
      }

      return {
        "@type": "ListItem",
        position: index + 1,
        name: item.name,
        item: absoluteItemUrl,
      };
    }),
  });
}


// 6. Article
if (type === "article") {
  const cleanDomain = siteURL.replace(/https?:\/\/(www\.)?/, "").replace(/\/$/, "");

  schemaGraph.push({
    "@type": "Article",
    "@id": `${seoResolved.canonical}#article`,
    headline: seoResolved.title,
    description: seoResolved.description,
    author: { "@id": `${siteURL}/#person` },
    publisher: { "@id": `${siteURL}/#organization` },
    datePublished,
    dateModified,
    mainEntityOfPage: { "@id": `${seoResolved.canonical}#webpage` },
    inLanguage: lang,
    ...(category?.name && { articleSection: category.name }),
    ...(tags.length > 0 && { keywords: tags.join(", ") }),
    image: {
      "@type": "ImageObject",
      url: ogImageURL,
      width: 1200,
      height: 630,
    },
    isAccessibleForFree: true, 
    isPartOf: {
      "@type": ["CreativeWork", "Product"],
      name: siteConfig.siteName,
      productID: `${cleanDomain}:news_subscription`
    }
  });
}

const jsonLdString = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": schemaGraph
});
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={formattedTitle} href={new URL("rss.xml", Astro.site)} />
<link rel="manifest" href="/site.webmanifest" />

<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-GeistSans" preload />
<Font cssVariable="--font-GeistMono" preload />

<link rel="canonical" href={seoResolved.canonical.toString()} />

<link rel="preconnect" href="https://api.c0desk1.my.id" crossorigin />
<link rel="preconnect" href="https://cdn.c0desk1.my.id" crossorigin />

<link rel="dns-prefetch" href="https://yandex.ru" />
<link rel="dns-prefetch" href="https://mc.yandex.ru" />
<link rel="dns-prefetch" href="https://an.yandex.ru" />

<title>{formattedTitle}</title>
<meta name="description" content={seoResolved.description} />
<meta name="author" content={activeAuthor.name} />



<meta name="color-scheme" content="light dark" />
<meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

<meta name="robots" content={seoResolved.noIndex ? "noindex,nofollow" : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"} />

<meta property="og:type" content={type === "article" ? "article" : "website"} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={seoResolved.description} />
<meta property="og:url" content={seoResolved.canonical.toString()} />
<meta property="og:site_name" content={siteConfig.siteName} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:alt" content={propsImage?.alt ?? formattedTitle} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={lang === "id" ? "id_ID" : "en_US"} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={seoResolved.description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:creator" content={twitterHandle} />

{type === "article" && tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}
{type === "article" && datePublished && (
  <meta property="article:published_time" content={datePublished} />
)}
{type === "article" && dateModified && (
  <meta property="article:modified_time" content={dateModified} />
)}
{type === "article" && category?.name && (
  <meta property="article:section" content={category.name} />
)}

{siteConfig.googleSiteVerification && (
  <meta name="google-site-verification" content={siteConfig.googleSiteVerification} />
)}
{siteConfig.googleAdsenseId && (
  <meta name="google-adsense-account" content={siteConfig.googleAdsenseId} />
)}
{siteConfig.yandexVerification && (
  <meta name="yandex-verification" content={siteConfig.yandexVerification} />
)}

<script type="application/ld+json" set:html={jsonLdString} />
