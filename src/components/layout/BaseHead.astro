---
// src/components/layout/BaseHead.astro

import { siteConfig } from "@/config/site";
import Analytics from "./Analytics.astro";
import Ads from "./Ads.astro";

interface Props {
  title?: string;
  description?: string;
  image?: any;
  canonicalURL?: URL | string;
  type?: "website" | "article";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const {
  title,
  description = siteConfig.description,
  image,
  type = "website",
  noIndex = false,
  publishedTime,
  modifiedTime,
  tags = []
} = Astro.props;

const siteURL = Astro.site ?? siteConfig.url;

const canonical = Astro.props.canonicalURL
  ? new URL(Astro.props.canonicalURL, siteURL)
  : new URL(Astro.url.pathname, siteURL);

const formattedTitle =
  title && title !== siteConfig.name
    ? `${title} | ${siteConfig.name}`
    : siteConfig.name;
let fullImageURL: string;

if (!image) {
  fullImageURL = new URL(siteConfig.ogImage, siteURL).toString();
} else if (typeof image === "string") {
  fullImageURL = image.startsWith("http")
    ? image
    : new URL(image, siteURL).toString();
} else if (typeof image?.src === "string") {
  fullImageURL = new URL(image.src, siteURL).toString();
} else {
  fullImageURL = new URL(siteConfig.ogImage, siteURL).toString();
}

const lastModified =
  modifiedTime?.toISOString() ?? publishedTime?.toISOString();

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteURL}#website`,
      url: siteURL,
      name: siteConfig.name,
      description: siteConfig.description,
      inLanguage: "id-ID"
    },
    {
      "@type": "Organization",
      "@id": `${siteURL}#organization`,
      name: siteConfig.name,
      url: siteURL,
      logo: {
        "@type": "ImageObject",
        url: `${siteURL}/favicon.svg`
      }
    },
    {
      "@type": "WebPage",
      "@id": canonical.toString(),
      url: canonical.toString(),
      name: formattedTitle,
      description,
      inLanguage: "id-ID",
      isPartOf: { "@id": `${siteURL}#website` },
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: fullImageURL
      },
      breadcrumb: { "@id": `${canonical}#breadcrumb` }
    },
    ...(type === "article" ? [
      {
        "@type": "BlogPosting",
        "@id": `${canonical.toString()}#article`,
        headline: title,
        url: canonical.toString(),
        image: {
          "@type": "ImageObject",
          url: fullImageURL,
          width: 1200,
          height: 630
        },
        author: {
          "@type": "Person",
          name: siteConfig.author
        },
        publisher: { "@id": `${siteURL}#organization` },
        datePublished: publishedTime?.toISOString(),
        dateModified: lastModified,
        keywords: tags.join(", "),
        mainEntityOfPage: canonical.toString()
      }
    ] : [])
  ]
};
---

<!-- BASIC SEO -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>{formattedTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical.toString()} />

<!-- ROBOTS -->
{noIndex ? (
  <meta name="robots" content="noindex,nofollow" />
) : (
  <>
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />
    <meta name="googlebot" content="index,follow" />
  </>
)}

<!-- PRELOAD -->
<!-- <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin /> -->
<!-- <link rel="preconnect" href="https://mc.yandex.ru" crossorigin /> -->
<link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

<!-- OPEN GRAPH -->
<meta property="og:type" content={type} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageURL} />
<meta property="og:image:secure_url" content={fullImageURL} />
<meta property="og:url" content={canonical.toString()} />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:locale" content="id_ID" />

<!-- TWITTER -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageURL} />
<meta name="twitter:creator" content={siteConfig.links?.twitter} />

<!-- STRUCTURED DATA -->
<script type="application/ld+json" set:html={JSON.stringify(graph)} />

<!-- TAGS -->
<meta name="google-site-verification" content="ZxoHYWipAMoGhvwVi5nxolWsZOntrYkNkVcG9HTfFZQ" />
<meta name="yandex-verification" content="1878480c0d7b5510" />

<!-- ANALYTICS -->
<Analytics />
<Ads />