---
// src/components/layout/BaseHead.astro
import { siteConfig } from "@/config/site";

interface Props {
  title?: string;
  description?: string;
  image?: any;
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  category?: string;

}

const {
  title,
  description = siteConfig.description,
  image,
  type = "website",
  noIndex = false,
  publishedTime,
  modifiedTime,
  tags = [],
  category,
} = Astro.props;

const siteURL = Astro.site?.toString() ?? siteConfig.url;

const canonical = Astro.props.canonicalURL
  ? new URL(Astro.props.canonicalURL, siteURL)
  : new URL(Astro.url.pathname, siteURL);

const formattedTitle = title && title !== siteConfig.name ? `${title} | ${siteConfig.name}` : siteConfig.name;

// ================= IMAGE =================
let fullImageURL: string;
if (!image) {
  fullImageURL = new URL(siteConfig.ogImage, siteURL).toString();
} else if (typeof image === "string") {
  fullImageURL = image.startsWith("http") ? image : new URL(image, siteURL).toString();
} else if (typeof image?.src === "string") {
  fullImageURL = new URL(image.src, siteURL).toString();
} else {
  fullImageURL = new URL(siteConfig.ogImage, siteURL).toString();
}

// ================= PAGE TYPE CHECK =================
const pathname = Astro.url.pathname;
const isHomepage = pathname === '/';
const isBlogIndex = pathname === '/blog/';
const isPortfolioIndex = pathname === '/portfolio/';
const isAuthorPage = pathname.startsWith('/author/');
const isAboutPage = pathname === '/about/';
const isSearchPage = pathname === '/search/';
const shouldRenderWebPage = !isHomepage && !isBlogIndex && !isPortfolioIndex && !isAuthorPage && !isAboutPage && !isSearchPage && type !== "article";

// ================= SCHEMA GRAPH =================

//Organization
const organizationSchema = {
  "@type": "Organization",
  "@id": `${siteURL}#organization`,
  "name": siteConfig.name,
  "url": siteURL,
  "logo": {
    "@type": "ImageObject",
    "url": new URL("favicon.svg", siteURL).toString(),
    "width": 512,
    "height": 512
  },
  "sameAs": [
    siteConfig.social?.github,
    siteConfig.social?.twitter,
    siteConfig.social?.linkedin,
  ].filter(Boolean)
};

// Person
const personSchema = {
  "@type": "Person",
  "@id": `${siteURL}#person`,
  "name": siteConfig.author.name,
  "url": new URL(`author/${siteConfig.author.slug}/`, siteURL).toString(),
  "jobTitle": "Music Producer, Stock Contributor, Developer",
  "description": siteConfig.author.bio,
  "knowsAbout": [
    "FL Studio", 
    "Music Production", 
    "Adobe Stock", 
    "Web Development", 
    "Automation",
    "Gaming",
    "Anime",
    "Technology",
    "Content Creation"
  ],
  "mainEntityOfPage": { "@id": new URL(`author/${siteConfig.author.slug}/`, siteURL).toString() },
  "image": {
    "@type": "ImageObject",
    "url": new URL(siteConfig.author.avatar, siteURL).toString(),
    "width": 96,
    "height": 96
  },
  "worksFor": { "@id": `${siteURL}#organization` },
  "sameAs": [
    siteConfig.social?.github,
    siteConfig.social?.twitter,
    siteConfig.social?.linkedin,
  ].filter(Boolean)
};

// WebSite
const websiteSchema = isHomepage ? [{
  "@type": "WebSite",
  "@id": `${siteURL}#website`,
  "keywords": siteConfig.keywords.join(", "),
  "url": siteURL,
  "name": siteConfig.name,
  "description": siteConfig.description,
  "inLanguage": "id-ID",
  "publisher": { "@id": `${siteURL}#organization` },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": new URL("search/", siteURL).toString() + "?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}] : [];

// WebPage
const webPageSchema = shouldRenderWebPage ? [{
  "@type": "WebPage",
  "@id": `${canonical.toString()}#webpage`,
  "url": canonical.toString(),
  "name": formattedTitle,
  "description": description,
  "inLanguage": "id-ID",
  "isPartOf": { "@id": `${siteURL}#website` },
  "about": type === "profile" ? { "@id": `${siteURL}#person` } : { "@id": `${siteURL}#organization` },
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": fullImageURL
  },
  "breadcrumb": {
    "@id": `${canonical.toString()}#breadcrumb`
  }
}] : [];

// Article
const articleSchema = type === "article" ? [{
  "@type": "BlogPosting",
  "@id": `${canonical.toString()}#article`,
  "name": title,
  "headline": title,
  "description": description,
  "url": canonical.toString(),
  "image": {
    "@type": "ImageObject",
    "url": fullImageURL,
    "width": 1200,
    "height": 630
  },
  "author": { "@id": `${siteURL}#person` },
  "publisher": { "@id": `${siteURL}#organization` },
  "mainEntityOfPage": {
    "@id": `${canonical.toString()}#webpage`
  },
  "datePublished": publishedTime?.toISOString(),
  "dateModified": modifiedTime?.toISOString() ?? publishedTime?.toISOString(),
  "keywords": tags.length ? tags.join(", ") : undefined,
  "articleSection": category
}] : [];

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    organizationSchema,
    personSchema,
    ...websiteSchema,
    ...webPageSchema,
    ...articleSchema
  ]
};
---

<!-- BASIC SEO -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>{formattedTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical.toString()} />

<!-- ROBOTS -->
{noIndex ? (
  <meta name="robots" content="noindex,nofollow" />
) : (
  <>
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow" />
  </>
)}

<!-- OPEN GRAPH -->
<meta property="og:type" content={type === "article" ? "article" : type === "profile" ? "profile" : "website"} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageURL} />
<meta property="og:image:secure_url" content={fullImageURL} />
<meta property="og:url" content={canonical.toString()} />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:locale" content="id_ID" />

<!-- TWITTER -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageURL} />
<meta name="twitter:site" content="@c0desk1" />
<meta name="twitter:creator" content={siteConfig.links?.twitter?.replace('https://twitter.com/', '@')} />

<!-- SOCIAL MEDIA -->
<meta name="pinterest-rich-pin" content="true" />

<!-- PERFORMANCE -->
<link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

<!-- STRUCTURED DATA -->
<script type="application/ld+json" set:html={JSON.stringify(graph)} />

<!-- VERIFICATION -->
<meta name="google-site-verification" content="ZxoHYWipAMoGhvwVi5nxolWsZOntrYkNkVcG9HTfFZQ" />
<meta name="google-adsense-account" content="ca-pub-4943136052113535">
<meta name="yandex-verification" content="1878480c0d7b5510" />