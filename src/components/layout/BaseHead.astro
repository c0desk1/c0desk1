---
// src/components/layout/BaseHead.astro
import { siteConfig } from "@/config/site";
import { getEntry } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile" | "creativeWork";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  category?: { name: string; description?: string; slug: string };
  author?: { name: string; role: string; avatar: string; bio: string; slug: string };
  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };
  organization?: any;
  client?: string;
  role?: string;
  duration?: string;
  demoUrl?: string;
  repoUrl?: string;
}

const {
  title: propsTitle,
  description: propsDescription,
  image: propsImage,
  seo,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  category,
  author,
  organization: orgFromProps,
  client,
  role: creativeWorkRole,
  duration,
  demoUrl,
  repoUrl,
} = Astro.props;

// ================= DATA SETTINGS =================
let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {
  console.warn('Settings not found, using siteConfig fallback');
}

const siteData = settings?.data || siteConfig;

// ================= DATA ORGANIZATION =================
let org;
if (orgFromProps) {
  org = { data: orgFromProps };
} else {
  try {
    org = await getEntry('organizations', 'c0desk1');
  } catch (error) {
    console.warn('Organization not found, proceeding without');
  }
}

const orgData = org?.data;

const siteURL = Astro.site?.toString() ?? siteData.siteUrl ?? siteConfig.siteUrl;

// ================= DYNAMIC DATA RESOLVER =================
const activeAuthor = {
  name: author?.name || siteData.siteName,
  role: author?.role || siteConfig.author?.title || "Content Creator",
  avatar: author?.avatar || siteData.siteLogo,
  bio: author?.bio || siteData.siteDescription,
  slug: author?.slug || "bima-akbar",
};

const seoData = {
  title: seo?.title || propsTitle || siteData.defaultSeo?.title || siteData.siteName,
  description: seo?.description || propsDescription || siteData.defaultSeo?.description || siteData.siteDescription,
  canonical: seo?.canonical 
    ? new URL(seo.canonical, siteURL) 
    : (Astro.props.canonicalURL ? new URL(Astro.props.canonicalURL, siteURL) : new URL(Astro.url.pathname, siteURL)),
  noIndex: seo?.noIndex ?? Astro.props.noIndex ?? false,
};

const formattedTitle = seoData.title === siteData.siteName 
  ? siteData.siteName 
  : `${seoData.title} — ${siteData.siteName}`;

let ogImageURL: string;
const rawImage = seo?.ogImage || propsImage?.src || siteData.defaultSeo?.ogImage || siteConfig.ogImage;
if (!rawImage) {
  ogImageURL = new URL(siteData.siteLogo, siteURL).toString();
} else {
  ogImageURL = rawImage.startsWith("http") ? rawImage : new URL(rawImage, siteURL).toString();
}

// ================= PAGE CONTEXT =================
const pathname = Astro.url.pathname;
const isHomepage = pathname === '/';

// ================= JSON-LD GRAPH =================
const schemaGraph: any[] = [];

if (orgData) {
  schemaGraph.push({
    "@type": "Organization",
    "@id": `${siteURL}#organization`,
    "name": orgData.name,
    "legalName": orgData.legalName,
    "url": orgData.url || siteURL,
    "logo": {
      "@type": "ImageObject",
      "@id": `${siteURL}#logo`,
      "url": new URL(orgData.logo, siteURL).toString(),
      "width": 512,
      "height": 512
    },
    "sameAs": Object.values(orgData.social || {}).filter(Boolean)
  });
} else if (siteData.siteName) {
  schemaGraph.push({
    "@type": "Organization",
    "@id": `${siteURL}#organization`,
    "name": siteData.siteName,
    "url": siteURL,
    "logo": {
      "@type": "ImageObject",
      "@id": `${siteURL}#logo`,
      "url": new URL(siteData.siteLogo, siteURL).toString(),
      "width": 512,
      "height": 512
    }
  });
}

// Person
schemaGraph.push({
  "@type": "Person",
  "@id": `${siteURL}#person`,
  "name": activeAuthor.name,
  "jobTitle": activeAuthor.role,
  "description": activeAuthor.bio,
  "image": activeAuthor.avatar,
  "url": new URL(`author/${activeAuthor.slug}/`, siteURL).toString(),
  ...(orgData || siteData.siteName ? { "worksFor": { "@id": `${siteURL}#organization` } } : {})
});

// Webpage
schemaGraph.push({
  "@type": "WebPage",
  "@id": `${seoData.canonical}#webpage`,
  "url": seoData.canonical.toString(),
  "name": formattedTitle,
  "description": seoData.description,
  "isPartOf": { "@id": `${siteURL}#website` },
  "breadcrumb": { "@id": `${seoData.canonical}#breadcrumb` },
  "inLanguage": "id-ID",
  "potentialAction": [{ "@type": "ReadAction", "target": [seoData.canonical.toString()] }]
});

// Website
if (isHomepage) {
  schemaGraph.push({
    "@type": "WebSite",
    "@id": `${siteURL}#website`,
    "url": siteURL,
    "name": siteData.siteName,
    "publisher": { "@id": `${siteURL}#organization` },
    "potentialAction": [{
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": `${siteURL}search?q={search_term_string}` },
      "query-input": "required name=search_term_string"
    }]
  });
}

// Breadcrumb
if (!isHomepage) {
  schemaGraph.push({
    "@type": "BreadcrumbList",
    "@id": `${seoData.canonical}#breadcrumb`,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteURL },
      category ? { "@type": "ListItem", "position": 2, "name": category.name, "item": new URL(`category/${category.slug}/`, siteURL).toString() } : null,
      { "@type": "ListItem", "position": category ? 3 : 2, "name": seoData.title, "item": seoData.canonical.toString() }
    ].filter(Boolean)
  });
}

// Articles
if (type === "article") {
  schemaGraph.push({
    "@type": "BlogPosting",
    "@id": `${seoData.canonical}#article`,
    "headline": seoData.title,
    "description": seoData.description,
    "author": { "@id": `${siteURL}#person` },
    "publisher": { "@id": `${siteURL}#organization` },
    "datePublished": publishedTime?.toISOString(),
    "dateModified": modifiedTime?.toISOString() || publishedTime?.toISOString(),
    "image": { "@type": "ImageObject", "@id": `${seoData.canonical}#primaryimage`, "url": ogImageURL, "width": 1200, "height": 630 },
    "mainEntityOfPage": { "@id": `${seoData.canonical}#webpage` },
    "articleSection": category?.name,
    "keywords": tags.join(", ")
  });
}

// Creative Work
if (type === "creativeWork") {
  schemaGraph.push({
    "@type": "CreativeWork",
    "@id": `${seoData.canonical}#creativework`,
    "url": seoData.canonical.toString(),
    "name": seoData.title,
    "headline": seoData.title,
    "description": seoData.description,
    "image": { "@type": "ImageObject", "url": ogImageURL },
    "dateCreated": publishedTime?.toISOString(),
    "dateModified": modifiedTime?.toISOString() || publishedTime?.toISOString(),
    "author": { "@id": `${siteURL}#person` },
    "creator": { "@id": `${siteURL}#person` },
    "publisher": { "@id": `${siteURL}#organization` },
    "keywords": tags.join(", "),
    "isPartOf": { "@id": `${siteURL}#website` },
    "mainEntityOfPage": { "@id": `${seoData.canonical}#webpage` },
    ...(client && { "client": { "@type": "Organization", "name": client } }),
    ...(creativeWorkRole && { "contributor": { "@id": `${siteURL}#person`, "roleName": creativeWorkRole } }),
    ...(duration && { "timeRequired": duration }),
    ...(demoUrl && { "workExample": { "@type": "WebSite", "url": demoUrl } }),
    ...(repoUrl && { "codeRepository": repoUrl })
  });
}

const twitterUsername = siteData.social?.twitter?.split('/').pop() || siteConfig.social?.twitter?.split('/').pop() || "@c0desk1";
---

<link rel="preconnect" href="https://c0desk1-api.dev-c0desk1.workers.dev" crossorigin />
<link rel="dns-prefetch" href="https://c0desk1-api.dev-c0desk1.workers.dev" />
<link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>{formattedTitle}</title>
<meta name="description" content={seoData.description} />
<meta name="author" content={activeAuthor.name} />

<link rel="canonical" href={seoData.canonical.toString()} />
<meta name="robots" content={seoData.noIndex ? "noindex,nofollow" : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"} />
<meta name="googlebot" content={seoData.noIndex ? "noindex,nofollow" : "index,follow"} />

<meta property="og:type" content={type === "article" ? "article" : "website"} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={seoData.description} />
<meta property="og:url" content={seoData.canonical.toString()} />
<meta property="og:site_name" content={siteData.siteName} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:secure_url" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="id_ID" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={seoData.description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:site" content={twitterUsername} />
<meta name="twitter:creator" content={twitterUsername} />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#38B66B" />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

<script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": schemaGraph })} />

{siteData.googleSiteVerification && (
  <meta name="google-site-verification" content={siteData.googleSiteVerification} />
)}
{siteData.googleAdsenseId && (
  <meta name="google-adsense-account" content={siteData.googleAdsenseId} />
)}
{siteData.yandexVerification && (
  <meta name="yandex-verification" content={siteData.yandexVerification} />
)}

{(() => {
  const analyticsId = siteData.googleAnalyticsId || siteConfig.googleAnalyticsId;
  if (analyticsId) {
    return (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${analyticsId}`}></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '{analyticsId}');
        </script>
      </>
    );
  }
})()}
