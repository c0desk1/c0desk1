---
// src/components/layout/BaseHead.astro
import { siteConfig } from "@/config/site";

interface Props {
  title?: string;
  description?: string;
  image?: any; // Menggunakan any karena bisa berupa ImageMetadata (objek) atau string
  canonicalURL?: URL | string;
  type?: "website" | "article";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const { 
  title, 
  description = siteConfig.description, 
  image,
  type = "website",
  noIndex = false,
  publishedTime,
  modifiedTime,
  tags = []
} = Astro.props;

const canonical = Astro.props.canonicalURL 
  ? new URL(Astro.props.canonicalURL, Astro.site ?? siteConfig.url)
  : new URL(Astro.url.pathname, Astro.site ?? siteConfig.url);

const formattedTitle = title ? `${title} | ${siteConfig.name}` : siteConfig.name;

let fullImageURL: string;

if (!image) {
  fullImageURL = new URL(siteConfig.ogImage, siteConfig.url).toString();
} else if (typeof image === 'string') {
  fullImageURL = image.startsWith('http') 
    ? image 
    : new URL(image, siteConfig.url).toString();
} else if (typeof image === 'object' && image.src) {
  fullImageURL = new URL(image.src, siteConfig.url).toString();
} else {
  fullImageURL = new URL(siteConfig.ogImage, siteConfig.url).toString();
}

const schema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "BlogPosting" : "WebSite",
  "name": formattedTitle,
  "description": description,
  "url": canonical.toString(),
  "author": {
    "@type": "Person",
    "name": siteConfig.author
  }
};

if (type === "article" && title) {
  schema.headline = title;
  if (publishedTime) schema.datePublished = publishedTime.toISOString();
  if (modifiedTime) schema.dateModified = modifiedTime.toISOString();
  if (tags.length > 0) schema.keywords = tags.join(", ");
  schema.image = fullImageURL;
}
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="mask-icon" href="/favicon.svg" color="#18181b" />
<meta name="generator" content={Astro.generator} />

<meta name="theme-color" content="#18181b" media="(prefers-color-scheme: dark)" />
<meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />

<link rel="canonical" href={canonical} />
{noIndex ? (
  <meta name="robots" content="noindex, nofollow" />
) : (
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
)}

<title>{formattedTitle}</title>
<meta name="title" content={formattedTitle} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />
<meta name="keywords" content={siteConfig.keywords.join(", ")} />

<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageURL} />
<meta property="og:image:alt" content={description} />
<meta property="og:site_name" content={siteConfig.name} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageURL} />
<meta name="twitter:image:alt" content={description} />

<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} - Blog`} href={`${Astro.site}rss.xml`} />

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

{type === 'website' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": siteConfig.name,
    "url": siteConfig.url,
    "logo": `${siteConfig.url}/favicon.svg`,
    "sameAs": [
      siteConfig.links?.github,
      siteConfig.links?.twitter,
    ].filter(Boolean)
  })} />
)}

<link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

