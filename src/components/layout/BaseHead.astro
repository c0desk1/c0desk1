---
// src/components/layout/BaseHead.astro

import { siteConfig } from "@/config/site";
// import Analytics from "./Analytics.astro";
// import Ads from "./Ads.astro";

interface Props {
  title?: string;
  description?: string;
  image?: any;
  canonicalURL?: URL | string;
  type?: "website" | "article";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const {
  title,
  description = siteConfig.description,
  image,
  type = "website",
  noIndex = false,
  publishedTime,
  modifiedTime,
  tags = []
} = Astro.props;

const siteURL = Astro.site ?? siteConfig.url;

const canonical = Astro.props.canonicalURL
  ? new URL(Astro.props.canonicalURL, siteURL)
  : new URL(Astro.url.pathname, siteURL);

const formattedTitle =
  title && title !== siteConfig.name
    ? `${title} | ${siteConfig.name}`
    : siteConfig.name;

// ================= IMAGE =================
let fullImageURL: string;

if (!image) {
  fullImageURL = new URL(siteConfig.ogImage, siteURL).toString();
} else if (typeof image === "string") {
  fullImageURL = image.startsWith("http")
    ? image
    : new URL(image, siteURL).toString();
} else if (typeof image?.src === "string") {
  fullImageURL = new URL(image.src, siteURL).toString();
} else {
  fullImageURL = new URL(siteConfig.ogImage, siteURL).toString();
}

const lastModified =
  modifiedTime?.toISOString() ?? publishedTime?.toISOString();

// ================= SEO GRAPH =================
const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteURL}#website`,
      "url": siteURL,
      "name": siteConfig.name,
      "description": siteConfig.description,
      "inLanguage": "id-ID",
      "publisher": { "@id": `${siteURL}#organization` },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteURL}search?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": `${siteURL}#organization`,
      "name": siteConfig.name,
      "url": siteURL,
      logo: {
  		"@type": "ImageObject",
  		"url": new URL("/favicon.svg", siteURL).toString(),
  		"width": 512,
  		"height": 512
		},
      "sameAs": [
        siteConfig.social?.github,
        siteConfig.social?.twitter,
        siteConfig.social?.linkedin,
      ].filter(Boolean)
    },
    {
      "@type": "Person",
      "@id": `${siteURL}#person`,
      "name": siteConfig.author.name,
      "url": `${siteURL}/author/${siteConfig.author.slug}/`,
      "image": {
        "@type": "ImageObject",
        "url": `${siteURL}${siteConfig.author.avatar}`,
        "width": 96,
        "height": 96
      },
      "worksFor": { "@id": `${siteURL}#organization` }
    },
    {
      "@type": "WebPage",
      "@id": `${canonical.toString()}#webpage`,
      "url": canonical.toString(),
      "name": formattedTitle,
      "description": description,
      "inLanguage": "id-ID",
      "isPartOf": { "@id": `${siteURL}#website` },
      "about": { "@id": `${siteURL}#organization` },
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": fullImageURL
      },
      "breadcrumb": {
        "@id": `${canonical.toString()}#breadcrumb`
      }
    },
    ...(type === "article" ? [
      {
        "@type": "BlogPosting",
        "@id": `${canonical.toString()}#article`,
        "name": title,
        "headline": title,
        "description": description,
        "url": canonical.toString(),
        "image": {
          "@type": "ImageObject",
          "url": fullImageURL,
          "width": 1200,
          "height": 630
        },
        "author": { "@id": `${siteURL}#person` },
        "publisher": { "@id": `${siteURL}#organization` },
        "mainEntityOfPage": {
          "@id": `${canonical.toString()}#webpage`
        },
        "datePublished": publishedTime?.toISOString(),
        "dateModified": lastModified,
        "keywords": tags.length ? tags.join(", ") : undefined
      }
    ] : [])
  ]
};
---

<!-- BASIC SEO -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>{formattedTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical.toString()} />

<!-- ROBOTS -->
{noIndex ? (
  <meta name="robots" content="noindex,nofollow" />
) : (
  <>
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow" />
  </>
)}

<!-- OPEN GRAPH -->
<meta property="og:type" content={type} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageURL} />
<meta property="og:image:secure_url" content={fullImageURL} />
<meta property="og:url" content={canonical.toString()} />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:locale" content="id_ID" />

<!-- TWITTER -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageURL} />
<meta name="twitter:creator" content={siteConfig.links?.twitter?.replace('https://twitter.com/', '@')} />

<!-- PERFORMANCE -->
<link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

<!-- STRUCTURED DATA -->
<script type="application/ld+json" set:html={JSON.stringify(graph)} />

<!-- VERIFICATION -->
<meta name="google-site-verification" content="ZxoHYWipAMoGhvwVi5nxolWsZOntrYkNkVcG9HTfFZQ" />
<meta name="google-adsense-account" content="ca-pub-4943136052113535">
<meta name="yandex-verification" content="1878480c0d7b5510" />

