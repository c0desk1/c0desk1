---
// src/components/layout/BaseHead.astro
import { siteConfig } from "@/config/site";

interface Props {
  title?: string;
  description?: string;
  image?: any;
  canonicalURL?: URL | string;
  type?: "website" | "article";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const { 
  title, 
  description = siteConfig.description, 
  image,
  type = "website",
  noIndex = false,
  publishedTime,
  modifiedTime,
  tags = []
} = Astro.props;

const canonical = Astro.props.canonicalURL 
  ? new URL(Astro.props.canonicalURL, Astro.site ?? siteConfig.url)
  : new URL(Astro.url.pathname, Astro.site ?? siteConfig.url);

const formattedTitle = title && title !== siteConfig.name 
  ? `${title} | ${siteConfig.name}` 
  : siteConfig.name;

let fullImageURL: string;

if (!image) {
  fullImageURL = new URL(siteConfig.ogImage, siteConfig.url).toString();
} else if (typeof image === 'string') {
  fullImageURL = image.startsWith('http') 
    ? image 
    : new URL(image, siteConfig.url).toString();
} else if (typeof image === 'object' && image.src) {
  fullImageURL = new URL(image.src, siteConfig.url).toString();
} else {
  fullImageURL = new URL(siteConfig.ogImage, siteConfig.url).toString();
}

const schema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "BlogPosting" : "WebSite",
  "name": formattedTitle,
  "description": description,
  "url": canonical.toString(),
  "author": {
    "@type": "Person",
    "name": siteConfig.author
  }
};

if (type === "article" && title) {
  schema.headline = title;
  schema.mainEntityOfPage = { 
    "@type": "WebPage", 
    "@id": canonical.toString() 
  };
  schema.publisher = {
    "@type": "Organization",
    "name": siteConfig.name,
    "logo": { 
      "@type": "ImageObject", 
      "url": `${siteConfig.url}/favicon.svg` 
    }
  };
  if (publishedTime) schema.datePublished = publishedTime.toISOString();
  if (modifiedTime) schema.dateModified = modifiedTime.toISOString();
  if (tags.length > 0) schema.keywords = tags.join(", ");
  schema.image = fullImageURL;
}

if (type === "website") {
  schema.potentialAction = {
    "@type": "SearchAction",
    "target": `${siteConfig.url}/search?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  };
}
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="manifest" href="/site.webmanifest" />

<link rel="mask-icon" href="/favicon.svg" color="#18181b" />
<meta name="generator" content={Astro.generator} />

<meta name="theme-color" content="#18181b" media="(prefers-color-scheme: dark)" />
<meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />

<link rel="canonical" href={canonical.toString()} />

{noIndex ? (
  <meta name="robots" content="noindex, nofollow" />
) : (
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
)}

<title>{formattedTitle}</title>
<meta name="title" content={formattedTitle} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />

{siteConfig.keywords?.length > 0 && (
  <meta name="keywords" content={siteConfig.keywords.join(", ")} />
)}

<meta property="og:type" content={type} />
<meta property="og:url" content={canonical.toString()} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={description} />
<meta property="og:image:type" content="image/webp" />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:locale" content="id_ID" />

{type === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{type === "article" && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime.toISOString()} />
)}
{type === "article" && (
  <meta property="article:author" content={siteConfig.author} />
)}
{type === "article" && tags.map(tag => (
  <meta property="article:tag" content={tag} />
))}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical.toString()} />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageURL} />
<meta name="twitter:image:alt" content={description} />
<meta name="twitter:site" content={siteConfig.links?.twitter} />

<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} - Blog`} href={new URL('/rss.xml', Astro.site ?? siteConfig.url)} />

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

{type === 'website' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": siteConfig.name,
    "url": siteConfig.url,
    "logo": `${siteConfig.url}/favicon.svg`,
    "sameAs": [
      siteConfig.links?.github,
      siteConfig.links?.twitter,
    ].filter(Boolean)
  })} />
)}

<link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
<link rel="preconnect" href="https://www.google-analytics.com" crossorigin>
<link rel="preconnect" href="https://mc.yandex.ru" crossorigin>

