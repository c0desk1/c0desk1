---
// src/components/layout/BaseHead.astro

import { siteConfig } from "@/config/site";
import { getEntry } from "astro:content";
import { getCurrentLocale, getLabel } from "@/utils/i18n";

type Locale = "id" | "en" | "ru";
type LocaleMap = { id: string; en: string; ru: string };
type PartialLocaleMap = { id?: string; en?: string; ru?: string };

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile" | "creativeWork";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];

  category?: {
    name: LocaleMap;
    description?: PartialLocaleMap;
    slug: string;
  };

  author?: {
    name: string;
    role: string;
    avatar: string;
    bio: string;
    slug: string;
  };

  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };

  organization?: any;
  client?: string;
  role?: string;
  duration?: string;
  demoUrl?: string;
  repoUrl?: string;
  siteData?: any;
  alternateSlugs?: Record<string, string>;
  basePath?: 'blog' | 'portfolio' | 'legal' | '';
}

const locale = getCurrentLocale(Astro) as Locale;

const {
  title: propsTitle,
  description: propsDescription,
  image: propsImage,
  seo,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  category,
  author,
  organization: orgFromProps,
  client,
  role: creativeWorkRole,
  duration,
  demoUrl,
  repoUrl,
  siteData: siteDataFromProps,
  alternateSlugs,
  basePath= '',
} = Astro.props;

function toBcp47(lang: string): string {
  if (lang === "id") return "id-ID";
  if (lang === "en") return "en-US";
  if (lang === "ru") return "ru-RU";
  return lang;
}

function toOgLocale(lang: string): string {
  return toBcp47(lang).replace("-", "_");
}

function t(map: PartialLocaleMap | LocaleMap): string {
  return map[locale] ?? (map as LocaleMap).en ?? (map as LocaleMap).id ?? "";
}

const htmlLang  = toBcp47(locale);

const homeLabel = getLabel(locale, "home") ?? "Home";
const blogLabel = getLabel(locale, "blog") ?? "Blog";
const portfolioLabel = getLabel(locale, "portfolio") ?? "Portfolio";

const contentCreatorLabel = getLabel(locale, "contentCreator") ?? "Content Creator";

const siteData = siteDataFromProps ?? siteConfig;

let org: { data: any } | undefined;
if (orgFromProps) {
  org = { data: orgFromProps };
} else {
  try {
    const entry = await getEntry("organizations", "c0desk1");
    if (entry) org = { data: entry.data };
  } catch {
  }
}
const orgData = org?.data;

const rawSiteURL = Astro.site?.toString() ?? siteConfig.siteUrl;
const siteURL    = rawSiteURL.endsWith("/") ? rawSiteURL : `${rawSiteURL}/`;

const currentPath       = Astro.url.pathname;
const localePattern     = new RegExp(`^\\/(${siteConfig.locales.join("|")})`);
const pathWithoutLocale = currentPath.replace(localePattern, "") || "/";

const hreflangLinks = (siteConfig.locales as string[]).map((lang) => {
  const langSlug = alternateSlugs?.[lang];
  const path     = langSlug ?? pathWithoutLocale;
  const href     =
    lang === siteConfig.defaultLocale
      ? new URL(path, siteURL).toString()
      : new URL(`/${lang}${path}`, siteURL).toString();
  return { lang: toBcp47(lang), href };
});

const xDefaultHref = new URL(pathWithoutLocale, siteURL).toString();

const authorBioResolved: string =
  author?.bio ??
  (siteConfig.author?.bio ? t(siteConfig.author.bio as PartialLocaleMap) : "");

const activeAuthor = {
  name:   author?.name   ?? siteConfig.author?.name   ?? siteConfig.siteName,
  role:   author?.role   ?? siteConfig.author?.title  ?? contentCreatorLabel,
  avatar: author?.avatar ?? siteConfig.author?.avatar ?? siteConfig.siteLogo,
  bio:    authorBioResolved,
  slug:   author?.slug   ?? siteConfig.author?.slug   ?? "bima-akbar",
};

// siteConfig.defaultSeo = { id: { title, description }, en: {...}, ru: {...} }
const localeSeo = (siteConfig.defaultSeo as Record<string, { title?: string; description?: string }>)?.[locale];

const seoResolved = {
  title:
    seo?.title ??
    propsTitle ??
    localeSeo?.title ??
    siteConfig.siteName,

  description:
    seo?.description ??
    propsDescription ??
    localeSeo?.description ??
    authorBioResolved,

  canonical: seo?.canonical
    ? new URL(seo.canonical, siteURL)
    : Astro.props.canonicalURL
    ? new URL(Astro.props.canonicalURL, siteURL)
    : new URL(Astro.url.pathname, siteURL),

  noIndex: seo?.noIndex ?? Astro.props.noIndex ?? false,
};

const formattedTitle =
  seoResolved.title === siteConfig.siteName
    ? siteConfig.siteName
    : `${seoResolved.title} — ${siteConfig.siteName}`;

const rawImage = seo?.ogImage ?? propsImage?.src ?? siteConfig.ogImage;
const ogImageURL: string = !rawImage
  ? new URL(siteConfig.siteLogo, siteURL).toString()
  : rawImage.startsWith("http")
  ? rawImage
  : new URL(rawImage, siteURL).toString();

const categoryName: string | undefined = category ? t(category.name) : undefined;

const pathname = Astro.url.pathname;
const localeRootPattern = new RegExp(
  `^\\/(${siteConfig.locales.join("|")})\\/?$`
);
const isHomepage = pathname === "/" || localeRootPattern.test(pathname);

const datePublished = publishedTime?.toISOString();
const dateModified  = modifiedTime?.toISOString() ?? datePublished;

const twitterHandle = (() => {
  const tw = Array.isArray(siteConfig.social)
    ? siteConfig.social.find((s: { label: string; href: string }) => s.label === "twitter")
    : null;
  return tw ? `@${tw.href.split("/").pop()}` : "@c0desk1";
})();

const schemaGraph: any[] = [];

// 1. Organization
if (orgData) {
  schemaGraph.push({
    "@type":   "Organization",
    "@id":     `${siteURL}#organization`,
    name:      orgData.name,
    legalName: orgData.legalName,
    url:       orgData.url ?? siteURL,
    logo: {
      "@type": "ImageObject",
      "@id":   `${siteURL}#logo`,
      url:     new URL(orgData.logo, siteURL).toString(),
      width:   512,
      height:  512,
    },
    sameAs: Object.values(orgData.social ?? {}).filter(Boolean),
  });
} else {
  schemaGraph.push({
    "@type": "Organization",
    "@id":   `${siteURL}#organization`,
    name:    siteConfig.siteName,
    url:     siteURL,
    logo: {
      "@type": "ImageObject",
      "@id":   `${siteURL}#logo`,
      url:     new URL(siteConfig.siteLogo, siteURL).toString(),
      width:   512,
      height:  512,
    },
  });
}

// 2. WebSite
schemaGraph.push({
  "@type":   "WebSite",
  "@id":     `${siteURL}#website`,
  url:       siteURL,
  name:      siteConfig.siteName,
  publisher: { "@id": `${siteURL}#organization` },
  potentialAction: [
    {
      "@type": "SearchAction",
      target: {
        "@type":      "EntryPoint",
        urlTemplate: `${siteURL}search?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  ],
});

// 3. Person
schemaGraph.push({
  "@type":     "Person",
  "@id":       `${siteURL}#person`,
  name:        activeAuthor.name,
  jobTitle:    activeAuthor.role,
  description: activeAuthor.bio,
  image: {
    "@type": "ImageObject",
    url:     activeAuthor.avatar.startsWith("http")
               ? activeAuthor.avatar
               : new URL(activeAuthor.avatar, siteURL).toString(),
    width:   400,
    height:  400,
  },
  url:      new URL(`author/${activeAuthor.slug}/`, siteURL).toString(),
  worksFor: { "@id": `${siteURL}#organization` },
});

// 4. WebPage
schemaGraph.push({
  "@type":      "WebPage",
  "@id":        `${seoResolved.canonical}#webpage`,
  url:          seoResolved.canonical.toString(),
  name:         formattedTitle,
  description:  seoResolved.description,
  isPartOf:     { "@id": `${siteURL}#website` },
  ...(!isHomepage && { breadcrumb: { "@id": `${seoResolved.canonical}#breadcrumb` } }),
  inLanguage:   htmlLang,
  ...(datePublished && { datePublished }),
  ...(dateModified  && { dateModified }),
  potentialAction: [{ "@type": "ReadAction", target: [seoResolved.canonical.toString()] }],
});

// 5. BreadcrumbList — non-homepage only
if (!isHomepage) {
  const breadcrumbItems: any[] = [
    { "@type": "ListItem", position: 1, name: homeLabel, item: siteURL },
  ];

  if (basePath === "blog") {
    breadcrumbItems.push({
      "@type": "ListItem",
      position: breadcrumbItems.length + 1,
      name: blogLabel,
      item: new URL("blog/", siteURL).toString(),
    });
  }

  if (type === "creativeWork" && basePath === "portfolio") {
    breadcrumbItems.push({
      "@type": "ListItem",
      position: breadcrumbItems.length + 1,
      name: portfolioLabel,
      item: new URL("portfolio/", siteURL).toString(),
    });
  }

  if (category && categoryName) {
    breadcrumbItems.push({
      "@type": "ListItem",
      position: breadcrumbItems.length + 1,
      name: categoryName,
      item: new URL(`category/${category.slug}/`, siteURL).toString(),
    });
  }

  breadcrumbItems.push({
    "@type": "ListItem",
    position: breadcrumbItems.length + 1,
    name: seoResolved.title,
    item: seoResolved.canonical.toString(),
  });

  schemaGraph.push({
    "@type": "BreadcrumbList",
    "@id": `${seoResolved.canonical}#breadcrumb`,
    itemListElement: breadcrumbItems,
  });
}

// 6. BlogPosting
if (type === "article") {
  schemaGraph.push({
    "@type":       "BlogPosting",
    "@id":         `${seoResolved.canonical}#article`,
    headline:      seoResolved.title,
    description:   seoResolved.description,
    author:        { "@id": `${siteURL}#person` },
    publisher:     { "@id": `${siteURL}#organization` },
    datePublished,
    dateModified,
    image: {
      "@type": "ImageObject",
      "@id":   `${seoResolved.canonical}#primaryimage`,
      url:     ogImageURL,
      width:   1200,
      height:  630,
    },
    mainEntityOfPage: { "@id": `${seoResolved.canonical}#webpage` },
    articleSection:   categoryName,
    keywords:         tags.join(", "),
    inLanguage:       htmlLang,
  });
}

// 7. SoftwareSourceCode / CreativeWork
if (type === "creativeWork") {
  const baseWork = {
    url:         seoResolved.canonical.toString(),
    name:        seoResolved.title,
    headline:    seoResolved.title,
    description: seoResolved.description,
    image:       { "@type": "ImageObject", url: ogImageURL },
    ...(datePublished    && { dateCreated:  datePublished }),
    ...(dateModified     && { dateModified }),
    author:           { "@id": `${siteURL}#person` },
    creator:          { "@id": `${siteURL}#person` },
    publisher:        { "@id": `${siteURL}#organization` },
    keywords:         tags.join(", "),
    isPartOf:         { "@id": `${siteURL}#website` },
    mainEntityOfPage: { "@id": `${seoResolved.canonical}#webpage` },
    inLanguage:       htmlLang,
    ...(client           && { provider:    { "@type": "Organization", name: client } }),
    ...(creativeWorkRole && { contributor: { "@id": `${siteURL}#person`, roleName: creativeWorkRole } }),
    ...(duration         && { timeRequired: duration }),
    ...(demoUrl          && { workExample:  { "@type": "WebSite", url: demoUrl } }),
  };

  schemaGraph.push(
    repoUrl
      ? { "@type": "SoftwareSourceCode", "@id": `${seoResolved.canonical}#creativework`, codeRepository: repoUrl, ...baseWork }
      : { "@type": "CreativeWork",        "@id": `${seoResolved.canonical}#creativework`, ...baseWork }
  );
}
---

<link rel="preconnect" href="https://api.c0desk1.my.id" crossorigin />
<link rel="dns-prefetch" href="https://api.c0desk1.my.id" />
<link rel="preconnect" href="https://cdn.c0desk1.my.id" crossorigin />
<link rel="dns-prefetch" href="https://cdn.c0desk1.my.id" />

<!-- Yandex RTB + Metrica -->
<link rel="dns-prefetch" href="https://yandex.ru" />
<link rel="dns-prefetch" href="https://mc.yandex.ru" />
<link rel="dns-prefetch" href="https://an.yandex.ru" />

<link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin />

<meta name="generator" content={Astro.generator} />

<title>{formattedTitle}</title>
<meta name="description" content={seoResolved.description} />
<meta name="author"      content={activeAuthor.name} />

<link rel="canonical" href={seoResolved.canonical.toString()} />

<meta
  name="robots"
  content={seoResolved.noIndex
    ? "noindex,nofollow"
    : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"}
/>
<meta
  name="googlebot"
  content={seoResolved.noIndex ? "noindex,nofollow" : "index,follow"}
/>

<meta property="og:type"             content={type === "article" ? "article" : "website"} />
<meta property="og:title"            content={formattedTitle} />
<meta property="og:description"      content={seoResolved.description} />
<meta property="og:url"              content={seoResolved.canonical.toString()} />
<meta property="og:site_name"        content={siteConfig.siteName} />
<meta property="og:image"            content={ogImageURL} />
<meta property="og:image:alt"        content={propsImage?.alt ?? formattedTitle} />
<meta property="og:image:secure_url" content={ogImageURL} />
<meta property="og:image:width"      content="1200" />
<meta property="og:image:height"     content="630" />
<meta property="og:locale"           content={toOgLocale(locale)} />
<meta name="google"                  content="notranslate" />

{(siteConfig.locales as string[])
  .filter((l) => l !== locale)
  .map((l) => (
    <meta property="og:locale:alternate" content={toOgLocale(l)} />
  ))}

{type === "article" && tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}
{type === "article" && datePublished && (
  <meta property="article:published_time" content={datePublished} />
)}
{type === "article" && dateModified && (
  <meta property="article:modified_time" content={dateModified} />
)}
{type === "article" && categoryName && (
  <meta property="article:section" content={categoryName} />
)}

<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={formattedTitle} />
<meta name="twitter:description" content={seoResolved.description} />
<meta name="twitter:image"       content={ogImageURL} />
<meta name="twitter:site"        content={twitterHandle} />
<meta name="twitter:creator"     content={twitterHandle} />

<link rel="icon"             href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest"         href="/site.webmanifest" />

<meta name="color-scheme"                          content="light dark" />
<meta name="theme-color"                           content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color"                           content="#000000" media="(prefers-color-scheme: dark)" />
<meta name="mobile-web-app-capable"                content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

<script
  type="application/ld+json"
  set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": schemaGraph })}
/>

{siteConfig.googleSiteVerification && (
  <meta name="google-site-verification" content={siteConfig.googleSiteVerification} />
)}
{siteConfig.googleAdsenseId && (
  <meta name="google-adsense-account" content={siteConfig.googleAdsenseId} />
)}
{siteConfig.yandexVerification && (
  <meta name="yandex-verification" content={siteConfig.yandexVerification} />
)}

{hreflangLinks.map(({ lang, href }: { lang: string; href: string }) => (
  <link rel="alternate" hreflang={lang} href={href} />
))}
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />