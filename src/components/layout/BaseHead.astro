---
// src/components/layout/BaseHead.astro

import { siteConfig } from "@/config/site";
import { getEntry } from "astro:content";
import { getCurrentLocale, getLabel } from "@/utils/i18n";

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile" | "creativeWork";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  category?: { name: string; description?: string; slug: string };
  author?: { name: string; role: string; avatar: string; bio: string; slug: string };
  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };
  organization?: any;
  client?: string;
  role?: string;
  duration?: string;
  demoUrl?: string;
  repoUrl?: string;
  siteData?: any;
  alternateSlugs?: Record<string, string>;
}

const locale = getCurrentLocale(Astro);

const {
  title: propsTitle,
  description: propsDescription,
  image: propsImage,
  seo,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  category,
  author,
  organization: orgFromProps,
  client,
  role: creativeWorkRole,
  duration,
  demoUrl,
  repoUrl,
  siteData: siteDataFromProps,
  alternateSlugs,
} = Astro.props;

// ─── LOCALISATION ────────────────────────────────────────────────────────────
function toBcp47(lang: string): string {
  if (lang === "id") return "id-ID";
  if (lang === "en") return "en-US";
  if (lang === "ru") return "ru-RU";
  return lang;
}

// Map locale code → underscore form required by Open Graph
function toOgLocale(lang: string): string {
  return toBcp47(lang).replace("-", "_");
}

const htmlLang = toBcp47(locale);

const contentCreatorLabel = getLabel(locale, "contentCreator") || "Content Creator";
const homeLabel           = getLabel(locale, "home") || "Home";

// ─── SITE DATA ────────────────────────────────────────────────────────────────
const siteData = siteDataFromProps || siteConfig;

// ─── ORGANISATION ─────────────────────────────────────────────────────────────
let org: { data: any } | undefined;
if (orgFromProps) {
  org = { data: orgFromProps };
} else {
  try {
    const entry = await getEntry("organizations", "c0desk1");
    if (entry) org = { data: entry.data };
  } catch {
    // Organisation collection absent — degrade gracefully
  }
}

const orgData = org?.data;

// ─── URLS ─────────────────────────────────────────────────────────────────────
const rawSiteURL = Astro.site?.toString() ?? siteData.siteUrl ?? siteConfig.siteUrl;
const siteURL    = rawSiteURL.endsWith("/") ? rawSiteURL : `${rawSiteURL}/`;

// ─── HREFLANG ────────────────────────────────────────────────────────────────
const currentPath       = Astro.url.pathname;
const localePattern     = new RegExp(`^\\/(${siteConfig.locales.join("|")})`);
const pathWithoutLocale = currentPath.replace(localePattern, "") || "/";

const hreflangLinks = (siteConfig.locales as string[]).map((lang) => {
  const langSlug = alternateSlugs?.[lang];
  const path     = langSlug ?? pathWithoutLocale;

  const href =
    lang === siteConfig.defaultLocale
      ? new URL(path, siteURL).toString()
      : new URL(`/${lang}${path}`, siteURL).toString();

  return { lang: toBcp47(lang), href };
});

const xDefaultHref = new URL(pathWithoutLocale, siteURL).toString();

// ─── AUTHOR ───────────────────────────────────────────────────────────────────
const activeAuthor = {
  name:   author?.name   || siteData.siteName,
  role:   author?.role   || siteConfig.author?.title || contentCreatorLabel,
  avatar: author?.avatar || siteData.siteLogo,
  bio:    author?.bio    || siteData.siteDescription,
  slug:   author?.slug   || "bima-akbar",
};

// ─── SEO CORE ─────────────────────────────────────────────────────────────────
const seoData = {
  title: seo?.title || propsTitle || siteData.defaultSeo?.title || siteData.siteName,
  description:
    seo?.description ||
    propsDescription ||
    siteData.defaultSeo?.description ||
    siteData.siteDescription,
  canonical: seo?.canonical
    ? new URL(seo.canonical, siteURL)
    : Astro.props.canonicalURL
    ? new URL(Astro.props.canonicalURL, siteURL)
    : new URL(Astro.url.pathname, siteURL),
  noIndex: seo?.noIndex ?? Astro.props.noIndex ?? false,
};

const formattedTitle =
  seoData.title === siteData.siteName
    ? siteData.siteName
    : `${seoData.title} — ${siteData.siteName}`;

// ─── OG IMAGE ────────────────────────────────────────────────────────────────
const rawImage = seo?.ogImage || propsImage?.src || siteData.defaultSeo?.ogImage || siteConfig.ogImage;
const ogImageURL: string = !rawImage
  ? new URL(siteData.siteLogo, siteURL).toString()
  : rawImage.startsWith("http")
  ? rawImage
  : new URL(rawImage, siteURL).toString();

// ─── PAGE CONTEXT ─────────────────────────────────────────────────────────────
const pathname   = Astro.url.pathname;
const isHomepage = pathname === "/";

// ─── DATES ───────────────────────────────────────────────────────────────────
const datePublished = publishedTime?.toISOString();
const dateModified  = modifiedTime?.toISOString() || publishedTime?.toISOString();

// ─── JSON-LD GRAPH ────────────────────────────────────────────────────────────
const schemaGraph: any[] = [];

// 1. Organization
if (orgData) {
  schemaGraph.push({
    "@type":     "Organization",
    "@id":       `${siteURL}#organization`,
    name:        orgData.name,
    legalName:   orgData.legalName,
    url:         orgData.url || siteURL,
    logo: {
      "@type":  "ImageObject",
      "@id":    `${siteURL}#logo`,
      url:      new URL(orgData.logo, siteURL).toString(),
      width:    512,
      height:   512,
    },
    sameAs: Object.values(orgData.social || {}).filter(Boolean),
  });
} else {
  schemaGraph.push({
    "@type": "Organization",
    "@id":   `${siteURL}#organization`,
    name:    siteData.siteName,
    url:     siteURL,
    logo: {
      "@type":  "ImageObject",
      "@id":    `${siteURL}#logo`,
      url:      new URL(siteData.siteLogo, siteURL).toString(),
      width:    512,
      height:   512,
    },
  });
}

// 2. WebSite
schemaGraph.push({
  "@type": "WebSite",
  "@id":   `${siteURL}#website`,
  url:     siteURL,
  name:    siteData.siteName,
  publisher: { "@id": `${siteURL}#organization` },
  potentialAction: [
    {
      "@type": "SearchAction",
      // FIX: siteURL already has trailing slash, so no slash needed before "search"
      target: {
        "@type":      "EntryPoint",
        urlTemplate: `${siteURL}search?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  ],
});

// 3. Person
schemaGraph.push({
  "@type":       "Person",
  "@id":         `${siteURL}#person`,
  name:          activeAuthor.name,
  jobTitle:      activeAuthor.role,
  description:   activeAuthor.bio,
  image: {
    "@type": "ImageObject",
    url:     activeAuthor.avatar.startsWith("http")
               ? activeAuthor.avatar
               : new URL(activeAuthor.avatar, siteURL).toString(),
    width:  400,
    height: 400,
  },
  url:      new URL(`author/${activeAuthor.slug}/`, siteURL).toString(),
  worksFor: { "@id": `${siteURL}#organization` },
});

// 4. WebPage
schemaGraph.push({
  "@type":       "WebPage",
  "@id":         `${seoData.canonical}#webpage`,
  url:           seoData.canonical.toString(),
  name:          formattedTitle,
  description:   seoData.description,
  isPartOf:      { "@id": `${siteURL}#website` },
  ...(!isHomepage && { breadcrumb: { "@id": `${seoData.canonical}#breadcrumb` } }),
  inLanguage:    htmlLang,
  ...(datePublished && { datePublished }),
  ...(dateModified  && { dateModified }),
  potentialAction: [{ "@type": "ReadAction", target: [seoData.canonical.toString()] }],
});

// 5. BreadcrumbList (non-homepage only)
if (!isHomepage) {
  const breadcrumbItems: any[] = [
    { "@type": "ListItem", position: 1, name: homeLabel, item: siteURL },
  ];

  if (category) {
    breadcrumbItems.push({
      "@type":   "ListItem",
      position:  2,
      name:      category.name,
      item:      new URL(`category/${category.slug}/`, siteURL).toString(),
    });
  }

  breadcrumbItems.push({
    "@type":   "ListItem",
    position:  category ? 3 : 2,
    name:      seoData.title,
    item:      seoData.canonical.toString(),
  });

  schemaGraph.push({
    "@type":           "BreadcrumbList",
    "@id":             `${seoData.canonical}#breadcrumb`,
    itemListElement:   breadcrumbItems,
  });
}

// 6. BlogPosting (article pages)
if (type === "article") {
  schemaGraph.push({
    "@type":       "BlogPosting",
    "@id":         `${seoData.canonical}#article`,
    headline:      seoData.title,
    description:   seoData.description,
    author:        { "@id": `${siteURL}#person` },
    publisher:     { "@id": `${siteURL}#organization` },
    datePublished,
    dateModified,
    image: {
      "@type":  "ImageObject",
      "@id":    `${seoData.canonical}#primaryimage`,
      url:      ogImageURL,
      width:    1200,
      height:   630,
    },
    mainEntityOfPage: { "@id": `${seoData.canonical}#webpage` },
    articleSection:   category?.name,
    keywords:         tags.join(", "),
    inLanguage:       htmlLang,
  });
}

// 7. SoftwareSourceCode / CreativeWork
if (type === "creativeWork") {
  const baseWork = {
    url:         seoData.canonical.toString(),
    name:        seoData.title,
    headline:    seoData.title,
    description: seoData.description,
    image:       { "@type": "ImageObject", url: ogImageURL },
    ...(datePublished && { dateCreated: datePublished }),
    ...(dateModified  && { dateModified }),
    author:            { "@id": `${siteURL}#person` },
    creator:           { "@id": `${siteURL}#person` },
    publisher:         { "@id": `${siteURL}#organization` },
    keywords:          tags.join(", "),
    isPartOf:          { "@id": `${siteURL}#website` },
    mainEntityOfPage:  { "@id": `${seoData.canonical}#webpage` },
    inLanguage:        htmlLang,
    ...(client && { provider: { "@type": "Organization", name: client } }),
    ...(creativeWorkRole && {
      contributor: { "@id": `${siteURL}#person`, roleName: creativeWorkRole },
    }),
    ...(duration && { timeRequired: duration }),
    ...(demoUrl  && { workExample: { "@type": "WebSite", url: demoUrl } }),
  };

  if (repoUrl) {
    // FIX: codeRepository belongs to SoftwareSourceCode, not CreativeWork
    schemaGraph.push({
      "@type":          "SoftwareSourceCode",
      "@id":            `${seoData.canonical}#creativework`,
      codeRepository:   repoUrl,
      ...baseWork,
    });
  } else {
    schemaGraph.push({
      "@type": "CreativeWork",
      "@id":   `${seoData.canonical}#creativework`,
      ...baseWork,
    });
  }
}

// ─── TWITTER HANDLE ───────────────────────────────────────────────────────────
const twitterHandle = siteData.social?.twitter
  ? `@${siteData.social.twitter.split("/").pop()}`
  : "@c0desk1";
---

<!-- ═══════════════════════════════════════════════════════════
     PRECONNECT & DNS PREFETCH
     ═══════════════════════════════════════════════════════════ -->
<link rel="preconnect" href="https://api.c0desk1.my.id" crossorigin />
<link rel="dns-prefetch" href="https://api.c0desk1.my.id" />

<link rel="preconnect" href="https://cdn.c0desk1.my.id" crossorigin />
<link rel="dns-prefetch" href="https://cdn.c0desk1.my.id" />

<!-- Yandex RTB + Metrica -->
<link rel="dns-prefetch" href="https://yandex.ru" />
<link rel="dns-prefetch" href="https://mc.yandex.ru" />
<link rel="dns-prefetch" href="https://an.yandex.ru" />

<!-- ═══════════════════════════════════════════════════════════
     FONT PRELOAD
     ═══════════════════════════════════════════════════════════ -->
<link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin />

<!-- ═══════════════════════════════════════════════════════════
     CORE META
     ═══════════════════════════════════════════════════════════ -->
<meta name="generator" content={Astro.generator} />

<title>{formattedTitle}</title>
<meta name="description" content={seoData.description} />
<meta name="author" content={activeAuthor.name} />

<link rel="canonical" href={seoData.canonical.toString()} />

<meta
  name="robots"
  content={seoData.noIndex
    ? "noindex,nofollow"
    : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"}
/>
<meta
  name="googlebot"
  content={seoData.noIndex ? "noindex,nofollow" : "index,follow"}
/>

<!-- ═══════════════════════════════════════════════════════════
     OPEN GRAPH
     ═══════════════════════════════════════════════════════════ -->
<meta property="og:type"              content={type === "article" ? "article" : "website"} />
<meta property="og:title"             content={formattedTitle} />
<meta property="og:description"       content={seoData.description} />
<meta property="og:url"               content={seoData.canonical.toString()} />
<meta property="og:site_name"         content={siteData.siteName} />
<meta property="og:image"             content={ogImageURL} />
<meta property="og:image:alt"         content={propsImage?.alt || formattedTitle} />
<meta property="og:image:secure_url"  content={ogImageURL} />
<meta property="og:image:width"       content="1200" />
<meta property="og:image:height"      content="630" />
<meta property="og:locale"            content={toOgLocale(locale)} />
<meta name="google"                   content="notranslate" />

{(siteConfig.locales as string[])
  .filter((l) => l !== locale)
  .map((l) => (
    <meta property="og:locale:alternate" content={toOgLocale(l)} />
  ))}

<!-- Article-specific OG -->
{type === "article" && tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}
{type === "article" && datePublished && (
  <meta property="article:published_time" content={datePublished} />
)}
{type === "article" && dateModified && (
  <meta property="article:modified_time" content={dateModified} />
)}
{type === "article" && category && (
  <meta property="article:section" content={category.name} />
)}

<!-- ═══════════════════════════════════════════════════════════
     TWITTER / X CARD
     ═══════════════════════════════════════════════════════════ -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={formattedTitle} />
<meta name="twitter:description" content={seoData.description} />
<meta name="twitter:image"       content={ogImageURL} />
<meta name="twitter:site"        content={twitterHandle} />
<meta name="twitter:creator"     content={twitterHandle} />

<!-- ═══════════════════════════════════════════════════════════
     ICONS & MANIFEST
     ═══════════════════════════════════════════════════════════ -->
<link rel="icon"             href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest"         href="/site.webmanifest" />

<!-- ═══════════════════════════════════════════════════════════
     THEME & PWA
     ═══════════════════════════════════════════════════════════ -->
<meta name="color-scheme"                        content="light dark" />
<meta name="theme-color"                         content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color"                         content="#000000" media="(prefers-color-scheme: dark)" />
<meta name="mobile-web-app-capable"              content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

<!-- ═══════════════════════════════════════════════════════════
     JSON-LD STRUCTURED DATA
     ═══════════════════════════════════════════════════════════ -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": schemaGraph })}
/>

<!-- ═══════════════════════════════════════════════════════════
     VERIFICATIONS & AD ACCOUNTS
     ═══════════════════════════════════════════════════════════ -->
{siteData.googleSiteVerification && (
  <meta name="google-site-verification" content={siteData.googleSiteVerification} />
)}
{siteData.googleAdsenseId && (
  <meta name="google-adsense-account" content={siteData.googleAdsenseId} />
)}
{siteData.yandexVerification && (
  <meta name="yandex-verification" content={siteData.yandexVerification} />
)}

<!-- ═══════════════════════════════════════════════════════════
     HREFLANG — SEO MULTILINGUAL
     ═══════════════════════════════════════════════════════════ -->
{hreflangLinks.map(({ lang, href }: { lang: string; href: string }) => (
  <link rel="alternate" hreflang={lang} href={href} />
))}
<link rel="alternate" hreflang="x-default" href={xDefaultHref} />