---
// src/components/layout/BaseHead.astro
import { siteConfig } from "@/config/site";
import { Font } from "astro:assets";

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt: string };
  canonicalURL?: URL | string;
  type?: "website" | "article" | "profile" | "creativeWork";
  noIndex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  lang?: string;
  category?: {
    name: string;
    description?: string;
    slug: string;
  };
  author?: {
    name: string;
    role: string;
    avatar: string;
    bio: string;
    slug: string;
  };
  seo?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    noIndex?: boolean;
  };
  client?: string;
  role?: string;
  duration?: string;
  demoUrl?: string;
  repoUrl?: string;
  siteData?: any;
  basePath?: 'blog' | 'portfolio' | 'legal' | 'blog/category' | 'author' | '';
}

const {
  title: propsTitle,
  description: propsDescription,
  image: propsImage,
  seo,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  lang = "en",
  category,
  author,
  client,
  role: creativeWorkRole,
  duration,
  demoUrl,
  repoUrl,
  basePath = '',
} = Astro.props;

// ─── Helpers

const rawSiteURL = Astro.site?.toString() ?? siteConfig.siteUrl;
const siteURL = rawSiteURL.endsWith("/") ? rawSiteURL.slice(0, -1) : rawSiteURL;
const seoResolved = {
  title:
    seo?.title ??
    propsTitle ??
    siteConfig.defaultSeo.title ??
    siteConfig.siteName,
  description:
    seo?.description ??
    propsDescription ??
    siteConfig.defaultSeo.description ??
    "",
  canonical: seo?.canonical
    ? new URL(seo.canonical, siteURL)
    : Astro.props.canonicalURL
    ? new URL(Astro.props.canonicalURL, siteURL)
    : new URL(Astro.url.pathname, siteURL),
  noIndex: seo?.noIndex ?? Astro.props.noIndex ?? false,
};

const formattedTitle =
  seoResolved.title === siteConfig.siteName
    ? siteConfig.siteName
    : `${seoResolved.title} — ${siteConfig.siteName}`;

const rawImage = seo?.ogImage ?? propsImage?.src ?? siteConfig.ogImage;
const ogImageURL: string = !rawImage
  ? new URL(siteConfig.siteLogo, siteURL).toString()
  : rawImage.startsWith("http")
  ? rawImage
  : new URL(rawImage, siteURL).toString();

const authorConfig = siteConfig.author;
const activeAuthor = {
  name: author?.name ?? authorConfig.name,
  role: author?.role ?? authorConfig.role,
  avatar: author?.avatar ?? authorConfig.avatar,
  bio: author?.bio ?? authorConfig.bio,
  slug: author?.slug ?? authorConfig.slug,
};

const isHomepage = Astro.url.pathname === "/";
const isTimedContent = type === "article" || type === "creativeWork";
const datePublished = isTimedContent ? publishedTime?.toISOString() : undefined;
const dateModified = isTimedContent
  ? (modifiedTime?.toISOString() ?? datePublished)
  : undefined;

const twitterHandle = "@c0desk1";

const schemaGraph: any[] = [];

// 1. Organization
schemaGraph.push({
  "@type": "Organization",
  "@id": `${siteURL}/#organization`,
  name: siteConfig.siteName,
  url: siteURL,
  logo: {
    "@type": "ImageObject",
    "@id": `${siteURL}/#logo`,
    url: new URL(siteConfig.siteLogo, siteURL).toString(),
    width: 512,
    height: 512,
  },
});

// 2. WebSite
schemaGraph.push({
  "@type": "WebSite",
  "@id": `${siteURL}/#website`,
  url: siteURL,
  name: siteConfig.siteName,
  publisher: { "@id": `${siteURL}/#organization` },
  potentialAction: [
    {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${siteURL}/search?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  ],
});

// 3. Person
schemaGraph.push({
  "@type": "Person",
  "@id": `${siteURL}/#person`,
  name: activeAuthor.name,
  jobTitle: activeAuthor.role,
  description: activeAuthor.bio,
  image: {
    "@type": "ImageObject",
    url: activeAuthor.avatar.startsWith("http")
      ? activeAuthor.avatar
      : new URL(activeAuthor.avatar, siteURL).toString(),
    width: 400,
    height: 400,
  },
  url: new URL(`author/${activeAuthor.slug}`, siteURL).toString(),
  worksFor: { "@id": `${siteURL}/#organization` },
});

// 4. WebPage
schemaGraph.push({
  "@type": "WebPage",
  "@id": `${seoResolved.canonical}#webpage`,
  url: seoResolved.canonical.toString(),
  name: formattedTitle,
  description: seoResolved.description,
  isPartOf: { "@id": `${siteURL}/#website` },
  ...(!isHomepage && { breadcrumb: { "@id": `${seoResolved.canonical}#breadcrumb` } }),
  inLanguage: lang,
  ...(datePublished && { datePublished }),
  ...(dateModified && { dateModified }),
  potentialAction: [{ "@type": "ReadAction", target: [seoResolved.canonical.toString()] }],
});

// 5. BreadcrumbList (non-homepage only)
if (!isHomepage) {
  const breadcrumbItems: any[] = [
    { "@type": "ListItem", position: 1, name: "Home", item: siteURL },
  ];

  if (basePath === "blog" || basePath === "blog/category") {
    breadcrumbItems.push({
      "@type": "ListItem",
      position: breadcrumbItems.length + 1,
      name: "Blog",
      item: new URL("blog", siteURL).toString(),
    });
  }

  if (basePath === "portfolio") {
    breadcrumbItems.push({
      "@type": "ListItem",
      position: breadcrumbItems.length + 1,
      name: "Portfolio",
      item: new URL("portfolio", siteURL).toString(),
    });
  }

  if (basePath === "author") {
    breadcrumbItems.push({
      "@type": "ListItem",
      position: breadcrumbItems.length + 1,
      name: "Authors",
      item: new URL("author", siteURL).toString(),
    });
  }

  if (basePath === "blog" && category?.name) {
    breadcrumbItems.push({
      "@type": "ListItem",
      position: breadcrumbItems.length + 1,
      name: category.name,
      item: new URL(`blog/category/${category.slug}`, siteURL).toString(),
    });
  }

  breadcrumbItems.push({
    "@type": "ListItem",
    position: breadcrumbItems.length + 1,
    name: seoResolved.title,
    item: seoResolved.canonical.toString(),
  });

  schemaGraph.push({
    "@type": "BreadcrumbList",
    "@id": `${seoResolved.canonical}#breadcrumb`,
    itemListElement: breadcrumbItems,
  });
}

// 6. BlogPosting
if (type === "article") {
  schemaGraph.push({
    "@type": "BlogPosting",
    "@id": `${seoResolved.canonical}#article`,
    headline: seoResolved.title,
    description: seoResolved.description,
    author: { "@id": `${siteURL}/#person` },
    publisher: { "@id": `${siteURL}/#organization` },
    datePublished,
    dateModified,
    image: {
      "@type": "ImageObject",
      "@id": `${seoResolved.canonical}#primaryimage`,
      url: ogImageURL,
      width: 1200,
      height: 630,
    },
    mainEntityOfPage: { "@id": `${seoResolved.canonical}#webpage` },
    articleSection: category?.name,
    keywords: tags.join(", "),
    inLanguage: lang,
  });
}

// 7. SoftwareSourceCode / CreativeWork
if (type === "creativeWork") {
  const baseWork = {
    url: seoResolved.canonical.toString(),
    name: seoResolved.title,
    headline: seoResolved.title,
    description: seoResolved.description,
    image: { "@type": "ImageObject", url: ogImageURL },
    ...(datePublished && { dateCreated: datePublished }),
    ...(dateModified && { dateModified }),
    author: { "@id": `${siteURL}/#person` },
    creator: { "@id": `${siteURL}/#person` },
    publisher: { "@id": `${siteURL}/#organization` },
    keywords: tags.join(", "),
    isPartOf: { "@id": `${siteURL}/#website` },
    mainEntityOfPage: { "@id": `${seoResolved.canonical}#webpage` },
    inLanguage: lang,
    ...(client && { provider: { "@type": "Organization", name: client } }),
    ...(creativeWorkRole && {
      contributor: {
        "@type": "Role",
        roleName: creativeWorkRole,
        person: { "@id": `${siteURL}/#person` },
      },
    }),
    ...(duration && { timeRequired: duration }),
    ...(demoUrl && { workExample: { "@type": "WebSite", url: demoUrl } }),
  };

  schemaGraph.push(
    repoUrl
      ? { "@type": "SoftwareSourceCode", "@id": `${seoResolved.canonical}#creativework`, codeRepository: repoUrl, ...baseWork }
      : { "@type": "CreativeWork", "@id": `${seoResolved.canonical}#creativework`, ...baseWork }
  );
}
---
<Font cssVariable="--font-GeistSans" preload />
<Font cssVariable="--font-GeistMono" preload />

<link rel="preconnect" href="https://api.c0desk1.my.id" crossorigin />
<link rel="preconnect" href="https://cdn.c0desk1.my.id" crossorigin />

<link rel="dns-prefetch" href="https://yandex.ru" />
<link rel="dns-prefetch" href="https://mc.yandex.ru" />
<link rel="dns-prefetch" href="https://an.yandex.ru" />

<meta name="generator" content={Astro.generator} />

<title>{formattedTitle}</title>
<meta name="description" content={seoResolved.description} />
<meta name="author" content={activeAuthor.name} />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<meta name="color-scheme" content="light dark" />
<meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={formattedTitle} href={new URL("rss.xml", Astro.site)}/>
<link rel="manifest" href="/site.webmanifest" />
<link rel="canonical" href={seoResolved.canonical.toString()} />

<meta name="robots" content={seoResolved.noIndex ? "noindex,nofollow" : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"} />

<meta property="og:type" content={type === "article" ? "article" : "website"} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={seoResolved.description} />
<meta property="og:url" content={seoResolved.canonical.toString()} />
<meta property="og:site_name" content={siteConfig.siteName} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:alt" content={propsImage?.alt ?? formattedTitle} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={lang === "id" ? "id_ID" : "en_US"} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={seoResolved.description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:creator" content={twitterHandle} />

{type === "article" && tags.map((tag) => (<meta property="article:tag" content={tag} />))}
{type === "article" && datePublished && (<meta property="article:published_time" content={datePublished} />)}
{type === "article" && dateModified && (<meta property="article:modified_time" content={dateModified} />)}
{type === "article" && category?.name && (<meta property="article:section" content={category.name} />)}

{siteConfig.googleSiteVerification && (<meta name="google-site-verification" content={siteConfig.googleSiteVerification} />)}
{siteConfig.googleAdsenseId && (<meta name="google-adsense-account" content={siteConfig.googleAdsenseId} />)}
{siteConfig.yandexVerification && (<meta name="yandex-verification" content={siteConfig.yandexVerification} />)}

<script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": schemaGraph })} />
