---
// src/components/layout/Footer.astro
import { siteConfig } from "@/config/site";
import { getEntry } from "astro:content";

import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import StatusPanel from "../layout/StatusPanel.astro";
import Newsletter from "../layout/Newsletter.astro";

let settings;
try {
  settings = await getEntry("settings", "site");
} catch {
  console.warn("Settings not found, menggunakan siteConfig fallback");
}

const siteData = settings?.data || siteConfig;
const footerSections = siteData.footerSections || siteConfig.footerSections;
---

<footer class="border-t border-(--border) bg-(--bg) relative overflow-hidden">
  <Section size="sm">
    <Container size="full">
      <div class="w-full justify-between grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-10 lg:gap-16 mb-8">

        <div class="flex items-start justify-center lg:justify-start lg:border-r lg:border-(--border) lg:pr-16">
          <Newsletter />
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-x-4 gap-y-8 py-4 md:py-0 border-t border-(--border) lg:border-none">
          {footerSections.map((section) => (
            <div class="flex flex-col gap-3">
              <span class="text-[14px] font-semibold text-(--fg) uppercase tracking-wide">
                {section.title}
              </span>
              <ul class="flex flex-col gap-1.5">
                {section.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      target={item.isExternal ? "_blank" : undefined}
                      rel={item.isExternal ? "noopener noreferrer" : undefined}
                      class="text-[13px] text-(--fg-muted) hover:text-(--fg) transition-colors inline-flex items-center gap-1 group"
                    >
                      {item.label}
                      {item.isExternal && (
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                          stroke="currentColor" stroke-width="2.5"
                          class="opacity-0 group-hover:opacity-100 transition-opacity">
                          <path d="M7 7h10v10M7 17L17 7"/>
                        </svg>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        

      </div>

      <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-6 border-t border-(--border)">
        <div class="flex items-center gap-4">
          <a
            href="#top"
            class="w-8 h-8 flex items-center justify-center rounded-md border border-(--border) text-(--fg-muted) hover:text-(--fg) hover:border-(--border-strong) transition-all active:scale-90"
            aria-label="Kembali ke atas"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 19V5M5 12l7-7 7 7"/>
            </svg>
          </a>
          <p class="text-[13px] text-(--fg-muted) tracking-tight">
            © {new Date().getFullYear()} {siteData.siteName}. All rights reserved.
          </p>
        </div>
        <button
          id="status-toggle"
          class="group flex items-center gap-2.5 px-3 py-1.5 rounded-md border border-(--border) bg-(--bg-muted) hover:border-(--border-strong) transition-all active:scale-95"
        >
          <span class="relative flex h-2 w-2">
            <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-zinc-400 opacity-75"></span>
            <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-zinc-400"></span>
          </span>
          <span id="status-label" class="text-[13px] font-medium text-(--fg-muted) group-hover:text-(--fg) transition-colors">
            Memuat Sistem...
          </span>
        </button>
      </div>
    </Container>
  </Section>
  <StatusPanel />
</footer>

<style is:global>
  #status-label { text-transform: capitalize; }

  @media (max-width: 1023px) {
    .nls-wrap {
      border-bottom: 1px solid var(--border);
      padding-bottom: 2.5rem;
      width: 100%;
    }
  }

  .nls-wrap { border-top: none; }
</style>
