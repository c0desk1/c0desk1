---
// src/components/layout/Footer.astro

import { siteConfig } from "@/config/site";
import Container from "../ui/Container.astro";
---

<footer class="border-t border-black/20 dark:border-white/5 bg-white dark:bg-black">
  <Container size="md" class="mx-auto my-6">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-2 text-[13px] text-zinc-500 dark:text-zinc-500">
      <div class="flex items-center gap-2">
        <span>© {new Date().getFullYear()} {siteConfig.name}</span>
      </div>
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center hover:text-emerald-500" aria-label="Home">
          <span class="text-black dark:text-white font-bold">▼</span>
        </a>
      </div>
    </div>
  </Container>
</footer>