---
// src/components/layout/Footer.astro
import { siteConfig } from "@/config/site";
import { getEntry } from "astro:content";

import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import StatusPanel from "../layout/StatusPanel.astro";

let settings;
try {
  settings = await getEntry("settings", "site");
} catch {
  console.warn("Settings not found, menggunakan siteConfig fallback");
}

const siteData = settings?.data || siteConfig;

const footerSections = siteData.footerSections || siteConfig.footerSections;
---

<footer class="border-t border-zinc-100 dark:border-zinc-900 bg-white dark:bg-black relative overflow-hidden">
  <Section size="sm" class="py-8 md:py-12">
    <Container size="lg">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-8 mb-8">
        {footerSections.map((section) => (
          <div class="flex flex-col gap-3">
            <span class="text-[13px] font-semibold text-black dark:text-white uppercase">
              {section.title}
            </span>
            <ul class="flex flex-col gap-1.5">
              {section.items.map((item) => (
                <li>
                  <a 
                    href={item.href}
                    target={item.isExternal ? "_blank" : undefined}
                    rel={item.isExternal ? "noopener noreferrer" : undefined}
                    class="text-[13px] text-zinc-500 dark:text-zinc-400 hover:text-emerald-600 dark:hover:text-white transition-colors inline-flex items-center gap-1 group"
                  >
                    {item.label}
                    {item.isExternal && (
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="opacity-0 group-hover:opacity-100 transition-opacity">
                        <path d="M7 7h10v10M7 17L17 7"/>
                      </svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="flex flex-col md:flex-row items-center justify-between gap-6 pt-6 border-t border-zinc-50 dark:border-zinc-900/50">     
        <div class="flex items-center gap-4">
          <a href="#top" class="w-8 h-8 flex items-center justify-center rounded-md border border-zinc-100 dark:border-zinc-900 text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-all active:scale-90" aria-label="Back to top">
            <span class="text-[13px]">▼</span>
          </a>
          <div class="text-[13px] font-medium text-zinc-500 dark:text-zinc-400 tracking-tight">
            © {new Date().getFullYear()} {siteData.siteName}
          </div>
        </div>
        <button id="status-toggle" class="group flex items-center gap-2.5 px-3 py-1.5 rounded-md border border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-900/50 hover:border-zinc-300 dark:hover:border-zinc-700 transition-all active:scale-95">
          <span class="relative flex h-2 w-2">
            <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-zinc-400 opacity-75"></span>
            <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-zinc-400"></span>
          </span>
          <span id="status-label" class="text-[12px] font-medium text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-100 transition-colors">
            Memuat Sistem...
          </span>
        </button>
      </div>
    </Container>
  </Section>
  <StatusPanel />
</footer>

<style is:global>
  #status-label {
    text-transform: capitalize;
  }
</style>