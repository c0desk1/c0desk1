---
// src/components/layout/Footer.astro
import { Image } from "astro:assets";
import { siteConfig } from "@/config/site";

import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import Icon from "@/components/ui/Icon";
import ThemeToggle from "../ui/ThemeToggle.astro";

const siteData = siteConfig;
const footerSections = siteConfig.footerSections;
---

<footer class="relative border-t border-(--border) bg-(--bg)">
  <Section size="sm">
    <Container size="xl">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_280px] gap-12 py-10">
        <nav
          aria-label={siteData.footerNav || "Footer navigation"}
          class="grid grid-cols-2 gap-8 sm:grid-cols-4">
          {footerSections.map((section) => (
            <div class="min-w-0">
              <p class="text-label-mono-13 uppercase text-strong mb-3">
                {section.title}
              </p>
              <ul class="flex flex-col gap-2">
                {section.items.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      target={link.isExternal ? "_blank" : undefined}
                      rel={link.isExternal ? "noopener noreferrer" : undefined}
                      class="group inline-flex items-center gap-1 text-copy-14 text-muted transition-colors duration-150 hover:text-(--fg)">
                      {link.label}
                      {link.isExternal && (
                        <Icon
                          name="external"
                          className="h-3 w-3 shrink-0 opacity-40 transition-opacity duration-150 group-hover:opacity-100"
                        />
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
        <div class="flex flex-col gap-5 md:border-l md:border-(--border) md:pl-12">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 flex items-center justify-center shrink-0">
              <Image
                src={siteData.siteLogo}
                alt={siteData.siteName}
                width={48}
                height={48}
                loading="lazy"
                fetchpriority="low"
                class="w-8 h-8 object-contain"
              />
            </div>
            <p class="text-heading-20 lg:text-heading-24 text-(--fg) font-semibold text-balance">{siteData.siteName}</p>
          </div>
          <p class="text-copy-14 text-muted text-pretty">
            {siteData.defaultSeo?.description ?? "A creative portal for the age of automation."}
          </p>
        </div>
      </div>
    </Container>
  </Section>
  
  <div class="border-t border-(--border)">
    <Container size="xl">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-4">
        <div class="flex flex-wrap gap-4 items-center justify-center text-center sm:text-left">
          <p class="text-copy-13 text-muted">
            &copy; {new Date().getFullYear()} {siteData.siteName}
          </p>
        </div>
        <ThemeToggle />
      </div>
    </Container>
  </div>
</footer>
