---
// src/components/layout/Footer.astro

import { siteConfig } from "@/config/site";
import { getEntry } from "astro:content";

import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";

import Icon from "@/components/ui/Icon";

import StatusPanel from "../layout/StatusPanel.astro";
import Newsletter from "../layout/Newsletter.astro";
import StatusButton from "../ui/StatusButton.astro";

let settings;

try {
  settings = await getEntry("settings", "site");
} catch {
  console.warn("Settings not found, menggunakan siteConfig fallback");
}

const siteData = settings?.data || siteConfig;

const footerSections =
  siteData.footerSections || siteConfig.footerSections;

const social = siteData.social ?? {};

const year = new Date().getFullYear();

const socialEntries = Object.entries(social).filter(([_, url]) => url);
---

<footer class="relative border-t border-(--border)/60 bg-(--bg)">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-[0.025]">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,var(--border)_1px,transparent_1px),linear-gradient(to_bottom,var(--border)_1px,transparent_1px)] bg-size-[28px_28px]" />
  </div>
  <Section size="none">
    <div class="flex items-center border-b border-dashed border-(--border)/60 py-6">
      <Container size="xl">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
          <div class="flex w-full flex-col gap-5 lg:max-w-sm">
            <Newsletter />
          </div>
          <div class="grid w-full gap-x-10 gap-y-8 sm:grid-cols-2 lg:max-w-3xl lg:grid-cols-4">
            {footerSections.map((section) => (
              <div class="min-w-0">
                <div class="mb-3 flex items-center gap-2 text-[13px] md:text-sm font-semibold uppercase tracking-[0.18em] text-(--fg)">
                  <span class="truncate">
                    {section.title}
                  </span>
                </div>
                <ul class="space-y-1">
                  {section.items.map((link) => (
                    <li>
                      <a href={link.href} target={link.isExternal ? "_blank" : undefined} rel={link.isExternal ? "noopener noreferrer" : undefined} class="group flex items-center justify-between gap-3 py-1.5 text-sm text-(--fg-muted) transition-colors hover:text-(--fg)">
                        <span class="truncate">
                          {link.label}
                        </span>
                        {link.isExternal && (
                          <Icon name="external" className="size-3 shrink-0 opacity-0 transition-opacity group-hover:opacity-100" />
                        )}
                      </a>
                    </li>
                  ))}
                 </ul>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </div>
    <Container size="xl">
      <div class="flex flex-col gap-3 py-4 md:flex-row md:items-center md:justify-between">
        <div class="flex flex-wrap items-center gap-1.5">
          {socialEntries.map(([platform, url]) => (
            <a href={url} target="_blank" rel="noopener noreferrer" aria-label={platform} class="flex size-6 items-center justify-center rounded-(--radius-full) text-(--fg-muted) transition-all hover:bg-(--bg-muted) hover:text-(--fg)">
              <Icon name={platform as any} className="size-4" />
            </a>
          ))}
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <div class="flex items-center gap-3 text-sm text-(--fg-muted)">
            <span>
              © {year} {siteData.siteName}
            </span>
          </div>
          <StatusButton />
        </div>
      </div>
    </Container>
  </Section>
  <StatusPanel />
</footer>
