---
// src/components/layout/Footer.astro
import { siteConfig } from "@/config/site";

import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import Icon from "@/components/ui/Icon";
import ThemeToggle from "../ui/ThemeToggle.astro";
import SocialLinks from "../ui/SocialLinks.astro";

const siteData = siteConfig;
const social = siteConfig.social;

const footerSections = siteConfig.footerSections;
---

<footer class="relative border-t border-(--border) bg-(--bg)">
  <Section size="sm">
    <Section size="sm">
      <Container size="xl">
        <div class="flex flex-col items-start gap-8 md:flex-row md:justify-between">
          <nav aria-label={siteData.footerNav} class="grid w-full grid-cols-2 gap-x-6 gap-y-8 md:grid-cols-4 md:gap-x-8 md:gap-y-6">
            {footerSections.map((section) => (
              <div class="min-w-0">
                <p class="text-label-mono-13 mb-2 uppercase text-(--fg)">{section.title}</p>
                <ul class="flex flex-col gap-2">
                  {section.items.map((link) => (
                    <li>
                      <a href={link.href} target={link.isExternal ? "_blank" : undefined} rel={link.isExternal ? "noopener noreferrer" : undefined} class="text-copy-14 inline-flex items-center gap-1 text-muted transition-colors duration-150 hover:text-(--fg)">
                        {link.label}
                        {link.isExternal && (<Icon name="external" className="h-3 w-3 shrink-0 opacity-50 transition-opacity duration-150 group-hover:opacity-100"/>)}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </nav>
        </div>
      </Container> 
    </Section>
    <Section size="sm">
      <Container size="xl">
        <div class="flex items-center justify-between gap-4">
          <SocialLinks items={social} class="flex items-center gap-0.5" iconClass="h-4 w-4 block"/>
          <ThemeToggle />
        </div>
      </Container>
    </Section>
  </Section>
</footer>