---
// src/components/layout/Footer.astro

import { siteConfig } from "@/config/site";
import Container from "../ui/Container.astro";
---

<footer class="border-t border-zinc-100 dark:border-zinc-900 bg-white dark:bg-zinc-950">
  <Container size="md" class="mx-auto py-10">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-3 text-sm font-mono text-zinc-500 dark:text-zinc-500">
      <div class="flex items-center gap-2">
        <span>© {new Date().getFullYear()} {siteConfig.name}</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-zinc-400">▼</span>
        <span>Astro-powered</span>
      </div>
    </div>
  </Container>
</footer>