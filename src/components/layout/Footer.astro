---
// src/components/layout/Footer.astro
import { siteConfig } from "@/config/site";
import { getEntry } from "astro:content";
import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import StatusPanel from "../layout/StatusPanel.astro";

let settings;
try {
  settings = await getEntry("settings", "site");
} catch {
  console.warn("Settings not found, using fallback");
}

const siteData = settings?.data || siteConfig;
const footerSections = siteData.footerSections || [];
---

<footer class="border-t border-zinc-100 dark:border-zinc-900 bg-white dark:bg-black relative overflow-hidden">
  <Section size="sm">
    <Container size="lg">
      <!-- 1. Link Grid (Navigasi, Legal, Social) -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
        {footerSections.map((section) => (
          <div class="flex flex-col gap-4">
            <span class="text-[13px] font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight">
              {section.title}
            </span>
            <ul class="flex flex-col gap-2">
              {section.items.map((item) => (
                <li>
                  <a 
                    href={item.href}
                    target={item.isExternal ? "_blank" : undefined}
                    rel={item.isExternal ? "noopener noreferrer" : undefined}
                    class="text-[13px] font-medium text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- 2. Bottom Bar (Copyright & Status) -->
      <div class="grid grid-cols-1 md:grid-cols-3 items-center gap-6 border-t border-zinc-50 dark:border-zinc-900/50 pt-8">
        <div class="flex items-center justify-center md:justify-start gap-3">
          <a href="#top" class="text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition" aria-label="Back to top">
            <span class="text-[10px]">▲</span>
          </a>
          <div class="text-[13px] font-medium text-zinc-500 dark:text-zinc-400 tracking-tight">
            © {new Date().getFullYear()} {siteData.siteName}
          </div>
        </div>

        <div class="flex items-center justify-center gap-4"><a
            href="https://webmaster.yandex.ru/siteinfo/?site=https://c0desk1.my.id"
            target="_blank"
            class="hidden grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all"
          >
            <img
              src="https://yandex.ru/cycounter?https://c0desk1.my.id&theme=dark&lang=en"
              alt="Yandex"
              class="h-5 w-auto rounded-md"
              loading="lazy"
            />
          </a>
        </div>

        <div class="flex items-center justify-center md:justify-end">
          <button
            id="status-toggle"
            class="group flex items-center gap-2.5 px-3 py-1.5 rounded-full border border-zinc-100 dark:border-zinc-900 hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-all active:scale-95"
          >
            <span class="relative flex h-2 w-2">
              <span id="status-pulse" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-zinc-400 opacity-75"></span>
              <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-zinc-400"></span>
            </span>
            <span id="status-label" class="text-[12px] font-medium text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-100 transition-colors">
              Loading Systems...
            </span>
          </button>
        </div>
      </div>
    </Container>
  </Section>
  <StatusPanel />
</footer>

<style is:global>
  #status-label {
    text-transform: capitalize;
  }
</style>
