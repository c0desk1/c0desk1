---
// src/components/layout/Footer.astro

import { siteConfig } from "@/config/site";
import { getEntry } from "astro:content";

import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";

import Icon from "@/components/ui/Icon";

import StatusPanel from "../layout/StatusPanel.astro";
import Newsletter from "../layout/Newsletter.astro";
import StatusButton from "../ui/StatusButton.astro";

let settings;

try {
  settings = await getEntry("settings", "site");
} catch {
  console.warn("Settings not found, menggunakan siteConfig fallback");
}

const siteData = settings?.data || siteConfig;

const footerSections = siteData.footerSections || siteConfig.footerSections;

const social = siteData.social || siteConfig.social;

const year = new Date().getFullYear();
---

<footer class="relative border-t border-(--border)/60 bg-(--bg)">
  <Section size="none">
    <div class="flex items-center border-b border-dashed border-(--border)/60 py-6">
      <Container size="xl">
        <div class="flex flex-col-reverse md:flex-row items-start md:items-center justify-self-start md:justify-between w-full gap-6">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {footerSections.map((section) => (
              <div class="min-w-0">
                <div class="mb-3 flex items-center text-[13px] font-semibold uppercase tracking-[0.18em] text-(--fg)">
                  <span class="truncate">
                    {section.title}
                  </span>
                </div>
                <ul class="space-y-1">
                  {section.items.map((link) => (
                    <li>
                      <a href={link.href} target={link.isExternal ? "_blank" : undefined} rel={link.isExternal ? "noopener noreferrer" : undefined} class="group flex items-center py-1 text-[13px] md:text-sm text-(--fg-muted) transition-colors hover:text-(--fg) gap-2">
                        {link.label}
                        {link.isExternal && (
                          <Icon name="external" className="size-3 shrink-0 opacity-0 transition-opacity group-hover:opacity-100" />
                        )}
                      </a>
                    </li>
                  ))}
                 </ul>
              </div>
            ))}
          </div>
          <div class="flex items-center">
            <Newsletter />
          </div>
        </div>
      </Container>
    </div>
    <Container size="xl">
      <div class="flex flex-col gap-3 py-4 md:flex-row md:items-center md:justify-between">
        <div class="flex flex-wrap items-center gap-2">
           {social.map((item: { href: string; label: string }) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={item.label}
              class="flex size-6 items-center justify-center rounded-(--radius-full) text-(--fg-muted) transition-all hover:bg-(--bg-muted) hover:text-(--fg)"
            >
              <Icon name={item.label as any} className="size-4" />
            </a>
          ))}
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <div class="flex items-center gap-3 text-sm text-(--fg-muted)">
            <span>
              © {year} {siteData.siteName}
            </span>
          </div>
          <StatusButton />
        </div>
      </div>
    </Container>
  </Section>
  <StatusPanel />
</footer>
