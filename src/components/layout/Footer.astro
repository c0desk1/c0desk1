---
// src/components/layout/Footer.astro
import { siteConfig } from "@/config/site";
import { getEntry } from 'astro:content';
import Container from "../ui/Container.astro";

let settings;
try {
  settings = await getEntry('settings', 'site');
} catch (error) {
  console.warn('Settings not found, using siteConfig fallback');
}
const siteData = settings?.data || siteConfig;
---

<footer class="border-t border-black/10 dark:border-white/10 bg-white dark:bg-black">
  <Container size="lg">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 py-6 text-[13px] text-zinc-500 dark:text-zinc-400">
      
      <!-- Left -->
      <div class="flex items-center gap-2">
        <span>
          © {new Date().getFullYear()} {siteData.siteName}
        </span>
      </div>

      <!-- Right -->
      <div class="flex items-center gap-4">

        <!-- Yandex Badge -->
        <a 
          href="https://webmaster.yandex.ru/siteinfo/?site=https://c0desk1.my.id"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block opacity-70 hover:opacity-100 transition"
          aria-label="Yandex Site Quality Index"
        >
          <img 
            src="https://yandex.ru/cycounter?https://c0desk1.my.id&theme=dark&lang=en"
            width="88"
            height="31"
            alt="Yandex SQI"
            class="rounded-full"
            loading="lazy"
          />
        </a>

        <!-- Back to top -->
        <a
          href="/"
          class="inline-flex items-center justify-center text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors duration-150"
          aria-label="Home"
        >
          <span class="text-sm">
            ▲
          </span>
        </a>
      </div>
    </div>
  </Container>
</footer>