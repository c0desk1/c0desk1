---
// src/components/layout/Footer.astro

import { siteConfig } from "@/config/site";
import Container from "../ui/Container.astro";
---

<footer class="border-t border-black/10 dark:border-white/10 bg-white dark:bg-black">
  <Container size="lg">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 py-6 text-[13px] text-zinc-500 dark:text-zinc-400">
      <div class="flex items-center gap-2">
        <span>
          © {new Date().getFullYear()} {siteConfig.siteName}
        </span>
      </div>
      <div class="flex items-center gap-4">
        <a
          href="/"
          class="inline-flex items-center justify-center text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors duration-150"
          aria-label="Home"
        >
          <span class="text-sm">
            ▲
          </span>
        </a>
      </div>
    </div>
  </Container>
</footer>