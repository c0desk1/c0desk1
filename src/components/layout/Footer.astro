---
// src/components/layout/Footer.astro

import Container from "../ui/Container.astro";
import Icon from "../ui/Icon.astro";
import { siteConfig } from "@/config/site";
---

<footer class="border-t border-zinc-100 dark:border-zinc-900 bg-white dark:bg-zinc-950">
  <Container size="md" class="mx-auto py-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      <div class="space-y-3">
        <div class="flex items-center gap-2">
          <span class="text-emerald-600 dark:text-emerald-500 font-mono font-bold text-sm">$</span>
          <span class="text-base font-semibold font-mono tracking-tight text-zinc-900 dark:text-white">
            {siteConfig.name}
          </span>
        </div>
        <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
          {siteConfig.description.substring(0, 100)}...
        </p>
        <div class="flex gap-3 pt-1">
          {siteConfig.social.github && (
            <a 
              href={siteConfig.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
              aria-label="GitHub"
            >
              <Icon name="github" class="w-4 h-4" />
            </a>
          )}
          {siteConfig.social.twitter && (
            <a 
              href={siteConfig.social.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
              aria-label="Twitter"
            >
              <Icon name="twitter" class="w-4 h-4" />
            </a>
          )}
          {siteConfig.social.linkedin && (
            <a 
              href={siteConfig.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
              aria-label="LinkedIn"
            >
              <Icon name="linkedin" class="w-4 h-4" />
            </a>
          )}
        </div>
      </div>
      <div>
        <div class="flex items-center gap-1.5 mb-3">
          <div class="h-1 w-1 rounded-full bg-emerald-500"></div>
          <h2 class="text-xs font-bold tracking-wider text-zinc-500 dark:text-zinc-400">
            Explore
          </h2>
        </div>
        <ul class="space-y-1.5">
          {siteConfig.navItems.map((item) => (
            <li>
              <a 
                href={item.href} 
                class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      {/* Contact Section - Industrial Style */}
      <div>
        <div class="flex items-center gap-1.5 mb-3">
          <div class="h-1 w-1 rounded-full bg-emerald-500"></div>
          <h2 class="text-xs font-bold tracking-wider text-zinc-500 dark:text-zinc-400">
            Contact
          </h2>
        </div>
        <ul class="space-y-1.5">
          {siteConfig.links.mail && (
            <li>
              <a 
                href={`mailto:${siteConfig.links.mail}`}
                class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors break-all"
              >
                {siteConfig.links.mail}
              </a>
            </li>
          )}
          <li>
            <a 
              href={siteConfig.links.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>
      
      {/* CTA / Newsletter Section */}
      <div>
        <div class="flex items-center gap-1.5 mb-3">
          <span class="text-emerald-600 dark:text-emerald-500 font-mono font-bold text-[11px]">$</span>
          <h2 class="text-xs font-bold tracking-wider text-zinc-500 dark:text-zinc-400">
            Stay updated
          </h2>
        </div>
        <p class="text-xs text-zinc-600 dark:text-zinc-400 mb-3">
          Get notified about new projects and articles.
        </p>
        <form class="flex gap-2">
          <input 
            type="email" 
            placeholder="your@email.com"
            class="flex-1 px-2 py-1.5 text-xs border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 text-zinc-900 dark:text-white placeholder:text-zinc-400 focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-600 transition-colors"
            aria-label="Email address"
          />
          <button 
            type="submit"
            class="px-2 py-1.5 text-xs font-medium border border-zinc-200 dark:border-zinc-800 hover:border-zinc-400 dark:hover:border-zinc-600 hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-all"
          >
            Sub
          </button>
        </form>
      </div>
      
    </div>
    
    {/* Industrial Separator */}
    <div class="my-6">
      <div class="h-px w-full bg-linear-to-r from-transparent via-zinc-200 dark:via-zinc-800 to-transparent"></div>
    </div>
    
    {/* Copyright - Industrial Style */}
    <div class="flex flex-col sm:flex-row justify-between items-center gap-2 text-sm text-zinc-500 dark:text-zinc-500">
      <div class="flex items-center gap-2">
        <span class="text-emerald-600 dark:text-emerald-500 font-bold">$</span>
        <span>© {new Date().getFullYear()} {siteConfig.name}</span>
      </div>
      <div class="flex items-center gap-3">
        <span>[Built with Astro]</span>
        <span>▼</span>
      </div>
    </div>
    
  </Container>
</footer>