---
// src/components/layout/Footer.astro
// @ts-nocheck
import Icon from "../ui/Icon.astro";
import { siteConfig } from "@/config/site";
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      
      {/* Brand Section */}
      <div class="col-span-1 md:col-span-2 space-y-4">
        <div class="flex items-center gap-2.5">
          <Icon name="logo" class="w-5 h-5 text-zinc-900 dark:text-white" />
          <span class="text-lg font-semibold tracking-tight text-zinc-900 dark:text-white">
            {siteConfig.name}
          </span>
        </div>
        <p class="text-sm text-zinc-600 dark:text-zinc-400 max-w-sm">
          {siteConfig.description}
        </p>
        <div class="flex gap-4">
          {siteConfig.social.github && (
            <a 
              href={siteConfig.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
              aria-label="GitHub"
            >
              <Icon name="github" class="w-5 h-5" />
            </a>
          )}
          {siteConfig.social.twitter && (
            <a 
              href={siteConfig.social.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
              aria-label="Twitter"
            >
              <Icon name="twitter" class="w-5 h-5" />
            </a>
          )}
          {siteConfig.social.linkedin && (
            <a 
              href={siteConfig.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
              aria-label="LinkedIn"
            >
              <Icon name="linkedin" class="w-5 h-5" />
            </a>
          )}
        </div>
      </div>
      
      {/* Navigation Links */}
      <div>
        <h4 class="font-semibold text-sm mb-4 text-zinc-900 dark:text-white">Explore</h4>
        <ul class="space-y-2 text-sm">
          {siteConfig.navItems.map((item) => (
            <li>
              <a 
                href={item.href} 
                class="text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      {/* Contact Section */}
      <div>
        <h4 class="font-semibold text-sm mb-4 text-zinc-900 dark:text-white">Contact</h4>
        <ul class="space-y-2 text-sm">
          {siteConfig.links.mail && (
            <li>
              <a 
                href={`mailto:${siteConfig.links.mail}`}
                class="text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
              >
                {siteConfig.links.mail}
              </a>
            </li>
          )}
          <li>
            <a 
              href={siteConfig.links.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>
    
    {/* Copyright */}
    <div class="mt-12 pt-8 border-t border-zinc-200 dark:border-zinc-800 text-center text-sm text-zinc-500">
      © {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
    </div>
  </div>
</footer>