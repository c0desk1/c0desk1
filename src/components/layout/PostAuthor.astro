---
// src/components/layout/PostAuthor.astro
import { siteConfig } from '@/config/site';
import { Image } from 'astro:assets';
import { cdnImage, isCdnUrl } from '@/lib/utils';
import { getCurrentLocale, getLabel, localizePath } from "@/utils/i18n";

interface Props {
  name?: string;
  avatar?: string;
  title?: string | { id?: string; en?: string; ru?: string };
  slug?: string;
}

const { name, avatar, title, slug } = Astro.props;

const locale = getCurrentLocale(Astro);

function resolveLocale(val: unknown): string {
  if (typeof val === 'object' && val !== null) {
    const map = val as Record<string, string>;
    return map[locale] ?? map.en ?? map.id ?? '';
  }
  return String(val ?? '');
}

const authorLabel = getLabel(locale, 'author') || 'Author';
const avatarOfLabel = getLabel(locale, 'avatarOf') || 'Avatar of';

const authorName = name || siteConfig.author?.name || siteConfig.siteName;
const authorAvatar = avatar || siteConfig.author?.avatar || siteConfig.siteLogo;
const authorTitle = title
  ? resolveLocale(title)
  : resolveLocale(siteConfig.author?.title) || authorLabel;
const authorSlug = slug || siteConfig.author?.slug || "author";

const authorPath = localizePath(`/author/${authorSlug}`, locale);
const optimizedAvatar = isCdnUrl(authorAvatar) ? cdnImage(authorAvatar, { w: 48, h: 48, q: 80 }) : authorAvatar;
---
<div class="flex flex-col items-center w-full relative">
  <div class="flex flex-col items-center justify-center flex-initial">
    <a href={authorPath} aria-label={`${authorLabel}: ${authorName}`}>
      <div class="flex flex-row items-stretch justify-start gap-2 flex-initial">
        {authorAvatar && (
          <Image
            src={optimizedAvatar}
            alt={`${avatarOfLabel} ${authorName}`}
            width={48}
            height={48}
            class="w-6 h-6 border-px border-(--border) object-cover shrink-0 rounded-full inline-block overflow-hidden leading-0 align-top relative duration-200 ease-in-out"
            loading="eager"
            decoding='async'
          />
        )}
        <div class="flex flex-row items-stretch justify-start gap-2 flex-initial">
          <span class="text-[14px] leading-[20px] font-medium text-gray-1000">{authorName}</span>
          {authorTitle && (<span class="text-copy-14 text-(--fg-muted)">{authorTitle}</span>)}
        </div>
      </div>
    </a>
  </div>
</div>