---
// src/components/layout/PostMeta.astro
import { formatDate, getReadingTime } from '@/lib/utils';
import { getCurrentLocale } from '@/utils/i18n';
import Icon from '@/components/ui/Icon';

interface Props {
  pubDate: Date;
  content: string;
}

const { pubDate, content } = Astro.props;
const locale = getCurrentLocale(Astro);

const dateLocale =
  locale === 'en' ? 'en-US' :
  locale === 'ru' ? 'ru-RU' :
  locale === 'jp' ? 'ja-JP' :
  'id-ID';

const formattedDate = formatDate(pubDate, dateLocale);
const readingTime = getReadingTime(content, locale as 'id' | 'en' | 'ru' | 'jp');
---

<div class="flex flex-row items-center justify-between w-full gap-4 pt-2">
  <div class="flex items-center gap-1.5 text-copy-14 text-(--fg-muted)">
    <Icon name="clock" className="w-4 h-4" />
    {readingTime && <span class="whitespace-nowrap">{readingTime}</span>}
  </div>

  <time 
    datetime={pubDate.toISOString()} 
    class="text-copy-14 text-(--fg-muted) whitespace-nowrap order-2 md:order-3"
  >
    {formattedDate}
  </time>
</div>