---
// src/components/layout/PostMeta.astro
import { formatDate } from '@/lib/utils';
import { getCurrentLocale, getLabel } from '@/utils/i18n';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  pubDate: Date;
  readingTime: string;
}

const { pubDate, readingTime } = Astro.props;
const locale = getCurrentLocale(Astro);

const dateLocale = locale === 'id'? 'id-ID' : locale === 'ru'? 'ru-RU' : 'en-US';
const formattedDate = formatDate(pubDate, dateLocale);

const minReadLabel = getLabel(locale, 'minRead') || 'min read';
const readingTimeText = readingTime? `${readingTime} ${minReadLabel}` : '';
---

<div class="flex flex-wrap items-center justify-start md:justify-center gap-x-2 gap-y-1 text-[13px] md:text-sm text-(--fg-muted)">
  {readingTimeText && (
    <div class="flex items-center justify-center gap-2">
      <Icon name="clock" className="w-4 h-4" />
      <span class="whitespace-nowrap">{readingTimeText}</span>
    </div>
  )}

  {readingTimeText && <span aria-hidden="true">―</span>}

  <div class="flex items-center justify-center gap-2">
    <Icon name="calendar" className="w-4 h-4" />
    <time datetime={pubDate.toISOString()} class="whitespace-nowrap">
      {formattedDate}
    </time>
  </div>
</div>