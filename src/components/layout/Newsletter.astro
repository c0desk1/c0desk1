---
// src/components/ui/Newsletter.astro
interface Props {
  heading?    : string;
  subheading? : string;
  placeholder?: string;
  btnLabel?   : string;
}

const {
  heading     = 'Berlangganan Newsletter kami',
  subheading  = 'Dapatkan postingan terbaru langsung di kotak masuk Anda.',
  placeholder = 'namakamu@email.com',
  btnLabel    = 'Berlangganan',
} = Astro.props;
---

<section class="nl-section">
  <div class="nl-container">
    <div class="nl-content">
      <div class="nl-header">
        <h2 class="nl-heading">{heading}</h2>
        <p class="nl-sub">{subheading}</p>
      </div>
      
      <form class="nl-form" id="nl-form">
        <div class="nl-form-group">
          <input
            id="nl-email"
            type="email"
            required
            placeholder={placeholder}
            autocomplete="email"
            class="nl-input"
            aria-label="Email address"
          />
          <button id="nl-submit" type="submit" class="nl-button">
            <span id="nl-btn-label">{btnLabel}</span>
            <svg
              id="nl-spinner"
              class="hidden nl-spinner"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="10" stroke-opacity="0.3"/>
              <path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </form>
      
      <p class="nl-note">
        Tidak ada spam. Anda dapat berhenti berlangganan kapan saja.
      </p>
    </div>
  </div>
</section>

<style>
  .nl-section {
    border-top: 1px solid var(--border);
    padding: 3rem 1rem;
  }

  .nl-container {
    max-width: 560px;
    margin: 0 auto;
  }

  .nl-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .nl-header {
    text-align: center;
  }

  .nl-heading {
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 0 0 0.25rem 0;
  }

  .nl-sub {
    font-size: 0.875rem;
    color: var(--fg-muted);
    margin: 0;
  }

  .nl-form-group {
    display: flex;
    gap: 0.5rem;
  }

  .nl-input {
    flex: 1;
    padding: 0.625rem 0.875rem;
    font-size: 0.875rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    outline: none;
    outline-offset: 2px;
    outline-color: var(--border-strong);
    color: var(--fg);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .nl-input::placeholder {
    color: var(--fg-muted);
  }

  .nl-input:focus {
    border-color: var(--fg);
    box-shadow: 0 0 0 1px var(--fg);
  }

  .nl-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--fg);
    color: var(--bg);
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .nl-button:hover {
    opacity: 0.8;
  }

  .nl-button:active {
    transform: scale(0.98);
  }

  .nl-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .nl-spinner {
    width: 1rem;
    height: 1rem;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .nl-note {
    font-size: 0.85rem;
    color: var(--fg-subtle);
    text-align: center;
    margin: 0;
  }
</style>

<script>
  (() => {
    const form     = document.getElementById('nl-form');
    const emailInput = document.getElementById('nl-email') as HTMLInputElement;
    const submitBtn  = document.getElementById('nl-submit') as HTMLButtonElement;
    const btnLabel   = document.getElementById('nl-btn-label');
    const spinner    = document.getElementById('nl-spinner');

    if (!form || !emailInput || !submitBtn) return;

    const setLoading = (on: boolean) => {
      if (submitBtn) submitBtn.disabled = on;
      if (btnLabel) btnLabel.style.display = on ? 'none' : 'inline';
      if (spinner) spinner.classList.toggle('hidden', !on);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      const toast = (window as any).toast;
      
    if (!toast) return;
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        toast.show('Please enter a valid email address.', { type: 'error' });
        emailInput.focus();
        return;
      }

      setLoading(true);

      try {
        const res = await fetch('https://api.c0desk1.my.id/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          if (res.status === 409) {
            toast.show('Email already subscribed!', { type: 'error' });
          } else {
            toast.show(data.error || 'Something went wrong. Please try again.', { type: 'error' });
          }
          return;
        }
        emailInput.value = '';
        toast.show(data.message || 'Thanks for subscribing!', { type: 'success' });

      } catch (err) {
        console.error('[Newsletter] Error:', err);
        toast.show('Failed to connect. Please try again later.', { type: 'error' });
      } finally {
        setLoading(false);
      }
    });
  })();
</script>
