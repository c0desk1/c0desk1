---
// src/components/ui/Newsletter.astro
import { getCurrentLocale, getLabel } from '@/utils/i18n';
import Icon from "@/components/ui/Icon";

interface Props {
  heading?    : string;
  subheading? : string;
  placeholder?: string;
  btnLabel?   : string;
  message?    : string;
  note?       : string;
}

const locale = getCurrentLocale(Astro);

const {
  heading = getLabel(locale, 'newsletterHeading'),
  subheading = getLabel(locale, 'newsletterSub'),
  placeholder = getLabel(locale, 'newsletterPlaceholder'),
  btnLabel = getLabel(locale, 'newsletterBtn'),
  message = getLabel(locale, 'newsletterSuccess'),
  note = getLabel(locale, 'newsletterNote'),
} = Astro.props;

const toastMessages = {
  invalid: getLabel(locale, 'newsletterInvalid'),
  exists: getLabel(locale, 'newsletterExists'),
  error: getLabel(locale, 'newsletterError'),
  success: getLabel(locale, 'newsletterToastSuccess'),
  network: getLabel(locale, 'newsletterNetwork'),
};
---

<div class="nls-root">
  <div class="nls-glow"></div>
  
  <div class="nls-card">
    <div class="nls-header">
      <div class="nls-icon-wrap">
        <Icon name="mail" />
      </div>
      <div>
        <h2 class="nls-heading">{heading}</h2>
        <p class="nls-sub">{subheading}</p>
      </div>
    </div>

    <div id="nls-form-state">
      <form id="nls-form" novalidate>
        <div class="nls-row" id="nls-field">
          <div class="nls-input-wrap">
            <Icon name="mail" class="nls-input-icon" />
            <input
              id="nls-email"
              type="email"
              required
              placeholder={placeholder}
              autocomplete="email"
              inputmode="email"
              class="nls-input"
              aria-label="Email address"
            />
          </div>
          <button id="nls-submit" type="submit" class="nls-btn" aria-label={btnLabel}>
            <span class="nls-btn-label">{btnLabel}</span>
            <svg class="nls-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9" stroke-opacity="0.25" />
              <path d="M12 3a9 9 0 0 1 9 9" stroke-linecap="round" />
            </svg>
            <Icon name="arrow-right" class="nls-btn-icon" />
          </button>
        </div>
      </form>
    </div>

    <div id="nls-success" class="nls-success" hidden aria-live="polite">
      <div class="nls-success-icon">
        <Icon name="check" />
      </div>
      <span>{message}</span>
    </div>

    <p class="nls-note">{note}</p>
  </div>
</div>

<style>
  .nls-root {
    position: relative;
    width: 100%;
    isolation: isolate;
  }

  /* Subtle gradient glow */
  .nls-glow {
    position: absolute;
    inset: -2px;
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), 
      rgba(56, 189, 248, 0.15), 
      transparent 40%);
    border-radius: 24px;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .nls-root:hover .nls-glow {
    opacity: 1;
  }

  .nls-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.75rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .nls-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-2px);
  }

  @media (prefers-color-scheme: light) {
    .nls-card {
      background: rgba(255, 255, 255, 0.7);
      border-color: rgba(0, 0, 0, 0.08);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
    }
    .nls-card:hover {
      border-color: rgba(0, 0, 0, 0.12);
    }
    .nls-glow {
      background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), 
        rgba(59, 130, 246, 0.12), 
        transparent 40%);
    }
  }

  .nls-header {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .nls-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(139, 92, 246, 0.15));
    color: #3b82f6;
    flex-shrink: 0;
  }

  .nls-icon-wrap svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .nls-heading {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--fg);
    margin: 0 0 0.25rem 0;
  }

  .nls-sub {
    font-size: 0.875rem;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Form */
  .nls-row {
    display: flex;
    gap: 0.5rem;
  }

  .nls-input-wrap {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .nls-input-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1rem;
    height: 1rem;
    color: var(--fg-subtle);
    pointer-events: none;
    transition: color 0.15s ease;
  }

  .nls-input {
    width: 100%;
    height: 2.75rem;
    padding: 0 0.875rem 0 2.5rem;
    font-size: 0.875rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    outline: none;
    color: var(--fg);
    transition: all 0.15s ease;
  }

  .nls-input::placeholder {
    color: var(--fg-subtle);
  }

  .nls-input:focus {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .nls-input:focus + .nls-input-icon,
  .nls-input:focus ~ .nls-input-icon {
    color: #3b82f6;
  }

  /* Button */
  .nls-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    height: 2.75rem;
    padding: 0 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    color: white;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: all 0.15s ease;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.25);
  }

  .nls-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.35);
  }

  .nls-btn:active {
    transform: translateY(0);
  }

  .nls-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .nls-btn-icon {
    width: 1rem;
    height: 1rem;
    transition: transform 0.15s ease;
  }

  .nls-btn:hover .nls-btn-icon {
    transform: translateX(2px);
  }

  .nls-spinner {
    width: 1rem;
    height: 1rem;
    display: none;
    animation: nls-spin 0.65s linear infinite;
  }

  @keyframes nls-spin {
    to { transform: rotate(360deg); }
  }

  .nls-btn.is-loading .nls-btn-label,
  .nls-btn.is-loading .nls-btn-icon { 
    display: none; 
  }
  .nls-btn.is-loading .nls-spinner { 
    display: block; 
  }

  /* Shake animation */
  .nls-row.nls-shake {
    animation: nls-shake 0.3s cubic-bezier(.36,.07,.19,.97);
  }

  @keyframes nls-shake {
    10%, 90% { transform: translateX(-1px); }
    20%, 80% { transform: translateX(2px); }
    30%, 50%, 70% { transform: translateX(-4px); }
    40%, 60% { transform: translateX(4px); }
  }

  /* Success state */
  .nls-success {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg);
    animation: nls-slide-up 0.3s ease;
  }

  .nls-success-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: #10b981;
    color: white;
    flex-shrink: 0;
  }

  .nls-success-icon svg {
    width: 0.875rem;
    height: 0.875rem;
  }

  @keyframes nls-slide-up {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .nls-note {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    margin: 0;
    line-height: 1.5;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .nls-card {
      padding: 1.25rem;
      border-radius: 16px;
    }

    .nls-row {
      flex-direction: column;
    }

    .nls-btn {
      width: 100%;
    }

    .nls-heading {
      font-size: 1.125rem;
    }
  }

  /* Dark mode vars fallback */
  :root {
    --fg: #0f172a;
    --fg-muted: #475569;
    --fg-subtle: #94a3b8;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --fg: #f8fafc;
      --fg-muted: #cbd5e1;
      --fg-subtle: #64748b;
    }
  }
</style>

<script define:vars={{ toastMessages }}>
  (() => {
    const form = document.getElementById('nls-form');
    const emailEl = document.getElementById('nls-email');
    const submitBtn = document.getElementById('nls-submit');
    const field = document.getElementById('nls-field');
    const formState = document.getElementById('nls-form-state');
    const successEl = document.getElementById('nls-success');
    const root = document.querySelector('.nls-root');

    if (!form || !emailEl || !submitBtn) return;

    // Mouse follow glow effect
    root?.addEventListener('mousemove', (e) => {
      const rect = root.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      root.style.setProperty('--mouse-x', `${x}px`);
      root.style.setProperty('--mouse-y', `${y}px`);
    });

    const isValidEmail = (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

    const setLoading = (on) => {
      submitBtn.disabled = on;
      submitBtn.classList.toggle('is-loading', on);
    };

    const shake = () => {
      field?.classList.add('nls-shake');
      field?.addEventListener('animationend', () => field.classList.remove('nls-shake'), { once: true });
    };

    emailEl.addEventListener('input', () => field?.classList.remove('nls-shake'));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = emailEl.value.trim();
      const toast = window.toast;

      if (!email || !isValidEmail(email)) {
        shake();
        emailEl.focus();
        toast?.show?.(toastMessages.invalid, { type: 'error' });
        return;
      }

      setLoading(true);

      try {
        const res = await fetch('https://api.c0desk1.my.id/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (!res.ok) {
          shake();
          const msg = res.status === 409 ? toastMessages.exists : toastMessages.error;
          toast?.show?.(msg, { type: 'error' });
          return;
        }

        emailEl.value = '';
        formState.hidden = true;
        successEl.hidden = false;

        setTimeout(() => {
          successEl.hidden = true;
          formState.hidden = false;
        }, 4000);

        toast?.show?.(toastMessages.success, { type: 'success' });

      } catch {
        shake();
        toast?.show?.(toastMessages.network, { type: 'error' });
      } finally {
        setLoading(false);
      }
    });
  })();
</script>