---
// src/components/ui/Newsletter.astro
import { getCurrentLocale, getLabel } from '@/utils/i18n';

interface Props {
  heading?    : string;
  subheading? : string;
  placeholder?: string;
  btnLabel?   : string;
  message?    : string;
  note?       : string;
}

const locale = getCurrentLocale(Astro);

const {
  heading = getLabel(locale, 'newsletterHeading'),
  subheading = getLabel(locale, 'newsletterSub'),
  placeholder = getLabel(locale, 'newsletterPlaceholder'),
  btnLabel = getLabel(locale, 'newsletterBtn'),
  message = getLabel(locale, 'newsletterSuccess'),
  note = getLabel(locale, 'newsletterNote'),
} = Astro.props;

const toastMessages = {
  invalid: getLabel(locale, 'newsletterInvalid'),
  exists: getLabel(locale, 'newsletterExists'),
  error: getLabel(locale, 'newsletterError'),
  success: getLabel(locale, 'newsletterToastSuccess'),
  network: getLabel(locale, 'newsletterNetwork'),
};
---

<div class="nls-root">
  <h2 class="nls-heading">{heading}</h2>
  <p class="nls-sub">{subheading}</p>

  <div id="nls-form-state">
    <form id="nls-form" novalidate>
      <div class="nls-row" id="nls-field">
        <input
          id="nls-email"
          type="email"
          required
          placeholder={placeholder}
          autocomplete="email"
          inputmode="email"
          class="nls-input"
          aria-label="Email address"
        />
        <button id="nls-submit" type="submit" class="nls-btn" aria-label={btnLabel}>
          <span class="nls-btn-label">{btnLabel}</span>
          <svg class="nls-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="9" stroke-opacity="0.25" />
            <path d="M12 3a9 9 0 0 1 9 9" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </form>
  </div>

  <div id="nls-success" class="nls-success" hidden aria-live="polite">
    {message}
  </div>

  <p class="nls-note">{note}</p>
</div>

<style>
  .nls-root {
    width: 100%;
    max-width: 480px;
  }

  .nls-heading {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--fg);
    margin: 0 0 0.375rem 0;
    letter-spacing: -0.02em;
  }

  .nls-sub {
    font-size: 0.875rem;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0 0 1rem 0;
  }

  .nls-row {
    display: flex;
    gap: 0.5rem;
    width: 100%;
  }

  .nls-input {
    flex: 1;
    min-width: 0;
    height: 40px;
    padding: 0 12px;
    font-size: 0.875rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    outline: none;
    color: var(--fg);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .nls-input::placeholder {
    color: var(--fg-subtle);
  }

  .nls-input:focus {
    border-color: var(--fg);
    box-shadow: 0 0 0 1px var(--fg);
  }

  .nls-input:invalid:focus {
    border-color: #e5484d;
    box-shadow: 0 0 0 1px #e5484d;
  }

  .nls-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 16px;
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--fg);
    color: var(--bg);
    border: 1px solid var(--fg);
    border-radius: 6px;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.15s ease;
  }

  .nls-btn:hover {
    opacity: 0.8;
  }

  .nls-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .nls-spinner {
    width: 16px;
    height: 16px;
    display: none;
    animation: nls-spin 0.65s linear infinite;
  }

  @keyframes nls-spin {
    to { transform: rotate(360deg); }
  }

  .nls-btn.is-loading .nls-btn-label { 
    display: none; 
  }
  .nls-btn.is-loading .nls-spinner { 
    display: block; 
  }

  .nls-row.nls-shake {
    animation: nls-shake 0.25s ease;
  }

  @keyframes nls-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  .nls-success {
    display: flex;
    align-items: center;
    height: 40px;
    padding: 0 12px;
    font-size: 0.875rem;
    color: var(--fg);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 6px;
    animation: nls-fade 0.2s ease;
  }

  @keyframes nls-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .nls-note {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    margin: 0.75rem 0 0 0;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .nls-row {
      flex-direction: column;
    }
    
    .nls-btn {
      width: 100%;
    }
    
    .nls-input {
      height: 44px;
      font-size: 16px; /* cegah zoom iOS */
    }
    
    .nls-btn {
      height: 44px;
    }
  }

  /* Vercel color scheme */
  :root {
    --bg: #ffffff;
    --bg-subtle: #fafafa;
    --fg: #000;
    --fg-muted: #666;
    --fg-subtle: #888;
    --border: #ea;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #000;
      --bg-subtle: #111;
      --fg: #ffffff;
      --fg-muted: #888;
      --fg-subtle: #666;
      --border: #333;
    }
  }
</style>

<script define:vars={{ toastMessages }}>
  (() => {
    const form = document.getElementById('nls-form');
    const emailEl = document.getElementById('nls-email');
    const submitBtn = document.getElementById('nls-submit');
    const field = document.getElementById('nls-field');
    const formState = document.getElementById('nls-form-state');
    const successEl = document.getElementById('nls-success');

    if (!form || !emailEl || !submitBtn) return;

    const isValidEmail = (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

    const setLoading = (on) => {
      submitBtn.disabled = on;
      submitBtn.classList.toggle('is-loading', on);
    };

    const shake = () => {
      field?.classList.add('nls-shake');
      field?.addEventListener('animationend', () => field.classList.remove('nls-shake'), { once: true });
    };

    emailEl.addEventListener('input', () => field?.classList.remove('nls-shake'));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = emailEl.value.trim();
      const toast = window.toast;

      if (!email || !isValidEmail(email)) {
        shake();
        emailEl.focus();
        toast?.show?.(toastMessages.invalid, { type: 'error' });
        return;
      }

      setLoading(true);

      try {
        const res = await fetch('https://api.c0desk1.my.id/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (!res.ok) {
          shake();
          const msg = res.status === 409 ? toastMessages.exists : toastMessages.error;
          toast?.show?.(msg, { type: 'error' });
          return;
        }

        emailEl.value = '';
        formState.hidden = true;
        successEl.hidden = false;

        setTimeout(() => {
          successEl.hidden = true;
          formState.hidden = false;
        }, 3000);

        toast?.show?.(toastMessages.success, { type: 'success' });

      } catch {
        shake();
        toast?.show?.(toastMessages.network, { type: 'error' });
      } finally {
        setLoading(false);
      }
    });
  })();
</script>