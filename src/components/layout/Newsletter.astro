---
// src/components/ui/Newsletter.astro
interface Props {
  heading?    : string;
  subheading? : string;
  placeholder?: string;
  btnLabel?   : string;
}

const {
  heading     = 'Stay in the loop',
  subheading  = 'Get the latest posts delivered to your inbox.',
  placeholder = 'you@email.com',
  btnLabel    = 'Subscribe',
} = Astro.props;
---

<div class="nls-root">
  <h3 class="nls-heading">{heading}</h3>
  <p class="nls-sub">{subheading}</p>

  <div id="nls-form-state">
    <form id="nls-form" class="nls-form" novalidate>
      <div class="nls-row" id="nls-field">
        <input
          id="nls-email"
          type="email"
          required
          placeholder={placeholder}
          autocomplete="email"
          class="nls-input"
          aria-label="Email address"
        />
        <button id="nls-submit" type="submit" class="nls-btn">
          <span class="nls-btn-label">{btnLabel}</span>
          <svg class="nls-spinner" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="9" stroke-opacity="0.2"/>
            <path d="M12 3a9 9 0 0 1 9 9" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </form>
  </div>

  <div id="nls-success" class="nls-success" hidden aria-live="polite">
    <span>Thanks for subscribing!</span>
  </div>

  <p class="nls-note">No spam. Unsubscribe anytime.</p>
</div>

<style>
  .nls-root {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 24rem;
  }

  .nls-heading {
    font-size: 1rem;
    font-weight: 500;
    color: var(--fg);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.4;
  }

  .nls-sub {
    font-size: 0.875rem;
    color: var(--fg-muted);
    margin: -0.25rem 0 0 0;
    line-height: 1.5;
  }

  .nls-form {
    margin: 0;
  }

  .nls-row {
    display: flex;
    height: 2.5rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--bg);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .nls-row:focus-within {
    border-color: var(--fg);
    box-shadow: 0 0 0 1px var(--fg);
  }

  .nls-row.nls-shake {
    animation: nls-shake 0.25s ease;
    border-color: #e5484d;
  }

  @keyframes nls-shake {
    0%, 100% { transform: translateX(0); }
    25%      { transform: translateX(-3px); }
    75%      { transform: translateX(3px); }
  }

  .nls-input {
    flex: 1;
    min-width: 0;
    padding: 0 0.875rem;
    font-size: 0.875rem;
    background: transparent;
    border: none;
    outline: none;
    color: var(--fg);
  }

  .nls-input::placeholder {
    color: var(--fg-muted);
  }

  .nls-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--fg);
    color: var(--bg);
    border: none;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.15s ease;
  }

  .nls-btn:hover {
    opacity: 0.8;
  }

  .nls-btn:active {
    transform: scale(0.97);
  }

  .nls-btn:focus-visible {
    outline: 2px solid var(--fg);
    outline-offset: 2px;
  }

  .nls-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .nls-spinner {
    width: 1rem;
    height: 1rem;
    display: none;
    animation: nls-spin 0.6s linear infinite;
  }

  @keyframes nls-spin {
    to { transform: rotate(360deg); }
  }

  .nls-btn.is-loading .nls-btn-label {
    display: none;
  }

  .nls-btn.is-loading .nls-spinner {
    display: block;
  }

  .nls-success {
    font-size: 0.875rem;
    color: var(--fg-muted);
    padding: 0.5rem 0;
    animation: nls-fade 0.2s ease;
  }

  @keyframes nls-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .nls-note {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    margin: 0;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .nls-root {
      max-width: 100%;
    }

    .nls-row {
      flex-direction: column;
      height: auto;
      gap: 0.5rem;
      border: none;
      background: transparent;
    }

    .nls-row:focus-within {
      box-shadow: none;
    }

    .nls-input {
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      padding: 0.75rem 0.875rem;
      font-size: 1rem;
    }

    .nls-input:focus {
      border-color: var(--fg);
      box-shadow: 0 0 0 1px var(--fg);
    }

    .nls-btn {
      width: 100%;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
    }
  }
</style>

<script>
  (() => {
    const form      = document.getElementById('nls-form');
    const emailEl   = document.getElementById('nls-email');
    const submitBtn = document.getElementById('nls-submit');
    const field     = document.getElementById('nls-field');
    const formState = document.getElementById('nls-form-state');
    const successEl = document.getElementById('nls-success');

    if (!form || !emailEl || !submitBtn) return;

    const setLoading = (on) => {
      submitBtn.disabled = on;
      submitBtn.classList.toggle('is-loading', on);
    };

    const shakeField = () => {
      if (!field) return;
      field.classList.add('nls-shake');
      field.addEventListener('animationend', () => {
        field.classList.remove('nls-shake');
      }, { once: true });
    };

    emailEl.addEventListener('input', () => {
      field?.classList.remove('nls-shake');
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailEl.value.trim();
      const toast = window.toast;

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        shakeField();
        emailEl.focus();
        toast?.show?.('Please enter a valid email address.', { type: 'error' });
        return;
      }

      setLoading(true);

      try {
        const res = await fetch('https://api.c0desk1.my.id/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          shakeField();
          if (res.status === 409) {
            toast?.show?.('Email already subscribed.', { type: 'error' });
          } else {
            toast?.show?.('Something went wrong. Please try again.', { type: 'error' });
          }
          return;
        }

        emailEl.value = '';
        if (formState) formState.hidden = true;
        if (successEl) successEl.hidden = false;

        setTimeout(() => {
          if (successEl) successEl.hidden = true;
          if (formState) formState.hidden = false;
        }, 3000);

        toast?.show?.('Subscribed! Check your inbox.', { type: 'success' });

      } catch {
        shakeField();
        toast?.show?.('Failed to connect. Please try again later.', { type: 'error' });
      } finally {
        setLoading(false);
      }
    });
  })();
</script>