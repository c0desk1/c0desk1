---
// src/components/ui/Newsletter.astro
interface Props {
  heading?    : string;
  subheading? : string;
  placeholder?: string;
  btnLabel?   : string;
}

const {
  heading     = 'Stay in the loop',
  subheading  = 'Artikel & catatan terbaru. Langsung ke inbox.',
  placeholder = 'you@email.com',
  btnLabel    = 'Subscribe',
} = Astro.props;
---

<div class="nls-root">
  <div class="nls-eyebrow">
    <span class="nls-dot" aria-hidden="true"></span>
    Newsletter
  </div>

  <div class="nls-body">
    <h3 class="nls-heading">{heading}</h3>
    <p class="nls-sub">{subheading}</p>
  </div>

  <div id="nls-form-state">
    <form id="nls-form" class="nls-form" novalidate>
      <div class="nls-row" id="nls-field">
        <input
          id="nls-email"
          type="email"
          required
          placeholder={placeholder}
          autocomplete="email"
          class="nls-input"
          aria-label="Alamat email"
        />
        <button id="nls-submit" type="submit" class="nls-btn">
          <span class="nls-btn-label">{btnLabel}</span>
          <svg class="nls-spinner" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <circle cx="12" cy="12" r="9" stroke-opacity="0.2"/>
            <path d="M12 3a9 9 0 0 1 9 9" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </form>
  </div>


  <div id="nls-success" class="nls-success" hidden aria-live="polite">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      aria-hidden="true">
      <path d="M20 6 9 17l-5-5"/>
    </svg>
    <span>Cek inbox kamu untuk konfirmasi.</span>
  </div>

  <p class="nls-note">No spam — unsubscribe anytime.</p>

</div>

<style>
  .nls-root {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    width: 100%;
    max-width: 22rem;
  }

  .nls-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
    font-family: ui-monospace, 'Cascadia Code', monospace;
  }

  .nls-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--fg);
    opacity: 0.4;
    flex-shrink: 0;
  }

  .nls-body { display: flex; flex-direction: column; gap: 0.2rem; }

  .nls-heading {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .nls-sub {
    font-size: 0.8125rem;
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.5;
  }

  .nls-form { margin: 0; }

  .nls-row {
    display: flex;
    height: 2.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md, 0.5rem);
    overflow: hidden;
    background: var(--bg);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .nls-row:focus-within {
    border-color: var(--fg);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--fg) 7%, transparent);
  }

  .nls-row.nls-shake {
    animation: nls-shake 0.3s ease;
    border-color: #f87171;
    box-shadow: 0 0 0 3px color-mix(in srgb, #f87171 10%, transparent);
  }

  @keyframes nls-shake {
    0%,100% { transform: translateX(0); }
    25%     { transform: translateX(-4px); }
    75%     { transform: translateX(4px); }
  }

  .nls-input {
    flex: 1;
    min-width: 0;
    padding: 0 0.75rem;
    font-size: 0.8125rem;
    background: transparent;
    border: none;
    outline: none;
    color: var(--fg);
    caret-color: var(--fg);
    /* Vercel: subtle separator kanan */
    border-right: 1px solid var(--border);
  }

  .nls-input::placeholder {
    color: var(--fg-muted);
    opacity: 0.6;
  }

  .nls-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 0 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    background: var(--bg-muted);
    color: var(--fg);
    border: none;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s;
    letter-spacing: -0.01em;
  }

  .nls-btn:hover {
    background: var(--fg);
    color: var(--bg);
  }

  .nls-btn:active  { opacity: 0.8; }
  .nls-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .nls-btn:disabled:hover {
    background: var(--bg-muted);
    color: var(--fg);
  }

  .nls-spinner {
    width: 0.875rem;
    height: 0.875rem;
    display: none;
    animation: nls-spin 0.7s linear infinite;
  }

  @keyframes nls-spin { to { transform: rotate(360deg); } }

  .nls-btn.is-loading .nls-btn-label { display: none; }
  .nls-btn.is-loading .nls-spinner   { display: block; }

  .nls-success {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--fg-muted);
    animation: nls-fade 0.3s ease both;
  }

  .nls-success svg {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    color: var(--fg);
  }

  @keyframes nls-fade {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .nls-note {
    font-size: 0.6875rem;
    color: var(--fg-muted);
    opacity: 0.55;
    margin: 0;
    font-family: ui-monospace, 'Cascadia Code', monospace;
  }

  @media (max-width: 400px) {
    .nls-root { max-width: 100%; }

    .nls-row {
      height: auto;
      flex-direction: column;
      overflow: visible;
      border-radius: var(--radius-md, 0.5rem);
    }

    .nls-input {
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 0.6rem 0.75rem;
      font-size: 1rem; /* hindari iOS zoom */
    }

    .nls-btn {
      height: 2.5rem;
      width: 100%;
      border-radius: 0;
    }
  }
</style>

<script>
  (() => {
    const form      = document.getElementById('nls-form')      as HTMLFormElement | null;
    const emailEl   = document.getElementById('nls-email')     as HTMLInputElement | null;
    const submitBtn = document.getElementById('nls-submit')    as HTMLButtonElement | null;
    const field     = document.getElementById('nls-field')     as HTMLElement | null;
    const formState = document.getElementById('nls-form-state');
    const successEl = document.getElementById('nls-success');

    if (!form || !emailEl || !submitBtn) return;

    const setLoading = (on: boolean) => {
      submitBtn.disabled = on;
      submitBtn.classList.toggle('is-loading', on);
    };

    const shakeField = () => {
      if (!field) return;
      field.classList.remove('nls-shake');
      void field.offsetWidth;
      field.classList.add('nls-shake');
      field.addEventListener('animationend', () =>
        field.classList.remove('nls-shake'), { once: true });
    };

    emailEl.addEventListener('input', () => field?.classList.remove('nls-shake'));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailEl.value.trim();
      const toast = (window as any).toast;

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        shakeField();
        emailEl.focus();
        toast?.show?.('Masukkan alamat email yang valid.', { type: 'error' });
        return;
      }

      setLoading(true);

      try {
        const res  = await fetch('https://api.c0desk1.my.id/api/newsletter', {
          method : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body   : JSON.stringify({ email }),
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          shakeField();
          toast?.show?.(
            res.status === 409
              ? 'Email ini sudah terdaftar!'
              : data.error || 'Terjadi kesalahan. Coba lagi.',
            { type: 'error' }
          );
          return;
        }

        emailEl.value = '';
        if (formState) formState.hidden = true;
        if (successEl) successEl.hidden = false;
        toast?.show?.(data.message || 'Berhasil berlangganan!', { type: 'success' });

      } catch {
        shakeField();
        toast?.show?.('Gagal terhubung. Coba lagi nanti.', { type: 'error' });
      } finally {
        setLoading(false);
      }
    });
  })();
</script>
