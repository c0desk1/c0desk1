---
// src/components/ui/Newsletter.astro
interface Props {
  heading?    : string;
  subheading? : string;
  placeholder?: string;
  btnLabel?   : string;
}

const {
  heading     = 'Stay in the loop',
  subheading  = 'Artikel & catatan terbaru. Langsung ke inbox.',
  placeholder = 'you@email.com',
  btnLabel    = 'Subscribe',
} = Astro.props;
---

<div class="nls-root">
  <div class="nls-eyebrow">
    <span class="nls-dot" aria-hidden="true"></span>
    Newsletter
  </div>

  <div class="nls-body">
    <h3 class="nls-heading">{heading}</h3>
    <p class="nls-sub">{subheading}</p>
  </div>

  <div id="nls-form-state">
    <form id="nls-form" class="nls-form" novalidate>
      <div class="nls-row" id="nls-field">
        <input
          id="nls-email"
          type="email"
          required
          placeholder={placeholder}
          autocomplete="email"
          class="nls-input"
          aria-label="Alamat email"
        />
        <button id="nls-submit" type="submit" class="nls-btn">
          <span class="nls-btn-label">{btnLabel}</span>
          <svg class="nls-spinner" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <circle cx="12" cy="12" r="9" stroke-opacity="0.2"/>
            <path d="M12 3a9 9 0 0 1 9 9" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </form>
  </div>

  <div id="nls-success" class="nls-success" hidden aria-live="polite">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      aria-hidden="true">
      <path d="M20 6 9 17l-5-5"/>
    </svg>
    <span>Cek inbox kamu untuk konfirmasi.</span>
  </div>

  <p class="nls-note">No spam — unsubscribe anytime.</p>
</div>

<style>
  .nls-root {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 24rem;
  }

  .nls-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg);
    opacity: 0.7;
  }

  .nls-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 1;
    flex-shrink: 0;
  }

  .nls-body { 
    display: flex; 
    flex-direction: column; 
    gap: 0.25rem; 
  }

  /* Heading - larger for better readability */
  .nls-heading {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  /* Subheading - better contrast */
  .nls-sub {
    font-size: 0.875rem;
    color: var(--fg-subtle);
    opacity: 0.75;
    margin: 0;
    line-height: 1.5;
  }

  .nls-form { margin: 0; }

  .nls-row {
    display: flex;
    height: 2.5rem;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md, 0.5rem);
    overflow: hidden;
    background: var(--bg);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .nls-row:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-ring);
    outline: none;
  }

  .nls-row.nls-shake {
    animation: nls-shake 0.3s ease;
    border-color: #dc2626;
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.2);
  }

  @keyframes nls-shake {
    0%,100% { transform: translateX(0); }
    25%     { transform: translateX(-4px); }
    75%     { transform: translateX(4px); }
  }

  .nls-input {
    flex: 1;
    min-width: 0;
    padding: 0 0.875rem;
    font-size: 0.875rem;
    font-weight: 400;
    background: transparent;
    border: none;
    outline: none;
    color: var(--fg);
    caret-color: var(--accent);
    border-right: 1px solid var(--border);
  }

  .nls-input::placeholder {
    color: var(--fg-muted);
    opacity: 0.7;
  }

  .nls-input:focus {
    outline: none;
  }

  .nls-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 0 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    background: var(--bg-muted);
    color: var(--fg);
    border: none;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: all 0.15s ease;
    letter-spacing: -0.01em;
  }

  .nls-btn:hover {
    background: var(--fg);
    color: var(--bg);
  }

  .nls-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm, 0.25rem);
  }

  .nls-btn:active { 
    opacity: 0.85; 
    transform: scale(0.98);
  }
  
  .nls-btn:disabled { 
    opacity: 0.4; 
    cursor: not-allowed; 
  }
  
  .nls-btn:disabled:hover {
    background: var(--bg-muted);
    color: var(--fg);
  }

  .nls-spinner {
    width: 1rem;
    height: 1rem;
    display: none;
    animation: nls-spin 0.7s linear infinite;
  }

  @keyframes nls-spin { 
    to { transform: rotate(360deg); } 
  }

  .nls-btn.is-loading .nls-btn-label { display: none; }
  .nls-btn.is-loading .nls-spinner   { display: block; }

  .nls-success {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg);
    background: var(--accent-soft);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md, 0.5rem);
    border-left: 3px solid var(--accent);
    animation: nls-fade 0.3s ease both;
  }

  .nls-success svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--accent);
  }

  @keyframes nls-fade {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Note - small but readable */
  .nls-note {
    font-size: 0.75rem;
    color: var(--fg-muted);
    opacity: 0.7;
    margin: 0;
    letter-spacing: -0.01em;
  }

  @media (max-width: 400px) {
    .nls-root { max-width: 100%; }

    .nls-row {
      height: auto;
      flex-direction: column;
      overflow: visible;
      border-radius: var(--radius-md, 0.5rem);
      gap: 0.5rem;
      border: none;
      background: transparent;
    }

    .nls-row:focus-within {
      box-shadow: none;
    }

    .nls-input {
      border-right: none;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-md, 0.5rem);
      padding: 0.75rem 0.875rem;
      font-size: 1rem;
    }

    .nls-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-ring);
    }

    .nls-btn {
      width: 100%;
      padding: 0.75rem 1rem;
      border-radius: var(--radius-md, 0.5rem);
    }

    .nls-btn:focus-visible {
      outline-offset: 1px;
    }
  }
</style>

<script>
  (() => {
    const form      = document.getElementById('nls-form');
    const emailEl   = document.getElementById('nls-email');
    const submitBtn = document.getElementById('nls-submit');
    const field     = document.getElementById('nls-field');
    const formState = document.getElementById('nls-form-state');
    const successEl = document.getElementById('nls-success');

    if (!form || !emailEl || !submitBtn) return;

    const setLoading = (on) => {
      submitBtn.disabled = on;
      submitBtn.classList.toggle('is-loading', on);
    };

    const shakeField = () => {
      if (!field) return;
      field.classList.remove('nls-shake');
      void field.offsetWidth;
      field.classList.add('nls-shake');
      field.addEventListener('animationend', () =>
        field.classList.remove('nls-shake'), { once: true });
    };

    emailEl.addEventListener('input', () => field?.classList.remove('nls-shake'));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailEl.value.trim();
      const toast = window.toast;

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        shakeField();
        emailEl.focus();
        toast?.show?.('Masukkan alamat email yang valid.', { type: 'error' });
        return;
      }

      setLoading(true);

      try {
        const res  = await fetch('https://api.c0desk1.my.id/api/newsletter', {
          method : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body   : JSON.stringify({ email }),
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          shakeField();
          toast?.show?.(
            res.status === 409
              ? 'Email ini sudah terdaftar!'
              : data.error || 'Terjadi kesalahan. Coba lagi.',
            { type: 'error' }
          );
          return;
        }

        emailEl.value = '';
        if (formState) formState.hidden = true;
        if (successEl) successEl.hidden = false;
        
        setTimeout(() => {
          if (successEl) successEl.hidden = true;
          if (formState) formState.hidden = false;
        }, 5000);
        
        toast?.show?.(data.message || 'Berhasil berlangganan!', { type: 'success' });

      } catch {
        shakeField();
        toast?.show?.('Gagal terhubung. Coba lagi nanti.', { type: 'error' });
      } finally {
        setLoading(false);
      }
    });
  })();
</script>