---
// src/components/ui/Newsletter.astro
interface Props {
  heading?    : string;
  subheading? : string;
  placeholder?: string;
  btnLabel?   : string;
}

const {
  heading     = 'Tetap terhubung',
  subheading  = 'Artikel terbaru langsung ke kotak masukmu. Tanpa spam.',
  placeholder = 'nama@email.com',
  btnLabel    = 'Langganan',
} = Astro.props;
---

<section class="nls-wrap">
  <div class="nls-card">

    <!-- Header: icon + copy -->
    <div class="nls-header">
      <div class="nls-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>
      <div>
        <p class="nls-title">{heading}</p>
        <p class="nls-sub">{subheading}</p>
      </div>
    </div>

    <!-- Form state -->
    <div id="nls-form-state">
      <form id="nls-form" class="nls-form" novalidate>
        <div class="nls-field" id="nls-field">
          <input
            id="nls-email"
            type="email"
            required
            placeholder={placeholder}
            autocomplete="email"
            class="nls-input"
            aria-label="Alamat email"
          />
          <button id="nls-submit" type="submit" class="nls-btn">
            <span class="nls-btn-label">{btnLabel}</span>
            <svg class="nls-btn-arrow" viewBox="0 0 20 20" fill="none"
              stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 10h12M11 5l5 5-5 5"/>
            </svg>
            <svg class="nls-spinner" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke-opacity="0.2"/>
              <path d="M12 3a9 9 0 0 1 9 9" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </form>
    </div>

    <!-- Success state -->
    <div id="nls-success" class="nls-success" hidden aria-live="polite">
      <div class="nls-success-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </div>
      <div>
        <p class="nls-success-title">Berhasil terdaftar!</p>
        <p class="nls-success-sub">Cek kotak masukmu untuk konfirmasi.</p>
      </div>
    </div>

    <!-- Note -->
    <p class="nls-note">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor"
        stroke-width="1.5" aria-hidden="true">
        <path d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13z"
          stroke-linecap="round"/>
        <path d="M8 7v4M8 5.5v.01" stroke-linecap="round"/>
      </svg>
      Tidak ada spam. Berhenti kapan saja.
    </p>

  </div>
</section>

<style>
  /* ── Wrap ───────────────────────────────────────────────────────────────── */
  .nls-wrap {
    padding: 2.5rem 1rem;
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--border);
  }

  /* ── Card — sama persis dengan Cookie card ──────────────────────────────── */
  .nls-card {
    width: min(22rem, 100%);
    background: var(--bg);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-xl, 1rem);
    box-shadow:
      0 4px 6px -1px rgba(0,0,0,.05),
      0 10px 24px -4px rgba(0,0,0,.08);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ── Header ─────────────────────────────────────────────────────────────── */
  .nls-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .nls-icon {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg, 0.75rem);
    color: var(--fg-muted);
  }

  .nls-icon svg { width: 1rem; height: 1rem; }

  .nls-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 0.2rem;
    letter-spacing: -0.01em;
  }

  .nls-sub {
    font-size: 0.75rem;
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.45;
  }

  /* ── Field ──────────────────────────────────────────────────────────────── */
  .nls-form { display: flex; flex-direction: column; gap: 0; }

  .nls-field {
    display: flex;
    gap: 0;
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg, 0.75rem);
    padding: 0.25rem 0.25rem 0.25rem 0.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .nls-field:focus-within {
    border-color: var(--fg);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--fg) 8%, transparent);
  }

  .nls-field.nls-shake {
    animation: nls-shake 0.35s ease;
    border-color: #ef4444;
    box-shadow: 0 0 0 3px color-mix(in srgb, #ef4444 10%, transparent);
  }

  @keyframes nls-shake {
    0%,100% { transform: translateX(0); }
    20%     { transform: translateX(-4px); }
    40%     { transform: translateX(4px); }
    60%     { transform: translateX(-3px); }
    80%     { transform: translateX(3px); }
  }

  .nls-input {
    flex: 1;
    min-width: 0;
    padding: 0.45rem 0;
    font-size: 0.8125rem;
    background: transparent;
    border: none;
    outline: none;
    color: var(--fg);
    caret-color: var(--fg);
  }

  .nls-input::placeholder { color: var(--fg-muted); }

  /* ── Button — sama vibe dengan Cookie buttons ───────────────────────────── */
  .nls-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.45rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    background: var(--fg);
    color: var(--bg);
    border: none;
    border-radius: calc(var(--radius-lg, 0.75rem) - 3px);
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.15s, transform 0.1s;
  }

  .nls-btn:hover   { opacity: 0.82; }
  .nls-btn:active  { transform: scale(0.96); }
  .nls-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .nls-btn-arrow {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    transition: transform 0.18s;
  }
  .nls-btn:not(:disabled):hover .nls-btn-arrow { transform: translateX(2px); }

  .nls-spinner {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    display: none;
    animation: nls-spin 0.7s linear infinite;
  }

  @keyframes nls-spin { to { transform: rotate(360deg); } }

  .nls-btn.is-loading .nls-btn-label,
  .nls-btn.is-loading .nls-btn-arrow { display: none; }
  .nls-btn.is-loading .nls-spinner   { display: block; }

  /* ── Success state ───────────────────────────────────────────────────────── */
  .nls-success {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    animation: nls-fade-up 0.35s cubic-bezier(0.34, 1.4, 0.64, 1) both;
  }

  @keyframes nls-fade-up {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .nls-success-icon {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg);
  }

  .nls-success-icon svg { width: 0.875rem; height: 0.875rem; }

  .nls-success-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 0.2rem;
    letter-spacing: -0.01em;
  }

  .nls-success-sub {
    font-size: 0.75rem;
    color: var(--fg-muted);
    margin: 0;
  }

  /* ── Note ───────────────────────────────────────────────────────────────── */
  .nls-note {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.6875rem;
    color: var(--fg-muted);
    margin: 0;
    opacity: 0.7;
  }

  .nls-note svg {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
  }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 400px) {
    .nls-field {
      flex-direction: column;
      padding: 0.625rem;
      gap: 0.5rem;
    }

    .nls-input {
      padding: 0;
      font-size: 1rem; /* hindari iOS zoom */
    }

    .nls-btn {
      width: 100%;
      border-radius: calc(var(--radius-lg, 0.75rem) - 4px);
    }
  }
</style>

<script>
  (() => {
    const form      = document.getElementById('nls-form')      as HTMLFormElement | null;
    const emailEl   = document.getElementById('nls-email')     as HTMLInputElement | null;
    const submitBtn = document.getElementById('nls-submit')    as HTMLButtonElement | null;
    const field     = document.getElementById('nls-field')     as HTMLElement | null;
    const formState = document.getElementById('nls-form-state');
    const successEl = document.getElementById('nls-success');

    if (!form || !emailEl || !submitBtn) return;

    const setLoading = (on: boolean) => {
      submitBtn.disabled = on;
      submitBtn.classList.toggle('is-loading', on);
    };

    const shakeField = () => {
      if (!field) return;
      field.classList.remove('nls-shake');
      void field.offsetWidth; // reflow
      field.classList.add('nls-shake');
      field.addEventListener('animationend', () =>
        field.classList.remove('nls-shake'), { once: true });
    };

    emailEl.addEventListener('input', () => {
      field?.classList.remove('nls-shake');
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailEl.value.trim();
      const toast = (window as any).toast;

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        shakeField();
        emailEl.focus();
        toast?.show?.('Masukkan alamat email yang valid.', { type: 'error' });
        return;
      }

      setLoading(true);

      try {
        const res  = await fetch('https://api.c0desk1.my.id/api/newsletter', {
          method : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body   : JSON.stringify({ email }),
        });

        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          shakeField();
          toast?.show?.(
            res.status === 409
              ? 'Email ini sudah terdaftar!'
              : data.error || 'Terjadi kesalahan. Coba lagi.',
            { type: 'error' }
          );
          return;
        }

        emailEl.value = '';
        if (formState) formState.hidden = true;
        if (successEl) successEl.hidden = false;
        toast?.show?.(data.message || 'Berhasil berlangganan!', { type: 'success' });

      } catch {
        shakeField();
        toast?.show?.('Gagal terhubung. Coba lagi nanti.', { type: 'error' });
      } finally {
        setLoading(false);
      }
    });
  })();
</script>
