---
// src/components/layout/MobileNav.astro

import { siteConfig } from "@/config/site";
---

<div class="md:hidden relative">
  <button 
    id="mobile-menu-button" 
    aria-label="Menu" 
    class="p-2 rounded-md text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800/50 transition-all duration-200"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>
  
  <div 
    id="mobile-dropdown" 
    class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-lg opacity-0 invisible transition-all duration-200 z-50"
  >
    <nav class="flex flex-col p-2">
      {siteConfig.navItems.map(item => (
        <a 
          href={item.href}
          class="px-3 py-2 text-sm font-mono text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded-md transition-colors"
        >
          {item.label}
        </a>
      ))}
      <div class="h-px bg-zinc-100 dark:bg-zinc-800 my-1"></div>
      <a 
        href={siteConfig.links.github}
        target="_blank"
        rel="noopener noreferrer"
        class="px-3 py-2 text-sm font-mono text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded-md transition-colors"
      >
        GitHub
      </a>
    </nav>
  </div>
</div>

<script>
  (function() {
    const menuButton = document.getElementById('mobile-menu-button');
    const dropdown = document.getElementById('mobile-dropdown');
    
    if (!menuButton || !dropdown) return;
    
    let isOpen = false;
    
    const toggleMenu = (e) => {
      e.stopPropagation();
      isOpen = !isOpen;
      
      if (isOpen) {
        dropdown.classList.remove('opacity-0', 'invisible');
        dropdown.classList.add('opacity-100', 'visible');
      } else {
        dropdown.classList.remove('opacity-100', 'visible');
        dropdown.classList.add('opacity-0', 'invisible');
      }
    };
    
    const closeMenu = () => {
      isOpen = false;
      dropdown.classList.remove('opacity-100', 'visible');
      dropdown.classList.add('opacity-0', 'invisible');
    };
    
    menuButton.addEventListener('click', toggleMenu);
    
    document.addEventListener('click', (e) => {
      if (isOpen && !menuButton.contains(e.target) && !dropdown.contains(e.target)) {
        closeMenu();
      }
    });
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
      }
    });
    
    dropdown.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  })();
</script>