---
// src/components/blog/postHeader.astro
import { siteConfig } from '@/config/site';

import PostMeta from './PostMeta.astro';
import Overview from '../blog/BlogOverview.astro';
import PostAuthor from './PostAuthor.astro';
import BlogFeaturedImage from '../blog/BlogFeaturedImage.astro';
import SharePost from '../blog/SharePost.astro';


interface Props {
  title: string;
  description: string;
  pubDate: Date;
  overviewItems?: string[];
  content?: string;
  authorName?: string;
  authorAvatar?: string;
  authorRole?: string;
  authorSlug: string;
  image?: any;
  
}

const {
  title,
  description,
  pubDate,
  overviewItems,
  content = '',
  authorName,
  authorAvatar,
  authorRole,
  authorSlug,
  image
} = Astro.props;

const siteData = siteConfig;
const siteURL = Astro.site?.toString() ?? siteData.siteUrl;
const canonicalURL = new URL(Astro.url.pathname, siteURL).toString();
---

<header class="w-full">
  <div class="flex flex-col items-center text-center gap-4 md:gap-6">
    <h1 class="text-heading-24 md:text-heading-32 lg:text-heading-48 text-center text-(--fg) font-semibold">
      {title}
    </h1>
    {authorName && (
      <PostAuthor
        name={authorName}
        avatar={authorAvatar}
        role={authorRole}
        slug={authorSlug}
      />
    )}
    {content && (
      <div class="w-full mt-4">
        <PostMeta pubDate={pubDate} content={content} />
      </div>
    )}
    {overviewItems && overviewItems.length > 0 && (
      <div class="w-full">
        <Overview items={overviewItems} />
      </div>
    )}
    {image && (
      <div class="prose-custom w-full mt-4">
        <BlogFeaturedImage
          image={image.src}
          alt={image.alt || title}
          caption={(image as any).caption}
        />
      </div>
    )}
    <div class="flex justify-start items-center self-start">
      <SharePost url={canonicalURL} title={title} description={description} />
    </div>
  </div>
</header>