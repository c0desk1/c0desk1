---
// src/components/layout/Header.astro
import Container from "@/components/ui/Container.astro";
import Logo from "@/components/ui/Logo.astro";
import DesktopNav from "./DesktopNav.astro";
import SearchButton from "@/components/ui/SearchButton.astro";
import MenuButton from "@/components/ui/MenuButton.astro";
---

<header id="main-header" class="sticky top-0 z-50 mx-auto w-full">
  <Container size="xl">
    <div class="relative flex items-center h-14">
      <div class="flex items-center shrink-0">
        <Logo />
      </div>
       <div class="absolute inline-flex left-1/2 -translate-x-1/2 order-2">
        <DesktopNav />
      </div>
      <div class="ml-auto flex items-center gap-2 lg:gap-3 order-3">
        <SearchButton />
        <MenuButton />
      </div>
    </div>
  </Container>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-(--border) to-transparent opacity-0 transition-opacity duration-300" id="header-border"></div>
</header>

<style is:global>
  #main-header {
    background-color: transparent;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
  }
  
  #main-header.scrolled {
    background-color: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  
  #main-header.scrolled #header-border {
    opacity: 1;
  }
</style>

<script>
  const header = document.getElementById('main-header');
  if (header) {
    const updateHeader = () => {
      if (window.scrollY > 0) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();
  }
</script>
