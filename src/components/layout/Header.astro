---
// src/components/layout/Header.astro

import Logo from "@/components/ui/Logo.astro";
import DesktopNav from "./DesktopNav.astro";
import MobileNav from "./MobileNav.astro";
import ThemeToggle from "@/components/ui/ThemeToggle.astro";
import Container from "../ui/Container.astro";
---

<header class="sticky top-0 z-50 w-full border-b border-zinc-100 dark:border-zinc-900 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md">
  <Container size="md">
    <div class="grid grid-cols-3 h-14 sm:h-16 items-center">
      <div class="flex items-center">
        <Logo />
      </div>
      <div class="flex justify-center">
        <DesktopNav />
      </div>
      <div class="flex items-center justify-end gap-1">
        <ThemeToggle />
        <MobileNav />
      </div>
    </div>
  </Container>
</header>