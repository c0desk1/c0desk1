---
// src/components/layout/Header.astro
import Logo from "@/components/ui/Logo.astro";
import DesktopNav from "./DesktopNav.astro";
import ThemeToggle from "@/components/ui/ThemeToggle.astro";
import Container from "../ui/Container.astro";
import SearchButton from "../ui/SearchButton.astro";
import MenuButton from "@/components/ui/MenuButton.astro";
---

<header 
  id="main-header"
  class="sticky top-0 z-50 mx-auto w-full bg-(--bg)/80 backdrop-blur-md transition-all duration-300"
>
  <Container size="full">
    <div class="flex h-14 items-center">
      <div class="flex items-center gap-6">
        <Logo />
        <DesktopNav />
      </div>
      <div class="ml-auto flex items-center gap-2">
        <SearchButton />
        <ThemeToggle />
        <MenuButton />
      </div>
    </div>
  </Container>
</header>

<style is:global>
  #main-header {
    box-shadow: 0 1px 0 0 transparent;
  }
  
  #main-header.scrolled {
    box-shadow: 0 1px 0 0 var(--border);
  }
</style>

<script>
  const header = document.getElementById('main-header');
  
  if (header) {
    const updateHeaderBorder = () => {
      if (window.scrollY > 0) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };
    
    window.addEventListener('scroll', updateHeaderBorder);
    updateHeaderBorder();
  }
</script>
