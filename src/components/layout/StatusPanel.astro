---
// src/components/layout/StatusPanel.astro
import Icon from "../ui/Icon";
const services = ['api', 'web', 'cdn', 'bot'];
---

<div id="status-overlay" class="status-overlay fixed inset-0 z-90 bg-(--bg)/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-350"></div>

<div id="status-panel" class="status-panel fixed bottom-0 left-0 right-0 z-100 translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] bg-(--bg) border-t border-(--border) shadow-[0_-8px_40px_rgba(0,0,0,0.06)] dark:shadow-[0_-8px_40px_rgba(0,0,0,0.8)] max-h-[85vh] overflow-y-auto rounded-t-2xl overscroll-contain">
  
  <div class="mx-auto px-5 py-5 sm:px-8 sm:py-7">
    <div class="flex items-center justify-between pb-5 border-b border-(--border) mb-1">
      <div class="flex items-center gap-2.5">
        <span id="panel-dot" class="w-2 h-2 bg-(--bg-muted) shrink-0 transition-colors duration-300"></span>
        <div>
          <p class="text-base font-semibold tracking-tight text-(--fg) leading-relaxed">Status Sistem</p>
          <p id="last-updated-text" class="text-[0.9375rem] text-(--fg-muted) leading-tight mt-0.5">Menunggu sinkronisasi...</p>
        </div>
      </div>
      <button id="close-panel" class="flex items-center justify-center w-8 h-8 rounded-full border border-(--border) text-(--fg-muted) hover:bg-(--bg-subtle) hover:text-(--fg) transition-all duration-150">
        <Icon name="close" className="w-5 h-5" />
      </button>
    </div>

    <div class="flex flex-col">
      {services.map((id) => (
        <div class="group py-4 border-b border-(--border) last:border-none cursor-pointer" onclick={`toggleDetails('${id}')`}>
          <div class="flex items-center justify-between mb-2.5">
            <div class="flex items-center gap-2">
              <span class="text-[0.9375rem] font-semibold tracking-widest text-(--fg) font-mono group-hover:text-(--fg-subtle) transition-colors uppercase">{id}</span>
              <span id={`s-${id}-status-text`} class="text-[0.9375rem] font-medium font-mono opacity-90"></span>
            </div>
            <span id={`s-${id}-metrics`} class="text-[0.9375rem] text-(--fg-muted) font-mono">—</span>
          </div>
          
          <div class="flex items-end gap-[2px] h-7 bg-transparent min-h-[7px]">
            {Array.from({ length: 40 }).map((_, i) => (
              <div 
                data-bar={`${id}-${i}`} 
                class="flex-1 h-full min-w-[2px] bg-(--border) rounded-sm transition-all duration-200 hover:scale-y-115 hover:origin-bottom relative group/bar"
              ></div>
            ))}
          </div>

          <div id={`details-${id}`} class="hidden mt-3 p-3.5 bg-(--bg-subtle) border border-(--border) rounded-lg">
            <div class="grid grid-cols-[repeat(auto-fit,minmax(140px,1fr))] gap-3.5">
              <div>
                <p class="text-[0.8375rem] font-medium tracking-wider uppercase text-(--fg) mb-1">Riwayat Waktu Aktif</p>
                <p id={`s-${id}-uptime-val`} class="text-[0.8375rem] font-mono text-(--fg-muted)">Menghitung...</p>
              </div>
              <div>
                <p class="text-[0.8375rem] font-medium tracking-wider uppercase text-(--fg) mb-1">Identitas Node</p>
                <p id={`s-${id}-node-val`} class="text-[0.8375rem] font-mono text-(--fg-muted)">Mengidentifikasi...</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style is:global>
  .status-overlay.visible { opacity: 1; pointer-events: auto; }
  .status-panel.open { transform: translateY(0); }
  
  .header-dot.pulse { animation: pulse-dot 1.5s ease-in-out infinite; }
  @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  .bar[data-info]:hover::after {
    content: attr(data-info);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg);
    color: var(--fg);
    padding: 5px 8px;
    border-radius: 5px;
    font-size: 11px;
    font-family: 'Geist Mono';
    white-space: nowrap;
    border: 1px solid var(--border);
    z-index: 50;
    pointer-events: none;
  }
</style>

<script is:inline>
(function() {
  const API_URL = "/api/status";
 
  const panel     = document.getElementById("status-panel");
  const overlay   = document.getElementById("status-overlay");
  const closeBtn  = document.getElementById("close-panel");
  const panelDot  = document.getElementById("panel-dot");
  const lastUpdatedEl = document.getElementById("last-updated-text");
  const footerLabel   = document.getElementById("status-label");
  const footerDot     = document.getElementById("status-dot");
  const footerPulse   = document.getElementById("status-pulse");
 
  let latestUpdateTs = null;
  let hasFetched = false;
  const intervals = [];
 
  const STATUS_COLORS = {
    Fast:        "#0ea5e9",
    Operational: "#22c55e",
    Warning:     "#f59e0b",
    Outage:      "#ef4444",
  };
 
  function getRelativeTime(ts) {
    const d = Math.floor((Date.now() - ts) / 1000);
    if (d < 30)   return "Baru saja";
    if (d < 60)   return `${d}s yang lalu`;
    if (d < 3600) return `${Math.floor(d / 60)}m yang lalu`;
    return "Beberapa waktu yang lalu";
  }
 
  function toggleDetails(id) {
    const el = document.getElementById(`details-${id}`);
    if (el) el.classList.toggle("hidden");
  }
  
  window.toggleDetails = toggleDetails;
 
  function openStatus() {
    panel?.classList.add("open");
    overlay?.classList.add("visible");
    document.body.style.overflow = "hidden";

    

    if (!hasFetched) {
      fetchStatus();
      hasFetched = true;
      intervals.push(setInterval(fetchStatus, 300000));
      intervals.push(setInterval(() => {
        if (latestUpdateTs && lastUpdatedEl)
          lastUpdatedEl.textContent = `Periksa otomatis: ${getRelativeTime(latestUpdateTs)}`;
      }, 60000));
    }
  }
 
  function closeStatus() {
    panel?.classList.remove("open");
    overlay?.classList.remove("visible");
    document.body.style.overflow = "";
  }
 
  function updateFooter(overall) {
    const accent = STATUS_COLORS[overall] || "#888";
    if (footerLabel) footerLabel.textContent = overall === "Operational" ? "Semua Sistem Normal" : overall;
    if (footerDot)   footerDot.style.backgroundColor = accent;
    if (footerPulse) footerPulse.style.backgroundColor = accent;
  }
 
  async function fetchFooterStatus() {
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateFooter(data.overall || "Operational");
    } catch {
      if (footerLabel) footerLabel.textContent = "Offline";
      if (footerDot)   footerDot.style.backgroundColor = STATUS_COLORS.Outage;
      if (footerPulse) footerPulse.style.backgroundColor = STATUS_COLORS.Outage;
    }
  }
 
  function updateUI(overall, services, updatedTs) {
    overall = overall || "Operational";
    const accent = STATUS_COLORS[overall] || "#888";
 
    updateFooter(overall);
 
    if (panelDot) {
      panelDot.style.backgroundColor = accent;
      if (overall !== "Operational") panelDot.classList.add("pulse");
      else panelDot.classList.remove("pulse");
    }
 
    if (updatedTs) {
      latestUpdateTs = updatedTs;
      if (lastUpdatedEl)
        lastUpdatedEl.textContent = `Diperbarui ${getRelativeTime(latestUpdateTs)}`;
    }
 
    (services || []).forEach((s) => {
      const name   = s.name;
      const status = s.status || "Outage";
 
      const summaryEl  = document.getElementById(`s-${name}-details-summary`);
      const uptimeEl   = document.getElementById(`s-${name}-uptime-val`);
      const nodeEl     = document.getElementById(`s-${name}-node-val`);
      const metricsEl  = document.getElementById(`s-${name}-metrics`);
      const latencyEl  = document.getElementById(`s-${name}-status-text`);
      const bars       = document.querySelectorAll(`[data-bar^="${name}-"]`);
 
      if (summaryEl) summaryEl.textContent = s.details || "—";
      if (uptimeEl)  uptimeEl.textContent  = `${s.uptime ?? 0}% (40 cek terakhir)`;
      if (nodeEl)    nodeEl.textContent    = s.details || "Node tidak dikenal";
 
      if (latencyEl) {
        latencyEl.textContent = `${s.latency ?? "—"}ms`;
        latencyEl.style.color = STATUS_COLORS[status] || "#888";
      }
 
      if (metricsEl) {
        const up  = typeof s.uptime === "number" ? s.uptime : 100;
        const history = Array.isArray(s.history) ? s.history : [];
        const valid   = history.filter(h => typeof h.latency === "number");
        const avg     = valid.length
          ? Math.round(valid.reduce((a, c) => a + c.latency, 0) / valid.length)
          : null;
        metricsEl.textContent = `${up}% waktu aktif${avg !== null ? ` · avg ${avg}ms` : ""}`;
      }
 
      const history    = Array.isArray(s.history) ? s.history.slice(-40) : [];
      const startIndex = 40 - history.length;
 
      bars.forEach(el => {
        el.style.backgroundColor = "";
        el.style.opacity = "0.3";
        el.removeAttribute("data-info");
      });
 
      history.forEach((h, i) => {
        const el = bars[startIndex + i];
        if (!el) return;
 
        let color = STATUS_COLORS.Outage;
        if (h.status === "Operational") {
          if (h.latency < 50)   color = STATUS_COLORS.Fast;
          else if (h.latency > 1000) color = STATUS_COLORS.Warning;
          else                   color = STATUS_COLORS.Operational;
        }
 
        el.style.backgroundColor = color;
        el.style.opacity = "1";
 
        if (h.ts) {
          const time = new Date(h.ts).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
          const detail = h.details ? ` · ${h.details}` : "";
          el.setAttribute("data-info", `${time} · ${h.latency}ms${detail}`);
        }
      });
    });
  }
 
  async function fetchStatus() {
    if (lastUpdatedEl) lastUpdatedEl.textContent = "Memperbarui...";
    try {
      const res  = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateUI(data.overall, data.services, data.updated);
    } catch {
      if (lastUpdatedEl) lastUpdatedEl.textContent = "Offline";
      updateFooter("Outage");
    } finally {
    }
  }
 
  panel?.addEventListener("touchstart", (e) => {
    const bar = e.target.closest("[data-bar]");
    if (!bar) return;
    e.preventDefault();
    const info = bar.getAttribute("data-info");
    if (info && lastUpdatedEl) lastUpdatedEl.textContent = info;
  }, { passive: false });
 
  document.addEventListener("astro:before-swap", () => {
    intervals.forEach(clearInterval);
  });
 
  document.getElementById("status-toggle")?.addEventListener("click", openStatus);
  closeBtn?.addEventListener("click", closeStatus);
  overlay?.addEventListener("click", closeStatus);
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeStatus(); });
 
  requestIdleCallback(() => {
    fetchFooterStatus();
    intervals.push(setInterval(fetchFooterStatus, 300000));
  });
})();
</script>