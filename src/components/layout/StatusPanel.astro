---
// src/components/layout/StatusPanel.astro

import Icon from "../ui/Icon";

const services = ['api', 'web', 'cdn', 'bot'];
---

<div id="status-overlay" class="status-overlay"></div>
<div id="status-panel" class="status-panel">
  <div class="panel-inner">
    <div class="panel-header">
      <div class="header-left">
        <span id="panel-dot" class="header-dot"></span>
        <div>
          <p class="header-title">Status Sistem</p>
          <p id="last-updated-text" class="header-sub">Menunggu sinkronisasi...</p>
        </div>
      </div>
      <button id="close-panel" class="close-btn" aria-label="Tutup panel status">
        <Icon name="close" className="w-5 h-5" />
      </button>
    </div>
    <div class="services-list">
      {services.map((id) => (
        <div class="service-row" onclick={`toggleDetails('${id}')`}>
          <div class="service-top">
            <div class="service-left">
              <span class="service-name">{id.toUpperCase()}</span>
              <span id={`s-${id}-status-text`} class="service-latency"></span>
            </div>
            <span id={`s-${id}-metrics`} class="service-metrics">—</span>
          </div>
          <div class="bars-wrap">
            {Array.from({ length: 40 }).map((_, i) => (
              <div data-bar={`${id}-${i}`} class="bar"></div>
            ))}
          </div>
          <div id={`details-${id}`} class="service-detail hidden">
            <div class="detail-grid">
              <div>
                <p class="detail-label">Riwayat Waktu Aktif</p>
                <p id={`s-${id}-uptime-val`} class="detail-val">Menghitung...</p>
              </div>
              <div>
                <p class="detail-label">Identitas Node</p>
                <p id={`s-${id}-node-val`} class="detail-val">Mengidentifikasi...</p>
              </div>
              <div>
                <p class="detail-label">Pemeriksaan Terakhir</p>
                <p id={`s-${id}-details-summary`} class="detail-val">—</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="panel-footer">
      <span class="footer-note">Diperbarui otomatis setiap 5 menit</span>
      <button id="refresh-btn" class="refresh-btn">
        <Icon name="arrow-path" className="w-4 h-4" />
        Refresh
      </button>
    </div>
  </div>
</div>

<style is:global>
  .status-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 90;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .status-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .status-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transform: translateY(100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    background: var(--bg);
    border-top: 1px solid var(--border);
    box-shadow: 0 -8px 40px rgba(0, 0, 0, 0.06);
    max-height: 85vh;
    overflow-y: auto;
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
  }

  .status-panel.open {
    transform: translateY(0);
  }

  .dark .status-panel {
    box-shadow: 0 -8px 40px rgba(0, 0, 0, 0.8);
  }

  .panel-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 20px 20px 16px;
  }

  @media (min-width: 640px) {
    .panel-inner {
      padding: 28px 32px 20px;
    }
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4px;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .header-dot {
    width: 8px;
    height: 8px;
    background: var(--bg-muted);
    flex-shrink: 0;
    transition: background 0.3s;
  }

  .header-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
    line-height: 1.65;
  }

  .header-sub {
    font-size: 0.9375rem;
    color: var(--fg-subtle);
    line-height: 1.3;
    margin-top: 1px;
  }

  .close-btn {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .close-btn:hover {
    background: var(--bg-subtle);
    color: var(--fg);
  }

  .services-list {
    display: flex;
    flex-direction: column;
  }

  .service-row {
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.1s;
  }

  .service-row:last-child {
    border-bottom: none;
  }

  .service-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .service-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .service-name {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    font-family: 'Geist Mono', 'SF Mono', ui-monospace, monospace;
    transition: color 0.15s;
  }

  .service-row:hover .service-name {
    color: var(--fg);
  }

  .service-latency {
    font-size: 0.9375rem;
    font-family: 'Geist Mono', 'SF Mono', ui-monospace, monospace;
    font-weight: 500;
    opacity: 0.9;
  }

  .service-metrics {
    font-size: 0.9375rem;
    color: var(--fg-muted);
    font-family: 'Geist Mono', 'SF Mono', ui-monospace, monospace;
  }

  .bars-wrap {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 28px;
    position: relative;
    background: transparent;
    min-height: 28px;
  }

  .bar {
    flex: 1;
    height: 100%;
    min-width: 2px;
    background: var(--border);
    border-radius: 2px;
    transition: background 0.2s, opacity 0.2s, transform 0.1s;
    position: relative;
    cursor: default;
  }

  .bar:empty {
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.05) 2px,
      rgba(0,0,0,0.05) 4px
    );
  }

  .dark .bar:empty {
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 2px,
      rgba(255,255,255,0.05) 2px,
      rgba(255,255,255,0.05) 4px
    );
  }

  .bar:hover {
    transform: scaleY(1.15);
    transform-origin: bottom;
    z-index: 1;
  }

  .bar[data-info]:hover::after {
    content: attr(data-info);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg);
    color: var(--fg);
    padding: 5px 8px;
    border-radius: 5px;
    font-size: 13px;
    font-family: 'Geist Mono';
    white-space: nowrap;
    border: 1px solid var(--border-strong);
    z-index: 50;
    pointer-events: none;
  }

  .service-detail {
    margin-top: 12px;
    padding: 14px 16px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 8px;
  }

  .service-detail.hidden { 
    display: none; 
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 14px;
  }

  .detail-label {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--fg);
    margin-bottom: 3px;
  }

  .detail-val {
    font-size: 0.8375rem;
    font-family: 'Geist Mono', 'SF Mono', ui-monospace, monospace;
    color: var(--fg-muted);
  }

  .panel-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
    gap: 12px;
    flex-wrap: wrap;
  }

  .footer-note {
    font-size: 0.9375rem;
    color: var(--fg-subtle);
  }

  .refresh-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--fg-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .refresh-btn:hover {
    background: var(--bg-muted);
    color: var(--fg);
  }

  .refresh-btn.spinning svg {
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .header-dot.pulse {
    animation: pulse-dot 1.5s ease-in-out infinite;
  }
</style>

<script is:inline>
(function() {
  const API_URL = "/api/status";
 
  const panel     = document.getElementById("status-panel");
  const overlay   = document.getElementById("status-overlay");
  const closeBtn  = document.getElementById("close-panel");
  const refreshBtn = document.getElementById("refresh-btn");
  const panelDot  = document.getElementById("panel-dot");
  const lastUpdatedEl = document.getElementById("last-updated-text");
  const footerLabel   = document.getElementById("status-label");
  const footerDot     = document.getElementById("status-dot");
  const footerPulse   = document.getElementById("status-pulse");
 
  let latestUpdateTs = null;
  let hasFetched = false;
  const intervals = [];
 
  const STATUS_COLORS = {
    Fast:        "#0ea5e9",
    Operational: "#22c55e",
    Warning:     "#f59e0b",
    Outage:      "#ef4444",
  };
 
  function getRelativeTime(ts) {
    const d = Math.floor((Date.now() - ts) / 1000);
    if (d < 30)   return "Baru saja";
    if (d < 60)   return `${d}s yang lalu`;
    if (d < 3600) return `${Math.floor(d / 60)}m yang lalu`;
    return "Beberapa waktu yang lalu";
  }
 
  function toggleDetails(id) {
    const el = document.getElementById(`details-${id}`);
    if (el) el.classList.toggle("hidden");
  }
  
  window.toggleDetails = toggleDetails;
 
  function openStatus() {
    panel?.classList.add("open");
    overlay?.classList.add("visible");
    document.body.style.overflow = "hidden";

    

    if (!hasFetched) {
      fetchStatus();
      hasFetched = true;
      intervals.push(setInterval(fetchStatus, 300000));
      intervals.push(setInterval(() => {
        if (latestUpdateTs && lastUpdatedEl)
          lastUpdatedEl.textContent = `Periksa otomatis: ${getRelativeTime(latestUpdateTs)}`;
      }, 10000));
    }
  }
 
  function closeStatus() {
    panel?.classList.remove("open");
    overlay?.classList.remove("visible");
    document.body.style.overflow = "";
  }
 
  function updateFooter(overall) {
    const accent = STATUS_COLORS[overall] || "#888";
    if (footerLabel) footerLabel.textContent = overall === "Operational" ? "Semua Sistem Normal" : overall;
    if (footerDot)   footerDot.style.backgroundColor = accent;
    if (footerPulse) footerPulse.style.backgroundColor = accent;
  }
 
  async function fetchFooterStatus() {
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateFooter(data.overall || "Operational");
    } catch {
      if (footerLabel) footerLabel.textContent = "Offline";
      if (footerDot)   footerDot.style.backgroundColor = STATUS_COLORS.Outage;
      if (footerPulse) footerPulse.style.backgroundColor = STATUS_COLORS.Outage;
    }
  }
 
  function updateUI(overall, services, updatedTs) {
    overall = overall || "Operational";
    const accent = STATUS_COLORS[overall] || "#888";
 
    updateFooter(overall);
 
    if (panelDot) {
      panelDot.style.backgroundColor = accent;
      if (overall !== "Operational") panelDot.classList.add("pulse");
      else panelDot.classList.remove("pulse");
    }
 
    if (updatedTs) {
      latestUpdateTs = updatedTs;
      if (lastUpdatedEl)
        lastUpdatedEl.textContent = `Diperbarui ${getRelativeTime(latestUpdateTs)}`;
    }
 
    (services || []).forEach((s) => {
      const name   = s.name;
      const status = s.status || "Outage";
 
      const summaryEl  = document.getElementById(`s-${name}-details-summary`);
      const uptimeEl   = document.getElementById(`s-${name}-uptime-val`);
      const nodeEl     = document.getElementById(`s-${name}-node-val`);
      const metricsEl  = document.getElementById(`s-${name}-metrics`);
      const latencyEl  = document.getElementById(`s-${name}-status-text`);
      const bars       = document.querySelectorAll(`[data-bar^="${name}-"]`);
 
      if (summaryEl) summaryEl.textContent = s.details || "—";
      if (uptimeEl)  uptimeEl.textContent  = `${s.uptime ?? 0}% (40 cek terakhir)`;
      if (nodeEl)    nodeEl.textContent    = s.details || "Node tidak dikenal";
 
      if (latencyEl) {
        latencyEl.textContent = `${s.latency ?? "—"}ms`;
        latencyEl.style.color = STATUS_COLORS[status] || "#888";
      }
 
      if (metricsEl) {
        const up  = typeof s.uptime === "number" ? s.uptime : 100;
        const history = Array.isArray(s.history) ? s.history : [];
        const valid   = history.filter(h => typeof h.latency === "number");
        const avg     = valid.length
          ? Math.round(valid.reduce((a, c) => a + c.latency, 0) / valid.length)
          : null;
        metricsEl.textContent = `${up}% waktu aktif${avg !== null ? ` · avg ${avg}ms` : ""}`;
      }
 
      const history    = Array.isArray(s.history) ? s.history.slice(-40) : [];
      const startIndex = 40 - history.length;
 
      bars.forEach(el => {
        el.style.backgroundColor = "";
        el.style.opacity = "0.3";
        el.removeAttribute("data-info");
      });
 
      history.forEach((h, i) => {
        const el = bars[startIndex + i];
        if (!el) return;
 
        let color = STATUS_COLORS.Outage;
        if (h.status === "Operational") {
          if (h.latency < 50)   color = STATUS_COLORS.Fast;
          else if (h.latency > 1000) color = STATUS_COLORS.Warning;
          else                   color = STATUS_COLORS.Operational;
        }
 
        el.style.backgroundColor = color;
        el.style.opacity = "1";
 
        if (h.ts) {
          const time = new Date(h.ts).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
          const detail = h.details ? ` · ${h.details}` : "";
          el.setAttribute("data-info", `${time} · ${h.latency}ms${detail}`);
        }
      });
    });
  }
 
  async function fetchStatus() {
    if (refreshBtn) refreshBtn.classList.add("spinning");
    if (lastUpdatedEl) lastUpdatedEl.textContent = "Memperbarui...";
    try {
      const res  = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateUI(data.overall, data.services, data.updated);
    } catch {
      if (lastUpdatedEl) lastUpdatedEl.textContent = "Offline";
      updateFooter("Outage");
    } finally {
      if (refreshBtn) refreshBtn.classList.remove("spinning");
    }
  }
 
  panel?.addEventListener("touchstart", (e) => {
    const bar = e.target.closest("[data-bar]");
    if (!bar) return;
    e.preventDefault();
    const info = bar.getAttribute("data-info");
    if (info && lastUpdatedEl) lastUpdatedEl.textContent = info;
  }, { passive: false });
 
  document.addEventListener("astro:before-swap", () => {
    intervals.forEach(clearInterval);
  });
 
  document.getElementById("status-toggle")?.addEventListener("click", openStatus);
  closeBtn?.addEventListener("click", closeStatus);
  overlay?..("click", closeStatus);
  refreshBtn?.addEventListener("click", () => { if (hasFetched) fetchStatus(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeStatus(); });
 
  requestIdleCallback(() => {
    fetchFooterStatus();
    intervals.push(setInterval(fetchFooterStatus, 300000));
  });
})();
</script>