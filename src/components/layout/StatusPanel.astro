---
// src/components/layout/StatusPanel.astro
import Icon from "../ui/Icon";

const services = ['api', 'web', 'cdn', 'bot'];
---

<div id="status-overlay" class="status-overlay fixed inset-0 z-90 bg-(--bg)/60 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300"></div>

<div
  id="status-panel"
  class="fixed bottom-0 left-0 right-0 z-100 bg-(--bg) border-t border-(--border) shadow-lg rounded-t-(--radius-xl) max-h-[85vh] overflow-y-auto overscroll-contain transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
  style="transform: translateY(100%);"
  data-open="false"
>
  <div class="max-w-2xl mx-auto p-5 sm:p-7">
    <div class="flex items-center justify-between pb-5 border-b border-(--border) mb-1">
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2">
          <span id="panel-dot" class="w-2.5 h-2.5 bg-(--bg-subtle) shrink-0 transition-colors"></span>
          <p class="text-sm md:text-base font-semibold tracking-tight text-(--fg) leading-relaxed">Status Sistem</p>
        </div>
        <p id="last-updated-text" class="text-[13px] md:text-sm text(--fg-muted) leading-tight mt-0.5">Menunggu sinkronisasi...</p>
      </div>
      <button id="close-panel" class="w-8 h-8 flex items-center justify-center rounded-full border border-(--border) bg-transparent text-(--fg) hover:bg-(--bg-muted) transition-all" aria-label="Tutup panel status">
        <Icon name="close" className="w-5 h-5" />
      </button>
    </div>

    <div class="services-list flex flex-col divide-y divide-(--border)">
      {services.map((id) => (
        <div class="service-row py-4 cursor-pointer transition-colors hover:bg-(--bg-muted)/50" data-service={id}>
          <div class="flex justify-between items-center mb-2.5">
            <div class="flex items-center gap-2">
              <span class="text-[13px] md:text-sm font-mono font-semibold tracking-wide text-(--fg)">{id.toUpperCase()}</span>
              <span id={`s-${id}-status-text`} class="text-[13px] md:text-sm font-mono opacity-90"></span>
            </div>
            <span id={`s-${id}-metrics`} class="text-[13px] md:text-sm text-(--fg-subtle) font-mono">—</span>
          </div>
          <div class="flex items-end gap-[2px] h-7 bg-transparent min-h-[28px]">
            <canvas id={`chart-${id}`} data-service={id} class="w-full h-7 cursor-crosshair" width="320" height="28"></canvas>
          </div>
          <div id={`details-${id}`} class="hidden mt-3 p-3.5 bg-(--bg-subtle)/50 border border-(--border) rounded-(--radius-lg)">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3.5">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-(--fg) mb-1">Waktu Aktif</p>
                <p id={`s-${id}-uptime-val`} class="text-xs font-mono text-(--fg-muted)">Menghitung...</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-(--fg) mb-1">Node</p>
                <p id={`s-${id}-node-val`} class="text-xs font-mono text-(--fg-muted)">Mengidentifikasi...</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-(--fg) mb-1">Pemeriksaan Terakhir</p>
                <p id={`s-${id}-details-summary`} class="text-xs font-mono text-(--fg-muted)">—</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style is:global>
  #status-panel[data-open="true"] {
    transform: translateY(0)!important;
  }

.status-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

.header-dot.pulse {
    animation: pulse-dot 1.5s ease-in-out infinite;
  }

  canvas {
    display: block;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
    touch-action: none;
  }
</style>

<script is:inline>
(function() {
  const API_URL = "/api/status";

  const panel = document.getElementById("status-panel");
  const overlay = document.getElementById("status-overlay");
  const closeBtn = document.getElementById("close-panel");
  const panelDot = document.getElementById("panel-dot");
  const lastUpdatedEl = document.getElementById("last-updated-text");
  const footerLabel = document.getElementById("status-label");
  const footerDot = document.getElementById("status-dot");
  const footerPulse = document.getElementById("status-pulse");

  let latestUpdateTs = null;
  let hasFetched = false;
  const intervals = [];

  const STATUS_COLORS = {
    Fast: "#0ea5e9",
    Operational: "#22c55e",
    Warning: "#f59e0b",
    Outage: "#ef4444",
  };

  function getRelativeTime(ts) {
    const d = Math.floor((Date.now() - ts) / 1000);
    if (d < 30) return "Baru saja";
    if (d < 60) return `${d}s yang lalu`;
    if (d < 3600) return `${Math.floor(d / 60)}m yang lalu`;
    return "Beberapa waktu yang lalu";
  }

  const servicesContainer = document.querySelector('.services-list');
  if (servicesContainer) {
    servicesContainer.addEventListener('click', (e) => {
      const serviceRow = e.target.closest('.service-row');
      if (!serviceRow) return;
      const id = serviceRow.dataset.service;
      if (id) {
        const detailsEl = document.getElementById(`details-${id}`);
        if (detailsEl) detailsEl.classList.toggle('hidden');
      }
    });
  }

  function openStatus() {
    if (panel) panel.setAttribute('data-open', 'true');
    if (overlay) overlay.classList.add("visible");
    document.body.style.overflow = "hidden";

    if (!hasFetched) {
      fetchStatus();
      hasFetched = true;
      intervals.push(setInterval(fetchStatus, 300000));
      intervals.push(setInterval(() => {
        if (latestUpdateTs && lastUpdatedEl)
          lastUpdatedEl.textContent = `Periksa otomatis: ${getRelativeTime(latestUpdateTs)}`;
      }, 60000));
    }
  }

  function closeStatus() {
    if (panel) panel.setAttribute('data-open', 'false');
    if (overlay) overlay.classList.remove("visible");
    document.body.style.overflow = "";
  }

  window.openStatusPanel = openStatus;
  window.closeStatusPanel = closeStatus;

  function updateFooter(overall) {
    const accent = STATUS_COLORS[overall] || "#888";
    if (footerLabel) footerLabel.textContent = overall === "Operational"? "Semua Sistem Normal." : overall;
    footerLabel.style.color = accent;
    if (footerDot) footerDot.style.backgroundColor = accent;
    if (footerPulse) footerPulse.style.backgroundColor = accent;
  }

  async function fetchFooterStatus() {
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateFooter(data.overall || "Operational");
    } catch {
      if (footerLabel) footerLabel.textContent = "Offline";
    footerLabel.style.color = STATUS_COLORS.Outage;
      if (footerDot) footerDot.style.backgroundColor = STATUS_COLORS.Outage;
      if (footerPulse) footerPulse.style.backgroundColor = STATUS_COLORS.Outage;
    }
  }

function renderBarChart(canvas, history) {
  if (!canvas) return;

  const dpr = window.devicePixelRatio || 1;
  const rect = canvas.getBoundingClientRect();

  if (canvas.width!== rect.width * dpr) {
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
  }

  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);

  const W = rect.width;
  const H = rect.height;
  const data = Array.isArray(history)? history.slice(-40) : [];

  ctx.clearRect(0, 0, W, H);
  if (!data.length) return;

  ctx.imageSmoothingEnabled = false;

  const barCount = data.length;
  const gap = 2;
  const barWidth = 2;
  const barHeight = H - 4;
  const y = 2;

  data.forEach((h, i) => {
    const x = Math.floor(i * (W / barCount) + (W / barCount / 2) - (barWidth / 2));
    const lat = h.latency || 0;

    let color = 'rgba(128,128,128,0.15)';
    if (h.status === "Operational") {
      if (lat < 50) color = '#0ea5e9';
      else if (lat < 200) color = '#22c55e';
      else if (lat < 500) color = '#f59e0b';
      else color = '#ef4444';
    } else {
      color = '#ef4444';
    }

    ctx.fillStyle = color;
    ctx.fillRect(x, y, barWidth, barHeight);
  });

  if (!canvas._tooltipAttached) {
    const handleMove = (e) => {
      const rect = canvas.getBoundingClientRect();
      const clientX = e.touches? e.touches[0].clientX : e.clientX;
      const x = clientX - rect.left;
      const idx = Math.floor((x / rect.width) * data.length);
      const h = data[idx];
      if (h && h.ts && lastUpdatedEl) {
        const time = new Date(h.ts).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
        lastUpdatedEl.textContent = `${time} · ${h.latency}ms`;
      }
    };
    const handleLeave = () => {
      if (latestUpdateTs && lastUpdatedEl)
        lastUpdatedEl.textContent = `Diperbarui ${getRelativeTime(latestUpdateTs)}`;
    };
    canvas.addEventListener('mousemove', handleMove);
    canvas.addEventListener('touchstart', handleMove, { passive: true });
    canvas.addEventListener('mouseleave', handleLeave);
    canvas.addEventListener('touchend', handleLeave);
    canvas._tooltipAttached = true;
  }
}

  function updateUI(overall, services, updatedTs) {
    overall = overall || "Operational";
    const accent = STATUS_COLORS[overall] || "#888";

    updateFooter(overall);

    if (panelDot) {
      panelDot.style.backgroundColor = accent;
      if (overall!== "Operational") panelDot.classList.add("pulse");
      else panelDot.classList.remove("pulse");
    }

    if (updatedTs) {
      latestUpdateTs = updatedTs;
      if (lastUpdatedEl)
        lastUpdatedEl.textContent = `Diperbarui ${getRelativeTime(latestUpdateTs)}`;
    }

    (services || []).forEach((s) => {
      const name = s.name;
      const status = s.status || "Outage";

      const summaryEl = document.getElementById(`s-${name}-details-summary`);
      const uptimeEl = document.getElementById(`s-${name}-uptime-val`);
      const nodeEl = document.getElementById(`s-${name}-node-val`);
      const metricsEl = document.getElementById(`s-${name}-metrics`);
      const latencyEl = document.getElementById(`s-${name}-status-text`);
      const canvas = document.getElementById(`chart-${name}`);

      if (summaryEl) summaryEl.textContent = s.details || "—";
      if (uptimeEl) uptimeEl.textContent = `${s.uptime?? 0}% (40 cek terakhir)`;
      if (nodeEl) nodeEl.textContent = s.details || "Node tidak dikenal";

      if (latencyEl) {
        latencyEl.textContent = `${s.latency?? "—"}ms`;
        latencyEl.style.color = STATUS_COLORS[status] || "#888";
      }

      if (metricsEl) {
        const up = typeof s.uptime === "number"? s.uptime : 100;
        const history = Array.isArray(s.history)? s.history : [];
        const valid = history.filter(h => typeof h.latency === "number");
        const avg = valid.length
       ? Math.round(valid.reduce((a, c) => a + c.latency, 0) / valid.length)
          : null;
        metricsEl.textContent = `${up}% waktu aktif${avg!== null? ` · avg ${avg}ms` : ""}`;
      }

      renderBarChart(canvas, s.history);
    });
  }

  async function fetchStatus() {
    if (lastUpdatedEl &&!hasFetched) lastUpdatedEl.textContent = "Memperbarui...";
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateUI(data.overall, data.services, data.updated);
    } catch {
      if (lastUpdatedEl) lastUpdatedEl.textContent = "Offline";
      updateFooter("Outage");
    }
  }

  document.addEventListener("astro:before-swap", () => {
    intervals.forEach(clearInterval);
  });

  document.addEventListener('click', (e) => {
    if (e.target.closest('#status-toggle')) {
      e.preventDefault();
      openStatus();
    }
  });

  if (closeBtn) closeBtn.addEventListener("click", closeStatus);
  if (overlay) overlay.addEventListener("click", closeStatus);
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeStatus(); });

  const idleCallback = window.requestIdleCallback || function(cb) { setTimeout(cb, 1); };
  idleCallback(() => {
    fetchFooterStatus();
    intervals.push(setInterval(fetchFooterStatus, 300000));
  });
})();
</script>
