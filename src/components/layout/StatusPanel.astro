---
// src/components/layout/StatusPanel.astro
const services = ['api', 'web', 'cdn', 'bot'];
---

<div 
  id="status-overlay" 
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-90 opacity-0 pointer-events-none transition-opacity duration-500"
></div>

<div
  id="status-panel"
  class="fixed bottom-0 left-0 right-0 translate-y-full transition-transform duration-500 cubic-bezier(0.4, 0, 0.2, 1) bg-white dark:bg-black border-t border-black/20 dark:border-zinc-900 z-100 shadow-[0_-20px_50px_-12px_rgba(0,0,0,0.5)]"
>
  <div class="max-w-screen-lg mx-auto p-6 md:p-10">
    
    <div class="flex items-start justify-between mb-10 border-b border-zinc-900/50 pb-6">
      <div class="flex items-start gap-3">
        <div id="panel-dot" class="w-2.5 h-2.5 rounded-full bg-zinc-700 mt-1"></div>
        <div class="flex flex-col gap-1">
          <h3 class="text-[12px] sm:text-[13px] font-semibold text-black dark:text-white leading-none">
            Status Sistem
          </h3>
          <span id="last-updated-text" class="text-[11px] sm:text-[12px] font-medium text-zinc-500">
            Menunggu sinkronisasi...
          </span>
        </div>
      </div>

      <button id="close-panel" class="p-2 -mr-2 text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-black/10 dark:hover:bg-zinc-800/50 rounded-full transition-colors cursor-pointer">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>

    <div class="flex flex-col w-full mt-4">
      {services.map((id) => (
        <div class="mb-6 pb-6 border-b border-zinc-900/50">
          
          <span class="text-[12px] sm:text-[13px] font-semibold uppercase text-white mb-2 block tracking-wider">{id}</span>
          
          <div class="flex flex-wrap gap-[2px] w-full py-1">
            {Array.from({ length: 40 }).map((_, i) => (
              <div 
                data-bar={`${id}-${i}`}
                class="w-1.5 h-6 rounded-[1px] bg-zinc-900 transition-all duration-300 border border-white/5"
              ></div>
            ))}
          </div>
          
        </div>
      ))}
    </div>

  </div>
</div>

<script is:inline>
  const API_URL = "https://api.c0desk1.my.id";

  const panel = document.getElementById("status-panel");
  const overlay = document.getElementById("status-overlay");
  const toggle = document.getElementById("status-toggle");
  const closeBtn = document.getElementById("close-panel");

  const panelDot = document.getElementById("panel-dot");
  const footerLabel = document.getElementById("status-label");
  const footerDot = document.getElementById("status-dot");
  const footerPulse = document.getElementById("status-pulse");
  const lastUpdatedEl = document.getElementById("last-updated-text");

  let latestUpdateTs = null;

  function getRelativeTime(timestamp) {
    const diff = Math.floor((Date.now() - timestamp) / 1000);
    if (diff < 60) return "Diperbarui baru saja";
    const minutes = Math.floor(diff / 60);
    return `Diperbarui ${minutes}m yang lalu`;
  }

  function openStatus() {
    panel?.classList.remove("translate-y-full");
    overlay?.classList.remove("opacity-0", "pointer-events-none");
    overlay?.classList.add("opacity-100", "pointer-events-auto");
    document.body.style.overflow = "hidden";
  }

  function closeStatus() {
    panel?.classList.add("translate-y-full");
    overlay?.classList.remove("opacity-100", "pointer-events-auto");
    overlay?.classList.add("opacity-0", "pointer-events-none");
    document.body.style.overflow = "";
  }

  function updateUI(overall, services, updatedTs) {
    const colors = {
      Operational: "#10b981",
      Degraded: "#f59e0b",
      Outage: "#ef4444"
    };

    overall = overall || "Operational";
    const accent = colors[overall] || "#3f3f46";

    // Header updates (Dot & Time)
    if (panelDot) {
      panelDot.style.backgroundColor = accent;
      panelDot.className = "w-2.5 h-2.5 rounded-full " + (overall === "Operational" ? "" : "animate-pulse");
    }

    if (updatedTs) {
      latestUpdateTs = updatedTs;
      if (lastUpdatedEl) lastUpdatedEl.textContent = getRelativeTime(latestUpdateTs);
    }

    (services || []).forEach((s) => {
      const name = s.name;
      const status = s.status || "Outage";
      const bars = document.querySelectorAll(`[data-bar^="${name}-"]`);

      // Calculate bar placement from right
      const history = Array.isArray(s.history) ? s.history.slice(-40) : [];
      const startIndex = 40 - history.length;

      // Reset bars to default deep black
      bars.forEach(el => {
        if(el) el.style.backgroundColor = "#18181b"; // bg-zinc-900
      });

      // Color bars based on historical status
      history.forEach((h, i) => {
        const el = bars[startIndex + i];
        if (!el) return;
        const hStatus = h?.status || "Outage";
        el.style.backgroundColor = colors[hStatus] || "#333";
      });
    });
  }

  async function fetchStatus() {
    try {
      const res = await fetch(`${API_URL}/status/all?t=${Date.now()}`);
      if (!res.ok) throw new Error();

      const data = await res.json();
      // Update UI with historical data, but only process bars
      updateUI(data.overall, data.services, data.updated);
    } catch {
      if (footerLabel) footerLabel.textContent = "Offline";
    }
  }

  toggle?.addEventListener("click", openStatus);
  closeBtn?.addEventListener("click", closeStatus);
  overlay?.addEventListener("click", closeStatus);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeStatus();
  });

  // Ticks every 60 seconds to update the "2m yang lalu" text dynamically without fetching
  setInterval(() => {
    if (latestUpdateTs && lastUpdatedEl) {
      lastUpdatedEl.textContent = getRelativeTime(latestUpdateTs);
    }
  }, 60000);

  fetchStatus();
  setInterval(fetchStatus, 120000);
</script>