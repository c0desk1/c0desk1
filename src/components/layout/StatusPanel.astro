---
// src/components/layout/StatusPanel.astro
import Icon from "../ui/Icon";
import { getCurrentLocale, getLabel } from "@/utils/i18n";

const locale = getCurrentLocale(Astro);

const services = ["api", "web", "cdn", "bot"] as const;

const labels = {
  waiting: getLabel(locale, 's_WaitingSync') || "Menunggu sinkronisasi...",
  justNow: getLabel(locale, 's_JustNow') || "Baru saja",
  ago: getLabel(locale, 's_Ago') || "yang lalu",
  operational: getLabel(locale, 's_AllSystemsNormal') || "Semua Sistem Normal.",
  updated: getLabel(locale, 's_Updated') || "Diperbarui",
  checks: getLabel(locale, 's_LastChecks') || "cek terakhir",
  offline: getLabel(locale, 's_Offline') || "Offline",
  uptimeLabel: getLabel(locale, 's_Uptime') || "Waktu Aktif",
  avg: getLabel(locale, 's_Average') || "rata-rata",
  nodeIdent: getLabel(locale, 's_IdentifyingNode') || "Mengidentifikasi...",
  calc: getLabel(locale, 's_Calculating') || "Menghitung...",
  systemStatus: getLabel(locale, 's_SystemStatus') || "Status Sistem",
  closePanel: getLabel(locale, 's_ClosePanel') || "Tutup panel",
  uptime: getLabel(locale, 's_Uptime') || "Waktu Aktif",
  node: getLabel(locale, 's_Node') || "Node",
  lastCheck: getLabel(locale, 's_LastCheck') || "Pemeriksaan Terakhir",
  someTimeAgo: getLabel(locale, 's_SomeTimeAgo') || "Beberapa waktu lalu",
  globalEdge: getLabel(locale, 's_GlobalEdge') || "Global Edge",
};
---

<!-- Overlay -->
<div id="status-overlay" class="sp-overlay"></div>

<!-- Panel -->
<div
  id="status-panel"
  class="sp-panel"
  style="transform: translateY(100%);"
  data-open="false"
  data-locale={locale}
  role="dialog"
  aria-modal="true"
  aria-label={labels.systemStatus}
>
  <div class="sp-inner">

    <!-- Header -->
    <div class="sp-header">
      <div class="sp-header-meta">
        <div class="sp-header-title">
          <span id="panel-dot" class="sp-dot"></span>
          <p class="sp-title">{labels.systemStatus}</p>
        </div>
        <p id="last-updated-text" class="sp-updated">{labels.waiting}</p>
      </div>
      <button
        id="close-panel"
        class="sp-close"
        aria-label={labels.closePanel}
      >
        <Icon name="close" className="sp-close-icon" />
      </button>
    </div>

    <!-- Service rows -->
    <div class="sp-services services-list">
      {services.map((id) => (
        <div class="sp-row service-row" data-service={id}>

          <div class="sp-row-header">
            <div class="sp-row-left">
              <span class="sp-service-name">{id.toUpperCase()}</span>
              <span id={`s-${id}-status-text`} class="sp-latency"></span>
            </div>
            <span id={`s-${id}-metrics`} class="sp-metrics">—</span>
          </div>

          <canvas
            id={`chart-${id}`}
            data-service={id}
            class="sp-canvas"
            width="320"
            height="28"
          ></canvas>

          <div id={`details-${id}`} class="sp-details sp-details--hidden">
            <div class="sp-details-grid">
              <div>
                <p class="sp-detail-label">{labels.uptime}</p>
                <p id={`s-${id}-uptime-val`} class="sp-detail-val">{labels.calc}</p>
              </div>
              <div>
                <p class="sp-detail-label">{labels.node}</p>
                <p id={`s-${id}-node-val`} class="sp-detail-val">{labels.nodeIdent}</p>
              </div>
              <div>
                <p class="sp-detail-label">{labels.lastCheck}</p>
                <p id={`s-${id}-details-summary`} class="sp-detail-val">—</p>
              </div>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</div>

<style is:global>
 .sp-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    background-color: color-mix(in srgb, var(--bg) 60%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

 .sp-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

 .sp-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background-color: var(--bg);
    border-top: 1px solid var(--border);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    max-height: 85dvh;
    overflow-y: auto;
    overscroll-behavior: contain;
    transition: transform 0.5s var(--ease);
    box-shadow: var(--shadow-lg);
  }

 .sp-panel[data-open="true"] {
    transform: translateY(0)!important;
  }

 .sp-inner {
    max-width: 42rem;
    margin-inline: auto;
    padding: 1.5rem 1.25rem 2rem;
  }

  @media (min-width: 640px) {
  .sp-inner { padding: 2rem 1.75rem 2.5rem; }
  }

 .sp-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.25rem;
  }

 .sp-header-meta {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

 .sp-header-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

 .sp-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-full);
    background-color: var(--border-strong);
    flex-shrink: 0;
    transition: background-color 0.3s ease;
  }

 .sp-dot.pulse {
    animation: sp-pulse 1.5s ease-in-out infinite;
  }

  @keyframes sp-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

 .sp-title {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 0;
    line-height: 1.25;
  }

 .sp-updated {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    letter-spacing: 0;
    line-height: 1.4;
    margin: 0;
  }

 .sp-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-subtle);
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

 .sp-close:hover { background-color: var(--bg-muted); color: var(--fg); }
 .sp-close:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

 .sp-close-icon { width: 1rem; height: 1rem; display: block; }

 .sp-row {
    padding-block: 1rem;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
  }

 .sp-row:last-child { border-bottom: none; }

 .sp-row-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.625rem;
  }

 .sp-row-left {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

 .sp-service-name {
    font-size: 0.6875rem;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    color: var(--fg);
  }

 .sp-latency,
 .sp-metrics {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    color: var(--fg-subtle);
    letter-spacing: 0;
  }

 .sp-canvas {
    display: block;
    width: 100%;
    height: 1.75rem;
    cursor: crosshair;
    image-rendering: crisp-edges;
    touch-action: none;
  }

 .sp-details {
    margin-top: 0.75rem;
    padding: 0.875rem 1rem;
    background-color: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    animation: sp-fadeup 0.2s var(--ease) both;
  }

  @keyframes sp-fadeup {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

 .sp-details--hidden { display: none; }

 .sp-details-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  @media (min-width: 480px) {
  .sp-details-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

 .sp-detail-label {
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    font-family: var(--font-sans);
    margin: 0 0 0.25rem;
  }

 .sp-detail-val {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--fg-muted);
    margin: 0;
    letter-spacing: 0;
  }
</style>

<script is:inline define:vars={{ labels }}>
(function () {
  const API_URL = "/api/status/";

  const panel = document.getElementById("status-panel");
  const locale = panel?.dataset.locale || "id";
  const overlay = document.getElementById("status-overlay");
  const closeBtn = document.getElementById("close-panel");
  const panelDot = document.getElementById("panel-dot");
  const lastUpdEl = document.getElementById("last-updated-text");
  const footerLabel = document.getElementById("status-label");
  const footerDot = document.getElementById("status-dot");
  const footerPulse = document.getElementById("status-pulse");

  let latestUpdateTs = null;
  let hasFetched = false;
  const intervals = [];

  const STATUS_COLORS = {
    Fast: "#0ea5e9",
    Operational: "#22c55e",
    Warning: "#f59e0b",
    Outage: "#ef4444",
  };

  function relTime(ts) {
    const s = Math.floor((Date.now() - ts) / 1000);
    if (s < 30) return labels.justNow;
    if (s < 60) return `${s}s ${labels.ago}`;
    if (s < 3600) return `${Math.floor(s / 60)}m ${labels.ago}`;
    return labels.someTimeAgo;
  }

  function openStatus() {
    panel?.setAttribute("data-open", "true");
    overlay?.classList.add("visible");
    document.body.style.overflow = "hidden";

    if (!hasFetched) {
      fetchStatus();
      hasFetched = true;
      intervals.push(setInterval(fetchStatus, 300_000));
      intervals.push(setInterval(() => {
        if (latestUpdateTs && lastUpdEl)
          lastUpdEl.textContent = `${labels.updated} ${relTime(latestUpdateTs)}`;
      }, 60_000));
    }
  }

  function closeStatus() {
    panel?.setAttribute("data-open", "false");
    overlay?.classList.remove("visible");
    document.body.style.overflow = "";
  }

  window.openStatusPanel = openStatus;
  window.closeStatusPanel = closeStatus;

  function updateFooter(overall) {
    const color = STATUS_COLORS[overall] || "#888";
    if (footerLabel) {
      footerLabel.textContent = overall === "Operational"? labels.operational : overall;
      footerLabel.style.color = color;
    }
    if (footerDot) footerDot.style.backgroundColor = color;
    if (footerPulse) footerPulse.style.backgroundColor = color;
  }

  async function fetchFooterStatus() {
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateFooter(data.overall || "Operational");
    } catch {
      if (footerLabel) footerLabel.textContent = labels.offline;
      updateFooter("Outage");
    }
  }

  async function fetchStatus() {
    if (lastUpdEl &&!hasFetched) lastUpdEl.textContent = labels.waiting;
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateUI(data.overall, data.services, data.updated);
    } catch {
      if (lastUpdEl) lastUpdEl.textContent = labels.offline;
      updateFooter("Outage");
    }
  }

  function updateUI(overall, services, updatedTs) {
    overall = overall || "Operational";
    const color = STATUS_COLORS[overall] || "#888";

    updateFooter(overall);

    if (panelDot) {
      panelDot.style.backgroundColor = color;
      panelDot.classList.toggle("pulse", overall!== "Operational");
    }

    if (updatedTs) {
      latestUpdateTs = updatedTs;
      if (lastUpdEl)
        lastUpdEl.textContent = `${labels.updated} ${relTime(latestUpdateTs)}`;
    }

    (services || []).forEach((s) => {
      const id = s.name;
      const status = s.status || "Outage";
      const get = (sfx) => document.getElementById(`s-${id}-${sfx}`);

      const summaryEl = get("details-summary");
      const uptimeEl = get("uptime-val");
      const nodeEl = get("node-val");
      const metricsEl = get("metrics");
      const latEl = get("status-text");
      const canvas = document.getElementById(`chart-${id}`);

      if (summaryEl) summaryEl.textContent = s.details || "—";
      if (uptimeEl) uptimeEl.textContent = `${s.uptime?? 0}% (${labels.checks})`;
      if (nodeEl) nodeEl.textContent = s.details || labels.globalEdge;

      if (latEl) {
        latEl.textContent = `${s.latency?? "—"}ms`;
        latEl.style.color = STATUS_COLORS[status] || "#888";
      }

      if (metricsEl) {
        const up = typeof s.uptime === "number"? s.uptime : 100;
        const history = Array.isArray(s.history)? s.history : [];
        const valid = history.filter((h) => typeof h.latency === "number");
        const avg = valid.length
        ? Math.round(valid.reduce((a, c) => a + c.latency, 0) / valid.length)
          : null;
        metricsEl.textContent =
          `${up}% ${labels.uptimeLabel}${avg!== null? ` · ${labels.avg} ${avg}ms` : ""}`;
      }

      if (canvas) renderBarChart(canvas, s.history);
    });
  }

  function renderBarChart(canvas, history) {
    if (!canvas) return;

    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();

    if (canvas.width!== rect.width * dpr) {
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + "px";
      canvas.style.height = rect.height + "px";
    }

    const ctx = canvas.getContext("2d");
    ctx.scale(dpr, dpr);

    const data = Array.isArray(history)? history.slice(-40) : [];
    ctx.clearRect(0, 0, rect.width, rect.height);
    if (!data.length) return;

    ctx.imageSmoothingEnabled = false;

    const W = rect.width;
    const H = rect.height;
    const barW = 2;
    const barH = H - 4;
    const y = 2;

    data.forEach((h, i) => {
      const x = Math.floor(i * (W / data.length) + W / data.length / 2 - barW / 2);
      const lat = h.latency || 0;
      let color = "rgba(128,128,128,0.15)";

      if (h.status === "Operational") {
        if (lat < 50) color = "#0ea5e9";
        else if (lat < 200) color = "#22c55e";
        else if (lat < 500) color = "#f59e0b";
        else color = "#ef4444";
      } else {
        color = "#ef4444";
      }

      ctx.fillStyle = color;
      ctx.fillRect(x, y, barW, barH);
    });

    if (!canvas._tooltipAttached) {
      const localeCode = locale === "id"? "id-ID" : "en-US";

      const onMove = (e) => {
        const r = canvas.getBoundingClientRect();
        const clientX = e.touches? e.touches[0].clientX : e.clientX;
        const idx = Math.floor(((clientX - r.left) / r.width) * data.length);
        const h = data[idx];
        if (h && h.ts && lastUpdEl) {
          const time = new Date(h.ts).toLocaleTimeString(localeCode, {
            hour: "2-digit", minute: "2-digit",
          });
          lastUpdEl.textContent = `${time} · ${h.latency}ms`;
        }
      };

      const onLeave = () => {
        if (latestUpdateTs && lastUpdEl)
          lastUpdEl.textContent = `${labels.updated} ${relTime(latestUpdateTs)}`;
      };

      canvas.addEventListener("mousemove", onMove);
      canvas.addEventListener("touchstart", onMove, { passive: true });
      canvas.addEventListener("mouseleave", onLeave);
      canvas.addEventListener("touchend", onLeave);
      canvas._tooltipAttached = true;
    }
  }

  document.querySelector(".services-list")?.addEventListener("click", (e) => {
    const row = e.target.closest(".service-row");
    if (!row) return;
    document.getElementById(`details-${row.dataset.service}`)
   ?.classList.toggle("sp-details--hidden");
  });

  document.addEventListener("click", (e) => {
    if (e.target.closest("#status-toggle")) {
      e.preventDefault();
      openStatus();
    }
  });

  closeBtn?.addEventListener("click", closeStatus);
  overlay?.addEventListener("click", closeStatus);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeStatus();
  });
  document.addEventListener("astro:before-swap", () => {
    intervals.forEach(clearInterval);
  });

  const idle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));
  idle(() => {
    fetchFooterStatus();
    intervals.push(setInterval(fetchFooterStatus, 300_000));
  });
})();
</script>