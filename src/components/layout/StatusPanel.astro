---
// src/components/layout/StatusPanel.astro
const services = ['api', 'web', 'cdn', 'bot'];
---

<div 
  id="status-overlay" 
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-90 opacity-0 pointer-events-none transition-opacity duration-500"
></div>

<div
  id="status-panel"
  class="fixed bottom-0 left-0 right-0 translate-y-full transition-transform duration-500 cubic-bezier(0.4, 0, 0.2, 1) bg-white dark:bg-black border-t border-black/20 dark:border-zinc-900 z-100 shadow-[0_-20px_50px_-12px_rgba(0,0,0,0.5)]"
>
  <div class="max-w-screen-lg mx-auto p-6 md:p-10">
    
    <div class="flex items-start justify-between mb-8 border-b border-zinc-900/50 pb-6">
      <div class="flex items-start gap-3">
        <div id="panel-dot" class="w-2.5 h-2.5 rounded-full bg-zinc-700 mt-1"></div>
        <div class="flex flex-col gap-1">
          <h3 class="text-[12px] sm:text-[13px] font-semibold text-black dark:text-white leading-none">
            Status Sistem
          </h3>
          <span id="last-updated-text" class="text-[11px] sm:text-[12px] font-medium text-zinc-500">
            Menunggu sinkronisasi...
          </span>
        </div>
      </div>

      <button id="close-panel" aria-label="Tutup panel status" class="p-2 -mr-2 text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white hover:bg-black/10 dark:hover:bg-zinc-800/50 rounded-full transition-colors cursor-pointer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>

    <div class="flex flex-col w-full">
      {services.map((id) => (
        <div class="mb-6 pb-4 group cursor-pointer" onclick={`document.getElementById('details-${id}').classList.toggle('hidden')`}>
          
          <div class="flex items-center justify-between mb-3">
            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-2">
                <span class="text-[11px] font-bold uppercase tracking-widest text-zinc-400 group-hover:text-white transition-colors">{id}</span>
                <span id={`s-${id}-status-text`} class="text-[11px] font-medium opacity-80"></span>
              </div>
              <span id={`s-${id}-details-summary`} class="text-[9px] font-mono uppercase text-zinc-500 opacity-60"></span>
            </div>
            <span id={`s-${id}-metrics`} class="text-[12px] sm:text-[13px] font-medium text-zinc-500">--</span>
          </div>

          <div id={`details-${id}`} class="hidden mb-4 p-3 bg-zinc-900/50 border border-zinc-800 rounded-sm">
              <div class="grid grid-cols-2 gap-4">
                  <div>
                      <p class="text-[10px] text-zinc-500 uppercase font-bold">Riwayat Waktu Aktif</p>
                      <p id={`s-${id}-uptime-val`} class="text-xs text-white font-mono">Menghitung...</p>
                  </div>
                  <div>
                      <p class="text-[10px] text-zinc-500 uppercase font-bold">Identitas Node</p>
                      <p id={`s-${id}-node-val`} class="text-xs text-white font-mono">Mengidentifikasi...</p>
                  </div>
              </div>
          </div>
          
          <div class="flex justify-between w-full py-1 relative">
            {Array.from({ length: 40 }).map((_, i) => (
              <div data-bar={`${id}-${i}`} class="w-[1.5px] h-6 bg-[#111] transition-all duration-300"></div>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</div>

<style>
  [data-bar]:hover::after {
    content: attr(data-info);
    position: absolute;
    bottom: 35px;
    left: 50%;
    transform: translateX(-50%);
    background: #000;
    color: #fff;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-family: 'Geist Mono', monospace;
    white-space: nowrap;
    border: 1px solid #333;
    z-index: 50;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
  }

  #status-panel {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>

<script is:inline>
  const API_URL = "/api/status";

  const panel = document.getElementById("status-panel");
  const overlay = document.getElementById("status-overlay");
  const closeBtn = document.getElementById("close-panel");
  const panelDot = document.getElementById("panel-dot");
  const lastUpdatedEl = document.getElementById("last-updated-text");
  const footerLabel = document.getElementById("status-label");
  const footerDot = document.getElementById("status-dot");
  const footerPulse = document.getElementById("status-pulse");

  let latestUpdateTs = null;
  let hasFetched = false;
  const intervals = [];

  function getRelativeTime(timestamp) {
    const diff = Math.floor((Date.now() - timestamp) / 1000);
    if (diff < 30) return "Sekarang";
    if (diff < 60) return `${diff} detik yang lalu`;
    if (diff < 3600) return `${Math.floor(diff / 60)}m yang lalu`;
    return "Lama yang lalu";
  }

  function openStatus() {
    panel?.classList.remove("translate-y-full");
    overlay?.classList.remove("opacity-0", "pointer-events-none");
    overlay?.classList.add("opacity-100", "pointer-events-auto");
    document.body.style.overflow = "hidden";

    if (!hasFetched) {
      fetchStatus();
      hasFetched = true;
      
      intervals.push(setInterval(fetchStatus, 300000));
      
      intervals.push(setInterval(() => {
        if (latestUpdateTs && lastUpdatedEl) {
          lastUpdatedEl.textContent = `Pengecekan otomatis: ${getRelativeTime(latestUpdateTs)}`;
        }
      }, 10000));
    }
  }

  function closeStatus() {
    panel?.classList.add("translate-y-full");
    overlay?.classList.remove("opacity-100", "pointer-events-auto");
    overlay?.classList.add("opacity-0", "pointer-events-none");
    document.body.style.overflow = "";
  }

  function updateFooter(overall) {
    const colors = { Operational: "#10b981", Degraded: "#f59e0b", Outage: "#ef4444" };
    const accent = colors[overall] || "#3f3f46";
    if (footerLabel) footerLabel.textContent = overall === "Operational" ? "Semua Sistem Normal" : overall;
    if (footerDot) footerDot.style.backgroundColor = accent;
    if (footerPulse) footerPulse.style.backgroundColor = accent;
  }

  async function fetchFooterStatus() {
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateFooter(data.overall || "Operational");
    } catch {
      if (footerLabel) footerLabel.textContent = "Offline";
      if (footerDot) footerDot.style.backgroundColor = "#ef4444";
      if (footerPulse) footerPulse.style.backgroundColor = "#ef4444";
    }
  }

  function updateUI(overall, services, updatedTs) {
    const colors = { 
      Fast: "#22d3ee",
      Operational: "#10b981",
      Warning: "#f59e0b",
      Outage: "#ef4444"
    };
    overall = overall || "Operational";
    const accent = colors[overall] || "#3f3f46";

    updateFooter(overall);

    if (panelDot) {
      panelDot.style.backgroundColor = accent;
      panelDot.className = "w-2.5 h-2.5 rounded-full " + (overall === "Operational" ? "" : "animate-pulse");
    }

    if (updatedTs) {
      latestUpdateTs = updatedTs;
      if (lastUpdatedEl) lastUpdatedEl.textContent = `Pengecekan otomatis: ${getRelativeTime(latestUpdateTs)}`;
    }

    (services || []).forEach((s) => {
      const name = s.name;
      const status = s.status || "Outage";

      const detailsSummaryEl = document.getElementById(`s-${name}-details-summary`);
      if (detailsSummaryEl) detailsSummaryEl.textContent = s.details || '';

      const uptimeValEl = document.getElementById(`s-${name}-uptime-val`);
      const nodeValEl = document.getElementById(`s-${name}-node-val`);
      
      if (uptimeValEl) uptimeValEl.textContent = `${s.uptime || 0}% (40 Pengecekan Terakhir)`;
      if (nodeValEl) nodeValEl.textContent = s.details || 'Unknown Node';

      const metricsEl = document.getElementById(`s-${name}-metrics`);
      const statusTextEl = document.getElementById(`s-${name}-status-text`);
      const bars = document.querySelectorAll(`[data-bar^="${name}-"]`);
      const detailsEl = document.getElementById(`s-${name}-details`)

      if (statusTextEl) {
        statusTextEl.textContent = `• ${s.latency ?? '-'}ms`;
        statusTextEl.style.color = colors[status];
      }

      if (detailsEl) {
        detailsEl.textContent = s.details || ''; 
      }

      const history = Array.isArray(s.history) ? s.history.slice(-40) : [];
      
      const validLatencies = history.filter(h => typeof h.latency === 'number');
      const avgLatencyDisplay = validLatencies.length
        ? `${Math.round(validLatencies.reduce((a, c) => a + c.latency, 0) / validLatencies.length)}ms`
        : "";

      if (metricsEl) {
        const uptime = typeof s.uptime === "number" ? s.uptime : 100;
        metricsEl.textContent = `${uptime}% Uptime${avgLatencyDisplay ? ` • Avg ${avgLatencyDisplay}` : ''}`;
      }

      const startIndex = 40 - history.length;

      bars.forEach(el => {
        if (!el) return;

        el.style.backgroundColor = "#18181b";
        el.style.opacity = "0.3";
        el.removeAttribute('data-info');
      });

      history.forEach((h, i) => {
        const el = bars[startIndex + i];
        if (!el) return;

        let barColor = colors.Outage;
        if (h.status === 'Operational') {
          if (h.latency > 0 && h.latency < 50) barColor = colors.Fast;
          else if (h.latency > 1000) barColor = colors.Warning;
          else barColor = colors.Operational;
        }

        el.style.backgroundColor = barColor;
        el.style.opacity = "1";
        
        if (h.ts) {
          const time = new Date(h.ts).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
          const detailLog = h.details ? ` • ${h.details}` : '';
          el.setAttribute('data-info', `${time} • ${h.latency}ms${detailLog}`);
        }
      });
    });
  }

  async function fetchStatus() {
    if (lastUpdatedEl) lastUpdatedEl.textContent = "Memperbarui...";
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateUI(data.overall, data.services, data.updated);
    } catch {
      if (lastUpdatedEl) lastUpdatedEl.textContent = "Offline";
      updateFooter("Outage");
    }
  }

  document.getElementById("status-panel")?.addEventListener('touchstart', (e) => {
    const bar = e.target.closest('[data-bar]');
    if (!bar) return;
    e.preventDefault();
    const info = bar.getAttribute('data-info');
    if (info && lastUpdatedEl) lastUpdatedEl.textContent = info;
  }, { passive: false });

  document.addEventListener("astro:before-swap", () => {
    intervals.forEach(clearInterval);
  });

  document.getElementById("status-toggle")?.addEventListener("click", openStatus);
  closeBtn?.addEventListener("click", closeStatus);
  overlay?.addEventListener("click", closeStatus);
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeStatus(); });

  fetchFooterStatus();
  setInterval(fetchFooterStatus, 300000);
</script>
