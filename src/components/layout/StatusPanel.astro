---
// src/components/layout/StatusPanel.astro
const services = ['api', 'web', 'cdn', 'bot'];
---

<div
  id="status-overlay"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[90] opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<div
  id="status-panel"
  class="fixed bottom-0 left-0 right-0 z-[100] max-h-[85vh] overflow-y-auto
         translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]
         bg-white dark:bg-[#0a0a0a] border-t border-zinc-200 dark:border-zinc-900
         shadow-[0_-8px_40px_rgba(0,0,0,0.08)] dark:shadow-[0_-8px_40px_rgba(0,0,0,0.6)]"
>

  <div class="max-w-[720px] mx-auto px-5 py-5 sm:px-8 sm:py-7">

    <!-- HEADER -->
    <div class="flex items-center justify-between pb-5 border-b border-zinc-200 dark:border-zinc-900">
      <div class="flex items-center gap-3">
        <span
          id="panel-dot"
          class="w-2 h-2 rounded-full bg-zinc-500 transition-all"
        ></span>

        <div>
          <p class="text-[13px] font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
            System Status
          </p>
          <p id="last-updated-text" class="text-[12px] text-zinc-500">
            Waiting for sync...
          </p>
        </div>
      </div>

      <button
        id="close-panel"
        class="w-8 h-8 flex items-center justify-center rounded-md border
               border-zinc-200 dark:border-zinc-800 text-zinc-500
               hover:bg-zinc-100 dark:hover:bg-zinc-900
               hover:text-zinc-900 dark:hover:text-zinc-50 transition"
      >
        ✕
      </button>
    </div>

    <!-- SERVICES -->
    <div class="flex flex-col">
      {services.map((id) => (
        <div
          class="py-4 border-b border-zinc-100 dark:border-zinc-900 cursor-pointer"
          onclick={`toggleDetails('${id}')`}
        >

          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="text-[12px] font-semibold tracking-widest text-zinc-500 font-mono">
                {id.toUpperCase()}
              </span>

              <span
                id={`s-${id}-status-text`}
                class="text-[12px] font-mono"
              ></span>
            </div>

            <span
              id={`s-${id}-metrics`}
              class="text-[12px] text-zinc-500 font-mono"
            >
              —
            </span>
          </div>

          <!-- BARS -->
          <div class="flex items-end gap-[2px] h-7">
            {Array.from({ length: 40 }).map((_, i) => (
              <div
                data-bar={`${id}-${i}`}
                class="flex-1 h-full rounded-[2px] bg-zinc-200 dark:bg-zinc-800
                       opacity-30 hover:scale-y-110 origin-bottom transition"
              ></div>
            ))}
          </div>

          <!-- DETAILS -->
          <div
            id={`details-${id}`}
            class="hidden mt-3 p-4 rounded-lg border
                   bg-zinc-50 dark:bg-zinc-900
                   border-zinc-200 dark:border-zinc-800"
          >
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

              <div>
                <p class="text-[11px] uppercase tracking-wider text-zinc-400 font-semibold">
                  Uptime History
                </p>
                <p id={`s-${id}-uptime-val`} class="text-[12px] font-mono text-zinc-700 dark:text-zinc-300">
                  Calculating...
                </p>
              </div>

              <div>
                <p class="text-[11px] uppercase tracking-wider text-zinc-400 font-semibold">
                  Node Identity
                </p>
                <p id={`s-${id}-node-val`} class="text-[12px] font-mono text-zinc-700 dark:text-zinc-300">
                  Identifying...
                </p>
              </div>

              <div>
                <p class="text-[11px] uppercase tracking-wider text-zinc-400 font-semibold">
                  Last Check
                </p>
                <p id={`s-${id}-details-summary`} class="text-[12px] font-mono text-zinc-700 dark:text-zinc-300">
                  —
                </p>
              </div>

            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- FOOTER -->
    <div class="flex items-center justify-between mt-4 pt-4 border-t border-zinc-100 dark:border-zinc-900">

      <span class="text-[12px] text-zinc-400">
        Auto-refreshes every 5 minutes
      </span>

      <button
        id="refresh-btn"
        class="flex items-center gap-2 px-3 py-1.5 text-[12px]
               border rounded-md transition
               border-zinc-200 dark:border-zinc-800
               text-zinc-600 dark:text-zinc-400
               hover:bg-zinc-100 dark:hover:bg-zinc-900"
      >
        <svg
          class="w-3 h-3"
          id="refresh-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
        >
          <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
          <path d="M21 3v5h-5"/>
          <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
          <path d="M8 16H3v5"/>
        </svg>
        Refresh
      </button>

    </div>

  </div>
</div>

<script is:inline>
(function() {
  const API_URL = "/api/status";

  const panel     = document.getElementById("status-panel");
  const overlay   = document.getElementById("status-overlay");
  const closeBtn  = document.getElementById("close-panel");
  const refreshBtn = document.getElementById("refresh-btn");
  const panelDot  = document.getElementById("panel-dot");
  const lastUpdatedEl = document.getElementById("last-updated-text");
  const footerLabel   = document.getElementById("status-label");
  const footerDot     = document.getElementById("status-dot");
  const footerPulse   = document.getElementById("status-pulse");

  let latestUpdateTs = null;
  let hasFetched = false;
  const intervals = [];

  const STATUS_COLORS = {
    Fast:        "#0ea5e9",
    Operational: "#22c55e",
    Warning:     "#f59e0b",
    Outage:      "#ef4444",
  };

  function getRelativeTime(ts) {
    const d = Math.floor((Date.now() - ts) / 1000);
    if (d < 30)   return "Just now";
    if (d < 60)   return `${d}s ago`;
    if (d < 3600) return `${Math.floor(d / 60)}m ago`;
    return "A while ago";
  }

  function toggleDetails(id) {
    const el = document.getElementById(`details-${id}`);
    if (el) el.classList.toggle("hidden");
  }
  window.toggleDetails = toggleDetails;

  function openStatus() {
    panel?.classList.add("translate-y-0");
    panel?.classList.remove("translate-y-full");

    overlay?.classList.add("opacity-100", "pointer-events-auto");
    overlay?.classList.remove("opacity-0", "pointer-events-none");

    document.body.style.overflow = "hidden";

    if (!hasFetched) {
      fetchStatus();
      hasFetched = true;

      intervals.push(setInterval(fetchStatus, 300000));
      intervals.push(setInterval(() => {
        if (latestUpdateTs && lastUpdatedEl)
          lastUpdatedEl.textContent = `Auto-check: ${getRelativeTime(latestUpdateTs)}`;
      }, 10000));
    }
  }

  function closeStatus() {
    panel?.classList.add("translate-y-full");
    panel?.classList.remove("translate-y-0");

    overlay?.classList.add("opacity-0", "pointer-events-none");
    overlay?.classList.remove("opacity-100", "pointer-events-auto");

    document.body.style.overflow = "";
  }

  function updateFooter(overall) {
    const accent = STATUS_COLORS[overall] || "#888";
    if (footerLabel) footerLabel.textContent = overall === "Operational" ? "All Systems Normal" : overall;
    if (footerDot)   footerDot.style.backgroundColor = accent;
    if (footerPulse) footerPulse.style.backgroundColor = accent;
  }

  async function fetchFooterStatus() {
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateFooter(data.overall || "Operational");
    } catch {
      if (footerLabel) footerLabel.textContent = "Offline";
      if (footerDot)   footerDot.style.backgroundColor = STATUS_COLORS.Outage;
      if (footerPulse) footerPulse.style.backgroundColor = STATUS_COLORS.Outage;
    }
  }

  function updateUI(overall, services, updatedTs) {
    overall = overall || "Operational";
    const accent = STATUS_COLORS[overall] || "#888";

    updateFooter(overall);

    if (panelDot) {
      panelDot.style.backgroundColor = accent;
      if (overall !== "Operational") panelDot.classList.add("pulse");
      else panelDot.classList.remove("pulse");
    }

    if (updatedTs) {
      latestUpdateTs = updatedTs;
      if (lastUpdatedEl)
        lastUpdatedEl.textContent = `Updated ${getRelativeTime(latestUpdateTs)}`;
    }

    (services || []).forEach((s) => {
      const name   = s.name;
      const status = s.status || "Outage";

      const summaryEl  = document.getElementById(`s-${name}-details-summary`);
      const uptimeEl   = document.getElementById(`s-${name}-uptime-val`);
      const nodeEl     = document.getElementById(`s-${name}-node-val`);
      const metricsEl  = document.getElementById(`s-${name}-metrics`);
      const latencyEl  = document.getElementById(`s-${name}-status-text`);
      const bars       = document.querySelectorAll(`[data-bar^="${name}-"]`);

      if (summaryEl) summaryEl.textContent = s.details || "—";
      if (uptimeEl)  uptimeEl.textContent  = `${s.uptime ?? 0}% (last 40 checks)`;
      if (nodeEl)    nodeEl.textContent    = s.details || "Unknown node";

      if (latencyEl) {
        latencyEl.textContent = `${s.latency ?? "—"}ms`;
        latencyEl.style.color = STATUS_COLORS[status] || "#888";
      }

      if (metricsEl) {
        const up  = typeof s.uptime === "number" ? s.uptime : 100;
        const history = Array.isArray(s.history) ? s.history : [];
        const valid   = history.filter(h => typeof h.latency === "number");
        const avg     = valid.length
          ? Math.round(valid.reduce((a, c) => a + c.latency, 0) / valid.length)
          : null;

        metricsEl.textContent = `${up}% uptime${avg !== null ? ` · avg ${avg}ms` : ""}`;
      }

      const history    = Array.isArray(s.history) ? s.history.slice(-40) : [];
      const startIndex = 40 - history.length;

      bars.forEach(el => {
        el.style.backgroundColor = "";
        el.style.opacity = "0.3";
        el.removeAttribute("data-info");
      });

      history.forEach((h, i) => {
        const el = bars[startIndex + i];
        if (!el) return;

        let color = STATUS_COLORS.Outage;
        if (h.status === "Operational") {
          if (h.latency < 50) color = STATUS_COLORS.Fast;
          else if (h.latency > 1000) color = STATUS_COLORS.Warning;
          else color = STATUS_COLORS.Operational;
        }

        el.style.backgroundColor = color;
        el.style.opacity = "1";

        if (h.ts) {
          const time = new Date(h.ts).toLocaleTimeString("id-ID", {
            hour: "2-digit",
            minute: "2-digit"
          });

          const detail = h.details ? ` · ${h.details}` : "";
          el.setAttribute("data-info", `${time} · ${h.latency}ms${detail}`);
        }
      });
    });
  }

  async function fetchStatus() {
    if (refreshBtn) refreshBtn.classList.add("spinning");
    if (lastUpdatedEl) lastUpdatedEl.textContent = "Updating...";

    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateUI(data.overall, data.services, data.updated);
    } catch {
      if (lastUpdatedEl) lastUpdatedEl.textContent = "Offline";
      updateFooter("Outage");
    } finally {
      if (refreshBtn) refreshBtn.classList.remove("spinning");
    }
  }

  document.getElementById("status-toggle")?.addEventListener("click", openStatus);
  closeBtn?.addEventListener("click", closeStatus);
  overlay?.addEventListener("click", closeStatus);
  refreshBtn?.addEventListener("click", () => { if (hasFetched) fetchStatus(); });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeStatus();
  });

  fetchFooterStatus();
  setInterval(fetchFooterStatus, 300000);

})();
</script>
