---
// src/components/layout/StatusPanel.astro
const services = ['api', 'web', 'cdn', 'bot'];
---

<div
  id="status-overlay"
  class="status-overlay"
></div>

<div id="status-panel" class="status-panel">

  <div class="mx-auto max-w-[720px] p-5 sm:p-7 sm:pb-5">

    <div class="flex items-center justify-between border-b border-gray-200 pb-5 dark:border-gray-800 mb-1">
      <div class="flex items-center gap-2.5">
        <span id="panel-dot" class="header-dot h-2 w-2 rounded-full bg-gray-500 flex-shrink-0 transition-colors duration-300"></span>
        <div>
          <p class="text-[13px] font-semibold tracking-[-0.01em] text-gray-900 dark:text-gray-50 leading-tight">System Status</p>
          <p id="last-updated-text" class="text-xs text-gray-500 dark:text-gray-400 leading-tight mt-px">Waiting for sync...</p>
        </div>
      </div>
      <button id="close-panel" class="close-btn flex h-8 w-8 items-center justify-center rounded-md border border-gray-200 dark:border-gray-800 bg-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-900 hover:border-gray-300 dark:hover:border-gray-700 hover:text-gray-900 dark:hover:text-gray-50 transition-all duration-150" aria-label="Close status panel">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>

    <div class="flex flex-col">
      {services.map((id) => (
        <div class="service-row cursor-pointer border-b border-gray-100 dark:border-gray-900 py-4 last:border-none transition-colors duration-100 hover:[&_.service-name]:text-gray-900 dark:hover:[&_.service-name]:text-gray-50" onclick={`toggleDetails('${id}')`}>

          <div class="mb-2.5 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="service-name text-xs font-semibold tracking-[0.06em] text-gray-500 dark:text-gray-400 font-['Geist_Mono','SF_Mono',ui-monospace,monospace] transition-colors duration-150">{id.toUpperCase()}</span>
              <span id={`s-${id}-status-text`} class="service-latency text-xs font-mono font-medium opacity-90"></span>
            </div>
            <span id={`s-${id}-metrics`} class="service-metrics text-xs text-gray-500 dark:text-gray-400 font-mono">—</span>
          </div>

          <div class="bars-wrap flex h-7 items-end gap-[2px] relative">
            {Array.from({ length: 40 }).map((_, i) => (
              <div data-bar={`${id}-${i}`} class="bar flex-1 h-full rounded-sm bg-gray-100 dark:bg-gray-900 transition-all duration-200 relative cursor-default"></div>
            ))}
          </div>

          <div id={`details-${id}`} class="service-detail hidden mt-3 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50 p-[14px_16px]">
            <div class="detail-grid grid grid-cols-1 gap-3.5 sm:grid-cols-[repeat(auto-fit,minmax(140px,1fr))]">
              <div>
                <p class="detail-label mb-0.5 text-[11px] font-semibold uppercase tracking-[0.05em] text-gray-400 dark:text-gray-500">Uptime History</p>
                <p id={`s-${id}-uptime-val`} class="detail-val text-xs font-mono text-gray-700 dark:text-gray-300">Calculating...</p>
              </div>
              <div>
                <p class="detail-label mb-0.5 text-[11px] font-semibold uppercase tracking-[0.05em] text-gray-400 dark:text-gray-500">Node Identity</p>
                <p id={`s-${id}-node-val`} class="detail-val text-xs font-mono text-gray-700 dark:text-gray-300">Identifying...</p>
              </div>
              <div>
                <p class="detail-label mb-0.5 text-[11px] font-semibold uppercase tracking-[0.05em] text-gray-400 dark:text-gray-500">Last Check</p>
                <p id={`s-${id}-details-summary`} class="detail-val text-xs font-mono text-gray-700 dark:text-gray-300">—</p>
              </div>
            </div>
          </div>

        </div>
      ))}
    </div>

    <div class="panel-footer mt-4 flex items-center justify-between border-t border-gray-100 dark:border-gray-900 pt-[14px]">
      <span class="footer-note text-xs text-gray-400 dark:text-gray-500">Auto-refreshes every 5 minutes</span>
      <button id="refresh-btn" class="refresh-btn flex items-center gap-1.5 rounded-md border border-gray-200 dark:border-gray-800 bg-transparent px-3 py-1.5 text-xs font-medium text-gray-600 dark:text-gray-400 transition-all duration-150 hover:border-gray-300 dark:hover:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-900 hover:text-gray-900 dark:hover:text-gray-50">
        <svg id="refresh-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
        Refresh
      </button>
    </div>

  </div>
</div>

<style is:global>
  .status-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 90;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .status-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .status-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transform: translateY(100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    background: #ffffff;
    border-top: 1px solid #e5e5e5;
    box-shadow: 0 -8px 40px rgba(0,0,0,0.08);
    max-height: 85vh;
    overflow-y: auto;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
  }

  .status-panel.open {
    transform: translateY(0);
  }

  .dark .status-panel {
    background: #0a0a0a;
    border-top-color: #1a1a1a;
    box-shadow: 0 -8px 40px rgba(0,0,0,0.6);
  }

  .header-dot.pulse {
    animation: pulse-dot 1.5s ease-in-out infinite;
  }

  .refresh-btn.spinning svg {
    animation: spin 0.7s linear infinite;
  }

  .bar[data-info]:hover::after {
    content: attr(data-info);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #0a0a0a;
    color: #fafafa;
    padding: 5px 8px;
    border-radius: 5px;
    font-size: 11px;
    font-family: 'Geist Mono', 'SF Mono', ui-monospace, monospace;
    white-space: nowrap;
    border: 1px solid #2a2a2a;
    z-index: 50;
    pointer-events: none;
  }

  .dark .bar[data-info]:hover::after {
    background: #fafafa;
    color: #0a0a0a;
    border-color: #e0e0e0;
  }

  .bar:hover {
    transform: scaleY(1.15);
    transform-origin: bottom;
    z-index: 1;
  }

  .service-detail.hidden {
    display: none;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>

<script is:inline>
(function() {
  const API_URL = "/api/status";

  const panel     = document.getElementById("status-panel");
  const overlay   = document.getElementById("status-overlay");
  const closeBtn  = document.getElementById("close-panel");
  const refreshBtn = document.getElementById("refresh-btn");
  const panelDot  = document.getElementById("panel-dot");
  const lastUpdatedEl = document.getElementById("last-updated-text");

  let latestUpdateTs = null;
  let hasFetched = false;
  const intervals = [];

  const STATUS_COLORS = {
    Fast:        "#0ea5e9",
    Operational: "#22c55e",
    Warning:     "#f59e0b",
    Outage:      "#ef4444",
  };

  function getRelativeTime(ts) {
    const d = Math.floor((Date.now() - ts) / 1000);
    if (d < 30)   return "Just now";
    if (d < 60)   return `${d}s ago`;
    if (d < 3600) return `${Math.floor(d / 60)}m ago`;
    return "A while ago";
  }

  function toggleDetails(id) {
    const el = document.getElementById(`details-${id}`);
    if (el) el.classList.toggle("hidden");
  }
  window.toggleDetails = toggleDetails;

  function openStatus() {
    panel?.classList.add("open");
    overlay?.classList.add("visible");
    document.body.style.overflow = "hidden";
    if (!hasFetched) {
      fetchStatus();
      hasFetched = true;
      intervals.push(setInterval(fetchStatus, 300000));
      intervals.push(setInterval(() => {
        if (latestUpdateTs && lastUpdatedEl)
          lastUpdatedEl.textContent = `Auto-check: ${getRelativeTime(latestUpdateTs)}`;
      }, 10000));
    }
  }

  function closeStatus() {
    panel?.classList.remove("open");
    overlay?.classList.remove("visible");
    document.body.style.overflow = "";
  }

  function updatePanelDot(overall) {
    const accent = STATUS_COLORS[overall] || "#888";
    if (panelDot) {
      panelDot.style.backgroundColor = accent;
      if (overall !== "Operational") panelDot.classList.add("pulse");
      else panelDot.classList.remove("pulse");
    }
  }

  function updateUI(overall, services, updatedTs) {
    overall = overall || "Operational";
    
    updatePanelDot(overall);

    if (updatedTs) {
      latestUpdateTs = updatedTs;
      if (lastUpdatedEl)
        lastUpdatedEl.textContent = `Updated ${getRelativeTime(latestUpdateTs)}`;
    }

    (services || []).forEach((s) => {
      const name   = s.name;
      const status = s.status || "Outage";

      const summaryEl  = document.getElementById(`s-${name}-details-summary`);
      const uptimeEl   = document.getElementById(`s-${name}-uptime-val`);
      const nodeEl     = document.getElementById(`s-${name}-node-val`);
      const metricsEl  = document.getElementById(`s-${name}-metrics`);
      const latencyEl  = document.getElementById(`s-${name}-status-text`);
      const bars       = document.querySelectorAll(`[data-bar^="${name}-"]`);

      if (summaryEl) summaryEl.textContent = s.details || "—";
      if (uptimeEl)  uptimeEl.textContent  = `${s.uptime ?? 0}% (last 40 checks)`;
      if (nodeEl)    nodeEl.textContent    = s.details || "Unknown node";

      if (latencyEl) {
        latencyEl.textContent = `${s.latency ?? "—"}ms`;
        latencyEl.style.color = STATUS_COLORS[status] || "#888";
      }

      if (metricsEl) {
        const up  = typeof s.uptime === "number" ? s.uptime : 100;
        const history = Array.isArray(s.history) ? s.history : [];
        const valid   = history.filter(h => typeof h.latency === "number");
        const avg     = valid.length
          ? Math.round(valid.reduce((a, c) => a + c.latency, 0) / valid.length)
          : null;
        metricsEl.textContent = `${up}% uptime${avg !== null ? ` · avg ${avg}ms` : ""}`;
      }

      const history    = Array.isArray(s.history) ? s.history.slice(-40) : [];
      const startIndex = 40 - history.length;

      bars.forEach(el => {
        el.style.backgroundColor = "";
        el.style.opacity = "0.3";
        el.removeAttribute("data-info");
      });

      history.forEach((h, i) => {
        const el = bars[startIndex + i];
        if (!el) return;

        let color = STATUS_COLORS.Outage;
        if (h.status === "Operational") {
          if (h.latency < 50)   color = STATUS_COLORS.Fast;
          else if (h.latency > 1000) color = STATUS_COLORS.Warning;
          else                   color = STATUS_COLORS.Operational;
        }

        el.style.backgroundColor = color;
        el.style.opacity = "1";

        if (h.ts) {
          const time = new Date(h.ts).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
          const detail = h.details ? ` · ${h.details}` : "";
          el.setAttribute("data-info", `${time} · ${h.latency}ms${detail}`);
        }
      });
    });
  }

  async function fetchStatus() {
    if (refreshBtn) refreshBtn.classList.add("spinning");
    if (lastUpdatedEl) lastUpdatedEl.textContent = "Updating...";
    try {
      const res  = await fetch(API_URL);
      if (!res.ok) throw new Error();
      const data = await res.json();
      updateUI(data.overall, data.services, data.updated);
    } catch {
      if (lastUpdatedEl) lastUpdatedEl.textContent = "Offline";
      updatePanelDot("Outage");
    } finally {
      if (refreshBtn) refreshBtn.classList.remove("spinning");
    }
  }

  panel?.addEventListener("touchstart", (e) => {
    const bar = e.target.closest("[data-bar]");
    if (!bar) return;
    e.preventDefault();
    const info = bar.getAttribute("data-info");
    if (info && lastUpdatedEl) lastUpdatedEl.textContent = info;
  }, { passive: false });

  document.addEventListener("astro:before-swap", () => {
    intervals.forEach(clearInterval);
  });

  document.getElementById("status-toggle")?.addEventListener("click", openStatus);
  closeBtn?.addEventListener("click", closeStatus);
  overlay?.addEventListener("click", closeStatus);
  refreshBtn?.addEventListener("click", () => { if (hasFetched) fetchStatus(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeStatus(); });
})();
</script>
